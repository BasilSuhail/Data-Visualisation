   3.614256686926867*^9},ExpressionUUID->"0a8c1fe7-1b68-4da4-b996-\
854d106498e1"],

Cell[TextData[{
 StyleBox[ButtonBox["Map",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Map"],
  FontWeight->"Bold"],
 " is a powerful function that maps a function to elements within an \
expression (including a list)."
}], "Text",
 CellChangeTimes->{{3.6058289451443152`*^9, 3.605828980916319*^9}, {
  3.6058292298121243`*^9, 3.605829257155617*^9}, {3.6059599620232944`*^9, 
  3.6059599620252943`*^9}},ExpressionUUID->"5a6041f2-208a-4fdc-855c-\
9d78e9fed803"],

Cell[BoxData[
 RowBox[{"Map", "[", 
  RowBox[{"f", ",", 
   RowBox[{"{", 
    RowBox[{"a", ",", "b", ",", "c"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.611935634828631*^9, 3.6119356478929386`*^9}, {
  3.611935867273035*^9, 3.611935869176035*^9}},
 CellLabel->"In[74]:=",ExpressionUUID->"19056dc1-aaf0-4377-a116-7845f591751e"],

Cell[BoxData[
 RowBox[{"f", "/@", 
  RowBox[{"{", 
   RowBox[{"a", ",", "b", ",", "c"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.777877888763611*^9, 3.777877893884352*^9}},
 CellLabel->"In[75]:=",ExpressionUUID->"e8598f35-6d51-4795-b329-1862c39cf922"],

Cell[TextData[{
 "It also lets you specify the level at which the function should be mapped. \
The default ",
 StyleBox["levelspec",
  FontWeight->"Bold"],
 " is 1. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Map", "[", 
    RowBox[{"f", ",", " ", "expr", ",", " ", "levelspec"}], "]"}], MR]],
  ExpressionUUID->"e26858a1-0496-49e4-a121-8c4539f962a2"],
 " will apply ",
 Cell[BoxData[
  FormBox["f", MR]],ExpressionUUID->"78b8758f-5cb6-42ff-a933-d937d39d3491"],
 " from level 1 down to ",
 StyleBox["levelspec",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{
  3.6058291503627105`*^9, {3.63791687702742*^9, 
   3.637916908426878*^9}},ExpressionUUID->"6c6f3577-d7f4-44de-9803-\
f672fd607550"],

Cell[BoxData[
 RowBox[{
  RowBox[{"list", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", "3", ",", "4", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"c", ",", "d"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"e", ",", "f"}], "}"}]}], "}"}], ",", "5", ",", "6"}], 
    "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.611935671846035*^9, 3.611935678981035*^9}, 
   3.611935884567035*^9},
 CellLabel->"In[76]:=",ExpressionUUID->"9439129b-53ef-44aa-a66f-f8a60a5a2c5e"],

Cell[BoxData[
 RowBox[{"TreeForm", "[", "list", "]"}]], "Input",
 CellChangeTimes->{{3.777877933868763*^9, 3.777877944976532*^9}},
 CellLabel->"In[78]:=",ExpressionUUID->"fd11d34b-0ace-45c6-88ec-6495cecb4df2"],

