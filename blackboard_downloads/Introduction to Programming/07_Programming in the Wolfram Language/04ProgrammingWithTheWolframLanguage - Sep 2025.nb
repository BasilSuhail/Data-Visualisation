Cell[BoxData[
 RowBox[{
  RowBox[{"list", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "100"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.604714869299794*^9, 3.604714890695992*^9}, 
   3.604715027880154*^9},ExpressionUUID->"5d1709d1-7442-4664-8964-\
e7b29375f84d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"product", "=", "0"}], ";"}]], "Input",
 CellChangeTimes->{{3.6047158098295946`*^9, 
  3.6047158145668554`*^9}},ExpressionUUID->"3b0d75f4-7e0b-4806-a38f-\
0e1ce2f6a40f"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"product", "=", "1."}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"product", "*=", 
       RowBox[{"list", "[", 
        RowBox[{"[", "n", "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", 
        RowBox[{"Length", "[", "list", "]"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", "product"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.604714916484934*^9, 3.6047149396232343`*^9}, {
