Cell[TextData[{
 "Suppose that ",
 StyleBox["mat1", "Program"],
 " contains some data where all the numbers are measurements that should be \
non-negative. Due to measurement errors some of them are negative. Replace \
all negative numbers in ",
 StyleBox["mat1", "Program"],
 " with ",
 StyleBox["$Failed", "Program"],
 "."
}], "ItemNumbered",
 CellChangeTimes->{{3.625490120841357*^9, 3.625490128047131*^9}, {
