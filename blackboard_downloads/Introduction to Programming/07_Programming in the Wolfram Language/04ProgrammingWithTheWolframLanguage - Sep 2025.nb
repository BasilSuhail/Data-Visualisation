Cell[CellGroupData[{

Cell["Advanced", "Subsubsection",
 CellChangeTimes->{{3.6254915813567758`*^9, 
  3.625491582685174*^9}},ExpressionUUID->"aaa648b5-ada3-4e24-9977-\
ebf3d221cd1b"],

Cell[TextData[{
 "Define a function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     StyleBox["invert",
      FontSlant->"Italic"], "(", "x", ")"}], "=", 
    FractionBox["1", "x"]}], TraditionalForm]],ExpressionUUID->
  "0511e606-956b-4d3d-9d66-cd5a69ee7a2c"],
 " that only evaluates when the input ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "b9b3fdd5-f75e-47b5-a0c7-e6e781ee548c"],
 " is not 0."
}], "ItemNumbered",
 CellChangeTimes->{{3.625493475477536*^9, 3.625493601328951*^9}, 
   3.625493685226915*^9},ExpressionUUID->"2274fb25-7311-4fee-889d-\
