Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"Thread", "[", 
    RowBox[{"f", "[", "args", "]"}], "]"}], MR]],ExpressionUUID->
  "0982ddaf-32d5-48ac-8754-2178e0b937a8"],
 " threads a function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]], "InlineMath",ExpressionUUID->
  "f94c93ff-6c42-4099-b6aa-519af2948679"],
 " over lists that appear in the provided argument."
}], "Text",
 CellChangeTimes->{
