Cell[TextData[{
 "Pattern matching is used commonly in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to define functions. It allows you to restrict the argument of a function \
to a certain type. If the type of the argument does not match with the \
pattern, the expression is not evaluated."
}], "Text",
 CellChangeTimes->{{3.562930461727346*^9, 3.56293059517627*^9}, {
   3.562930837710949*^9, 3.562930838343357*^9}, 3.56421715972651*^9, {
   3.605836636112035*^9, 3.6058366750183015`*^9}, {3.605836749860251*^9, 
   3.605836776985247*^9}, {3.611936409693035*^9, 3.611936441155035*^9}, {
   3.611936683123152*^9, 3.611936698267666*^9}, 3.611941439773673*^9, {
   3.6119414731650124`*^9, 3.611941601536848*^9}, {3.6149506031507263`*^9, 
   3.614950603796389*^9}, {3.615736316359586*^9, 3.615736317291637*^9}, {
   3.637942321604683*^9, 
   3.6379423236206837`*^9}},ExpressionUUID->"9bfb8104-9ea0-4e67-867c-\
11ecad211c20"],

