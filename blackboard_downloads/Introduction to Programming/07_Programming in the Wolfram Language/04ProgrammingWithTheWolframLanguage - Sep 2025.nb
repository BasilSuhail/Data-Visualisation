Cell["ReplaceAll", "Section",
 CellChangeTimes->{{3.562927517849917*^9, 3.562927524681031*^9}, {
  3.604165908100459*^9, 3.6041659252531743`*^9}, {3.605838328087108*^9, 
  3.605838329462211*^9}},ExpressionUUID->"6a814838-f25d-4cef-98b1-\
c19d59a61d46"],

Cell[TextData[{
 "To replace expressions that match certain patterns within a list, a \
convenient way is to use ",
 StyleBox[ButtonBox["ReplaceAll",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ReplaceAll"],
  FontWeight->"Bold"],
 ". The following commands show a possible way to handle a badly formatted \
dataset with the pattern-matching technique."
}], "Text",
 CellChangeTimes->{{3.562927535763719*^9, 3.562927598441628*^9}, 
   3.565029101632161*^9, {3.56805474592973*^9, 3.568054748263895*^9}, {
   3.605837900200411*^9, 3.605837966039109*^9}, {3.611936841128951*^9, 
   3.611937086937529*^9}, {3.614950669537317*^9, 3.614950676168819*^9}, {
   3.615736422194745*^9, 3.615736444221426*^9}, {3.6379425710741067`*^9, 
   3.6379425732463675`*^9}},ExpressionUUID->"6fdc82d1-32c8-4d31-a395-\
7a9ffdc419a3"],

