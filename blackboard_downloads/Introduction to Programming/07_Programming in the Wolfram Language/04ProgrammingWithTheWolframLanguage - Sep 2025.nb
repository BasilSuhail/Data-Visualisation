cd1ef545039e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"#", "^", "2"}], "+", 
     RowBox[{"Exp", "[", "#", "]"}], "-", "3"}], ")"}], "&"}], "[", "1", 
  "]"}]], "Input",
