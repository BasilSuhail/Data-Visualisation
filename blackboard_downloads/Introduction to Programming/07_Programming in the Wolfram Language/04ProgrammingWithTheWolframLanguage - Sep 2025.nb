Cell["Procedural Programming", "Subsection",
 CellChangeTimes->{{3.562927517849917*^9, 3.562927524681031*^9}, {
  3.604165908100459*^9, 3.6041659252531743`*^9}, {3.605839637701072*^9, 
  3.605839659909303*^9}},ExpressionUUID->"1912e7a8-e8f7-4a50-8449-\
d48639b3767b"],

Cell[TextData[{
 "The procedural approach required defining a product initially to 1 and \
telling ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to multiply each element end before printing the value of the product."
}], "Text",
 CellChangeTimes->{{3.611937186821517*^9, 3.6119372417270074`*^9}, {
  3.611937420565888*^9, 3.6119374216619987`*^9}, {3.611937486296461*^9, 
  3.611937532258057*^9}, {3.6119377251115174`*^9, 3.6119377463115177`*^9}, {
  3.611937827010516*^9, 3.611937831432516*^9}, {3.6119379618565173`*^9, 
  3.611937996262517*^9}, {3.61573682858038*^9, 3.615736828963841*^9}, {
  3.623779140042109*^9, 3.623779194361656*^9}, {3.637942744795396*^9, 
  3.6379427603093596`*^9}},ExpressionUUID->"41f45f24-7ddc-42e7-8b23-\
0525ba5e2fdd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"product", "=", "1."}], ";", 
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{"product", "*=", 
     RowBox[{"list", "[", 
      RowBox[{"[", "n", "]"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", 
      RowBox[{"Length", "[", "list", "]"}]}], "}"}]}], "]"}], ";", 
  "product"}]], "Input",
 CellChangeTimes->{{3.62377919794968*^9, 
  3.623779214438985*^9}},ExpressionUUID->"d4b54857-c3dd-4301-a861-\
2e879f08f289"]
}, Open  ]],

Cell[CellGroupData[{

