  RowBox[{"g", ",", 
   RowBox[{"f", "[", 
    RowBox[{"a", ",", "b", ",", "c"}], "]"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"g", "@@", 
  RowBox[{"f", "[", 
   RowBox[{"a", ",", "b", ",", "c"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.605829717106788*^9, 3.605829724549202*^9}, {
