Cell[CellGroupData[{

Cell["Pattern Matching on Defining Functions", "Section",
 CellChangeTimes->{{3.5618003618241253`*^9, 3.5618003644227962`*^9}, {
  3.562930444662204*^9, 3.562930454868427*^9}, {3.611936364296036*^9, 
  3.611936372791035*^9}},ExpressionUUID->"b384a785-dbb8-4f9c-8b3e-\
f6b17a49a798"],

Cell[CellGroupData[{

Cell["Using Multiple Definitions", "Subsection",
 CellChangeTimes->{{3.625470493403655*^9, 3.6254705057392817`*^9}, {
  3.637942335942026*^9, 
  3.6379423381767535`*^9}},ExpressionUUID->"a5f366f2-2430-4bab-a2a8-\
dd165da356c1"],

Cell[TextData[{
 "Multiple definitions can be given to a function, and ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " will attempt to use the definition that matches most specifically when you \
use the function. "
}], "Text",
 CellChangeTimes->{
  3.60596720204786*^9, {3.62546981467593*^9, 3.625469841491348*^9}, {
   3.6254700849703083`*^9, 3.625470103097474*^9}, {3.625470454292322*^9, 
   3.625470479179082*^9}, {3.625470512307722*^9, 
   3.625470539459339*^9}},ExpressionUUID->"5a6734e8-6e39-4d41-9f36-\
3ac5f09f7e41"],

Cell[TextData[{
 "Here are four definitions for the function ",
 StyleBox["isFour",
  FontWeight->"Bold"],
 ", given in increasing order of generality. Notice that the final definition \
does not label the argument since the argument is not used on the right-hand \
side."
}], "Text",
 CellChangeTimes->{{3.625470540886243*^9, 3.625470567186955*^9}, {
  3.625548532301894*^9, 3.625548570997567*^9}, {3.637917196131096*^9, 
  3.6379171994240594`*^9}, {3.637942351680044*^9, 
  3.63794235701487*^9}},ExpressionUUID->"9d4db1dd-352f-4344-8398-\
b56697265169"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"isFour", "[", "4", "]"}], ":=", "\"\<Yes!!\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"isFour", "[", "x_Integer", "]"}], ":=", 
   RowBox[{"\"\<No, but \>\"", "<>", 
    RowBox[{"ToString", "[", "x", "]"}], "<>", "\"\< is an integer!\>\""}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"isFour", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"\"\<No, but \>\"", "<>", 
    RowBox[{"ToString", "[", "x", "]"}], "<>", "\"\< is a number.\>\""}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"isFour", "[", "_", "]"}], ":=", 
   "\"\<No, not even close to four...\>\""}], ";"}]}], "Input",
 CellChangeTimes->{{3.625469855315772*^9, 3.625469910557938*^9}, {
   3.625469991437433*^9, 3.625470034422503*^9}, 3.62548596380142*^9},
 CellLabel->
  "In[376]:=",ExpressionUUID->"b1aaccfc-7bc8-4efc-bab3-3bda61200ecd"],

Cell["\<\
The number 4 matches all of the patterns given in the function definitions, \
but the most specific match is used.\
\>", "Text",
 CellChangeTimes->{{3.625470587738662*^9, 3.62547061935492*^9}, {
  3.625470688234995*^9, 3.625470769372205*^9}, {3.637942383895291*^9, 
  3.637942387309298*^9}},ExpressionUUID->"2664e89f-5032-4c2b-8341-\
41f206276959"],

Cell[BoxData[
 RowBox[{"isFour", "[", "2", "]"}]], "Input",
 CellChangeTimes->{{3.625470720578661*^9, 3.625470722131676*^9}, 
   3.625549500545082*^9, {3.777975903372878*^9, 3.777975935021472*^9}, {
   3.810485946197016*^9, 3.810485947806433*^9}},
 CellLabel->
  "In[380]:=",ExpressionUUID->"7e5c1d48-d3bf-4f38-924f-f7d90f2ec7b9"],

Cell[TextData[{
 "View the definition for ",
 StyleBox["isFour",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.637644955807289*^9, 3.6376449621817408`*^9}, {
  3.6379423950576677`*^9, 
  3.6379423974799833`*^9}},ExpressionUUID->"fc30ddb1-93cd-4f4a-aba7-\
e88ee37f723b"],

Cell[BoxData[
 RowBox[{"?", "isFour"}]], "Input",
 CellChangeTimes->{{3.637644963734951*^9, 
  3.6376449650146713`*^9}},ExpressionUUID->"5d9c090b-280a-42c3-b6b5-\
5aaf351b2d97"]
}, Open  ]],

