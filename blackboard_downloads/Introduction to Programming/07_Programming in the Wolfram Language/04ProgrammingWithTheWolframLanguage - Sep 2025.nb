   3.604715805103326*^9}},ExpressionUUID->"b439ae48-9c1f-4d19-85f5-\
4f818326817c"],

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"product", "=", "1."}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"product", "*=", 
       RowBox[{"list", "[", 
        RowBox[{"[", "n", "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", 
        RowBox[{"Length", "[", "list", "]"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", "product"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.604715825111448*^9, 
  3.6047158270555844`*^9}},ExpressionUUID->"1b675399-5e0e-449b-a9a8-\
fdd1851e095c"],

Cell[BoxData["product"], "Input",
 CellChangeTimes->{{3.6047158300357227`*^9, 
  3.604715830973776*^9}},ExpressionUUID->"160c4abc-bd0c-4f8b-895b-\
c3bfd2b4a516"],

Cell[TextData[{
 StyleBox[ButtonBox["Module",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Module"],
  FontWeight->"Bold"],
 " and ",
 StyleBox[ButtonBox["Block",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Block"],
  FontWeight->"Bold"],
 " work interchangeably in many situations. However, they localize the \
symbols in different ways."
}], "Text",
 CellChangeTimes->{{3.604715624501769*^9, 3.6047156514612875`*^9}, {
  3.60471603485297*^9, 3.604716043940527*^9}, {3.605812598069803*^9, 
  3.6058126443510685`*^9}, {3.605959585032816*^9, 
  3.605959594850797*^9}},ExpressionUUID->"f696d2fd-7a88-4a90-91b2-\
c9a9a81ee130"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", "5"}], ";"}]], "Input",
 CellChangeTimes->{{3.6047158739722185`*^9, 
  3.604715875622279*^9}},ExpressionUUID->"3fd3d347-a408-4a97-b34b-\
27462aae1366"],

Cell[TextData[{
 StyleBox[ButtonBox["Module",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Module"],
  FontWeight->"Bold"],
 " creates a temporary assignment for all specified variables during the \
evaluation."
}], "Text",
 CellChangeTimes->{{3.604716206020954*^9, 3.6047162347725677`*^9}, {
  3.605959626252938*^9, 
  3.605959626254937*^9}},ExpressionUUID->"c39ca84b-6ac8-4a55-8b87-\
2f0bf7593f55"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", "x", "}"}], ",", 
   RowBox[{"Print", "[", 
    RowBox[{"Expand", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", "x"}], ")"}], "^", "2"}], "]"}], "]"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.6047158958634043`*^9, 3.604715918775699*^9}, {
  3.6047159850951786`*^9, 
  3.604715988007381*^9}},ExpressionUUID->"4b12ef23-5667-41df-8d90-\
e59e1639adc2"],

Cell[TextData[{
 StyleBox[ButtonBox["Block",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Block"],
  FontWeight->"Bold"],
 " suspends any existing assignment for all specified variables during the \
evaluation. When the execution of the block is finished, the original values \
of these symbols are restored. "
}], "Text",
 CellChangeTimes->{{3.6047162585509067`*^9, 3.6047162782600346`*^9}, {
  3.6047163336841154`*^9, 3.6047163473323355`*^9}, {3.605959640816394*^9, 
  3.605959640819394*^9}},ExpressionUUID->"84332147-ce2d-4783-b135-\
4848d016af5d"],

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", "x", "}"}], ",", 
   RowBox[{"Print", "[", 
    RowBox[{"Expand", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", "x"}], ")"}], "^", "2"}], "]"}], "]"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.60471594192399*^9, 
  3.60471599424669*^9}},ExpressionUUID->"39be5a14-233c-4b0c-aa40-\
833afcc7daf4"]
