   3.614950073192862*^9, 3.6149500759113917`*^9}, {3.615735065221035*^9, 
   3.615735071948152*^9}},ExpressionUUID->"40114ab4-c318-4251-b308-\
2f3e576e74aa"],

Cell[TextData[{
 "Example: Calculate the product of a list of numbers by ",
 StyleBox[ButtonBox["Do",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Do"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.561801782160016*^9, 3.561801868066394*^9}, {
