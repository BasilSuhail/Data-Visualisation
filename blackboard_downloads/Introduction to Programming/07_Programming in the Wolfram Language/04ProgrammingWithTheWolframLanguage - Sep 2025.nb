Cell[TextData[{
 "Create a ",
 StyleBox[ButtonBox["Do",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Do"],
  FontWeight->"Bold"],
 ", ",
 StyleBox[ButtonBox["For",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/For"],
  FontWeight->"Bold"],
 ", and ",
 StyleBox[ButtonBox["While",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/While"],
  FontWeight->"Bold"],
 " loop to add up all the numbers in \[OpenCurlyDoubleQuote]list.\
\[CloseCurlyDoubleQuote]"
}], "Text",
 CellChangeTimes->{{3.637474572528015*^9, 3.637474615693083*^9}, {
  3.637653105657379*^9, 3.637653107679997*^9}, {3.637916764352727*^9, 
  3.637916777291899*^9}, {3.6379414802412467`*^9, 3.637941483601518*^9}, {
