Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " has built-in functions that could build up vectors, matrices, tensors, \
etc. easily. These functions provide the basic data structures that will be \
used in a functional programming approach."
}], "Text",
 CellChangeTimes->{{3.561801782160016*^9, 3.561801868066394*^9}, {
   3.562930946340777*^9, 3.562930963752026*^9}, {3.562931005000078*^9, 
   3.562931062456592*^9}, {3.564214396173115*^9, 3.564214409887048*^9}, {
   3.565028580967127*^9, 3.565028605643134*^9}, 3.568054445462513*^9, {
   3.604164148750564*^9, 3.6041642133445644`*^9}, {3.604164393630028*^9, 
   3.604164425544218*^9}, {3.6041644558492484`*^9, 3.60416445956062*^9}, {
   3.604164541019765*^9, 3.604164543852048*^9}, {3.604714298294949*^9, 
   3.6047143306787653`*^9}, {3.605808230836325*^9, 3.605808232452418*^9}, {
