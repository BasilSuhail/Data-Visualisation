Cell[CellGroupData[{

Cell["Pattern Matching and Rules", "Section",
 CellChangeTimes->{{3.561799462163089*^9, 3.5617994690491743`*^9}, {
  3.5628653757520237`*^9, 3.562865377903798*^9}, {3.562927305707418*^9, 
  3.5629273097634706`*^9}, {3.605830640258235*^9, 3.6058306441784487`*^9}, {
  3.605830683698644*^9, 3.6058306908180437`*^9}, {3.605831716320857*^9, 
  3.605831728512504*^9}},ExpressionUUID->"62b23db7-4178-4d44-b9f4-\
969d356410df"],

Cell[TextData[{
 "Pattern matching is used in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " for checking the presence of certain pattern(s) within an expression. It \
could be used with ",
 StyleBox[ButtonBox["Rule",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Rule"],
  FontWeight->"Bold"],
 " for modifying/replacing the existing expressions. Pattern matching and ",
 StyleBox[ButtonBox["Rule",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Rule"],
  FontWeight->"Bold"],
 " could be used to perform complex tasks much more efficiently than using \
procedural programming. To see if a pattern is matched, ",
 StyleBox[ButtonBox["MatchQ",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/MatchQ"],
  FontWeight->"Bold"],
 " is used."
}], "Text",
 CellChangeTimes->{{3.561799494111046*^9, 3.561799608657658*^9}, {
   3.562927456876025*^9, 3.562927513954376*^9}, {3.5638677620088377`*^9, 
   3.5638678231646147`*^9}, {3.564214526800687*^9, 3.56421453933876*^9}, {
   3.568054734790388*^9, 3.56805473551206*^9}, {3.6058313757463126`*^9, 
   3.605831381200627*^9}, {3.605831484032864*^9, 3.605831505105065*^9}, {
   3.6058315491684694`*^9, 3.605831559873073*^9}, {3.605831601249369*^9, 
   3.605831636976343*^9}, {3.605831808208962*^9, 3.605831907711893*^9}, {
   3.605831965440077*^9, 3.6058319828480444`*^9}, {3.6059601284822946`*^9, 
   3.6059601461292944`*^9}, {3.614257242690687*^9, 3.614257272395171*^9}, {
   3.614257311667165*^9, 3.614257311670031*^9}, {3.615736053157278*^9, 
   3.61573611490411*^9}, 3.615827806138226*^9, {3.637942121941581*^9, 
   3.637942124639254*^9}},ExpressionUUID->"6ef27fa6-32df-4da2-8b62-\
fcc517fcbc86"],

