Cell[TextData[{
 "In a functional approach, you can use ",
 StyleBox[ButtonBox["Apply",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Apply"],
  FontWeight->"Bold"],
 " to change the ",
 StyleBox[ButtonBox["Head",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Head"],
  FontWeight->"Bold"],
 " of the list to ",
 StyleBox[ButtonBox["Times",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Times"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.611937186821517*^9, 3.6119372417270074`*^9}, {
  3.611937420565888*^9, 3.6119374216619987`*^9}, {3.611937486296461*^9, 
