     Cell[
      BoxData[
       RowBox[{
         RowBox[{"invert", "[", 
           RowBox[{"x_", "/;", 
             RowBox[{"x", "\[NotEqual]", "0"}]}], "]"}], ":=", 
         RowBox[{"1", "/", "x"}]}]], "Input"]}],
  Evaluator->Automatic,
  FrameMargins->4,
  Method->"Queued"]], "Text",
 CellChangeTimes->{
