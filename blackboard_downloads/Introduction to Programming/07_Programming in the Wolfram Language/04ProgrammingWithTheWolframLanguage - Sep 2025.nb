   RowBox[{"{", 
    RowBox[{"pt", "=", 
     RowBox[{"{", 
      RowBox[{"3", ",", "4.2", ",", 
       RowBox[{"RandomReal", "[", 
        RowBox[{"1", ",", "3"}], "]"}]}], "}"}]}], "}"}], ",", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"MatchQ", "[", 
