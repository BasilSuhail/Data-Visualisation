Cell[BoxData[{
 RowBox[{
  RowBox[{"product1", "=", "1."}], ";", 
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{"product1", "*=", 
     RowBox[{"list", "[", 
      RowBox[{"[", "n", "]"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", 
      RowBox[{"Length", "[", "list", "]"}]}], "}"}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", "product1"}], "Input",
 CellChangeTimes->{{3.604714916484934*^9, 3.6047149396232343`*^9}, {
