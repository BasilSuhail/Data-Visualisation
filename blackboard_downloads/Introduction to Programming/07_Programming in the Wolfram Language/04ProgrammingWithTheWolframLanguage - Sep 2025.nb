Cell[CellGroupData[{

Cell["Functional Programming", "Section",
 CellChangeTimes->{{3.56179809434405*^9, 3.561798100869598*^9}, {
   3.561799471637233*^9, 3.5617994757462254`*^9}, 3.5628653247227483`*^9, {
