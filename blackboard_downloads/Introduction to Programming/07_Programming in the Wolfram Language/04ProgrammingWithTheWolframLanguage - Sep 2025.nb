9811f783287f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Mean", "[", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", "=", 
       RowBox[{"10", "^", "6"}]}], "}"}], ",", 
     RowBox[{"ParallelEvaluate", "[", 
      RowBox[{"f", "[", "n", "]"}], "]"}]}], "]"}], "]"}], "//", 
  "AbsoluteTiming"}]], "Input",ExpressionUUID->"704f42ff-e80a-4aa9-a103-\
3b99dc1a883f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", "=", 
      RowBox[{"10", "^", "6"}]}], "}"}], ",", 
    RowBox[{"f", "[", 
     RowBox[{"4", " ", "n"}], "]"}]}], "]"}], "//", 
  "AbsoluteTiming"}]], "Input",
 CellChangeTimes->{{3.623778372950806*^9, 
  3.623778375088006*^9}},ExpressionUUID->"63be6762-61cc-4170-a9a4-\
c28994be2f39"],

Cell["\<\
If the problem cannot be solved with parallel methods, the expression will be \
solved using normal methods.\
\>", "Text",
 CellChangeTimes->{{3.563443405608777*^9, 3.563443525156806*^9}, {
   3.563878280185405*^9, 3.563878288185071*^9}, 3.564217320839119*^9, {
   3.568142796663935*^9, 3.568142815791607*^9}, 3.568559155515969*^9, {
   3.605960599154294*^9, 3.6059606167472944`*^9}, {3.623778390720206*^9, 
   3.623778393122606*^9}},ExpressionUUID->"87b0ca83-b0f4-4ac0-86ec-\
54f224d89bf4"],

Cell[BoxData[
 RowBox[{"Parallelize", "[", 
  RowBox[{"\[Integral]", 
   RowBox[{
    FractionBox[
     RowBox[{"1", "+", 
      SuperscriptBox["x", "4"]}], 
     RowBox[{
      SuperscriptBox["x", "9"], "+", 
      RowBox[{"3", "x"}]}]], 
    RowBox[{"\[DifferentialD]", "x"}]}]}], "]"}]], "Input",ExpressionUUID->\
"fe625d54-1eed-4906-aa23-e0bb734b1348"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GPU-Based Parallelization", "Subsection",
 CellChangeTimes->{{3.563443771727072*^9, 3.563443779375296*^9}, 
   3.564217326295304*^9, 
   3.568142997020661*^9},ExpressionUUID->"84cb1847-2096-4429-a973-\
5cfa6848cbb8"],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " supports the two most widely used GPU platforms, CUDA and OpenCL, provided \
appropriate hardware is available. CUDA and OpenCL functions are coded and \
utilized in much the same way."
}], "Text",
 CellChangeTimes->{{3.563443781107859*^9, 3.56344378651048*^9}, {
   3.563443877893611*^9, 3.563444017495075*^9}, 3.563878302983913*^9, {
