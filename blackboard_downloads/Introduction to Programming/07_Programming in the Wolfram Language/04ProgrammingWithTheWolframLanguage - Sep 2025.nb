de59d3de2a8f"],

Cell[TextData[{
 "What is the most specific and the most general pattern to match the string ",
 StyleBox["\[OpenCurlyDoubleQuote]Programming\[CloseCurlyDoubleQuote]", 
  "Program"],
 "?"
}], "ItemNumbered",
 CellChangeTimes->{{3.6254860399312763`*^9, 3.6254860606751227`*^9}, {
  3.658473323328556*^9, 
  3.658473328281066*^9}},ExpressionUUID->"3be8c81f-755b-47df-9692-\
d8e5824c9d2a"],

Cell[BoxData[
 ButtonBox["Answer",
  Appearance->Automatic,
  ButtonFunction:>CreateDocument[{
     Cell["The most specific is the string itself.", "Text"], 
     Cell[
      BoxData["\"Programming\""], "Input"], 
     Cell["Check that it matches.", "Text"], 
     Cell[
      BoxData[
       RowBox[{"MatchQ", "[", 
         RowBox[{"\"Programming\"", ",", "\"Programming\""}], "]"}]], 
      "Input"], 
     Cell["The most general is a blank, any expression.", "Text"], 
     Cell[
      BoxData["_"], "Input"], 
     Cell["Check that it matches.", "Text"], 
     Cell[
      BoxData[
       RowBox[{"MatchQ", "[", 
         RowBox[{"\"Programming\"", ",", "_"}], "]"}]], "Input"]}],
  Evaluator->Automatic,
  FrameMargins->4,
  Method->"Queued"]], "Text",
 CellChangeTimes->{
  3.614359485023006*^9},ExpressionUUID->"cfbd56ff-bd5f-4266-b407-\
ee1173ee0cb3"],

