Cell[TextData[{
 "You can also add conditions on a pattern by using ",
 StyleBox[ButtonBox["Condition ",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Condition"],
  FontWeight->"Bold"],
 "(/;). Here a name is given to the ",
 StyleBox[ButtonBox["Blank",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Blank"],
  FontWeight->"Bold"],
 " so ",
 StyleBox[ButtonBox["Condition",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Condition"],
  FontWeight->"Bold"],
 " can be used to check to see if it is odd. The name is placed before the ",
 StyleBox[ButtonBox["Blank",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Blank"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.605834226397828*^9, 3.605834246908928*^9}, {
   3.605834283308956*^9, 3.605834406076131*^9}, {3.6059601977972946`*^9, 
   3.6059602136452947`*^9}, {3.614265647575756*^9, 3.614265647846054*^9}, {
   3.615736158790286*^9, 3.615736203033411*^9}, {3.615736233424389*^9, 
   3.615736243831534*^9}, {3.623776040798401*^9, 3.623776073012401*^9}, 
   3.637942141918773*^9},ExpressionUUID->"962412b2-5475-4a73-9d09-\
2c062af0e59d"],

Cell[BoxData[
 RowBox[{"MatchQ", "[", 
  RowBox[{"7.0", ",", 
   RowBox[{"x_", "/;", 
    RowBox[{"OddQ", "[", "x", "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.777879819231987*^9, 3.777879840119725*^9}},
 CellLabel->
  "In[123]:=",ExpressionUUID->"0e0d641b-04b0-4472-958a-4f8b43b922b0"],

Cell[BoxData[
 RowBox[{"MatchQ", "[", 
  RowBox[{"7.0", ",", 
   RowBox[{"x_", "/;", 
    RowBox[{"OddQ", "[", "x", "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.60583442201505*^9, 3.605834431261532*^9}, {
  3.614265704138359*^9, 3.614265718387194*^9}, {3.623776047943201*^9, 
  3.6237760524672017`*^9}},ExpressionUUID->"eb073eca-8179-4111-a74e-\
5499e9888b90"],

Cell[TextData[{
 "Note that 7.0 is not an exact number, so ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " treats it as neither even nor odd. However, 7 is an integer and is odd."
}], "Text",
 CellChangeTimes->{{3.614265765629801*^9, 3.614265848968483*^9}, {
   3.614265886294695*^9, 3.614265886297385*^9}, {3.614265933226076*^9, 
   3.614265947433519*^9}, {3.615736257907571*^9, 3.615736283086982*^9}, 
   3.615827823649335*^9, {3.623776069377601*^9, 3.6237761116224127`*^9}, {
   3.637942146704837*^9, 
   3.637942173211727*^9}},ExpressionUUID->"1b1800f2-22d5-4c54-8ed8-\
7d9d7334763f"],

