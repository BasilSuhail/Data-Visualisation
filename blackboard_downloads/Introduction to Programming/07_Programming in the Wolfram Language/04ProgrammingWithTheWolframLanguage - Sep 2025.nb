Cell[TextData[{
 "Loop constructs can be realized in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " using ",
 StyleBox[ButtonBox["Do",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Do"],
  FontWeight->"Bold"],
 ", ",
 StyleBox[ButtonBox["For",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/For"],
  FontWeight->"Bold"],
 ", or ",
 StyleBox[ButtonBox["While",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/While"],
  FontWeight->"Bold"],
 ". These functions do not return a value unless the body of the function has \
created a value. Here is a ",
 StyleBox[ButtonBox["Do",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Do"],
  FontWeight->"Bold"],
 " loop that does not create or return a value."
}], "Text",
