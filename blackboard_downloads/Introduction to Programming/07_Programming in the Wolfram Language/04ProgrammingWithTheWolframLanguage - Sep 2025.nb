Cell["\<\
Here is a basic example of a predicate function used to determine the \
equality of two expressions.\
\>", "Text",
 CellChangeTimes->{{3.623701411503635*^9, 3.623701427996835*^9}, 
   3.6379413389573927`*^9},ExpressionUUID->"d9a383c1-2ad6-4a32-8528-\
151fc7b93509"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["2", "2"], "\[Equal]", "4"}]], "Input",
 CellChangeTimes->{{3.623701431272835*^9, 
  3.623701435297635*^9}},ExpressionUUID->"4e4893f6-fb1b-4c9c-9a5f-\
9089843f2aaf"],

Cell[TextData[{
 "Predicate functions can be strung together. Here ",
 StyleBox[ButtonBox["And",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/And"],
  FontWeight->"Bold"],
 " (&&) is used to combine ",
 StyleBox[ButtonBox["Equal",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Equal"],
  FontWeight->"Bold"],
 " (==) with ",
 StyleBox[ButtonBox["Greater",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Greater"],
  FontWeight->"Bold"],
 " (>)."
}], "Text",
 CellChangeTimes->{{3.623701446640835*^9, 3.623701489837235*^9}, {
  3.63794134898991*^9, 
  3.637941403340443*^9}},ExpressionUUID->"3ecdc87e-e353-47ae-83de-\
2a7943e0c30a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["3", "3"], "\[Equal]", "27"}], "&&", 
  RowBox[{"2", ">", "Pi"}]}]], "Input",
 CellChangeTimes->{{3.623701492629635*^9, 
  3.623701504596835*^9}},ExpressionUUID->"65170b8d-1ff2-45f6-85e3-\
