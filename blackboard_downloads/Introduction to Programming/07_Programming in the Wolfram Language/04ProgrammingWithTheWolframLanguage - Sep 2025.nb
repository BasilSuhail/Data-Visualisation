Cell[TextData[{
 StyleBox[ButtonBox["Apply",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Apply"],
  FontWeight->"Bold"],
 " replaces the head of the expression to which it is applied. It uses the \
form ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Apply", "[", 
    RowBox[{"f", ",", " ", "expr"}], "]"}], MR]],ExpressionUUID->
  "9f494f1d-0fce-4b6c-85b9-b3fbde892543"],
 ". You could also use @@, which is the shorthand form."
}], "Text",
 CellChangeTimes->{
  3.60596709707286*^9, {3.615735754762394*^9, 3.6157357550813837`*^9}, {
   3.637917000223363*^9, 
