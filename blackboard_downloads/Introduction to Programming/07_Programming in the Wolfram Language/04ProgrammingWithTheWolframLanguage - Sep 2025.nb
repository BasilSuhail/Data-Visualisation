Cell["\<\
Create a pattern to match a list with three elements, where the first element \
is an odd prime and the second element is a string.\
\>", "ItemNumbered",
 CellChangeTimes->{{3.625490120841357*^9, 3.625490128047131*^9}, {
   3.625490171081171*^9, 3.625490171190847*^9}, {3.625491023650377*^9, 
   3.625491030185069*^9}, {3.625491111433337*^9, 3.625491145024579*^9}, {
   3.6254913464689636`*^9, 3.625491401500614*^9}, 3.637942199379027*^9, {
   3.658473650884076*^9, 
   3.658473651937165*^9}},ExpressionUUID->"312e28e8-6291-4a9c-8bc6-\
687d0791c9ae"],

Cell[BoxData[
 ButtonBox["Solution",
  Appearance->Automatic,
  ButtonFunction:>CreateDocument[{
     Cell[
      BoxData[
       RowBox[{"{", 
         RowBox[{
           RowBox[{"x_", "/;", "OddQ[x]", "&&", "PrimeQ[x]"}], ",", "_String",
            ",", "_"}], "}"}]], "Input"]}],
  Evaluator->Automatic,
  FrameMargins->4,
  Method->"Queued"]], "Text",
 CellChangeTimes->{
  3.614359485023006*^9},ExpressionUUID->"f76bcba4-8eee-4af0-ab5a-\
d690df254c32"]
