   3.637941520227539*^9},ExpressionUUID->"8e191f51-748f-4bff-b8ee-\
3fe673206c60"],

Cell[TextData[{
 "Example: Create a matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "a42c12c2-f750-4a9e-9f30-3048257767c4"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"n", ",", "1"}], "]"}], "]"}], "=", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{"n", "-", "1"}], ")"}], "\[Pi]"}], "10"]}], ",", " ", 
    RowBox[{
     RowBox[{"M", "[", 
      RowBox[{"[", 
       RowBox[{"n", ",", "2"}], "]"}], "]"}], "=", 
     RowBox[{"Sin", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "\[Pi]"}], "10"], "]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"f3311685-31df-4073-bb6e-c028b9f8424e"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[LessEqual]", " ", "n", "\[LessEqual]", " ", "11"}], 
   TraditionalForm]],ExpressionUUID->"bc516ea6-430c-4742-89ef-ba021a17e916"],
 "."
}], "Text",
 CellChangeTimes->{{3.561801782160016*^9, 3.561801868066394*^9}, {
   3.562930946340777*^9, 3.562930963752026*^9}, {3.562931005000078*^9, 
