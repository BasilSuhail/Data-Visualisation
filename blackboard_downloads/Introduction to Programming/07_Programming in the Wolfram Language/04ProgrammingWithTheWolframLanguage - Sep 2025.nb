 RowBox[{
  RowBox[{"newton", "[", 
   RowBox[{"f_", ",", "x0_"}], "]"}], ":=", 
  RowBox[{"x0", "-", 
   RowBox[{
    RowBox[{"f", "[", "x0", "]"}], "/", 
