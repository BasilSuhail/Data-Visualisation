Cell[BoxData[
 TagBox[GridBox[{
    {
     RowBox[{
      RowBox[{
       RowBox[{"x", "&&", "y"}], ",", " ", 
       RowBox[{"x", "\[And]", "y"}]}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"x", "||", "y"}], ",", " ", 
       RowBox[{"x", "\[Or]", "y"}]}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"!", "x"}], ",", " ", 
       RowBox[{"\[Not]", "x"}]}], "\[IndentingNewLine]", 
      RowBox[{"x", "\[Xor]", "y"}], "\[IndentingNewLine]", 
      RowBox[{"x", "\[Equal]", "y"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"x", "!=", "y"}], ",", " ", 
       RowBox[{"x", "\[NotEqual]", "y"}]}], "\[IndentingNewLine]", 
      RowBox[{"x", ">", "y"}], "\[IndentingNewLine]", 
      RowBox[{"x", "<", "y"}], "\[IndentingNewLine]", 
      RowBox[{"x", "\[GreaterEqual]", "y"}], "\[IndentingNewLine]", 
      RowBox[{"x", "\[LessEqual]", "y"}]}], 
     RowBox[{
     "And", "\[IndentingNewLine]", "Or", "\[IndentingNewLine]", "Not", 
      "\[IndentingNewLine]", "Xor", "\[IndentingNewLine]", "Equal", 
      "\[IndentingNewLine]", "Unequal", "\[IndentingNewLine]", "Greater", 
      "\[IndentingNewLine]", "Less", "\[IndentingNewLine]", "GreaterEqual", 
      "\[IndentingNewLine]", "LessEqual"}]}
   },
