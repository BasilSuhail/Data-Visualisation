   3.615735235387903*^9}},ExpressionUUID->"71ebf4dc-9804-4d96-9937-\
eedb1554c71b"],

Cell[TextData[{
 "Following are five equivalent ways of defining and using the anonymous \
function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     SuperscriptBox["x", "2"], "+", 
     RowBox[{"exp", "(", "x", ")"}], "-", "3"}]}], TraditionalForm]],
  ExpressionUUID->"a81a01be-758f-4f16-a69d-036c7d1b5a7f"],
 "."
}], "Text",
 CellChangeTimes->{{3.604716810611819*^9, 3.604716917331925*^9}, {
