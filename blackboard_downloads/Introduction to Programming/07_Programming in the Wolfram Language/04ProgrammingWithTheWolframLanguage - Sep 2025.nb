    RowBox[{"n", "\[GreaterEqual]", "2"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"gib", "[", 
    RowBox[{"n", "-", "1"}], "]"}], "+", 
   RowBox[{"gib", "[", 
    RowBox[{"n", "-", "2"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gib", "[", "0", "]"}], "=", "0"}], ";"}], "\[IndentingNewLine]", 
