           RowBox[{"AbsolutePointSize", "[", "3", "]"}], ",", 
           RowBox[{"Point", "[", "#", "]"}]}], "}"}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"\"\<\[Pi] is approximately \>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"4.0", 
             RowBox[{
