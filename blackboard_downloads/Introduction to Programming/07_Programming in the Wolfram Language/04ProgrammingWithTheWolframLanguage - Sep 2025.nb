Cell[TextData[{
 "Example: Calculate the product of a list of numbers. The ",
 StyleBox[ButtonBox["TimesBy",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/TimesBy"],
  FontWeight->"Bold"],
 " (*=) function is used here to assign the product value. Particular \
attention should be paid to the order of the arguments in each of these \
examples."
}], "Text",
