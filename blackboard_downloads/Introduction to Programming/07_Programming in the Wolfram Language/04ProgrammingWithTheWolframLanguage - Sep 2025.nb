Cell["Example: Fibonacci number.", "Text",
 CellChangeTimes->{
  3.60596720204786*^9},ExpressionUUID->"317cda9f-2c16-497d-9420-d6b3e96ec7aa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"fib", "[", 
   RowBox[{"n_Integer", "/;", 
    RowBox[{"n", "\[GreaterEqual]", "2"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"fib", "[", "n", "]"}], "=", 
   RowBox[{
    RowBox[{"fib", "[", 
     RowBox[{"n", "-", "1"}], "]"}], "+", 
    RowBox[{"fib", "[", 
     RowBox[{"n", "-", "2"}], "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fib", "[", "0", "]"}], "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fib", "[", "1", "]"}], "=", "1"}], ";"}]}], "Input",
 CellChangeTimes->{{3.562930723753166*^9, 3.562930870835839*^9}, {
   3.605837140426562*^9, 3.605837294397039*^9}, 3.614266037465658*^9, 
