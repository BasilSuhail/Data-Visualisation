Cell[TextData[{
 StyleBox["Missing[\[OpenCurlyDoubleQuote]NotAvailable\[CloseCurlyDoubleQuote]\
]", "Program"],
 " is used in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to show that data is missing. The string should contain the reason data is \
missing and can be anything. ",
 StyleBox["\[OpenCurlyDoubleQuote]NotAvailable\[CloseCurlyDoubleQuote]", 
  "Program"],
 " is a commonly used string. Many functions automatically ignore those \
elements."
}], "SubitemParagraph",
