Cell[CellGroupData[{

Cell["Anonymous Functions", "Section",
 CellChangeTimes->{{3.614254875674479*^9, 
  3.6142548839299088`*^9}},ExpressionUUID->"acb1b1ef-5502-48b6-9441-\
712a5e334438"],

Cell[TextData[{
 "The strength of an anonymous function is the minimal effect it has. Since \
an anonymous function has no side effects and does not have to be assigned to \
a symbol, you can perform a quick transformation of data with little impact \
further on. A common use is with the ",
 StyleBox[ButtonBox["Map",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Map"],
  FontWeight->"Bold"],
 " function. Here is a list with various kinds of elements."
}], "Text",
 CellChangeTimes->{{3.6237741374180026`*^9, 3.623774279503714*^9}, {
  3.6379170978624377`*^9, 3.637917097940564*^9}, {3.637941955029441*^9, 
  3.6379419735338693`*^9}},ExpressionUUID->"6b0bcf0b-b33b-49d3-8159-\
777c743f04b2"],

Cell[BoxData[
 RowBox[{"thisList", " ", "=", " ", 
  RowBox[{"{", 
   RowBox[{"a", ",", "12", ",", "\"\<hello\>\"", ",", 
    RowBox[{"{", 
     RowBox[{"3", ",", 
      RowBox[{"4", "/", "5"}]}], "}"}], ",", 
    RowBox[{"Plus", "[", 
     RowBox[{"a", ",", "b"}], "]"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.623774281016923*^9, 3.623774319798772*^9}, {
  3.777879341486863*^9, 
  3.7778793483747177`*^9}},ExpressionUUID->"4cb65d02-4bda-4998-8ffd-\
3be00afe79d4"],

Cell["\<\
By using an anonymous function, you could check for what elements are \
integers.\
\>", "Text",
 CellChangeTimes->{{3.623774352636982*^9, 3.6237743797967577`*^9}, {
   3.637917103003219*^9, 3.637917103456372*^9}, 
   3.63794198205706*^9},ExpressionUUID->"fe24b3bc-0521-4a94-8515-\
e72806937d27"],

Cell[BoxData[
 RowBox[{"Head", "[", "a", "]"}]], "Input",
 CellChangeTimes->{{3.777879284233057*^9, 3.77787928648879*^9}},
 CellLabel->
  "In[104]:=",ExpressionUUID->"48b70013-1350-4506-878c-ed108b9d9fc1"],

Cell[BoxData[
 RowBox[{"Map", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Head", "[", "#", "]"}], "===", "Integer"}], "&"}], ",", 
   "thisList"}], "]"}]], "Input",
 CellChangeTimes->{{3.623774323761197*^9, 3.623774350125366*^9}, {
  3.623774390779227*^9, 3.6237743919804354`*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"8cdfbd77-0f2f-4881-9b6e-0e56fa520ccf"],

Cell["\<\
Alternatively, you could use an anonymous function to transform data.\
\>", "Text",
 CellChangeTimes->{{3.623774414522579*^9, 3.623774431417487*^9}, {
   3.637917108001342*^9, 3.637917111740392*^9}, 
   3.6379419835886574`*^9},ExpressionUUID->"57ad3796-563c-4190-85c1-\
741e03df1837"],

Cell[BoxData[
 RowBox[{"data", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{"i", ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "0", ",", 
      RowBox[{"2", " ", "Pi"}], ",", "0.1"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.623774433991504*^9, 3.623774451338815*^9}},
 CellLabel->
  "In[106]:=",ExpressionUUID->"7ceada92-5894-4fd2-8dd2-21e345eeb265"],

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{"Transpose", "[", 
   RowBox[{"{", 
    RowBox[{"data", ",", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Sin", "[", "#", "]"}], "^", "2"}], "&"}], ",", "data"}], 
      "]"}]}], "}"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.623774456642849*^9, 3.6237744689825287`*^9}, {
  3.777879448594878*^9, 3.777879468878524*^9}},
 CellLabel->
  "In[109]:=",ExpressionUUID->"03dd0dea-0a37-4d3e-8dc6-2042f1c898f0"],

Cell[TextData[{
 "Of course, it can be helpful to use anonymous functions in a variety of \
situations. Using ",
 StyleBox[ButtonBox["NestList",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NestList"],
  FontWeight->"Bold"],
 ", you can quickly determine the results of interest compounded annually."
}], "Text",
 CellChangeTimes->{{3.6237745051123605`*^9, 3.623774523333277*^9}, {
  3.623774559104306*^9, 3.623774602082582*^9}, {3.637942029503248*^9, 
  3.637942039512608*^9}},ExpressionUUID->"c968d810-38c2-4642-889c-\
0757ba22b98a"],

Cell["Morgage \[Sterling]300000 over 30 years", "WolframAlphaLong",
 CellChangeTimes->{{3.7778795489205112`*^9, 3.777879569872423*^9}},
 CellLabel->
  "In[113]:=",ExpressionUUID->"a461aeb1-14e1-4a0d-b79b-4855fec80b68"],

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{"NestList", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"1.05", " ", "#"}], " ", "&"}], ",", "1000", ",", "120"}], "]"}],
   "]"}]], "Input",
 CellChangeTimes->{{3.6237745260476947`*^9, 3.6237745561402874`*^9}, {
  3.777879497171427*^9, 3.77787950712397*^9}},
 CellLabel->
  "In[112]:=",ExpressionUUID->"dffbd85c-7ced-4d63-8323-15b855df928f"],

Cell["Here is a set of amplitudes.", "Text",
 CellChangeTimes->{{3.6237747795649195`*^9, 3.6237747864133635`*^9}, {
   3.637917119651747*^9, 3.6379171227927685`*^9}, 3.637941986631672*^9, {
   3.6379420532243276`*^9, 
   3.637942054615034*^9}},ExpressionUUID->"0cde1f4c-f019-4023-9869-\
af235eb6702e"],

Cell[BoxData[
 RowBox[{"amplitudes", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "i"}], "/", "10."}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "10", ",", "100", ",", "10"}], "}"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.6237746754654527`*^9, 3.6237747638712196`*^9}},
 CellLabel->
  "In[114]:=",ExpressionUUID->"85b28fc7-1b15-4ba7-a3e9-b8ba134b2387"],

Cell["The amplitudes correspond to frequencies.", "Text",
 CellChangeTimes->{{3.623774789533383*^9, 3.623774797645435*^9}, {
   3.637917128282644*^9, 3.6379171324771147`*^9}, 3.637941988194259*^9, 
   3.6379420675394955`*^9},ExpressionUUID->"d0111be5-25e6-487f-92a6-\
6e53dd1696f1"],

Cell[BoxData[
 RowBox[{"frequencies", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{"i", ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "10", ",", "100", ",", "10."}], "}"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.623774741625476*^9, 3.6237747737148814`*^9}, 
   3.6237749334590483`*^9},
 CellLabel->
  "In[115]:=",ExpressionUUID->"5dc1956f-9f39-4378-8e10-5ffc71deb131"],

Cell[TextData[{
 "You can use ",
 StyleBox[ButtonBox["Thread",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Thread"],
  FontWeight->"Bold"],
 " with an anonymous function to generate the wavefunction."
}], "Text",
 CellChangeTimes->{{3.6237748006250486`*^9, 3.623774816318649*^9}, {
   3.6237750287282476`*^9, 3.623775032363048*^9}, {3.637917136240934*^9, 
   3.637917144475235*^9}, 3.637941990460251*^9, {3.637942074982117*^9, 
   3.637942088315936*^9}},ExpressionUUID->"5d4ae3fc-b5b7-46a3-80b7-\
1779050c97c5"],

Cell[BoxData[
 RowBox[{"Thread", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"#1", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"#2", " ", "x"}], "]"}]}], "&"}], "[", 
   RowBox[{"amplitudes", ",", "frequencies"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.623774637962812*^9, 3.62377464705767*^9}, {
