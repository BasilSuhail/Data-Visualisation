Cell[TextData[{
 "A basic tool of procedural programming is the predicate function. A \
predicate is a function with a range of two values, ",
 StyleBox[ButtonBox["True",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/True"],
  FontWeight->"Bold"],
 " and ",
 StyleBox[ButtonBox["False",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/False"],
  FontWeight->"Bold"],
 ". ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " has built-in symbols for these two values."
}], "Text",
 CellChangeTimes->{{3.561801782160016*^9, 3.561801868066394*^9}, {
   3.562930946340777*^9, 3.562930963752026*^9}, {3.562931005000078*^9, 
