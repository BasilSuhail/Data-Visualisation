   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "200"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.637474617701661*^9, 3.637474639720755*^9}, 
   3.637653274906241*^9, {3.8104907982322693`*^9, 3.810490837232647*^9}},
