46d74da8388f"],

Cell[TextData[{
 "Any time you assign a value to a symbol in ",
 StyleBox["Mathematica,",
  FontSlant->"Italic"],
 " that value can influence the outcomes of other evaluations. To avoid these \
sorts of problems, it is advisable to localize variables whenever possible. \
There are two ways to localize variables in ",
 StyleBox["Mathematica:",
  FontSlant->"Italic"],
 " ",
 StyleBox[ButtonBox["Module",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Module"],
  FontWeight->"Bold"],
 " and ",
 StyleBox[ButtonBox["Block",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Block"],
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.561801782160016*^9, 3.561801868066394*^9}, {
   3.562930946340777*^9, 3.562930963752026*^9}, {3.562931005000078*^9, 
   3.562931062456592*^9}, {3.564214396173115*^9, 3.564214409887048*^9}, {
