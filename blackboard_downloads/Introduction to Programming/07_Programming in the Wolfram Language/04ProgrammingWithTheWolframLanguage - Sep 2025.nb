Cell[BoxData[{
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"product2", "=", "1."}], ";", 
     RowBox[{"n", "=", "1"}]}], ",", 
    RowBox[{"n", "\[LessEqual]", 
     RowBox[{"Length", "[", "list", "]"}]}], ",", 
    RowBox[{"n", "++"}], ",", 
    RowBox[{"product2", "*=", 
     RowBox[{"list", "[", 
      RowBox[{"[", "n", "]"}], "]"}]}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", "product2"}], "Input",
 CellChangeTimes->{{3.60471506774937*^9, 3.604715145727712*^9}, {
