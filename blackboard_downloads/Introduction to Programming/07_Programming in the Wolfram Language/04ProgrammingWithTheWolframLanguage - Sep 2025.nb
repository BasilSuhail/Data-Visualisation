Cell[BoxData[{
 RowBox[{
  RowBox[{"points", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "2"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "100", ",", "400", ",", "300"}], "}"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"Grid", "[", 
  RowBox[{"Partition", "[", 
   RowBox[{
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Graphics", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", 
           RowBox[{"Circle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", "1", ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", 
               RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}], "]"}], ",", 
           RowBox[{"GrayLevel", "[", 
            RowBox[{"0.5", ",", "0.5"}], "]"}], ",", 
           RowBox[{"Disk", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", "1", ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", 
               RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}], "]"}], ",", 
