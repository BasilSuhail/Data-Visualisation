  3.651555882754223*^9}},ExpressionUUID->"cfc5b5ce-a820-4ce8-89b8-\
525aab5deb42"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"product3", "=", "1."}], ";", 
  RowBox[{"n", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"While", "[", 
   RowBox[{
    RowBox[{"n", "\[LessEqual]", " ", 
     RowBox[{"Length", "[", "list", "]"}]}], ",", 
    RowBox[{
     RowBox[{"product3", "*=", 
      RowBox[{"list", "[", 
