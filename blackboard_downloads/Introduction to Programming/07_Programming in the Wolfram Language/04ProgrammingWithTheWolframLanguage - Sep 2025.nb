   3.5629212303880653`*^9}},
 CellTags->
  "funcitonal",ExpressionUUID->"2a885b6d-62d8-425e-b088-df1867d04054"],

Cell["\<\
Functional programming uses functions as building blocks in programming. It \
provides an efficient, elegant way to represent common computations. \
Functions can be passed as arguments into higher-order functions to perform \
routine and recursive tasks. \
\>", "Text",
 CellChangeTimes->{{3.562921232603936*^9, 3.562921361471601*^9}, 
   3.564217161740508*^9, {3.565029393062718*^9, 3.565029442597568*^9}, {
   3.603159333488615*^9, 3.603159393754615*^9}, 3.603160392576615*^9, {
   3.605959672695581*^9, 3.605959674247736*^9}, {3.6119343631094728`*^9, 
   3.6119343941985807`*^9}, {3.6119345399641557`*^9, 
   3.6119345435725174`*^9}, {3.61193465132029*^9, 3.611934664544613*^9}, {
   3.61193469662582*^9, 3.611934753459503*^9}, {3.611934788244982*^9, 
   3.6119348365908155`*^9}, 3.611935010197174*^9, {3.611935101496303*^9, 
   3.611935119193073*^9}, {3.611935157905944*^9, 3.611935203067459*^9}, {
   3.6119352867268243`*^9, 3.611935314535605*^9}, {3.6119354473648868`*^9, 
   3.61193547500565*^9}, {3.6119355541605654`*^9, 
   3.611935556175767*^9}},ExpressionUUID->"78bb703e-08fd-44c4-9776-\
44e91a4df23d"],

