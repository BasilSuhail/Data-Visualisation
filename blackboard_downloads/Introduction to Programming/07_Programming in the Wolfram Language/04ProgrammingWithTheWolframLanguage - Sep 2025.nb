Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Button", "[", 
  RowBox[{"\"\<Solution\>\"", ",", 
   RowBox[{"NotebookPut", "[", 
    RowBox[{"Notebook", "[", 
     RowBox[{"{", 
      RowBox[{"Cell", "[", "\[IndentingNewLine]", 
       RowBox[{
       "\"\<sum1=0.;Do[sum1+=list[[n]],{n,1,Length[list]}];\\nsum1\\n\n\
For[sum2=0.;n=1,n\[LessEqual]Length[list],n++,sum2+=list[[n]]];\
\[IndentingNewLine]sum2\\n\n\
sum3=0.;n=1;\[IndentingNewLine]While[n\[LessEqual] \
Length[list],sum3+=list[[n]];n++];\\nsum3\n\>\"", ",", "\"\<Input\>\""}], 
       "]"}], "}"}], "]"}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.637652798548828*^9, 3.637652799644609*^9}, {
  3.6376528481202106`*^9, 3.6376528598250103`*^9}, {3.637652901357934*^9, 
  3.637652901977673*^9}, {3.637653110430884*^9, 3.637653178257508*^9}, {
  3.637653218693451*^9, 3.637653252852222*^9}, {3.6376532925150027`*^9, 
  3.637653295063036*^9}},ExpressionUUID->"75f13762-9bcd-492b-9086-\
9d2c40b492b5"],

Cell[BoxData[
 ButtonBox["\<\"Solution\"\>",
  Appearance->Automatic,
  ButtonFunction:>NotebookPut[
    Notebook[{
      Cell[
      "sum1=0.;Do[sum1+=list[[n]],{n,1,Length[list]}];\nsum1\n\n\
For[sum2=0.;n=1,n\[LessEqual]Length[list],n++,sum2+=list[[n]]];\
\[IndentingNewLine]sum2\n\nsum3=0.;n=1;\[IndentingNewLine]While[n\[LessEqual] \
Length[list],sum3+=list[[n]];n++];\nsum3\n", "Input"]}]],
  Evaluator->Automatic,
  Method->"Preemptive"]], "Output",
 CellChangeTimes->{{3.637652849854533*^9, 3.637652860566821*^9}, {
   3.637653167689493*^9, 3.637653180248186*^9}, 3.637653254743388*^9, 
   3.637653297519414*^9},ExpressionUUID->"5d739cc6-2ee7-4f15-99e7-\
90765450889e"]
}, {2}]],

Cell["\<\
Use built in Mathematica functions to do the same with less code.\
\>", "Text",
 CellChangeTimes->{{3.81048997047416*^9, 
  3.8104899846728*^9}},ExpressionUUID->"5a5bd144-d74e-40f8-a416-cf89219deff0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"total", "=", "0."}], ";", 
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "\[LessEqual]", 
     RowBox[{"Length", "[", "list", "]"}]}], ",", 
    RowBox[{"i", "++"}], ",", 
    RowBox[{"total", "=", 
     RowBox[{"total", "+", 
      RowBox[{"list", "[", 
       RowBox[{"[", "i", "]"}], "]"}]}]}]}], "]"}], ";", "total"}]], "Input",
