Cell[CellGroupData[{

Cell["The If Statement", "Subsection",
 CellChangeTimes->{{3.5618017458010283`*^9, 3.561801764109617*^9}, {
  3.562865394502983*^9, 3.562865406015101*^9}, {3.562930941257785*^9, 
  3.562930943435539*^9}, {3.563867389829905*^9, 3.563867394123258*^9}, {
  3.604164104031564*^9, 3.604164110647564*^9}, {3.604165508478501*^9, 
  3.6041655115668097`*^9}, {3.6058081556804113`*^9, 3.6058081602273097`*^9}, {
  3.605808191892191*^9, 3.605808193860273*^9}, {3.614256866201641*^9, 
  3.614256869352891*^9}, {3.6142569089179897`*^9, 3.614256908921117*^9}, {
  3.615734571813103*^9, 
  3.615734609200782*^9}},ExpressionUUID->"c5300c7e-8f1f-458c-9753-\
8bcac08d518d"],

Cell[TextData[{
 "The if-then-else statement is a basic procedural tool defining a course of \
action for when a test returns true and a course of action for when a test \
returns false. The conditional statement ",
 StyleBox["if-then-else",
  FontSlant->"Italic"],
 " can be realized in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " by ",
 StyleBox[ButtonBox["If",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/If"],
  FontWeight->"Bold"],
 "."
}], "Text",
