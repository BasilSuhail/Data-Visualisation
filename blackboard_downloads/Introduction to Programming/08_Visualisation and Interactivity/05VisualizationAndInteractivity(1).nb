Cell[CellGroupData[{

Cell["The Computable Document Format (CDF)", "Section",
 CellChangeTimes->{{3.606568915785029*^9, 3.606568923585029*^9}, {
  3.613324555028857*^9, 3.613324563459856*^9}, {3.613325859745857*^9, 
  3.613325866120857*^9}, {3.61333014214872*^9, 
  3.613330153773882*^9}},ExpressionUUID->"5fd321bf-7118-4a18-8fa3-\
7a75a769825a"],

Cell[TextData[{
 "CDFs are essentially ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " notebooks that can be viewed and interacted with in the Wolfram ",
 StyleBox["CDF",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["Player",
     FontSlant->"Italic"], "TM"], TraditionalForm]],ExpressionUUID->
  "57e3102b-c9ae-46aa-8d22-1304ab947efc"],
 " or with the CDF browser plugin. They trade a loss of functionality for \
free access for anyone. This means that if you create a FreeCDF, then anyone \
can view and interact with it. The major advantage over other formats is \
interactivity. There are different types of CDF."
}], "Text",
 CellChangeTimes->{{3.6133304864201436`*^9, 3.613330525797081*^9}, {
   3.61333060979348*^9, 3.613330640258526*^9}, 3.614951459996777*^9, {
