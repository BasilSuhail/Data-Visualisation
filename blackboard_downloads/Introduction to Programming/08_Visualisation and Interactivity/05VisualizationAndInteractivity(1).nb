Cell[CellGroupData[{

Cell["Interactivity with the Manipulate Function", "Section",
 CellChangeTimes->{{3.606568915785029*^9, 3.606568923585029*^9}, {
  3.613324555028857*^9, 
  3.613324563459856*^9}},ExpressionUUID->"c36b97c8-839c-4d19-81d9-\
db493754fc00"],

Cell[TextData[{
 "Many Wolfram Language expressions can be made interactive with the ",
 StyleBox[ButtonBox["Manipulate",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Manipulate"],
  FontWeight->"Bold"],
 " function. This is especially useful with visualization functions. For \
example, consider this basic ",
 StyleBox[ButtonBox["Plot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Plot"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.613324691236856*^9, 3.6133247372018566`*^9}, 
   3.614951379480661*^9, {3.6157374783873596`*^9, 3.615737480520986*^9}, {
   3.6157387018069153`*^9, 3.615738713889642*^9}, 
   3.615828691169072*^9},ExpressionUUID->"ed5a4994-8a21-4356-a310-\
b8e2c3d1e60f"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Sin", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.613324738968856*^9, 
  3.613324747857856*^9}},ExpressionUUID->"59413f27-aaa2-4995-af6b-\
f799c186508c"],

Cell[TextData[{
 "Wrap the previous expression with the ",
 StyleBox[ButtonBox["Manipulate",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Manipulate"],
  FontWeight->"Bold"],
 " function to enable interactivity. The ",
 StyleBox[ButtonBox["Manipulate",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Manipulate"],
  FontWeight->"Bold"],
 " function automatically constructs a graphical user interface."
}], "Text",
 CellChangeTimes->{{3.6133247920628567`*^9, 3.613324828316856*^9}, {
   3.613325050959856*^9, 3.613325064750856*^9}, {3.613383279556103*^9, 
   3.6133832978129296`*^9}, 3.6149513892221203`*^9, 3.6150442279660883`*^9, 
   3.615737482936807*^9, {3.615738723523738*^9, 
   3.615738737172483*^9}},ExpressionUUID->"d25c9809-f2cf-4a3d-b533-\
1a0b54ad7f11"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"B", "*", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"B", ",", "0.1", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.613325071007856*^9, 3.6133250923188562`*^9}, {
  3.613325144763856*^9, 
  3.613325148093856*^9}},ExpressionUUID->"074527a5-bfe6-4327-bb78-\
7165403aeadd"],

Cell["\<\
Multiple variable specifications create multiple controllers.\
\>", "Text",
 CellChangeTimes->{{3.6133251263638563`*^9, 3.6133251357788563`*^9}, 
   3.614951394413749*^9, 
   3.6150442306596727`*^9},ExpressionUUID->"d632f007-f98e-469b-b821-\
be4f92d04021"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{
       RowBox[{"B", "*", "x"}], "+", "p"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"B", ",", "0.1", ",", "10"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"p", ",", "0", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.613325153675856*^9, 
  3.6133251959298563`*^9}},ExpressionUUID->"7ed2b43c-82b4-4341-ba39-\
7831d2a6ac61"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot3D", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{
       RowBox[{"a", "*", "x"}], "+", 
       RowBox[{"b", "*", "y"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"a", ",", "1", ",", "3"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"b", ",", "1", ",", "3"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.613325684015856*^9, 
  3.6133258132058563`*^9}},ExpressionUUID->"8ec890c2-a1e1-45c4-904b-\
d88cd3f03bd0"],

Cell[TextData[{
 "A ",
 StyleBox[ButtonBox["Manipulate",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Manipulate"],
  FontWeight->"Bold"],
 " need not be tied to a visualization."
}], "Text",
 CellChangeTimes->{{3.613325216774856*^9, 3.613325231409856*^9}, {
   3.613325330815856*^9, 3.613325333559856*^9}, 3.614951396597587*^9, 
   3.615044234651495*^9, {3.615738750707244*^9, 
   3.615738770232345*^9}},ExpressionUUID->"97d2f2f5-a664-4b56-b54e-\
8a2e803f094a"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "x"], 
    RowBox[{
     RowBox[{"Sin", "[", "y", "]"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.613325234376856*^9, 
  3.613325314657856*^9}},ExpressionUUID->"128116df-5818-479d-90a7-\
5feb94e5c149"]
}, Open  ]]
}, Open  ]],

