Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["Show",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Show"],
  FontWeight->"Bold"],
 " function can be used to combine graphics. Coordinate system transforms are \
handled automatically. ",
 StyleBox[ButtonBox["Show",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Show"],
  FontWeight->"Bold"],
 " will allow options to be used, and that may be necessary for situations \
where the plot range is different for different plots."
}], "Text",
 CellChangeTimes->{{3.606569213840029*^9, 3.6065692380470295`*^9}, {
   3.6146262960888033`*^9, 3.614626385509681*^9}, 3.614951328355497*^9, 
