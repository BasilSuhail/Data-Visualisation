Cell[CellGroupData[{

Cell["Creating CDFs", "Section",
 CellChangeTimes->{{3.606568915785029*^9, 3.606568923585029*^9}, {
  3.613324555028857*^9, 3.613324563459856*^9}, {3.613325859745857*^9, 
  3.613325866120857*^9}, {3.61333014214872*^9, 3.613330153773882*^9}, {
  3.6133306773962398`*^9, 
  3.6133306797474756`*^9}},ExpressionUUID->"3812b324-3623-4166-8075-\
01165145c73a"],

Cell[TextData[{
 "Create CDFs in a ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " notebook, then deploy them with the Wizards (found in ",
 StyleBox["File \[FilledRightTriangle] CDF Export", "Menu"],
 ")."
}], "Text",
 CellChangeTimes->{{3.61333071580608*^9, 3.613330718061305*^9}, {
   3.613330784848984*^9, 3.613330814441942*^9}, {3.614951471812141*^9, 
   3.614951482825478*^9}, 3.615044276163672*^9, {3.637917977882687*^9, 
   3.637917991628375*^9}},ExpressionUUID->"670911b4-eaa4-490f-b72b-\
168af6176b1f"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"k", "*", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", 
       RowBox[{"2", "*", "Pi"}]}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "1", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.593373987325335*^9, 
  3.5933740040630083`*^9}},ExpressionUUID->"861556d9-7d69-4c11-beba-\
a586f87a1c0e"],

Cell[TextData[{
 "It is often useful to preview CDFs before you deploy them via ",
 StyleBox["File \[FilledRightTriangle] CDF Preview", "Menu"],
 ".\n\nYou cannot evaluate cells in the ",
 StyleBox["CDF Player",
  FontSlant->"Italic"],
 ". Therefore, a function definition, which is necessary for a ",
 StyleBox[ButtonBox["Manipulate",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Manipulate"],
  FontWeight->"Bold"],
 ", cannot be evaluated."
}], "Text",
 CellChangeTimes->{{3.613330846563154*^9, 3.6133308727957783`*^9}, {
   3.613330943583855*^9, 3.6133309528957872`*^9}, {3.6133309850490017`*^9, 
   3.613331024298927*^9}, 3.6133834698281283`*^9, {3.613385313651492*^9, 
   3.613385315107638*^9}, {3.614951478705683*^9, 3.614951499360883*^9}, {
   3.6150443062241087`*^9, 3.615044318959513*^9}, 3.615737509529777*^9, {
   3.61573896128891*^9, 
   3.6157389731684313`*^9}},ExpressionUUID->"317819e5-385d-4a5a-8886-\
c035f1d51ebb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{"x", "*", 
   RowBox[{"Sin", "[", "y", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.593374400639663*^9, 
  3.593374423327931*^9}},ExpressionUUID->"d91fa4fb-b178-4e89-a8da-\
c3ae60c84775"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"f", "[", "k", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", "0", ",", "10"}], "}"}], ",", " ", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "1", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.593374449770575*^9, 
  3.593374533261924*^9}},ExpressionUUID->"fb71f6cf-7d56-4ba6-a8e4-\
7e833b3b8a5d"],

Cell[TextData[{
 "This issue can be addressed by saving the necessary function and variable \
definitions along with the file. This can be accomplished with the ",
 StyleBox[ButtonBox["SaveDefinitions",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SaveDefinitions"],
  FontWeight->"Bold"],
 " option."
}], "Text",
 CellChangeTimes->{{3.613331122830778*^9, 3.613331155880083*^9}, 
   3.6150443239670143`*^9, 3.6157375114713583`*^9, {3.615738986996711*^9, 
   3.615738987051974*^9}},ExpressionUUID->"62766084-d0c8-4053-b6cf-\
81673a9f0860"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "SaveDefinitions"}]], "Input",
 CellChangeTimes->{{3.593374339179517*^9, 
  3.593374342690868*^9}},ExpressionUUID->"e834f910-b8cc-49a0-bd33-\
16ca8faaac1c"],

Cell[BoxData[
 RowBox[{
  StyleBox["\<\"SaveDefinitions is an option to Manipulate and related \
functions that specifies whether current definitions relevant for the \
evaluation of the expression being manipulated should automatically be saved.\
\"\>", "MSG"], "\[NonBreakingSpace]", 
  ButtonBox[
   StyleBox["\[RightSkeleton]", "SR"],
   Active->True,
   BaseStyle->"Link",
   ButtonData->"paclet:ref/SaveDefinitions"]}]], "Print", "PrintUsage",
 CellChangeTimes->{3.593374343238923*^9},
 CellTags->
  "Info3593352743-1297655",ExpressionUUID->"7379f3b2-79f7-4634-ad36-\
ccd46e9d10a4"]
}, Open  ]],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"f", "[", "k", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", "0", ",", "10"}], "}"}], ",", " ", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "1", ",", "10"}], "}"}], ",", " ", 
   RowBox[{"SaveDefinitions", "\[Rule]", "True"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.613331173330828*^9, 
  3.613331179789474*^9}},ExpressionUUID->"6b93c6f3-ad52-45b8-a90a-\
a78fd6fec057"],

Cell[CellGroupData[{

Cell[TextData[{
 "Cloud",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["CDF", "\[Trademark]"], TraditionalForm]],ExpressionUUID->
  "36517909-41e7-4964-9b24-90dacd4e99d4"]
}], "Subsubsection",
 CellChangeTimes->{{3.636475694232172*^9, 3.63647569699339*^9}, {
   3.6380134618713493`*^9, 3.6380134619026*^9}, 
   3.6380169051657667`*^9},ExpressionUUID->"8aa5b8b0-d6a8-472f-ac0c-\
16293f5b5f36"],

Cell[BoxData[
 RowBox[{"CloudDeploy", "[", 
  RowBox[{"Manipulate", "[", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"k", "*", "x"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", 
        RowBox[{"2", "*", "Pi"}]}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "10"}], "}"}]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.636475699380204*^9, 
  3.636475710050674*^9}},ExpressionUUID->"d06eedba-e0a1-45b6-ac58-\
ed2a1dc240b4"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

