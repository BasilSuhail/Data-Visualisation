 "The update frequency of the content can be controlled using ",
 StyleBox[ButtonBox["ControlActive",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ControlActive"],
  FontWeight->"Bold"],
 " and ",
 StyleBox[ButtonBox["ContinuousAction",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ContinuousAction"],
  FontWeight->"Bold"],
 "."
}], "Subitem",
