  3.606564722545029*^9}},ExpressionUUID->"4a600226-3398-45ef-ac9c-\
042970d83f4d"],

Cell[TextData[{
 "You can join the points with ",
 StyleBox[ButtonBox["ListLinePlot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ListLinePlot"],
  FontWeight->"Bold"],
 " (or the ",
 StyleBox[ButtonBox["Joined",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Joined"],
  FontWeight->"Bold"],
 " \[Rule] ",
 StyleBox[ButtonBox["True",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/True"],
  FontWeight->"Bold"],
 " option to ",
 StyleBox[ButtonBox["ListPlot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ListPlot"],
  FontWeight->"Bold"],
 ")."
}], "Text",
 CellChangeTimes->{{3.606567975727029*^9, 3.606567993334029*^9}, {
   3.606569788687029*^9, 3.606569791239029*^9}, 3.614951058046166*^9, 
   3.61504397489662*^9, {3.615737808019729*^9, 3.6157378327679253`*^9}, 
   3.615737943747962*^9, {3.615738014641736*^9, 3.615738017144285*^9}, {
   3.6157380970773582`*^9, 3.615738097130487*^9}, {3.61582855048127*^9, 
   3.615828550537498*^9}},ExpressionUUID->"494b3ae6-acb0-4978-8736-\
7dccb2edeb0f"],

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{"Prime", "[", 
   RowBox[{"Range", "[", "25", "]"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.606564799765029*^9, 
  3.606564800093029*^9}},ExpressionUUID->"0bc1e8cd-db38-4a33-b66d-\
52a6b02d8993"],

Cell[TextData[{
 "As seen above, if you simply provide a list of numbers, ",
 StyleBox[ButtonBox["ListPlot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ListPlot"],
  FontWeight->"Bold"],
 " assumes they are at unit intervals. You can also explicitly provide ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]], "InlineMath",ExpressionUUID->
  "c8cba95a-a55b-40b2-9180-19f27b81e388"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]], "InlineMath",ExpressionUUID->
  "f38ba787-35f4-4028-b273-20b308dc4aae"],
 " values."
}], "Text",
 CellChangeTimes->{{3.623779634161676*^9, 3.62377968781042*^9}, 
   3.6379173788905582`*^9, {3.637944715930063*^9, 3.637944730334438*^9}, 
   3.638013348191795*^9},ExpressionUUID->"e1f805f2-4898-4942-9730-\
e40bbbdb7a7f"],

