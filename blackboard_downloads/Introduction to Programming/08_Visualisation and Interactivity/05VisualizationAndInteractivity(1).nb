Cell[CellGroupData[{

Cell["3D Plotting", "Section",
 CellChangeTimes->{{3.606567781018029*^9, 
  3.606567783618029*^9}},ExpressionUUID->"34ba405e-68d9-414d-a29d-\
b5b75f9382f4"],

Cell["\<\
The Wolfram Language also supports 3D visualization. Note that the syntax is \
very similar to the 2D case\[LongDash]there is just an additional variable \
specification.\
\>", "Text",
 CellChangeTimes->{{3.606567791409029*^9, 3.606567845166029*^9}, 
   3.614951033921644*^9, 3.615043949188041*^9, 3.615737412078793*^9, {
   3.615737726056215*^9, 
   3.6157377272125473`*^9}},ExpressionUUID->"0d43f17f-24a7-433a-80da-\
7616be1e123a"],

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Sin", "[", 
     RowBox[{
      RowBox[{"x", "^", "2"}], "+", 
      RowBox[{"y", "^", "2"}]}], "]"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"x", "^", "2"}], "+", 
      RowBox[{"y", "^", "2"}], "+", "1"}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "4"}], ",", "4"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.60656455739603*^9, 
  3.60656455766703*^9}},ExpressionUUID->"e3520283-edde-4936-9e4e-\
99f1bfd521b5"],

Cell["The third axis can be mapped to a color axis.", "Text",
 CellChangeTimes->{{3.6065678563980293`*^9, 3.606567863989029*^9}, 
   3.614951044246982*^9, 3.615043956033393*^9, {3.615828473765062*^9, 
   3.615828481264722*^9}},ExpressionUUID->"430500fd-d53c-45a3-8415-\
2d89ee2833fa"],

Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Sin", "[", 
     RowBox[{
      RowBox[{"x", "^", "2"}], "+", 
      RowBox[{"y", "^", "2"}]}], "]"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"x", "^", "2"}], "+", 
      RowBox[{"y", "^", "2"}], "+", "1"}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "4"}], ",", "4"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.606564572019029*^9, 
  3.606564572371029*^9}},ExpressionUUID->"1a414dbb-699b-4f78-8c81-\
93e1265e5869"],

Cell["A three-dimensional parametric plot.", "Text",
 CellChangeTimes->{{3.606567872093029*^9, 3.606567888156029*^9}, 
   3.614951046046805*^9, 3.615043964449067*^9, {3.615737737534401*^9, 
   3.615737738235737*^9}},ExpressionUUID->"124778f9-2c7b-4723-9934-\
c2cfd5d5a264"],

Cell[BoxData[
 RowBox[{"ParametricPlot3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", "u", "]"}], ",", 
     RowBox[{
      RowBox[{"Sin", "[", "u", "]"}], "+", 
      RowBox[{"Cos", "[", "v", "]"}]}], ",", 
     RowBox[{"Sin", "[", "v", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"u", ",", "0", ",", 
     RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"v", ",", 
     RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}]}], "]"}]], "Input",Expressi\
onUUID->"9a57fcf0-439e-4fef-9e45-1db75ead714a"]
}, Open  ]]
}, Open  ]],

