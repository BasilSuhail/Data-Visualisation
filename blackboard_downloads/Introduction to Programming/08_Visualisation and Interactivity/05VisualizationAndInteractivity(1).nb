Cell[CellGroupData[{

Cell["Basic Plotting Syntax", "Section",
 CellChangeTimes->{{3.606567656937029*^9, 
  3.606567662985029*^9}},ExpressionUUID->"f6eb209b-59af-4a42-a269-\
37b6cc243077"],

Cell[TextData[{
 StyleBox["Plot[f,{x,xmin,xmax}]", "MR"],
 " is a frequently used function for plotting 2D expressions. The function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]], "InlineMath",ExpressionUUID->
  "10c3baa6-c2af-4452-8ea7-f8a3c08e838d"],
 " (or a list of functions) is plotted with respect to the variable ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]], "InlineMath",ExpressionUUID->
  "6e61b8b8-18d5-4c0c-b2ff-952b7dc46d71"],
 ", over the range ",
 Cell[BoxData[
  FormBox["xmin", TraditionalForm]], "InlineMath",ExpressionUUID->
  "0e968ae8-73df-4b2a-acab-a7ad0c1c1362"],
 " to ",
 Cell[BoxData[
  FormBox["xmax", TraditionalForm]], "InlineMath",ExpressionUUID->
  "72c6245b-1355-4a97-a661-8621d4187262"],
 "."
}], "Text",
 CellChangeTimes->{{3.6065674748200293`*^9, 3.6065675296880293`*^9}, 
   3.606567593437029*^9, 3.615737398591414*^9, {3.615737561747256*^9, 
   3.6157375955256248`*^9}, {3.6158281908514633`*^9, 3.615828246906145*^9}, {
   3.6158298318404493`*^9, 
   3.615829867564307*^9}},ExpressionUUID->"99e09c4f-1a79-4534-8e8a-\
9f8569703e53"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Sin", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}]], "Input",ExpressionUUI\
D->"0c601488-c693-42f9-8dd1-c0a7de6ccf8c"],

Cell[TextData[{
 "Other plotting functions follow a very similar syntax. The first argument \
is the function to be plotted (or a list of functions to be plotted), while \
subsequent arguments are variable specifications. For example, ",
 StyleBox[ButtonBox["ParametricPlot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ParametricPlot"],
  FontWeight->"Bold"],
 " can be used to create parametric plots."
}], "Text",
 CellChangeTimes->{{3.6065675449830294`*^9, 3.606567623907029*^9}, {
   3.6065697044690294`*^9, 3.606569706852029*^9}, 3.614950946375141*^9, {
   3.61573740030083*^9, 3.615737401117169*^9}, {3.615737613037098*^9, 
   3.615737622468886*^9}},ExpressionUUID->"4c98d20a-c409-4836-9f3b-\
8368623f4549"],

Cell[BoxData[
 RowBox[{"ParametricPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"t", " ", 
      RowBox[{"Cos", "[", "t", "]"}]}], ",", 
     RowBox[{"t", " ", 
      RowBox[{"Sin", "[", "t", "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     RowBox[{"2", "Pi"}]}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"23d0377c-8e3a-4bd2-9328-b94da566c1cd"],

Cell["Axes need not be linear.", "Text",
 CellChangeTimes->{{3.6065676346420293`*^9, 3.606567637514029*^9}, 
   3.614950952955295*^9},ExpressionUUID->"320178dd-0686-4739-844d-\
23dece12b6bb"],

Cell[BoxData[
 RowBox[{"LogPlot", "[", 
  RowBox[{
   RowBox[{"x", "^", "2"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "1", ",", "100"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.606567641427029*^9, 
  3.606567642835029*^9}},ExpressionUUID->"4f73a160-aadb-402e-942d-\
d3b7b4d9445b"],

Cell[BoxData[
 RowBox[{"LogLogPlot", "[", 
  RowBox[{
   RowBox[{"x", "^", "2"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "1", ",", "100"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.6065676439950294`*^9, 
  3.606567644419029*^9}},ExpressionUUID->"bc971f9a-7ed9-406b-b029-\
30fc0b2b5223"]
}, Open  ]]
}, Open  ]],

