Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"f", ",", "Tan"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"45007731-1a25-42db-81bf-6d06a595340f"],

Cell[TextData[{
 "There are many other controller options. The ",
 StyleBox[ButtonBox["ControlType",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ControlType"],
  FontWeight->"Bold"],
 " option can be used to specify the type of control."
}], "Text",
 CellChangeTimes->{{3.613326291016856*^9, 3.613326302919856*^9}, {
   3.613326428102806*^9, 3.613326432836011*^9}, 3.614951432867895*^9, 
