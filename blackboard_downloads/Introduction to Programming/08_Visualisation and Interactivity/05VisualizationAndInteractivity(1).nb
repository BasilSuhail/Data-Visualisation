     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"Pi", ",", "Pi"}], "}"}]}], "}"}]}], "]"}]], "Input",ExpressionU\
UID->"9f0039fe-8c36-48aa-a757-887301f4e73e"],

Cell["Textual input is also handled.", "Text",
 CellChangeTimes->{{3.613326261578856*^9, 3.613326268793856*^9}, 
   3.614951425084278*^9, 
   3.6150442486267858`*^9},ExpressionUUID->"b469115a-13c3-469b-bd86-\
