Cell[CellGroupData[{

Cell["Controllers", "Section",
 CellChangeTimes->{{3.606568915785029*^9, 3.606568923585029*^9}, {
  3.613324555028857*^9, 3.613324563459856*^9}, {3.613325859745857*^9, 
  3.613325866120857*^9}},ExpressionUUID->"7c240c65-a433-4851-8e84-\
6d814e9a9ad0"],

Cell[TextData[{
 StyleBox[ButtonBox["Manipulate",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Manipulate"],
  FontWeight->"Bold"],
 " automatically chooses and labels controllers based on the input. For \
example, a discrete list of inputs might create a series of buttons instead \
of the basic ",
 StyleBox[ButtonBox["Slider",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Slider"],
  FontWeight->"Bold"],
 " seen previously."
}], "Text",
 CellChangeTimes->{{3.613325872776856*^9, 3.613325968450856*^9}, {
   3.613326478124898*^9, 3.613326484625017*^9}, 3.6133266435921645`*^9, 
   3.6149514128152122`*^9, 3.615737489034281*^9, {3.6157387947618227`*^9, 
   3.615738808387168*^9}, 
   3.615828701024747*^9},ExpressionUUID->"3891b17e-c521-43ae-bca7-\
116cd94665d8"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"B", "*", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"B", ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.613325947258856*^9, 
  3.613325960333856*^9}},ExpressionUUID->"d9e8bacb-148a-4d21-b43c-\
e84f5a1c16b5"],

Cell["A larger list will create a drop-down menu.", "Text",
 CellChangeTimes->{{3.613325976794856*^9, 3.6133259863458557`*^9}, 
   3.6149514153166103`*^9, 3.615044240557351*^9, 
   3.615828706007699*^9},ExpressionUUID->"55be7b7c-9507-421d-85b1-\
b1d0877b9e1c"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"B", "*", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"B", ",", 
     RowBox[{"Range", "[", "20", "]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.613325991867856*^9, 
  3.613326012929857*^9}},ExpressionUUID->"d3acebdf-5b4a-4b2b-a3df-\
36e07326f30d"],

Cell[TextData[{
 "Two-dimensional input uses a ",
 StyleBox[ButtonBox["Slider2D",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Slider2D"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.613326229316856*^9, 3.613326249618856*^9}, {
   3.613326492572622*^9, 3.613326496878913*^9}, 3.614951422204471*^9, 
