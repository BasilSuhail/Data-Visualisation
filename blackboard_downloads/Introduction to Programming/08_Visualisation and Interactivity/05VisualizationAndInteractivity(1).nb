Cell["Domain-Specific Visualization", "Section",
 CellChangeTimes->{{3.6065676674810295`*^9, 3.606567671360029*^9}, 
   3.615737644636722*^9},ExpressionUUID->"4cbb0e4c-8b7b-4885-b66f-\
4d611fb36df9"],

Cell[TextData[{
 "The Wolfram Language has a wealth of domain-specific visualization \
functions\[LongDash]a few examples are below. One example is ",
 StyleBox[ButtonBox["VectorPlot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/VectorPlot"],
  FontWeight->"Bold"],
 ", which plots a vector field."
}], "Text",
 CellChangeTimes->{{3.6065676760960293`*^9, 3.60656772118103*^9}, {
   3.606567763755029*^9, 3.606567773522029*^9}, {3.614950980716083*^9, 
   3.614950994673359*^9}, 3.615737405838847*^9, {3.615737648729102*^9, 
   3.615737668314225*^9}},ExpressionUUID->"e4e987d6-5d74-458f-9f92-\
c58012e98462"],

Cell[BoxData[
 RowBox[{"VectorPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "x"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"a1a61a5c-63c0-4ea9-99a1-785dd8cce3e8"],

Cell[TextData[{
 StyleBox[ButtonBox["BodePlot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/BodePlot"],
  FontWeight->"Bold"],
 " generates a Bode plot of a linear time-invariant system."
}], "Text",
 CellChangeTimes->{{3.6065677322050295`*^9, 3.6065677441160297`*^9}, 
   3.614950998377075*^9, 3.615043909279563*^9, {3.61573768097772*^9, 
   3.615737681028111*^9}},ExpressionUUID->"ac2b4d4e-54b2-45c9-ae30-\
599ba29bb5ae"],

Cell[BoxData[
 RowBox[{"BodePlot", "[", 
  InterpretationBox[
   TemplateBox[{
     FractionBox["20", 
      RowBox[{"20", "+", "s"}]], 
     InterpretationBox["\[InvisibleSpace]", None]},
    "TransferFunctionModel",
    DisplayFunction->(SubsuperscriptBox[
      RowBox[{"(", 
        GridBox[{{
           TemplateSlotSequence[{1, 1}]}}, AllowedDimensions -> {1, 1}, 
         AutoDelete -> False, AllowScriptLevelChange -> False, 
         ColumnAlignments -> {Center}, BaseStyle -> {Deployed -> False}, 
         GridBoxItemStyle -> {}, 
         GridBoxDividers -> {
          "Rows" -> {False, {False}, False}, 
           "Columns" -> {False, {False}, False}}], ")"}], #2, 
      "\[ScriptCapitalT]", MultilineFunction -> None]& ),
    InterpretationFunction->(
     RowBox[{"TransferFunctionModel", "[", "Unevaluated", "[", 
       RowBox[{"{", 
         RowBox[{"{", 
           TemplateSlotSequence[{1, 1}, ","], "}"}], "}"}], "]", ",", "s", 
       ",", "SamplingPeriod", "->", 
       RowBox[{#2}], ",", "SystemsModelLabels", "->", "None", "]"}]& )],
   TransferFunctionModel[{{{20}}, 20 + $CellContext`s}, $CellContext`s],
   AutoDelete->True,
   Editable->True], "]"}]], "Input",ExpressionUUID->"e5d7a8f3-2cf3-47c2-946e-\
09ef4f0e10d3"],

Cell["Wavelets can also be visualized.", "Text",
 CellChangeTimes->{{3.606567748036029*^9, 3.606567757347029*^9}, 
   3.614951000361126*^9, 
   3.615043917843317*^9},ExpressionUUID->"599eecb2-7b22-4a72-8406-\
0800225eb6d4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DiscreteWaveletTransform", "[", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       SuperscriptBox["x", "2"], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "6"}], ",", "6", ",", "0.01"}], "}"}]}], "]"}], ",", 
    "Automatic", ",", "8"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"WaveletScalogram", "[", "%", "]"}]}], "Input",
 CellChangeTimes->{{3.6065645122540298`*^9, 3.606564512390029*^9}},
 CellID->531084382,ExpressionUUID->"c10759fb-dce7-4e76-a99d-21f18461992f"],

Cell[TextData[{
 "This is just a small subset of the available domain-specific functions. See \
the ",
 ButtonBox["Documentation Center",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/"], None},
  ButtonNote->"http://reference.wolfram.com/language/"],
 " for more examples."
}], "Text",
 CellChangeTimes->{{3.606569735066029*^9, 3.6065697545610294`*^9}, 
   3.615737408676597*^9, {3.615737695080687*^9, 3.615737703805749*^9}, 
   3.615828280597034*^9, {3.637917466929995*^9, 
   3.637917466929995*^9}},ExpressionUUID->"5d0a5afe-d39a-4996-90b1-\
904c69c2915b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"18c3ed6c-af2b-4fc0-ad33-779186ace00d"],

Cell[CellGroupData[{

Cell["Graphs", "Section",
 CellChangeTimes->{{3.606568621098029*^9, 
  3.606568621738029*^9}},ExpressionUUID->"80bc8150-bcb8-4137-8956-\
22c3efc03c60"],

Cell[TextData[{
 "Directed and undirected graphs can be created with the ",
 StyleBox[ButtonBox["Graph",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Graph"],
  FontWeight->"Bold"],
 " function."
}], "Text",
 CellChangeTimes->{{3.606568629434029*^9, 3.606568671327029*^9}, 
   3.61495113354844*^9, 3.615044029991766*^9, {3.615738359859968*^9, 
   3.6157383599132557`*^9}},ExpressionUUID->"894645b6-0cb7-45c1-98e6-\
6906dfe5c2e6"],

Cell[BoxData[
 RowBox[{"Graph", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"1", "\[UndirectedEdge]", "2"}], ",", 
    RowBox[{"2", "\[UndirectedEdge]", "3"}], ",", 
    RowBox[{"3", "\[UndirectedEdge]", "1"}]}], "}"}], "]"}]], "Input",
 CellID->433332197,ExpressionUUID->"8c879531-83f8-4051-8f93-b3543018c938"],

Cell[BoxData[
 RowBox[{"Graph", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"1", "\[Rule]", "2"}], ",", 
    RowBox[{"2", "\[Rule]", "3"}], ",", 
    RowBox[{"3", "\[Rule]", "1"}]}], "}"}], "]"}]], "Input",
 CellID->521471995,ExpressionUUID->"697f96bb-630d-453a-b4b1-47b7d38dde3b"],

Cell["Edges and vertices can be styled.", "Text",
 CellChangeTimes->{{3.606568662472029*^9, 3.6065686674950294`*^9}, 
   3.614951135410473*^9, 
   3.615044032661569*^9},ExpressionUUID->"c632bcdc-bd5e-49aa-be95-\
2ea4b0aeca4f"],

Cell[BoxData[
 RowBox[{"Graph", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"1", "\[UndirectedEdge]", "2"}], ",", 
     RowBox[{"2", "\[UndirectedEdge]", "3"}], ",", 
     RowBox[{"Labeled", "[", 
      RowBox[{
       RowBox[{"3", "\[UndirectedEdge]", "1"}], ",", "\"\<hello\>\""}], 
      "]"}]}], "}"}], ",", 
   RowBox[{"VertexLabels", "\[Rule]", "\"\<Name\>\""}], ",", 
   RowBox[{"ImagePadding", "\[Rule]", "10"}]}], "]"}]], "Input",
 CellID->542283642,ExpressionUUID->"2e445732-968d-42fb-9d30-f05cd786c676"],

Cell[BoxData[
 RowBox[{"Graph", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"1", "\[UndirectedEdge]", "2"}], ",", 
     RowBox[{"2", "\[UndirectedEdge]", "3"}], ",", 
     RowBox[{"3", "\[UndirectedEdge]", "1"}]}], "}"}], ",", 
   RowBox[{"VertexStyle", "\[Rule]", "Orange"}], ",", 
   RowBox[{"EdgeStyle", "\[Rule]", "Green"}]}], "]"}]], "Input",
 CellID->701207561,ExpressionUUID->"2c7e00cc-ebbd-4e36-a63c-7e6c7acb00bd"],

Cell["This allows for powerful visualization of connectivity.", "Text",
 CellChangeTimes->{{3.606568675983029*^9, 3.606568685790029*^9}, 
   3.614951138370433*^9, 
   3.615044039453386*^9},ExpressionUUID->"a2993d5d-b19f-4144-9b93-\
e28bc22cf1c4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"web", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<Ladybug\>\"", "\[DirectedEdge]", "\"\<Aphid\>\""}], ",", 
     RowBox[{"\"\<Beetle\>\"", "\[DirectedEdge]", "\"\<Caterpillar\>\""}], 
     ",", 
     RowBox[{"\"\<Towhee\>\"", "\[DirectedEdge]", "\"\<Caterpillar\>\""}], 
     ",", 
     RowBox[{"\"\<Towhee\>\"", "\[DirectedEdge]", "\"\<Grasshopper\>\""}], 
     ",", 
     RowBox[{"\"\<Towhee\>\"", "\[DirectedEdge]", "\"\<Ladybug\>\""}], ",", 
     RowBox[{"\"\<Dragonfly\>\"", "\[DirectedEdge]", "\"\<Mosquito\>\""}], 
     ",", 
     RowBox[{"\"\<Towhee\>\"", "\[DirectedEdge]", "\"\<Mosquito\>\""}], ",", 
     RowBox[{"\"\<Aphid\>\"", "\[DirectedEdge]", "\"\<Sunflower\>\""}], ",", 
     RowBox[{"\"\<Caterpillar\>\"", "\[DirectedEdge]", "\"\<Sunflower\>\""}], 
     ",", 
     RowBox[{"\"\<Grasshopper\>\"", "\[DirectedEdge]", "\"\<Sunflower\>\""}], 
     ",", 
     RowBox[{"\"\<Louse\>\"", "\[DirectedEdge]", "\"\<Sunflower\>\""}], ",", 
     RowBox[{"\"\<Owl\>\"", "\[DirectedEdge]", "\"\<Towhee\>\""}]}], "}"}]}], 
  ";"}]], "Input",
 CellID->1908635966,ExpressionUUID->"ad1fdfa6-676f-4792-ae53-3784f0b97733"],

