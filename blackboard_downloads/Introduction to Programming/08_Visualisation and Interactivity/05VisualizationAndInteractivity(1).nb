        RowBox[{"Sin", ",", "Cos", ",", "Tan", ",", "Cot"}], "}"}], ",", 
       RowBox[{"ControlType", "\[Rule]", "PopupMenu"}]}], "}"}]}], "]"}]}], 
  "}"}]], "Input",ExpressionUUID->"8968f882-a967-4e9b-85a8-4e0d1df7292a"],

Cell["\<\
Arbitrary labels and starting points may also be used for each controller.\
\>", "Text",
 CellChangeTimes->{{3.613326347869856*^9, 3.613326360156856*^9}, {
