Cell[TextData[{
 "First of all, click \[OpenCurlyDoubleQuote]New Document\
\[CloseCurlyDoubleQuote].  You will be presented with a blank notebook.  This \
is the basic file-type in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ", and it has extension .nb."
}], "Text",
 CellChangeTimes->{{3.643622405842705*^9, 3.64362242031437*^9}, {
