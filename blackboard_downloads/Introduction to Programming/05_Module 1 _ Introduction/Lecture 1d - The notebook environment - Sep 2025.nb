Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"90744b07-a8d9-47bb-835f-20afa9843f3a"],

Cell[CellGroupData[{

Cell["Writing code", "Section",
 CellChangeTimes->{{3.645342414466423*^9, 
  3.645342416112988*^9}},ExpressionUUID->"2ac104e3-47e9-4ea9-9092-\
f51139379f08"],

Cell["\<\
Now that you can create a document and make cells with different styles, let\
\[CloseCurlyQuote]s look at some tools you can use when writing code.\
\>", "Text",
 CellChangeTimes->{{3.64534241752078*^9, 3.645342467055567*^9}, {
  3.645342924291787*^9, 
  3.6453429601278353`*^9}},ExpressionUUID->"44ddf9d4-dc6e-4fe0-b162-\
0d73e35209ce"],

Cell[CellGroupData[{

Cell["Tools", "Subsection",
 CellChangeTimes->{{3.645342696704296*^9, 
  3.6453426973283253`*^9}},ExpressionUUID->"9838f905-5cbd-4be7-b791-\
74548b8bd8e4"],

Cell[CellGroupData[{

Cell["Palettes", "Subsubsection",
 CellChangeTimes->{{3.645342752223832*^9, 
  3.645342753526414*^9}},ExpressionUUID->"0be7b9f4-db76-4bc1-9638-\
b5cdd8e2548b"],

Cell["\<\
First of all, there are several useful toolsets called \
\[OpenCurlyQuote]Palettes\[CloseCurlyQuote] that give you an easy point and \
click interface for entering characters and objects.\
\>", "Text",
 CellChangeTimes->{{3.643623580769579*^9, 3.643623655208612*^9}, {
   3.643623747972054*^9, 3.643623786162594*^9}, {3.645336877217067*^9, 
   3.6453369039106913`*^9}, {3.645337226188882*^9, 3.645337227276699*^9}, 
   3.6573659556443644`*^9},ExpressionUUID->"f4d45a0b-9472-4835-8422-\
e6e3e1af848f"],

Cell["\<\
Go to Palettes > Basic Math Assistant.  This makes a popup window with \
buttons that let you do common tasks.  Insert a Sin function into a new Input \
cell using the button.\
\>", "Text",
 CellChangeTimes->{{3.649403307536935*^9, 3.649403322135539*^9}, {
  3.649403682003965*^9, 
  3.649403722049035*^9}},ExpressionUUID->"4b054a26-345f-4083-b747-\
a731bf295b18"],

Cell[BoxData[
 RowBox[{"Sin", "[", 
  TagBox[
   FrameBox["expr"],
   "SelectionPlaceholder"], "]"}]], "Input",ExpressionUUID->"af10808d-4f5e-\
454b-b244-0e062807e801"],

Cell["\<\
You can then fill in the slot and press Shift Enter to evaluate it.\
\>", "Text",
 CellChangeTimes->{{3.645337088330139*^9, 
  3.6453371020884047`*^9}},ExpressionUUID->"e7f110ee-cac1-4192-9f3d-\
0f6aa600e7de"],

Cell[BoxData[
 RowBox[{"Sin", "[", ".2", "]"}]], "Input",
 CellChangeTimes->{{3.645337202846178*^9, 
  3.645337204502225*^9}},ExpressionUUID->"41f80a72-2b77-4321-86fb-\
fb5ac19823f8"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Breakout Rooms", "Subsection",
 CellChangeTimes->{{3.810157917059628*^9, 
  3.8101579196089487`*^9}},ExpressionUUID->"17e5a248-0829-441e-bd1a-\
085426211757"],

Cell[TextData[{
 "Use the Basic Maths Assistant palette to compute the eigenvalues of ",
 Cell[BoxData[
  RowBox[{"(", GridBox[{
     {"5", "7"},
     {"4", "2"}
    }], ")"}]],
  CellChangeTimes->{{3.810157862720611*^9, 3.810157908791128*^9}},
  ExpressionUUID->"a61406ce-dc4e-4c66-94eb-07dacab180cc"],
 "."
}], "Item",
 CellChangeTimes->{{3.810157922842573*^9, 3.8101579532263403`*^9}, {
  3.810158556406097*^9, 
  3.810158556406941*^9}},ExpressionUUID->"878d2c62-1756-407f-9c02-\
bc2416b5c289"],

Cell[TextData[{
 "Use the Basic Maths Assistant palette to compute ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox["\[Integral]", "0", "Pi"], 
   RowBox[{
    RowBox[{"Sin", "[", 
     RowBox[{"1", "/", "x"}], "]"}], 
    RowBox[{"\[DifferentialD]", "x"}]}]}]],
  CellChangeTimes->{{3.810158531386601*^9, 3.8101585456502533`*^9}},
  ExpressionUUID->"d652a205-9dc6-40cb-818f-782c85b527f5"]
}], "Item",
 CellChangeTimes->{{3.810157922842573*^9, 3.8101579532263403`*^9}, {
  3.8101585573866568`*^9, 3.810158578382715*^9}, {3.810158630142375*^9, 
  3.810158630143664*^9}},ExpressionUUID->"5a27dc1e-ea27-487e-b816-\
c9c1c03f4c2c"],

Cell["\<\
Use the Basic Maths Assistant palette to plot Sin[1/x] from 0 to Pi\
\>", "Item",
 CellChangeTimes->{{3.810157922842573*^9, 3.8101579532263403`*^9}, {
  3.8101585573866568`*^9, 3.810158578382715*^9}, {3.8101586309421253`*^9, 
  3.810158654393923*^9}},ExpressionUUID->"78dd320d-401d-48e9-bf2b-\
d924d1603408"]
}, Open  ]]
}, Open  ]]
