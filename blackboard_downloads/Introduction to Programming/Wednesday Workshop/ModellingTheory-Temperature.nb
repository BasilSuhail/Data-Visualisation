Cell[BoxData[
 RowBox[{
  RowBox[{"tempdepth", "=", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Mean", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"\[Theta]", "[", 
                 RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", 
               RowBox[{"x", "\[Rule]", " ", "g"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"t", ",", "1", ",", "1000"}], "}"}]}], "]"}], "]"}], 
           "[", 
           RowBox[{"[", "1", "]"}], "]"}], "+", 
          RowBox[{
           RowBox[{"StandardDeviation", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"\[Theta]", "[", 
                 RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", 
               RowBox[{"x", "\[Rule]", " ", "g"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"t", ",", "1", ",", "1000"}], "}"}]}], "]"}], "]"}], 
           "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ",", 
         RowBox[{"-", "g"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"g", ",", "0", ",", "5", ",", "0.05"}], "}"}]}], "]"}], ",", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Mean", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"\[Theta]", "[", 
                 RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", 
               RowBox[{"x", "\[Rule]", " ", "g"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"t", ",", "1", ",", "1000"}], "}"}]}], "]"}], "]"}], 
           "[", 
           RowBox[{"[", "1", "]"}], "]"}], "+", 
          RowBox[{"-", 
           RowBox[{
            RowBox[{"StandardDeviation", "[", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"\[Theta]", "[", 
                  RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", 
                RowBox[{"x", "\[Rule]", " ", "g"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"t", ",", "1", ",", "1000"}], "}"}]}], "]"}], "]"}], 
            "[", 
            RowBox[{"[", "1", "]"}], "]"}]}]}], ",", 
         RowBox[{"-", "g"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"g", ",", "0", ",", "5", ",", "0.05"}], "}"}]}], "]"}]}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.602970902386426*^9, 3.602970924794541*^9}, {
  3.6029709679156446`*^9, 3.602970994314258*^9}, {3.633204592979982*^9, 
