Cell[TextData[StyleBox["We can now use that as external temperature into our \
model:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602968614202805*^9, 
  3.602968632647707*^9}},ExpressionUUID->"a1b8934d-3ecb-4375-a181-\
