Cell[TextData[{
 StyleBox["The Arduino is connected via a serial (i.e. USB) cable to the \
computer. ",
  FontSize->18],
 StyleBox["Mathematica",
  FontSize->18,
  FontSlant->"Italic"],
 StyleBox[" can connect to the serial port like so:",
  FontSize->18]
}], "Text",
 CellChangeTimes->{{3.6332064346145067`*^9, 
  3.633206476082981*^9}},ExpressionUUID->"9171db2b-c7eb-4c6f-bcf4-\
344ff7bfc600"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"myDSTemperature", "=", 
  RowBox[{"DeviceOpen", "[", 
   RowBox[{"\"\<Serial\>\"", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Quiet", "[", 
        RowBox[{"FileNames", "[", 
         RowBox[{"\"\<tty.usb*\>\"", ",", 
          RowBox[{"{", "\"\</dev\>\"", "}"}], ",", "Infinity"}], "]"}], "]"}],
        "[", 
       RowBox[{"[", "1", "]"}], "]"}], ",", 
      RowBox[{"\"\<BaudRate\>\"", "\[Rule]", "9600"}]}], "}"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.633206482043254*^9, 
  3.63320649383344*^9}},ExpressionUUID->"8008cb0a-83c1-45f3-ab89-\
db4d8d54245f"],

