Cell[TextData[StyleBox["We then need to upload an Arduino C-program -actually \
some dialect-, which is called Sketch, to the microcontroller.  ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.633206121913165*^9, 3.63320612218838*^9}, {
  3.633206153848321*^9, 3.633206191677308*^9}, {3.633206282850656*^9, 
  3.633206288202559*^9}},ExpressionUUID->"f07632c3-36a3-4994-82f8-\
e0cf4383a0ae"],

Cell["\<\
#include <OneWire.h>
#include <DallasTemperature.h>
 
// Data wire is plugged into pin 2 on the Arduino
#define ONE_WIRE_BUS 2
 
// Setup a oneWire instance to communicate with any OneWire devices 
// (not just Maxim/Dallas temperature ICs)
OneWire oneWire(ONE_WIRE_BUS);
 
// Pass our oneWire reference to Dallas Temperature.
DallasTemperature sensors(&oneWire);
 
void setup(void)
{
  // start serial port
  Serial.begin(9600);

  // Start up the library
  sensors.begin();
}
 
 
void loop(void)
{
 
  sensors.requestTemperatures(); // Send the command to get temperatures

  Serial.print(sensors.getTempCByIndex(0),4); 
  Serial.print(\[OpenCurlyDoubleQuote],\[CloseCurlyDoubleQuote]);
}
 \
\>", "Text",
 CellChangeTimes->{{3.633206194477377*^9, 3.633206194879877*^9}, {
  3.633206254418277*^9, 3.633206255378972*^9}, {3.633206300673607*^9, 
  3.633206350790254*^9}},ExpressionUUID->"63187528-e47e-438f-a0cb-\
e3a8b258c632"],

Cell[TextData[StyleBox["This upload is done via the Arduino IDE",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.63320626083785*^9, 3.633206273194885*^9}, {
  3.6332063582136097`*^9, 
  3.633206364901697*^9}},ExpressionUUID->"24c547e1-3551-4cb3-bd64-\
76c9554fe45e"],

