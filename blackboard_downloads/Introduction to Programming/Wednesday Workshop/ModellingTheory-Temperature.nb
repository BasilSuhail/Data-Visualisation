     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", " ", 
      RowBox[{"x", "\[Rule]", " ", "0.02"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", " ", 
      RowBox[{"x", "\[Rule]", " ", "0.04"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", " ", 
      RowBox[{"x", "\[Rule]", " ", "0.06"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", " ", 
      RowBox[{"x", "\[Rule]", " ", "0.08"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "20"}], "}"}]}], "]"}]], "Input",ExpressionUUI\
