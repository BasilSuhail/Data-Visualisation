Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
    "remove", " ", "average", "  ", "\[IndentingNewLine]", "tempdepth"}], "=", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"StandardDeviation", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"\[Theta]", "[", 
                 RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", 
               RowBox[{"x", "\[Rule]", " ", "g"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"t", ",", "1", ",", "1000"}], "}"}]}], "]"}], "]"}], 
           "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"-", "g"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"g", ",", "0", ",", "5", ",", "0.05"}], "}"}]}], "]"}], ",", 
      
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", 
