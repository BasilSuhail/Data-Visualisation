Cell[TextData[StyleBox["In order to calculate the cooling rate we need to \
find out when the measurements were taken. They were taken at approximately 5 \
seconds, but there were many false measurements which we needed to get rid \
of.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602963228988022*^9, 
  3.60296328357062*^9}},ExpressionUUID->"7403ceec-a7d7-44d3-a788-\
37c3b4105623"],

