                    "}"}]}], "}"}]}]}], "]"}], ",", "\"\<key characters\>\"", 
                   ",", "Top"}], "]"}]}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Labeled", "[", 
                  RowBox[{
                   RowBox[{"Column", "[", 
