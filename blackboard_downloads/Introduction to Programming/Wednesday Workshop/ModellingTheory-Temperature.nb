Cell[CellGroupData[{

Cell["Cooling/Heating with changing ambient temperature", "Section",
 CellChangeTimes->{{3.602968183316935*^9, 
  3.602968209370635*^9}},ExpressionUUID->"ca1aaf78-e185-495b-af27-\
ba061e68b5bc"],

Cell[TextData[StyleBox["In our calculations so far we have ignored a \
potential change in the ambient temperature.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.60296822335534*^9, 
  3.602968242178381*^9}},ExpressionUUID->"ff84d4e8-93f1-4454-a948-\
f18aee412a1f"],

Cell[TextData[StyleBox["Let\[CloseCurlyQuote]s consider a periodically \
changing ambient temperature:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602968266182356*^9, 3.60296829395334*^9}, 
   3.60296838360042*^9},ExpressionUUID->"e23552f9-19a8-4e45-a18b-\
aef98b752403"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox[
    RowBox[{"\[PartialD]", 
     RowBox[{"Temp", "(", "t", ")"}]}], 
    RowBox[{"\[PartialD]", "t"}],
    MultilineFunction->None], "\[LongEqual]", 
   RowBox[{
    RowBox[{"-", "\[Kappa]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Temp", "(", "t", ")"}], "-", 
      RowBox[{"TU", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"sin", "(", 
          RowBox[{"t", " ", "\[Omega]"}], ")"}], "+", "1"}], ")"}]}]}], 
     ")"}]}]}], TraditionalForm]], "Input",
 CellChangeTimes->{{3.602968304191829*^9, 
  3.60296831115079*^9}},ExpressionUUID->"7b88b3dc-2720-4921-bd72-\
a0e8cd4f2f8d"],

Cell[TextData[StyleBox["This yields:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602968320721361*^9, 
  3.60296832330462*^9}},ExpressionUUID->"efd78d12-3116-4b0d-a795-\
0ef4b886c579"],

Cell[BoxData[
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}]], "Input",ExpressionUUID->"2ceac5d3-ec08-4ca2-bfe2-10788412a324"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sols", "=", 
  RowBox[{"DSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Temp", "[", "t", "]"}], ",", "t"}], "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", "\[Kappa]"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Temp", "[", "t", "]"}], "-", 
          RowBox[{"TU", "*", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"Sin", "[", 
              RowBox[{"\[Omega]", "*", "t"}], "]"}]}], ")"}]}]}], ")"}]}]}], 
      ",", 
      RowBox[{
       RowBox[{"Temp", "[", "0", "]"}], "==", "80"}]}], "}"}], ",", "Temp", 
    ",", "t"}], "]"}]}]], "Input",ExpressionUUID->"9fee3c90-6cd6-4e1f-91c8-\
3935f1ed295e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"Temp", "\[Rule]", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", "t", "}"}], ",", 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "t"}], " ", "\[Kappa]"}]], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"80", " ", 
           SuperscriptBox["\[Kappa]", "2"]}], "-", 
          RowBox[{"TU", " ", 
           SuperscriptBox["\[Kappa]", "2"]}], "+", 
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"t", " ", "\[Kappa]"}]], " ", "TU", " ", 
           SuperscriptBox["\[Kappa]", "2"]}], "+", 
          RowBox[{"TU", " ", "\[Kappa]", " ", "\[Omega]"}], "+", 
          RowBox[{"80", " ", 
           SuperscriptBox["\[Omega]", "2"]}], "-", 
          RowBox[{"TU", " ", 
           SuperscriptBox["\[Omega]", "2"]}], "+", 
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"t", " ", "\[Kappa]"}]], " ", "TU", " ", 
           SuperscriptBox["\[Omega]", "2"]}], "-", 
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"t", " ", "\[Kappa]"}]], " ", "TU", " ", "\[Kappa]", " ", 
           "\[Omega]", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"t", " ", "\[Omega]"}], "]"}]}], "+", 
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"t", " ", "\[Kappa]"}]], " ", "TU", " ", 
           SuperscriptBox["\[Kappa]", "2"], " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"t", " ", "\[Omega]"}], "]"}]}]}], ")"}]}], 
       RowBox[{
        SuperscriptBox["\[Kappa]", "2"], "+", 
        SuperscriptBox["\[Omega]", "2"]}]]}], "]"}]}], "}"}], "}"}]], "Output",\

 CellChangeTimes->{3.664046310565855*^9, 3.696104056231101*^9, 
  3.727554453337812*^9},ExpressionUUID->"913ba647-d4e0-46f9-b07d-\
fe05e4c21b77"]
}, Open  ]],

Cell[TextData[StyleBox["And then",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602968339497079*^9, 
  3.602968340295817*^9}},ExpressionUUID->"92ab23eb-ba2c-4286-adcf-\
d0c26979840b"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Temp", "[", "t", "]"}], "/.", "sols"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Kappa]", "\[Rule]", " ", "0.1"}], ",", 
        RowBox[{"TU", "\[Rule]", " ", "20"}], ",", " ", 
        RowBox[{"\[Omega]", "\[Rule]", " ", "\[Omega]1"}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "200"}], "}"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", " ", 
      RowBox[{"{", 
       RowBox[{"All", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "100"}], "}"}]}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Omega]1", ",", "0"}], "}"}], ",", "0", ",", "10"}], "}"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.602968355978965*^9, 
  3.602968357368698*^9}},ExpressionUUID->"231402eb-399f-456a-81c5-\
dedb6bfa0b41"],

Cell[TextData[StyleBox["Of course, we can also model the case where the \
ambient temperature does not change so regularly, but rather eratically. We \
first create a \[OpenCurlyDoubleQuote]randomly perturbed\
\[CloseCurlyDoubleQuote] oscillating time series:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602968409126892*^9, 
  3.602968494979376*^9}},ExpressionUUID->"54d7e5fd-3685-4059-8f29-\
e743f241437d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"t", ",", 
      RowBox[{
       RowBox[{"RandomVariate", "[", 
        RowBox[{"NormalDistribution", "[", "]"}], "]"}], "+", "1", "+", 
       RowBox[{"Sin", "[", 
        RowBox[{"0.2", "*", "t"}], "]"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "100"}], "}"}]}], "]"}], "//", 
  "ListPlot"}]], "Input",
 CellChangeTimes->{{3.602968499108514*^9, 
  3.602968501780346*^9}},ExpressionUUID->"e4835256-eab1-4b42-99cb-\
932d64616958"],

