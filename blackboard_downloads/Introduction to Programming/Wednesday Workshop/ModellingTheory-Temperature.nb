Cell[CellGroupData[{

Cell["Matrix Population Models", "Section",
 CellChangeTimes->{{3.602344088572323*^9, 
  3.6023440925196257`*^9}},ExpressionUUID->"927b6d0d-455a-4002-8bff-\
4d7f3cd2fc9c"],

Cell[TextData[StyleBox["Matrix population models are commonly used to \
describe populations of individuals of different age classes. ",
 FontSize->18]], "Text",
 CellChangeTimes->{
  3.602344097964091*^9, {3.602357260003241*^9, 
   3.602357298135873*^9}},ExpressionUUID->"dc5550dc-a061-4dcb-bc4e-\
29f94b36ceb2"],

Cell[BoxData[
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.602357352258437*^9, 
  3.602357363918397*^9}},ExpressionUUID->"25b2fccb-3925-48b7-ad3b-\
9add740a18b6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["n", "1"], "[", "t_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["n", "1"], "[", "t", "]"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["F", "1"], 
      RowBox[{
       SubscriptBox["n", "1"], "[", 
       RowBox[{"t", "-", "1"}], "]"}]}], "+", 
     RowBox[{
      SubscriptBox["F", "2"], 
      RowBox[{
       SubscriptBox["n", "2"], "[", 
       RowBox[{"t", "-", "1"}], "]"}]}], "+", 
     RowBox[{
      SubscriptBox["F", "3"], 
      RowBox[{
       SubscriptBox["n", "3"], "[", 
       RowBox[{"t", "-", "1"}], "]"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["n", "2"], "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     SubscriptBox["n", "2"], "[", "t", "]"}], "=", 
    RowBox[{
     SubscriptBox["P", "1"], 
     RowBox[{
      SubscriptBox["n", "1"], "[", 
      RowBox[{"t", "-", "1"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["n", "3"], "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     SubscriptBox["n", "3"], "[", "t", "]"}], "=", 
    RowBox[{
     SubscriptBox["P", "2"], " ", 
     RowBox[{
      SubscriptBox["n", "2"], "[", 
      RowBox[{"t", "-", "1"}], "]"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.602357314184044*^9, 3.602357348239106*^9}, {
  3.60235738628764*^9, 3.602357520647303*^9}, {3.602357575012781*^9, 
  3.6023576835576077`*^9}, {3.6023579493251753`*^9, 3.6023579610737467`*^9}, {
  3.6023582562401953`*^9, 
  3.602358279966666*^9}},ExpressionUUID->"0b9bcb80-504f-4d35-9a41-\
48ca8fd461c3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["n", "1"], "[", "0", "]"}], "=", "10."}], ";", 
  RowBox[{
   RowBox[{
    SubscriptBox["n", "2"], "[", "0", "]"}], "=", "2."}], ";", 
  RowBox[{
   RowBox[{
    SubscriptBox["n", "3"], "[", "0", "]"}], "=", "1."}], ";", 
  RowBox[{
   SubscriptBox["F", "1"], "=", "20."}], ";", 
  RowBox[{
   SubscriptBox["F", "2"], "=", "20."}], ";", 
  RowBox[{
   SubscriptBox["F", "3"], "=", "10."}], ";", 
  RowBox[{
   SubscriptBox["P", "1"], "=", "0.05"}], ";", 
  RowBox[{
   SubscriptBox["P", "2"], "=", "0.1"}], ";"}]], "Input",
