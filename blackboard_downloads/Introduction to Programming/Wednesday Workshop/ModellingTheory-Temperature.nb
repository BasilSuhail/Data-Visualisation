Cell[BoxData[{
 RowBox[{
  RowBox[{"rand", ":=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{"UniformDistribution", "[", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"A", ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", 
      RowBox[{"2", "*", 
       RowBox[{"(", 
        RowBox[{"1", "+", "rand"}], ")"}]}], ",", 
      RowBox[{"5", 
       RowBox[{"(", 
        RowBox[{"1.", "+", "rand"}], ")"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"2.3", "*", 
       RowBox[{"(", 
        RowBox[{"1", "+", "rand"}], ")"}]}], ",", "0", ",", "0"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"0", ",", 
      RowBox[{"1.5", "*", 
       RowBox[{"(", 
        RowBox[{"1", "+", "rand"}], ")"}]}], ",", "0"}], "}"}]}], 
   "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vecs", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Sign", "[", 
       RowBox[{
        RowBox[{"Eigenvectors", "[", "#", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}], "*", 
