Cell[BoxData[
 RowBox[{
  RowBox[{"dataclean", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"data", "[", 
          RowBox[{"[", "k", "]"}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"1", ";;", "6"}], "]"}], "]"}], "}"}], ",", 
       RowBox[{
        RowBox[{"data", "[", 
         RowBox[{"[", "k", "]"}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"7", ";;", "9"}], "]"}], "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", 
       RowBox[{"Length", "[", "data", "]"}]}], "}"}]}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"198d5836-e669-4165-99d9-0449b3a7b8a3"],

