Cell[CellGroupData[{

Cell["Soil temperature for Aberdeen", "Section",
 CellChangeTimes->{{3.602970000333077*^9, 
  3.602970006569778*^9}},ExpressionUUID->"56305a85-6aef-4532-8a1e-\
7e5636ce9741"],

Cell[TextData[StyleBox["Based on the air temperature data for Aberdeen we can \
now model the expected temperature distribution in the soil (ignoring many \
factors...).",
 FontSize->16]], "Text",
 CellChangeTimes->{{3.602970012987173*^9, 
  3.602970056529228*^9}},ExpressionUUID->"5a7c4be0-f94b-4143-ac02-\
e67de28efc57"],

Cell[BoxData[
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}]], "Input",ExpressionUUID->"4c60e41f-74b2-485b-8ba2-139678629b37"],

Cell[TextData[StyleBox["First we need to get the temperature data for \
Aberdeen (actually the airport, EGPD) for a couple of years:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.6029700792337103`*^9, 
  3.602970114951824*^9}},ExpressionUUID->"cabadf81-d290-4bb4-ab54-\
f0c62b8dd60c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tempAberdeencity", "=", 
   RowBox[{
    RowBox[{"WeatherData", "[", 
     RowBox[{
      NamespaceBox["LinguisticAssistant",
       DynamicModuleBox[{WolframAlphaClient`Private`query$$ = "Aberdeen", 
        WolframAlphaClient`Private`boxes$$ = TemplateBox[{"\"Aberdeen\"", 
          RowBox[{"Entity", "[", 
            RowBox[{"\"City\"", ",", 
              RowBox[{"{", 
                
                RowBox[{
                 "\"Aberdeen\"", ",", "\"AberdeenCity\"", ",", 
                  "\"UnitedKingdom\""}], "}"}]}], "]"}], 
          "\"Entity[\\\"City\\\", {\\\"Aberdeen\\\", \\\"AberdeenCity\\\", \\\
\"UnitedKingdom\\\"}]\"", "\"city\""}, "Entity"], 
        WolframAlphaClient`Private`allassumptions$$ = {{
         "type" -> "Clash", "word" -> "Aberdeen", "template" -> 
          "Assuming \"${word}\" is ${desc1}. Use as ${desc2} instead", 
          "count" -> "3", 
          "Values" -> {{
            "name" -> "City", "desc" -> "a city", "input" -> 
             "*C.Aberdeen-_*City-"}, {
            "name" -> "AdministrativeDivision", "desc" -> 
             "an administrative division", "input" -> 
             "*C.Aberdeen-_*AdministrativeDivision-"}, {
            "name" -> "Movie", "desc" -> "a movie", "input" -> 
             "*C.Aberdeen-_*Movie-"}}}, {
         "type" -> "SubCategory", "word" -> "Aberdeen", "template" -> 
          "Assuming ${desc1}. Use ${desc2} instead", "count" -> "8", 
          "Values" -> {{
            "name" -> "{Aberdeen, AberdeenCity, UnitedKingdom}", "desc" -> 
             "Aberdeen (United Kingdom)", "input" -> 
             "*DPClash.CityE.Aberdeen-_**Aberdeen.AberdeenCity.UnitedKingdom--\
"}, {"name" -> "{Aberdeen, SouthDakota, UnitedStates}", "desc" -> 
             "Aberdeen (South Dakota, USA)", "input" -> 
             "*DPClash.CityE.Aberdeen-_**Aberdeen.SouthDakota.UnitedStates--"}\
, {"name" -> "{Aberdeen, Maryland, UnitedStates}", "desc" -> 
             "Aberdeen (Maryland, USA)", "input" -> 
             "*DPClash.CityE.Aberdeen-_**Aberdeen.Maryland.UnitedStates--"}, {
            "name" -> "{Aberdeen, Washington, UnitedStates}", "desc" -> 
             "Aberdeen (Washington, USA)", "input" -> 
             "*DPClash.CityE.Aberdeen-_**Aberdeen.Washington.UnitedStates--"},\
 {"name" -> "{Aberdeen, NorthCarolina, UnitedStates}", "desc" -> 
             "Aberdeen (North Carolina, USA)", "input" -> 
             "*DPClash.CityE.Aberdeen-_**Aberdeen.NorthCarolina.UnitedStates--\
"}, {"name" -> "{Aberdeen, Mississippi, UnitedStates}", "desc" -> 
             "Aberdeen (Mississippi, USA)", "input" -> 
             "*DPClash.CityE.Aberdeen-_**Aberdeen.Mississippi.UnitedStates--"}\
, {"name" -> "{Aberdeen, Idaho, UnitedStates}", "desc" -> 
             "Aberdeen (Idaho, USA)", "input" -> 
             "*DPClash.CityE.Aberdeen-_**Aberdeen.Idaho.UnitedStates--"}, {
            "name" -> "{Aberdeen, Ohio, UnitedStates}", "desc" -> 
             "Aberdeen (Ohio, USA)", "input" -> 
             "*DPClash.CityE.Aberdeen-_**Aberdeen.Ohio.UnitedStates--"}}}}, 
        WolframAlphaClient`Private`assumptions$$ = {}, 
        WolframAlphaClient`Private`open$$ = {1, 2}}, 
        DynamicBox[ToBoxes[
          AlphaIntegration`LinguisticAssistantBoxes["", 1, 
           Dynamic[WolframAlphaClient`Private`query$$], 
           Dynamic[WolframAlphaClient`Private`boxes$$], 
           Dynamic[WolframAlphaClient`Private`allassumptions$$], 
           Dynamic[WolframAlphaClient`Private`assumptions$$], 
           Dynamic[WolframAlphaClient`Private`open$$]], StandardForm],
         ImageSizeCache->{147.2724609375, {8.13623046875, 18.13623046875}},
         TrackedSymbols:>{
          WolframAlphaClient`Private`query$$, 
           WolframAlphaClient`Private`boxes$$, 
           WolframAlphaClient`Private`allassumptions$$, 
           WolframAlphaClient`Private`assumptions$$, 
           WolframAlphaClient`Private`open$$}],
        DynamicModuleValues:>{},
        UndoTrackedVariables:>{WolframAlphaClient`Private`open$$}],
       BaseStyle->{"Deploy"},
       DeleteWithContents->True,
       Editable->False,
       SelectWithContents->True], ",", "\"\<Temperature\>\"", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"2011", ",", " ", "1", ",", " ", "1"}], "}"}], ",", 
        RowBox[{"Date", "[", "]"}], ",", " ", "\"\<Day\>\""}], "}"}]}], "]"}],
     "[", "\"\<Values\>\"", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.633205593745379*^9, 3.6332056144286113`*^9}, {
