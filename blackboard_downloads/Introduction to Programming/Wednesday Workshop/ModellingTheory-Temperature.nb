Cell[TextData[StyleBox["Next we wait for 10 minutes and then pour the milk \
in:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602967175398857*^9, 
  3.602967194837338*^9}},ExpressionUUID->"fad3a69d-bc86-4fed-80f4-\
3aa05c5b20a2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sols2", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Temp", "[", "t", "]"}], ",", "t"}], "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", "0.1"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Temp", "[", "t", "]"}], "-", "20"}], ")"}]}]}], ",", 
      RowBox[{
       RowBox[{"Temp", "[", "0", "]"}], "\[Equal]", "80"}], ",", 
      RowBox[{"WhenEvent", "[", 
       RowBox[{
        RowBox[{"t", ">", "10"}], ",", 
        RowBox[{
         RowBox[{"Temp", "[", "t", "]"}], "\[Rule]", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"200.", "*", " ", 
             RowBox[{"Temp", "[", "t", "]"}]}], "+", 
            RowBox[{"50.", "*", " ", "5."}]}], ")"}], "/", "250."}]}]}], 
       "]"}]}], "}"}], ",", "Temp", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "30"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.60296611398361*^9, 3.602966124899842*^9}, {
   3.602966273768918*^9, 3.602966274584737*^9}, {3.602966349163185*^9, 
   3.602966373151933*^9}, {3.602966408196095*^9, 3.602966418767127*^9}, {
