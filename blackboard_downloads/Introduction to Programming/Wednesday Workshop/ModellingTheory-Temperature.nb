        (Part[{{Identity, Identity}, {Identity, Identity}}, 1, 2][#]& )[
         Part[#, 1]], 
        (Part[{{Identity, Identity}, {Identity, Identity}}, 2, 2][#]& )[
         Part[#, 2]]}& ), "CopiedValueFunction" -> ({
        (Part[{{Identity, Identity}, {Identity, Identity}}, 1, 2][#]& )[
         Part[#, 1]], 
        (Part[{{Identity, Identity}, {Identity, Identity}}, 2, 2][#]& )[
         Part[#, 2]]}& )}},
  PlotRange->{All, {0, 100}},
  PlotRangeClipping->True,
  PlotRangePadding->{{
     Scaled[0.02], 
     Scaled[0.02]}, {0, 0}},
  Ticks->{Automatic, Automatic}]], "Output",
 CellChangeTimes->{{3.697284524148657*^9, 
  3.697284547589027*^9}},ExpressionUUID->"f5eecd2c-3d6f-4bce-b35b-\
a86b54e3f1af"]
}, Open  ]],

Cell[TextData[StyleBox["This shows how the object cools down. ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602959191046912*^9, 3.602959203703771*^9}, {
   3.6029593001339407`*^9, 3.602959312084874*^9}, {3.602962010491145*^9, 
   3.60296201353053*^9}, {3.602962409122396*^9, 3.60296241779675*^9}, 
   3.6029624601062727`*^9},ExpressionUUID->"31c5f1b8-6c24-4840-8fb9-\
55cf73e8aa6e"],

Cell[TextData[StyleBox["We can now convert the function into discrete \
\[OpenCurlyDoubleQuote]measurements\[CloseCurlyDoubleQuote]  ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602962472990471*^9, 
  3.602962550950809*^9}},ExpressionUUID->"07be094b-8b87-4af4-8ba8-\
24a4c6988216"],

Cell[BoxData[
 RowBox[{
  RowBox[{"measurements", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Temp", "[", "t", "]"}], "-", "TU"}], "/.", "sols"}], "/.",
           " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\[Kappa]", "\[Rule]", " ", "0.1"}], ",", 
            RowBox[{"TU", "\[Rule]", " ", "20"}], ",", 
            RowBox[{"T0", "\[Rule]", " ", "80"}]}], "}"}]}], ")"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "60"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.602962552201165*^9, 3.602962617975051*^9}, {
  3.602962669862914*^9, 
  3.602962675005672*^9}},ExpressionUUID->"7e0d9486-318e-4879-8bec-\
3862feb4c2d3"],

Cell[BoxData[
 RowBox[{"ListLogPlot", "[", "measurements", "]"}]], "Input",
 CellChangeTimes->{{3.602962490731195*^9, 3.6029624983326197`*^9}, {
  3.602962621047357*^9, 
  3.6029626576863627`*^9}},ExpressionUUID->"f5e587ef-6d3d-44e9-a2ab-\
03665d1d84a7"],

Cell[BoxData[
 RowBox[{"Fit", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", 
       RowBox[{"Log", "[", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}], "&"}], " ", "/@", 
    "measurements"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "1"}], "}"}], ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.602962684120892*^9, 
  3.602962806449032*^9}},ExpressionUUID->"6fa8e358-c1bd-4e4e-ba7e-\
3b9ae240cde8"],

Cell[TextData[StyleBox["The 0.1 is the numerical value of \[Kappa].",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602962823348648*^9, 3.602962849946549*^9}, {
  3.633206036618668*^9, 
  3.633206044313183*^9}},ExpressionUUID->"cc9e8c69-f330-4118-ab5d-\
0ff8020e22f8"],

Cell[CellGroupData[{

Cell[TextData[{
 "In fact we can use a combination of Arduino and ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to actually measure temperature with an external sensor. "
}], "Subsection",
 CellChangeTimes->{{3.633206045740508*^9, 
  3.633206084288229*^9}},ExpressionUUID->"cce2da86-794e-40af-8df2-\
cfdbde22bff6"],

Cell[TextData[StyleBox["We use the Arduino and wire it like so:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.633206086843497*^9, 
  3.633206120095229*^9}},ExpressionUUID->"1d68c4c4-e4e2-4873-a806-\
630fe343fde9"],

