Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"s", "=", 
    RowBox[{"{", "}"}]}], ";", 
   RowBox[{"tZero", "=", 
    RowBox[{"AbsoluteTime", "[", "]"}]}], ";", 
   RowBox[{"DeviceReadBuffer", "[", "myDSTemperature", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{"RunScheduledTask", "[", 
  RowBox[{
   RowBox[{"AppendTo", "[", 
    RowBox[{"s", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"AbsoluteTime", "[", "]"}], "-", "tZero"}], ",", 
       RowBox[{"ToExpression", "@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"StringSplit", "[", 
           RowBox[{
            RowBox[{"FromCharacterCode", "@", 
             RowBox[{"DeviceReadBuffer", "[", "myDSTemperature", "]"}]}], 
            ",", "\"\<,\>\""}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}], ")"}]}]}], "}"}]}], "]"}], ",", 
   "1"}], "]"}]}], "Input",
