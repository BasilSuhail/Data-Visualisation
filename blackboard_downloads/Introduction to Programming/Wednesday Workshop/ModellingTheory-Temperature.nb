Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{
    "no", " ", "problems", " ", "with", " ", "the", " ", "boundary", " ", 
     RowBox[{"conditions", ":", "\[IndentingNewLine]", "f"}]}], "=", 
    RowBox[{"Interpolation", "[", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Range", "[", 
          RowBox[{"Length", "[", "tempAberdeen", "]"}], "]"}], "-", "1"}], 
        ",", "tempAberdeen"}], "}"}], "]"}], "]"}]}], ";", 
   RowBox[{"sols", "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Theta]", "[", 
            RowBox[{"x", ",", "t"}], "]"}], ",", "t"}], "]"}], "\[Equal]", 
         RowBox[{"0.01", "*", " ", 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"\[Theta]", "[", 
             RowBox[{"x", ",", "t"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "2"}], "}"}]}], "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"\[Theta]", "[", 
          RowBox[{"0", ",", "t"}], "]"}], "\[Equal]", 
         RowBox[{"f", "[", "t", "]"}]}], ",", 
        RowBox[{
         RowBox[{"\[Theta]", "[", 
          RowBox[{"x", ",", "0"}], "]"}], "\[Equal]", 
         RowBox[{"f", "[", "0", "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"\[Theta]", "[", 
             RowBox[{"x", ",", "t"}], "]"}], ",", "x"}], "]"}], "\[Equal]", 
          "0"}], "/.", " ", 
         RowBox[{"x", "\[Rule]", "0"}]}]}], "}"}], ",", 
      RowBox[{"\[Theta]", "[", 
       RowBox[{"x", ",", "t"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", 
        RowBox[{
         RowBox[{"Length", "[", "tempAberdeen", "]"}], "-", "1"}]}], "}"}], 
      ",", 
      RowBox[{"PrecisionGoal", "\[Rule]", "100"}], ",", 
      RowBox[{"MaxSteps", "\[Rule]", "Infinity"}], ",", 
      RowBox[{"MaxStepFraction", "\[Rule]", 
       RowBox[{"1", "/", "1000."}]}]}], "]"}]}]}], "*)"}]], "Input",
