Cell[TextData[StyleBox["This curve is much smoother (low pass filter!). \
Plotting both functions into one diagram gives:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602968657353113*^9, 
  3.602968694734201*^9}},ExpressionUUID->"e6f2aa1c-a5cc-4dbb-9d0e-\
ff6d5a84ca28"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"10.", "*", 
       RowBox[{"tcourseTemp", "[", "t", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", " ", "Red"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", " ", "All"}]}], "]"}], ",", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Temp", "[", "t", "]"}], "/.", "sols2"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", " ", 
       RowBox[{"{", 
        RowBox[{"All", ",", "All"}], "}"}]}]}], "]"}]}], "}"}], 
  "]"}]], "Input",ExpressionUUID->"69e446ea-19ea-4e23-a6c2-2e042212b737"],

Cell[TextData[StyleBox["Such a model could be amended to describe the heat \
loss of a house, and help us to develop an optimal heating strategy.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602968761279797*^9, 
  3.602968796510233*^9}},ExpressionUUID->"005a1aa4-c2ad-4d39-b74e-\
043d8cc90e55"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"bf4414e8-e069-4310-9df3-c664fc03accc"],

Cell[CellGroupData[{

Cell["Model for the temperature of soil at different depths", "Section",
 CellChangeTimes->{{3.602968863143774*^9, 
  3.602968881389532*^9}},ExpressionUUID->"9e3d54e9-cd1c-49f2-9428-\
bac830ea4e49"],

Cell[TextData[StyleBox["When we want to describe the diffusion of heat into \
the soil we need to use a partial differential equation.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602968888982766*^9, 
  3.602968920476162*^9}},ExpressionUUID->"582dc990-e90b-42b0-809f-\
a5bff420c989"],

Cell[BoxData[
 FormBox[
  StyleBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      RowBox[{"\[Theta]", "(", 
       RowBox[{"x", ",", "t"}], ")"}]}], 
     RowBox[{"\[PartialD]", "t"}],
     MultilineFunction->None], "\[LongEqual]", 
    RowBox[{"\[Kappa]", " ", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[PartialD]", "2"], 
       RowBox[{"\[Theta]", "(", 
        RowBox[{"x", ",", "t"}], ")"}]}], 
      RowBox[{"\[PartialD]", 
       SuperscriptBox["x", "2"]}],
      MultilineFunction->None]}]}],
   FontSize->16], TraditionalForm]], "Input",
 CellChangeTimes->{{3.602968922235708*^9, 
  3.60296896030736*^9}},ExpressionUUID->"1de96303-aa9d-4cc7-a414-\
a4b2b412d0c5"],

Cell[TextData[StyleBox["We will model the influence of the surface heating by \
the boundary conditions. ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.6029689973089533`*^9, 
  3.602969026826681*^9}},ExpressionUUID->"4506e750-ede6-4d1a-ad3e-\
9951fbc8fe82"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "t", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"10.", "+", 
     RowBox[{"A", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Omega]", " ", "t"}], "]"}]}]}], "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"A", "\[Rule]", " ", "10."}], ",", 
      RowBox[{"\[Omega]", "\[Rule]", " ", 
       RowBox[{"1.", "/", "35."}]}]}], "}"}]}]}], ";", 
  RowBox[{"sols", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[Theta]", "[", 
           RowBox[{"x", ",", "t"}], "]"}], ",", "t"}], "]"}], "\[Equal]", 
        RowBox[{"0.05", "*", " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Theta]", "[", 
            RowBox[{"x", ",", "t"}], "]"}], ",", 
           RowBox[{"{", 
