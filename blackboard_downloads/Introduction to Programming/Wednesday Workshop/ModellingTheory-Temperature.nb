   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1200"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", " ", "All"}], ",", 
   RowBox[{"PlotLegends", "\[Rule]", "True"}], ",", 
   RowBox[{"Contours", "\[Rule]", " ", "20"}]}], "]"}]], "Input",ExpressionUUI\
D->"76b330c9-eaf3-4755-a874-4565421f3b5c"],

Cell[TextData[StyleBox["We see that the daily fluctuations only influence the \
very top layers of the soil. Only the longer oscillations penetrate the soil. \
Again we can plot a profile of the temperature fluctuations at different \
depths.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602969835762641*^9, 3.602969911542067*^9}, 
   3.727554494001012*^9},ExpressionUUID->"6bcb1402-5415-4866-b820-\
a9e49647f9b9"],

