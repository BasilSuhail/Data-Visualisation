Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sols2", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"Temp", "[", "t", "]"}], ",", "t"}], "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"-", "\[Kappa]"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Temp", "[", "t", "]"}], "-", 
           RowBox[{"TU", "*", 
            RowBox[{"tcourseTemp", "[", "t", "]"}]}]}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{"Temp", "[", "0", "]"}], "\[Equal]", "20."}]}], "}"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Kappa]", "\[Rule]", " ", "0.4"}], ",", 
       RowBox[{"TU", "\[Rule]", " ", "10."}]}], "}"}]}], ",", "Temp", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "100"}], "}"}]}], "]"}]}]], "Input",Expressio\
nUUID->"f492120d-309b-442b-a136-ba46e570f422"],

