 RowBox[{"ListLinePlot", "[", 
  RowBox[{"tcourse", ",", 
   RowBox[{"AspectRatio", "\[Rule]", "0.2"}], ",", 
   RowBox[{"ImageSize", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"1000", ",", "300"}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.6023617173234267`*^9, 3.602361725922847*^9}, {
  3.602361758580921*^9, 
  3.60236182609271*^9}},ExpressionUUID->"8eef8f2c-b9da-454d-8779-\
b9cfe85449db"],

Cell[TextData[StyleBox["We should look at this for some longer time series \
and plot it in 3 dimensions. ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.6023642120072737`*^9, 
  3.602364273456711*^9}},ExpressionUUID->"33b73f7a-2ea7-4919-987a-\
96f9a5413c09"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tcourse", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"NestList", "[", 
     RowBox[{"A", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"RandomReal", "[", "]"}], ",", "0", ",", "0"}], "}"}], ",", 
      "50000"}], "]"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.602361991556084*^9, 3.602362004473597*^9}, {
  3.602362079423422*^9, 
  3.602362079935215*^9}},ExpressionUUID->"1e907724-b325-4abf-8427-\
b3ae240caf9e"],

Cell[BoxData[
 RowBox[{"ListPointPlot3D", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", "tcourse", "]"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", " ", 
    RowBox[{"PointSize", "[", "Tiny", "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.602361874081505*^9, 3.602361974346541*^9}, {
  3.602362050721949*^9, 3.602362060354718*^9}, {3.602367261423838*^9, 
  3.602367280309078*^9}},ExpressionUUID->"c3cd34aa-3e69-4264-ab17-\
1a2d6b9c6312"],

Cell[TextData[StyleBox["Let\[CloseCurlyQuote]s look at the distribution of \
these on the sphere:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602367281933612*^9, 
  3.602367299175757*^9}},ExpressionUUID->"f41fab56-cb3b-430e-b558-\
b3847d0bbb96"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vecs", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"Normalize", " ", "/@", " ", 
      RowBox[{"NestList", "[", 
       RowBox[{"A", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"RandomReal", "[", "]"}], ",", "0", ",", "0"}], "}"}], ",", 
        "10000"}], "]"}]}], ")"}], "[", 
    RowBox[{"[", 
     RowBox[{"100", ";;"}], "]"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.6023673001541986`*^9, 
  3.602367300996909*^9}},ExpressionUUID->"80d32227-6d20-4af2-ae9f-\
7387e8a4288e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"hist", "=", 
    RowBox[{"Image", "[", 
     RowBox[{
      RowBox[{"SmoothDensityHistogram", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"ArcTan", "[", 
             RowBox[{"#1", ",", "#2"}], "]"}], ",", 
            RowBox[{"ArcCos", "[", "#3", "]"}]}], "}"}], "&"}], "@@@", 
         "vecs"}], ",", 
        RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
        RowBox[{"ColorFunction", "\[Rule]", "\"\<ThermometerColors\>\""}], 
        ",", 
        RowBox[{"Frame", "\[Rule]", "False"}], ",", 
        RowBox[{"ImagePadding", "\[Rule]", "None"}], ",", 
        RowBox[{"PerformanceGoal", "\[Rule]", "\"\<Quality\>\""}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "\[Pi]"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"PlotRangePadding", "\[Rule]", "None"}]}], "]"}], ",", 
      RowBox[{"ImageResolution", "\[Rule]", "256"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"you", " ", "can", " ", "use", " ", 
    RowBox[{"SphericalPlot3D", "[", "]"}], " ", "instead"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "\[IndentingNewLine]", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[CurlyPhi]", "]"}]}], ",", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[CurlyPhi]", "]"}]}], ",", 
     RowBox[{"Cos", "[", "\[CurlyPhi]", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", 
     RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[CurlyPhi]", ",", "0", ",", "\[Pi]"}], "}"}], ",", 
   RowBox[{"Lighting", "\[Rule]", "\"\<Neutral\>\""}], ",", 
   RowBox[{"Mesh", "\[Rule]", "None"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"Texture", "[", "hist", "]"}]}], ",", 
   RowBox[{"TextureCoordinateFunction", "\[Rule]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"#4", ",", "#5"}], "}"}], "&"}], ")"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.602367317283479*^9, 
  3.602367321350576*^9}},ExpressionUUID->"577f2195-192a-4bce-bd5d-\
135793d67c97"],

Cell[TextData[StyleBox["These types of model can be applied for survival \
statistics, e.g. for life insurances. ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.6023641137568398`*^9, 3.602364117123332*^9}, 
   3.602364264464683*^9, {3.602364593887886*^9, 
   3.6023646212601*^9}},ExpressionUUID->"7afe8639-6f40-46db-b1c5-\
9796cec33f01"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"1c7d72cb-a13d-4008-a349-fb75a07ae20d"],

Cell[CellGroupData[{

Cell["Probability/transition/stochastic matrices", "Section",
 CellChangeTimes->{{3.602363238966814*^9, 3.602363248371902*^9}, {
  3.602363290909073*^9, 
  3.602363293435906*^9}},ExpressionUUID->"737f1c2e-72c2-4cd5-be3e-\
eb012dbaf31b"],

Cell[TextData[StyleBox["When we have a transition matrix the idea is that we \
look at the percentages with which each \[OpenCurlyDoubleQuote]component\
\[CloseCurlyDoubleQuote] transits into other classes. Let\[CloseCurlyQuote]s \
take the matrix from the previous example. ",
 FontSize->16]], "Text",
 CellChangeTimes->{{3.602363252949732*^9, 3.60236325485918*^9}, {
  3.602363306569521*^9, 3.602363326586463*^9}, {3.602363398937598*^9, 
  3.602363463857581*^9}},ExpressionUUID->"ffe95d7f-89e2-477b-83f7-\
fa0e0159d254"],

Cell[BoxData[
 RowBox[{"A", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"0.3", ",", "0", ",", "0"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0.5", ",", "0"}], "}"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.602363310719084*^9, 
  3.6023633107210617`*^9}},ExpressionUUID->"bec52b77-8718-43fd-b4cf-\
296e59cf873d"],

Cell[TextData[StyleBox["It had the following graph:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602363488188713*^9, 
  3.602363507373436*^9}},ExpressionUUID->"14a327f3-8b62-438b-b02d-\
f1f11022ca99"],

Cell[BoxData[
 RowBox[{"AdjacencyGraph", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"A", "/.", 
     RowBox[{
      RowBox[{"x_", "/;", 
       RowBox[{"x", ">", "0"}]}], "\[Rule]", "1"}]}], "]"}], ",", 
   RowBox[{"VertexLabels", "\[Rule]", "\"\<Name\>\""}], ",", 
   RowBox[{"ImagePadding", "\[Rule]", "30"}]}], "]"}]], "Input",ExpressionUUID\
->"cfb0e8f9-6bba-4ad5-86c7-4b8bf2ac839a"],

Cell[TextData[StyleBox["To obtain the percentages we need to normalise each \
column to one.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602363518416699*^9, 
  3.602363541324511*^9}},ExpressionUUID->"d1700af0-1a4b-4855-bb33-\
44f2d56fdaba"],

Cell[BoxData[
 RowBox[{"atransition", "=", 
  RowBox[{"Table", "[", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"[", "i", "]"}], "]"}], "/", 
     RowBox[{"Total", "[", 
      RowBox[{"A", "[", 
       RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", 
      RowBox[{"Length", "[", "A", "]"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.602363552267878*^9, 3.602363569083366*^9}, {
  3.6023636155116987`*^9, 
  3.602363647345311*^9}},ExpressionUUID->"a432d5bd-cc3a-4951-9f9e-\
545adcb6df82"],

Cell[TextData[StyleBox["Note that every column is now normalised so that the \
sum of its components is one. A fundamental theorem from algebra says that a \
probability matrix has a unique largest eigenvalue with magnitude one.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.60236365825406*^9, 
  3.602363748178402*^9}},ExpressionUUID->"493485f7-18b6-496e-8934-\
d49846cb3075"],

Cell[BoxData[
 RowBox[{"Eigenvalues", "[", "atransition", "]"}]], "Input",
 CellChangeTimes->{{3.602363751625092*^9, 
  3.602363756930715*^9}},ExpressionUUID->"2397aeee-536a-4eeb-a17a-\
3659c839f6bf"],

Cell[TextData[StyleBox["As before the eigenvector corresponding to the \
largest eigenvalues describes the equilibrium distribution.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602363767755223*^9, 
  3.602363808751708*^9}},ExpressionUUID->"26c3e597-d1a8-4377-bc90-\
b09a637dccdb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Eigenvectors", "[", "atransition", "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}], "/", 
  RowBox[{"Total", "[", 
   RowBox[{
    RowBox[{"Eigenvectors", "[", "atransition", "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.602363811033394*^9, 3.602363818556278*^9}, {
  3.602363867247149*^9, 
  3.602363888967168*^9}},ExpressionUUID->"f891a8d4-3178-43a7-bf37-\
4ef32286f643"],

Cell[TextData[StyleBox["Transition matrices will become important in many \
models. We will encounter them again when we discuss evolutionary processes. ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.60236397008599*^9, 
  3.60236400865547*^9}},ExpressionUUID->"fb0db21f-0e47-4a7c-bd25-\
5ff99d0d11ba"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"449802ca-81d0-4bbb-b736-33a5ff350b91"],

Cell[CellGroupData[{

Cell["Modelling Heat Transfer, from Newton to Fourier", "Section",
 CellChangeTimes->{{3.60295849897143*^9, 
  3.6029585169440737`*^9}},ExpressionUUID->"597be65b-aec1-459e-89a3-\
cfa9324c2274"],

Cell[BoxData[
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.602959136276957*^9, 
  3.602959143498765*^9}},ExpressionUUID->"941f47e6-eca5-4724-b278-\
59754515d8de"],

Cell[TextData[StyleBox["The problem of heat transfer has fascinated \
scientists for a long time. Newton described the cooling for an object. He \
used the simple assumption that the change of the temperature of an object is \
proportional to the temperature difference of the environment and the object.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602958523215994*^9, 3.602958541760054*^9}, {
  3.602958695908555*^9, 3.6029587415150414`*^9}, {3.697284018744858*^9, 
  3.69728402604106*^9}},ExpressionUUID->"a4bbd081-4295-43ee-be82-\
387296f7619d"],

Cell[BoxData[
 FormBox[
  StyleBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      RowBox[{"Temp", "(", "t", ")"}]}], 
     RowBox[{"\[PartialD]", "t"}],
     MultilineFunction->None], "\[LongEqual]", 
    RowBox[{
     RowBox[{"-", "\[Kappa]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Temp", "(", "t", ")"}], "-", "TU"}], ")"}]}]}],
   FontSize->16], TraditionalForm]], "Input",
 CellChangeTimes->{
  3.60295881457964*^9},ExpressionUUID->"ded79890-60db-4ed7-9f03-4808e863beb0"],

Cell[TextData[StyleBox["Here Temp is the temperature of the object and TU is \
the temperature of the environment, e.g. the ambient air. The coefficient \
\[Kappa] indicates how fast the adaptation to the outside temperature takes \
place. ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602958833479888*^9, 
  3.602958931300026*^9}},ExpressionUUID->"a9cb5ba3-4fce-48f4-9d54-\
e89b5b10d576"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sols", "=", 
  RowBox[{"DSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Temp", "[", "t", "]"}], ",", "t"}], "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", "\[Kappa]"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Temp", "[", "t", "]"}], "-", "TU"}], ")"}]}]}], ",", 
      RowBox[{
       RowBox[{"Temp", "[", "0", "]"}], "\[Equal]", "T0"}]}], "}"}], ",", 
    "Temp", ",", "t"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.6029589967586102`*^9, 
  3.602958999399522*^9}},ExpressionUUID->"3cd0d10c-c3e9-4231-a156-\
0832c754c373"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"Temp", "\[Rule]", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", "t", "}"}], ",", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "t"}], " ", "\[Kappa]"}]], " ", 
       RowBox[{"(", 
        RowBox[{"T0", "-", "TU", "+", 
         RowBox[{
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"t", " ", "\[Kappa]"}]], " ", "TU"}]}], ")"}]}]}], "]"}]}],
    "}"}], "}"}]], "Output",
 CellChangeTimes->{
  3.6972845054433002`*^9},ExpressionUUID->"17272b88-dd02-46c8-95a8-\
6ef0c9e84d75"]
}, Open  ]],

Cell[TextData[{
 StyleBox["Here we assumed that the starting temperature is T0. If we assume \
the starting temperature to be 80",
  FontSize->18],
 "\[Degree]",
 StyleBox["C and the air temperature to be 20",
  FontSize->18],
 "\[Degree]",
 StyleBox["C, and \[Kappa]=0.1 we obtain the following plot.",
  FontSize->18]
}], "Text",
 CellChangeTimes->{{3.602958976991556*^9, 3.60295899407728*^9}, {
  3.60295902766892*^9, 3.602959105122848*^9}, {3.6029591776168833`*^9, 
  3.602959184361072*^9}},ExpressionUUID->"84fe9c3b-ea7a-4ebb-ad86-\
c594d29af21f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Temp", "[", "t", "]"}], "/.", "sols"}], "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Kappa]", "\[Rule]", " ", "0.1"}], ",", 
      RowBox[{"TU", "\[Rule]", " ", "20"}], ",", 
      RowBox[{"T0", "\[Rule]", " ", "80"}]}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "60"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{"All", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "100"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Time\>\"", ",", "\"\<Temperature\>\""}], "}"}]}], ",", 
   RowBox[{"LabelStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Bold", ",", " ", "Medium"}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.602959015920444*^9, 3.60295902073702*^9}, {
  3.6029591285323772`*^9, 3.602959130083236*^9}, {3.602968001500993*^9, 
  3.602968027504277*^9}, {3.697284528017877*^9, 
  3.6972845472417727`*^9}},ExpressionUUID->"7e46a966-945c-4e16-ad16-\
5506c0f5a67d"],

