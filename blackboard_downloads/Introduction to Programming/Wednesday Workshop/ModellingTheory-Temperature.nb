8332f754b923"],

Cell[TextData[StyleBox["Let\[CloseCurlyQuote]s produce an adjacency graph for \
this matrix. First we take all non-zero entries to one:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.6023627034796247`*^9, 
  3.6023627484276543`*^9}},ExpressionUUID->"9dc26be5-4841-40a3-a3c1-\
b92d0e297f79"],

Cell[BoxData[
 RowBox[{"A", "/.", 
  RowBox[{
   RowBox[{"x_", "/;", 
    RowBox[{"x", ">", "0"}]}], "\[Rule]", "1"}]}]], "Input",
 CellChangeTimes->{{3.6023623629707603`*^9, 3.60236238969658*^9}, 
   3.6023624209529057`*^9},ExpressionUUID->"4928946c-0922-4c32-bc2a-\
d8ae6a7eda71"],

Cell[TextData[StyleBox["Now we can plot the graph:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602362751583155*^9, 
  3.60236276310804*^9}},ExpressionUUID->"a1dc9a42-94a1-4841-91eb-\
25182ed71840"],

Cell[BoxData[
 RowBox[{"AdjacencyGraph", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"A", "/.", 
     RowBox[{
      RowBox[{"x_", "/;", 
       RowBox[{"x", ">", "0"}]}], "\[Rule]", "1"}]}], "]"}], ",", 
   RowBox[{"VertexLabels", "\[Rule]", "\"\<Name\>\""}], ",", 
   RowBox[{"ImagePadding", "\[Rule]", "30"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.602362516448277*^9, 3.602362593518599*^9}, {
  3.602362654497631*^9, 3.602362662159881*^9}},
 NumberMarks->False,ExpressionUUID->"43ecc270-000d-4e81-81cb-6fa1f54102ef"],

Cell[TextData[StyleBox["Initially we only have \[OpenCurlyDoubleQuote]young\
