Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"gmap", "=", 
        RowBox[{"playNetwork", "[", 
         RowBox[{
          RowBox[{"speechSequences", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ",", "n"}], "]"}]}], ",", "g"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"g", "=", 
       RowBox[{"gmap", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Pane", "[", 
       RowBox[{
        RowBox[{"Labeled", "[", 
         RowBox[{
          RowBox[{"Text", "@", 
           RowBox[{"Grid", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Labeled", "[", 
                  RowBox[{
                   RowBox[{"GraphPlot", "[", 
                    RowBox[{"g", ",", 
                    RowBox[{"MultiedgeStyle", "\[Rule]", "None"}], ",", 
                    RowBox[{"ImageSize", "\[Rule]", 
                    RowBox[{"{", 
                    RowBox[{"300", ",", "200"}], "}"}]}], ",", 
                    RowBox[{"AspectRatio", "\[Rule]", 
                    RowBox[{"2", "/", "3"}]}]}], "]"}], ",", 
                   "\"\<character networks\>\"", ",", "Top"}], "]"}], ",", 
                 RowBox[{"Labeled", "[", 
                  RowBox[{
                   RowBox[{"Grid", "[", 
                    RowBox[{
                    RowBox[{"Join", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"{", 
                    RowBox[{"\"\<character\>\"", ",", "\"\<page rank\>\""}], 
                    "}"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"List", "@@@", 
                    RowBox[{"Take", "[", 
                    RowBox[{
                    RowBox[{"Sort", "[", 
                    RowBox[{
                    RowBox[{"GraphUtilities`PageRanks", "[", "g", "]"}], ",", 
                    
                    RowBox[{
                    RowBox[{
                    RowBox[{"#1", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], ">", 
                    RowBox[{"#2", "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], "&"}]}], "]"}], ",", 
                    "5"}], "]"}]}], ")"}], "/.", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"a_", ",", "b_"}], "}"}], "\[RuleDelayed]", 
                    RowBox[{"{", 
                    RowBox[{"a", ",", 
