        RowBox[{"t", "\[Rule]", " ", "0"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Theta]", "[", 
            RowBox[{"x", ",", "t"}], "]"}], ",", "x"}], "]"}], "\[Equal]", 
         "0"}], "/.", " ", 
        RowBox[{"x", "\[Rule]", "0"}]}]}], "}"}], ",", 
     RowBox[{"\[Theta]", "[", 
      RowBox[{"x", ",", "t"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0.0", ",", "1200"}], "}"}]}], "]"}]}]}]}], "Input",
