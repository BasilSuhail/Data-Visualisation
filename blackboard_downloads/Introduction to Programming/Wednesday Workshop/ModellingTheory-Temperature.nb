Cell[TextData[StyleBox["This gives:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602969052404565*^9, 
  3.6029690588499117`*^9}},ExpressionUUID->"ff2bf126-b007-47ce-90c1-\
f25511be5957"],

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Theta]", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1200"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", " ", "All"}]}], "]"}]], "Input",ExpressionU\
UID->"6b14297e-87ee-4516-9cc8-ec910cc24a50"],

Cell[TextData[StyleBox["We can clearly see the (annual/daily?) fluctuations \
and how the heat diffuses into the ground. A contour plot shows the \
temperature distribution in a clearer way: ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602969077706603*^9, 3.6029691584557257`*^9}, {
  3.727554481523958*^9, 
  3.727554482445636*^9}},ExpressionUUID->"8d9be608-cca3-40b8-b4c8-\
c6c70b985d9e"],

Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Theta]", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "9"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1200"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", " ", "All"}], ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Depth\>\"", ",", "\"\<Time\>\""}], "}"}]}], ",", 
   RowBox[{"LabelStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Medium", ",", "Bold"}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.602969160943862*^9, 3.602969215925539*^9}, {
  3.602969254049386*^9, 3.602969274999743*^9}, {3.602969350372869*^9, 
  3.602969351536099*^9}},ExpressionUUID->"5c66696d-f2f0-44a8-834d-\
5f841dae60dd"],

Cell[TextData[StyleBox["We observe that \[OpenCurlyDoubleQuote]at some depth \
there is winter in summer\[CloseCurlyDoubleQuote]. Let\[CloseCurlyQuote]s \
change a bit the timescales to make it more \[OpenCurlyDoubleQuote]realistic\
\[CloseCurlyDoubleQuote].",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602969363803168*^9, 
  3.602969446744314*^9}},ExpressionUUID->"48a5a632-55f9-41a4-b0eb-\
89ea771c62f5"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "t", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"10.", "+", 
     RowBox[{"A", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Omega]", " ", "t"}], "]"}]}]}], "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"A", "\[Rule]", " ", "10."}], ",", 
      RowBox[{"\[Omega]", "\[Rule]", " ", 
       RowBox[{"2.", 
        RowBox[{"Pi", "/", "365."}]}]}]}], "}"}]}]}], ";", 
  RowBox[{"sols", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[Theta]", "[", 
           RowBox[{"x", ",", "t"}], "]"}], ",", "t"}], "]"}], "\[Equal]", 
        RowBox[{"0.01", "*", " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Theta]", "[", 
            RowBox[{"x", ",", "t"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "2"}], "}"}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"\[Theta]", "[", 
         RowBox[{"0", ",", "t"}], "]"}], "\[Equal]", 
        RowBox[{"f", "[", "t", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Theta]", "[", 
          RowBox[{"x", ",", "0"}], "]"}], "\[Equal]", 
         RowBox[{"f", "[", "t", "]"}]}], "/.", 
        RowBox[{"t", "\[Rule]", " ", "0"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Theta]", "[", 
            RowBox[{"x", ",", "t"}], "]"}], ",", "x"}], "]"}], "\[Equal]", 
         "0"}], "/.", " ", 
        RowBox[{"x", "\[Rule]", "0"}]}]}], "}"}], ",", 
     RowBox[{"\[Theta]", "[", 
      RowBox[{"x", ",", "t"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0.0", ",", "1200"}], "}"}], ",", 
     RowBox[{"PrecisionGoal", "\[Rule]", "10"}]}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.6029694553301*^9, 
  3.6029694622042522`*^9}},ExpressionUUID->"3f5cb5e9-11e4-4c23-a9ea-\
c0079edb8cdb"],

Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Theta]", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1200"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", " ", "All"}], ",", 
   RowBox[{"PlotLegends", "\[Rule]", "True"}], ",", 
   RowBox[{"Contours", "\[Rule]", " ", "20"}], ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Depth\>\"", ",", "\"\<Time\>\""}], "}"}]}], ",", 
   RowBox[{"LabelStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Medium", ",", "Bold"}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{
  3.602969493074864*^9},ExpressionUUID->"f4b86d7d-7d35-4912-b35a-\
373b96573cc7"],

Cell[TextData[StyleBox["We can now plot the temperature curves at different \
depths.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.6029695210286913`*^9, 
  3.602969538690578*^9}},ExpressionUUID->"35c38490-98d0-48b2-a18a-\
c78fd38a26cd"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", " ", 
      RowBox[{"x", "\[Rule]", " ", "0"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", " ", 
      RowBox[{"x", "\[Rule]", " ", "1"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", " ", 
      RowBox[{"x", "\[Rule]", " ", "2"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", " ", 
      RowBox[{"x", "\[Rule]", " ", "3"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], "/.", " ", 
      RowBox[{"x", "\[Rule]", " ", "3.5"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1200"}], "}"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{
     "\"\<Time/[days]\>\"", ",", "\"\<Temperatre/[degrees Celsius]\>\""}], 
     "}"}]}], ",", 
   RowBox[{"LabelStyle", "\[Rule]", 
    RowBox[{"Directive", "[", "Medium", "]"}]}], ",", 
   RowBox[{"ImageSize", "\[Rule]", " ", "Large"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.602969585901598*^9, 
  3.6029696947375507`*^9}},ExpressionUUID->"d20998ea-e3a0-41bf-8af4-\
5af0bb4dc071"],

Cell[TextData[StyleBox["We observe a phase shift and a substantial damping of \
the amplitude at different depths. We can now also study what happens when we \
have daily and annual fluctuations of the temperature.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602969553162801*^9, 3.602969574713533*^9}, {
   3.6029697496850843`*^9, 3.60296977990648*^9}, 
   3.727554489246542*^9},ExpressionUUID->"fb476148-f69e-4cb7-9f7d-\
266438e9eb71"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "t", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"10.", "+", 
     RowBox[{"A", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Omega]", " ", "t"}], "]"}]}], "+", 
     RowBox[{"B", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"2", " ", "Pi", " ", "t"}], "]"}]}]}], "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"A", "\[Rule]", " ", "10."}], ",", 
      RowBox[{"B", "\[Rule]", " ", "6."}], ",", 
      RowBox[{"\[Omega]", "\[Rule]", " ", 
       RowBox[{"2.", 
        RowBox[{"Pi", "/", "365."}]}]}]}], "}"}]}]}], ";", 
  RowBox[{"sols", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[Theta]", "[", 
           RowBox[{"x", ",", "t"}], "]"}], ",", "t"}], "]"}], "\[Equal]", 
        RowBox[{"0.01", "*", " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Theta]", "[", 
            RowBox[{"x", ",", "t"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "2"}], "}"}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"\[Theta]", "[", 
         RowBox[{"0", ",", "t"}], "]"}], "\[Equal]", 
        RowBox[{"f", "[", "t", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Theta]", "[", 
          RowBox[{"x", ",", "0"}], "]"}], "\[Equal]", 
         RowBox[{"f", "[", "t", "]"}]}], "/.", 
        RowBox[{"t", "\[Rule]", " ", "0"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Theta]", "[", 
            RowBox[{"x", ",", "t"}], "]"}], ",", "x"}], "]"}], "\[Equal]", 
         "0"}], "/.", " ", 
        RowBox[{"x", "\[Rule]", "0"}]}]}], "}"}], ",", 
     RowBox[{"\[Theta]", "[", 
      RowBox[{"x", ",", "t"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0.0", ",", "1200"}], "}"}], ",", 
     RowBox[{"PrecisionGoal", "\[Rule]", "100"}], ",", 
     RowBox[{"MaxSteps", "\[Rule]", "Infinity"}], ",", 
     RowBox[{"MaxStepFraction", "\[Rule]", 
      RowBox[{"1", "/", "1000."}]}]}], "]"}]}]}]}], "Input",
