            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{"-", "g"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"g", ",", "0", ",", "5", ",", "0.05"}], "}"}]}], "]"}]}], 
     "]"}]}], ";"}], "*)"}]], "Input",
