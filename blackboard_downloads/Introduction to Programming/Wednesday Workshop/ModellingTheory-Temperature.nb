3203d4cb269c"],

Cell[TextData[StyleBox["The following command (slightly complicated) draws \
the distribution (the histogram) colour coded onto the surface of the sphere.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602366493577297*^9, 
  3.60236652903883*^9}},ExpressionUUID->"37970b6d-4e4a-4164-bcdd-\
78444be051ed"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"hist", "=", 
    RowBox[{"Image", "[", 
     RowBox[{
      RowBox[{"SmoothDensityHistogram", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"ArcTan", "[", 
             RowBox[{"#1", ",", "#2"}], "]"}], ",", 
            RowBox[{"ArcCos", "[", "#3", "]"}]}], "}"}], "&"}], "@@@", 
         "vecs"}], ",", 
        RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
        RowBox[{"ColorFunction", "\[Rule]", "\"\<ThermometerColors\>\""}], 
        ",", 
        RowBox[{"Frame", "\[Rule]", "False"}], ",", 
        RowBox[{"ImagePadding", "\[Rule]", "None"}], ",", 
        RowBox[{"PerformanceGoal", "\[Rule]", "\"\<Quality\>\""}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "\[Pi]"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"PlotRangePadding", "\[Rule]", "None"}]}], "]"}], ",", 
      RowBox[{"ImageResolution", "\[Rule]", "256"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"you", " ", "can", " ", "use", " ", 
    RowBox[{"SphericalPlot3D", "[", "]"}], " ", "instead"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "\[IndentingNewLine]", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[CurlyPhi]", "]"}]}], ",", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[CurlyPhi]", "]"}]}], ",", 
     RowBox[{"Cos", "[", "\[CurlyPhi]", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", 
     RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[CurlyPhi]", ",", "0", ",", "\[Pi]"}], "}"}], ",", 
   RowBox[{"Lighting", "\[Rule]", "\"\<Neutral\>\""}], ",", 
   RowBox[{"Mesh", "\[Rule]", "None"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"Texture", "[", "hist", "]"}]}], ",", 
   RowBox[{"TextureCoordinateFunction", "\[Rule]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"#4", ",", "#5"}], "}"}], "&"}], ")"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.602366530562467*^9, 
  3.602366552170002*^9}},ExpressionUUID->"a248269b-b301-49a3-bdf3-\
fd3ee610f71c"],

Cell[TextData[StyleBox["It is certainly interesting to calculate that \
distribution analytically as it will help us to understand the fluctuations \
of the population. We will have a closer look at linear stochastic systems \
again very soon, when we discuss AutoRegressive Moving Average (ARMA) \
Processes. ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.6023642941283493`*^9, 3.602364344941824*^9}, {
  3.602364666393836*^9, 3.602364673193523*^9}, {3.602366598195712*^9, 
