Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Theta]", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "/.", " ", "sols"}], ",", 
   RowBox[{"{", 
