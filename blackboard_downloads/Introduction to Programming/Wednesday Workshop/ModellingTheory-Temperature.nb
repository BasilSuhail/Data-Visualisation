        SubscriptBox["n", "3"], "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "10"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.602357529304193*^9, 3.602357553567053*^9}, {
  3.602357751103969*^9, 3.602357790111032*^9}, {3.6023582849821463`*^9, 
