Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"3cf2ad1e-5a95-400b-9e72-039ee9b2cc5a"],

Cell[CellGroupData[{

Cell["The eternal conundrum", "Section",
 CellChangeTimes->{{3.60296389046777*^9, 
  3.602963895681471*^9}},ExpressionUUID->"9c5c9fee-e436-4db8-b084-\
28f349af98e8"],

Cell[TextData[StyleBox["Every morning I consume a caffeinated hot beverage \
with sugar and (more importantly for this problem) with milk. Just after \
pouring the delicious beverage into the mug it has a temperature of about 80 \
degrees. I usually add a good portion of standard, semi-skimmed milk, which \
we assume to be from the fridge ; 5 or so degrees. As it happens (nearly \
every morning) I am late, but do not want to be burnt by the smokingly hot \
liquid. So, when do I add the milk? As soon as possible or just before I \
really have to leave. ",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.6029639145295067`*^9, 3.602963946400093*^9}, {
  3.602964051472104*^9, 3.602964189043641*^9}, {3.602964226614291*^9, 
  3.602964332691476*^9}, {3.602967105360547*^9, 3.6029671146002812`*^9}, {
  3.696104026618568*^9, 
  3.696104034604375*^9}},ExpressionUUID->"b3d84d74-b04d-4d45-8087-\
b20fabb2f8f8"],

Cell[TextData[StyleBox["We already know that the cooling of the drink depends \
on its difference to the room temperature.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602964347323524*^9, 
  3.6029643688264236`*^9}},ExpressionUUID->"9dfbaeb1-8f9e-4fd6-a523-\
bea48d772313"],

Cell[BoxData[
 FormBox[
  StyleBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      RowBox[{"Temp", "(", "t", ")"}]}], 
     RowBox[{"\[PartialD]", "t"}],
     MultilineFunction->None], "\[LongEqual]", 
    RowBox[{
     RowBox[{"-", "\[Kappa]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Temp", "(", "t", ")"}], "-", "TU"}], ")"}]}]}],
   FontSize->16], TraditionalForm]], "Input",
 CellChangeTimes->{
  3.60295881457964*^9},ExpressionUUID->"fc9f33d0-78cb-4a72-8ede-0336b9223eaa"],

Cell[TextData[StyleBox["Mixing of liquids (of the same kind, we assume \
Tcaffee > Tair > Tmilk), leads to this",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602964380477921*^9, 3.602964433220797*^9}, {
  3.6029670723918138`*^9, 
  3.602967087766471*^9}},ExpressionUUID->"fcd71162-56cb-4424-8604-\
ab9f300841bd"],

Cell[BoxData[
 FormBox[
  RowBox[{"Tmix", "=", 
   FractionBox[
    RowBox[{
     RowBox[{"mc", " ", "Tc"}], "+", 
     RowBox[{"mm", " ", "Tm"}]}], 
    RowBox[{"mc", "+", "mm"}]]}], TraditionalForm]], "Input",
 CellChangeTimes->{{3.602964449143697*^9, 3.602964526869842*^9}, 
   3.602964558146422*^9},ExpressionUUID->"5fdb3735-3d1a-4664-aa29-\
e56afdf75c09"],

Cell[TextData[StyleBox["where Tmix is the temperature of the resulting \
coffee-milk mix, mc and mm are the mass of the coffee and the milk, and Tc \
and Tm their respective temperatures. First we put the milk in right at the \
beginning:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.602964566002219*^9, 3.602964618010852*^9}, {
  3.602967161223921*^9, 
  3.6029671703577633`*^9}},ExpressionUUID->"7ef0e1db-16ba-49f8-a0bc-\
5135f858a3e0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sols", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Temp", "[", "t", "]"}], ",", "t"}], "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", "0.1"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Temp", "[", "t", "]"}], "-", "20"}], ")"}]}]}], ",", 
      RowBox[{
       RowBox[{"Temp", "[", "0", "]"}], "\[Equal]", "80"}], ",", 
      RowBox[{"WhenEvent", "[", 
       RowBox[{
        RowBox[{"t", ">", "1"}], ",", 
        RowBox[{
         RowBox[{"Temp", "[", "t", "]"}], "\[Rule]", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"200.", " ", 
             RowBox[{"Temp", "[", "t", "]"}]}], "+", 
            RowBox[{"50.", "*", " ", "5."}]}], ")"}], "/", "250."}]}]}], 
       "]"}]}], "}"}], ",", "Temp", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "30"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.6029650140139637`*^9, 3.602965028679173*^9}, {
   3.602965267579638*^9, 3.602965408673439*^9}, {3.602965750800155*^9, 
