Cell[TextData[StyleBox["We can then run a ScheduledTask every second:",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.633206514290724*^9, 
  3.633206540209579*^9}},ExpressionUUID->"92f7e99a-7b70-4962-a8eb-\
