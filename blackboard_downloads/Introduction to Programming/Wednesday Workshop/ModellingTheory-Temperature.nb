   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Range", "[", 
        RowBox[{"Length", "[", "tempAberdeen", "]"}], "]"}], "-", "1"}], ",", 
      "tempAberdeen"}], "}"}], "]"}], "]"}]}]], "Input",ExpressionUUID->\
"0900ce0e-10d2-4b1e-8a5a-efaa9f4a6cfd"],

