Cell[CellGroupData[{

Cell["Terminology", "Subsubsection",
 CellTags->
  "Introduction",ExpressionUUID->"b246918b-8dd4-49ba-a1a2-8a4e662ec1cd"],

Cell["\<\
People in many fields use statistics in their work. It is not uncommon for \
statistical concepts to have different names in different fields. Before \
proceeding, common terminology is introduced that will be used throughout \
this course.\
\>", "Text",
 CellTags->
  "Introduction",ExpressionUUID->"6c5162ab-0762-4ac6-8da3-a8c0e69874f3"],

