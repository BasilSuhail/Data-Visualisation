Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"cb6f4f09-5433-4382-aa79-621494fb5c30"],

Cell[CellGroupData[{

Cell["Constructing a Piecewise Continuous Model", "Section",
 CellChangeTimes->{{3.574679086117256*^9, 
  3.574679108131014*^9}},ExpressionUUID->"276c41cd-c6f7-4ae5-95c8-\
362ad1ed90a5"],

Cell[TextData[{
 "Fit three straight lines to the data. Straight lines can be expressed in \
the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"m", "\[InvisibleSpace]", "x"}], "+", "b"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"3f66cf9b-6eb5-439b-85af-e8a02206fb6b"],
 ", and the intersection of two such lines can be given as a function of the \
two slopes and intercepts."
}], "Text",
 CellChangeTimes->{{3.5746791429869413`*^9, 3.57467925975133*^9}, 
   3.580041991714176*^9, {3.6223055353851337`*^9, 3.6223055358777313`*^9}, {
   3.622459048863783*^9, 
   3.622459077396541*^9}},ExpressionUUID->"27dbb7e8-e58e-4eba-acca-\
4418abc5d9b3"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{
  "x", ",", "m1", ",", "m2", ",", "m3", ",", "b1", ",", "b2", ",", "b3"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.574679745295577*^9, 
  3.574679762388011*^9}},ExpressionUUID->"4d27d218-6b3b-488d-883a-\
134f65553e49"],

Cell[TextData[{
 "Use ",
 StyleBox[ButtonBox["Set",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Set"],
  FontWeight->"Bold"],
 " and not ",
 StyleBox[ButtonBox["SetDelayed",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SetDelayed"],
  FontWeight->"Bold"],
 " here because you do not want to reconstruct the model every time it is \
used."
}], "Text",
 CellChangeTimes->{{3.574679820569241*^9, 3.574679849216361*^9}, {
  3.577206142366433*^9, 3.577206145143662*^9}, {3.580042009920622*^9, 
  3.580042010870946*^9}, {3.6223055459174137`*^9, 
  3.62230557413174*^9}},ExpressionUUID->"28a50e67-3a6a-4aa2-a2cd-\
a509a9a3301c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"mdl", "[", 
    RowBox[{"x", ",", 
     RowBox[{"{", 
      RowBox[{"m1", ",", "m2", ",", "m3", ",", "b1", ",", "b2", ",", "b3"}], 
      "}"}]}], "]"}], "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"sol1", "=", " ", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"m1", " ", "x"}], " ", "+", "b1"}], "\[Equal]", 
           RowBox[{
            RowBox[{"m2", " ", "x"}], " ", "+", " ", "b2"}]}], ",", "x"}], 
         "]"}]}], ",", 
       RowBox[{"sol2", "=", " ", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"m2", " ", "x"}], " ", "+", " ", "b2"}], "\[Equal]", 
           RowBox[{
            RowBox[{"m3", " ", "x"}], " ", "+", " ", "b3"}]}], ",", "x"}], 
         "]"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"sols", "=", " ", 
       RowBox[{"Join", "[", 
        RowBox[{"sol1", ",", "sol2"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"int1", ",", "int2"}], "}"}], "=", 
       RowBox[{"x", "/.", "sols"}]}], ";", "\[IndentingNewLine]", 
      TagBox[GridBox[{
         {"\[Piecewise]", GridBox[{
            {
             RowBox[{
              RowBox[{"m1", " ", "x"}], " ", "+", " ", "b1"}], 
             RowBox[{"x", "<", "int1"}]},
            {
             RowBox[{
              RowBox[{"m2", " ", "x"}], " ", "+", " ", "b2"}], 
             RowBox[{"int1", "\[LessEqual]", " ", "x", "<", "int2"}]},
            {
             RowBox[{
              RowBox[{"m3", " ", "x"}], " ", "+", " ", "b3"}], 
             RowBox[{"int2", "\[LessEqual]", " ", "x"}]}
           },
           AllowedDimensions->{2, Automatic},
           Editable->True,
           
           GridBoxAlignment->{
            "Columns" -> {{Left}}, "ColumnsIndexed" -> {}, 
             "Rows" -> {{Baseline}}, "RowsIndexed" -> {}},
           
           GridBoxItemSize->{
            "Columns" -> {{Automatic}}, "ColumnsIndexed" -> {}, 
             "Rows" -> {{1.}}, "RowsIndexed" -> {}},
           GridBoxSpacings->{"Columns" -> {
               Offset[0.27999999999999997`], {
                Offset[0.84]}, 
               Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, "Rows" -> {
               Offset[0.2], {
                Offset[0.4]}, 
               Offset[0.2]}, "RowsIndexed" -> {}},
           Selectable->True]}
        },
        GridBoxAlignment->{
         "Columns" -> {{Left}}, "ColumnsIndexed" -> {}, 
          "Rows" -> {{Baseline}}, "RowsIndexed" -> {}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "ColumnsIndexed" -> {}, "Rows" -> {{1.}},
           "RowsIndexed" -> {}},
        GridBoxSpacings->{"Columns" -> {
            Offset[0.27999999999999997`], {
             Offset[0.35]}, 
            Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, "Rows" -> {
            Offset[0.2], {
             Offset[0.4]}, 
            Offset[0.2]}, "RowsIndexed" -> {}}],
       "Piecewise",
       DeleteWithContents->True,
       Editable->False,
       SelectWithContents->True,
       Selectable->False]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.5746793401612673`*^9, 3.5746794300942917`*^9}, {
   3.574679475283772*^9, 3.57467952729143*^9}, {3.574679568433497*^9, 
   3.574679713430958*^9}, {3.574679773533517*^9, 3.574679800075947*^9}, 
   3.574679868075815*^9, {3.57468011636021*^9, 
   3.574680135717203*^9}},ExpressionUUID->"8b29edd0-d1ad-4378-8aac-\
35a651b107dd"],

Cell[TextData[{
 "Use the model in ",
 StyleBox[ButtonBox["NonlinearModelFit",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NonlinearModelFit"],
  FontWeight->"Bold"],
 ". Use constraints with the model, and specify start values for the \
parameters estimated from the plot above."
}], "Text",
 CellChangeTimes->{{3.574679888066946*^9, 3.574679907014853*^9}, {
   3.574680158752966*^9, 3.574680203960181*^9}, 3.577206149026441*^9, {
   3.622305582939045*^9, 3.622305601716753*^9}, 
   3.622459099889743*^9},ExpressionUUID->"6818f523-76c3-4b57-bca7-\
2416991a7595"],

Cell[BoxData[
 RowBox[{"pcwsMdl", "=", 
  RowBox[{"NonlinearModelFit", "[", 
   RowBox[{"filipDat", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"mdl", "[", 
       RowBox[{"x", ",", 
        RowBox[{"{", 
         RowBox[{
         "m1", ",", "m2", ",", "m3", ",", "b1", ",", "b2", ",", "b3"}], 
         "}"}]}], "]"}], ",", 
      RowBox[{
       RowBox[{"-", "8.25"}], "<", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "b1"}], "+", "b2"}], 
        RowBox[{"m1", "-", "m2"}]], "<", 
       RowBox[{"-", "6.4"}]}], ",", 
      RowBox[{
       RowBox[{"-", "6.4"}], "<", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "b2"}], "+", "b3"}], 
        RowBox[{"m2", "-", "m3"}]], "<", 
       RowBox[{"-", "5.9"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"m1", ",", ".1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"m2", ",", "1.0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"m3", ",", ".1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"b1", ",", ".75"}], "}"}], ",", "b2", ",", 
      RowBox[{"{", 
       RowBox[{"b3", ",", ".87"}], "}"}]}], "}"}], ",", "x"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.574679983079316*^9, 3.5746799933521643`*^9}, {
   3.574680141452614*^9, 3.574680153019483*^9}, 3.57468020854642*^9, {
   3.574680415199296*^9, 3.5746804687995577`*^9}, {3.687606237924541*^9, 
   3.687606246749626*^9}, {3.6876064087605867`*^9, 3.687606446353649*^9}, 
   3.687606483559104*^9, {3.687607314204187*^9, 3.6876073796660347`*^9}, {
   3.6876076733210363`*^9, 3.687607682999806*^9}, {3.6876077662185507`*^9, 
   3.687607777369882*^9}},ExpressionUUID->"64cc78cd-610c-4ecb-b119-\
b8b117399a89"]
}, Open  ]]
}, Open  ]],

