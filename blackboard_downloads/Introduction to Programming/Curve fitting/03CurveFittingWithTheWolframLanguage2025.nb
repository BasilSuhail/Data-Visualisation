Cell[CellGroupData[{

Cell["Robust Regression", "Section",
 CellChangeTimes->{{3.574673058528323*^9, 
  3.574673067014801*^9}},ExpressionUUID->"d4cb2b22-8974-42be-a184-\
05d6deac22f7"],

Cell[TextData[{
 "The 2001 value in the data seems inconsistent with the rest of the values; \
it could have been recorded incorrectly, or it could be an outlier. In either \
case, you might want to use robust regression to reduce the influence of that \
observation on the fit. That is done in ",
 StyleBox[ButtonBox["NonlinearModelFit",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NonlinearModelFit"],
  FontWeight->"Bold"],
 " using the option ",
 StyleBox[ButtonBox["Weights",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Weights"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.57467308303856*^9, 3.574673127981382*^9}, {
  3.574673164780703*^9, 3.574673230866942*^9}, {3.57720608143335*^9, 
  3.577206085163229*^9}, {3.580041413614296*^9, 3.580041431886178*^9}, {
  3.6223052473742647`*^9, 
  3.6223052767388563`*^9}},ExpressionUUID->"4740ba42-f919-4464-a4f2-\
bbf2cc53890c"],

Cell[BoxData[
 RowBox[{"Framed", "[", 
  RowBox[{
   RowBox[{"NiceTable", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"#", ",", "14", ",", "\"\<Text\>\""}], "]"}], "&"}], "/@", 
     RowBox[{"Options", "[", "NonlinearModelFit", "]"}]}], "]"}], ",", 
   RowBox[{"RoundingRadius", "\[Rule]", " ", "8"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.574674286170529*^9, 3.5746743445137777`*^9}, 
   3.57467437723409*^9},ExpressionUUID->"4d93a40d-410d-4825-b007-\
ddd1187b2831"],

Cell["Fit using the absolute value norm.", "Text",
 CellChangeTimes->{{3.574673807470921*^9, 
  3.574673821053132*^9}},ExpressionUUID->"2630b8dd-4477-4d21-a857-\
6f23c16fff91"],

Cell[BoxData[
 RowBox[{
  RowBox[{"model2", "=", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"results", ",", 
     RowBox[{"a", "+", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"b", " ", 
        RowBox[{"(", 
         RowBox[{"t", "-", "c"}], ")"}]}]]}], ",", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b", ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "1990"}], "}"}]}], "}"}], ",", "t", ",", 
     RowBox[{"Weights", "\[Rule]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Norm", "[", 
         RowBox[{"#", ",", "1"}], "]"}], "&"}], ")"}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.574672941346868*^9, 3.574672994714348*^9}, 
   3.5746732906348343`*^9},ExpressionUUID->"3e916632-23fc-4e9d-8db7-\
91902bbb495c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"model", "[", "\"\<BestFit\>\"", "]"}], ",", 
   RowBox[{"model2", "[", "\"\<BestFit\>\"", "]"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.574673000166512*^9, 3.574673011424469*^9}, {
  3.5746732669953623`*^9, 
  3.574673284506566*^9}},ExpressionUUID->"1234d000-9907-499b-8f5f-\
81cb04c053a8"],

Cell["The results seem very similar, but they are different.", "Text",
 CellChangeTimes->{{3.5746733479452057`*^9, 3.574673364887501*^9}, 
   3.580041449708191*^9},ExpressionUUID->"468c76ed-2829-45bb-a657-\
e67d102fc738"],

