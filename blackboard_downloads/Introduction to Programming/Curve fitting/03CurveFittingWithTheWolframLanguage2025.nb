Cell["Visualizing the Results", "Section",
 CellChangeTimes->{{3.574680252930377*^9, 3.574680261590253*^9}, 
   3.580042043871429*^9, {3.632664183713135*^9, 
   3.632664184446458*^9}},ExpressionUUID->"e8442166-2f8e-436e-ac5c-\
abdd3778833c"],

Cell["\<\
The fit looks good, and you can get diagnostics from the fit.\
\>", "Text",
 CellChangeTimes->{{3.574680353821681*^9, 3.574680372851974*^9}, {
   3.6223056101241007`*^9, 3.622305610401812*^9}, 
   3.622459111186894*^9},ExpressionUUID->"2645d941-4bd7-482a-8ba6-\
30b4887feee7"],

Cell["The solution curve with the data points.", "Text",
 CellChangeTimes->{{3.5746805305682707`*^9, 
  3.574680547447209*^9}},ExpressionUUID->"8259e747-fd5b-42a0-9e1d-\
ca5d8c1c9b71"],

Cell[BoxData[
 RowBox[{"pcwsPlt", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"pcwsMdl", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", 
      RowBox[{"-", "9"}], ",", 
      RowBox[{"-", "3"}]}], "}"}], ",", 
    RowBox[{"Epilog", "\[Rule]", " ", 
     RowBox[{"{", 
      RowBox[{"Red", ",", 
       RowBox[{"Point", "[", "filipDat", "]"}]}], "}"}]}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", " ", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Piecewise Model\>\"", ",", "18", ",", "Bold"}], "]"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.574680273484634*^9, 3.574680323098893*^9}, {
   3.5746822972945423`*^9, 3.5746823017891493`*^9}, {3.574682427339418*^9, 
   3.574682461257884*^9}, 
   3.574682575943969*^9},ExpressionUUID->"fe7c8cdb-d84b-41c6-9e8b-\
7066efe5d63e"],

Cell["A look at the residuals.", "Text",
 CellChangeTimes->{{3.574680555455778*^9, 
  3.5746805654707212`*^9}},ExpressionUUID->"6869f268-6ac8-46fe-83e0-\
827d4d4843dc"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"pcwsMdl", "[", "\"\<FitResiduals\>\"", "]"}], "]"}]], "Input",
