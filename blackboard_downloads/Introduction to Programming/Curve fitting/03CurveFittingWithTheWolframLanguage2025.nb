 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Show", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"model", "[", "t", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "1993.5", ",", "2008.5"}], "}"}], ",", 
