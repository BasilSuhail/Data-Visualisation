   3.574507186523142*^9, 3.574507193114949*^9}, {3.574673843928246*^9, 
   3.574673846981533*^9}, 3.574673970084684*^9, {3.5750408907630157`*^9, 
   3.575040891996026*^9}},ExpressionUUID->"da24582c-5965-44a7-814d-\
d5e00296f888"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"model", ",", "model2"}], "]"}]], "Input",
 CellChangeTimes->{{3.574684284285429*^9, 
  3.574684293099821*^9}},ExpressionUUID->"1d7f872f-2523-4073-8930-\
00e53cc2d1e6"]
