       RowBox[{"Epilog", "\[Rule]", " ", 
        RowBox[{"{", 
         RowBox[{"Red", ",", 
          RowBox[{"Point", "[", "filipDat", "]"}]}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "\[Rule]", " ", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Spline Smoothing Model\>\"", ",", "18", ",", "Bold"}], 
         "]"}]}]}], "]"}]}], "}"}], ",", 
   RowBox[{"ImageSize", "\[Rule]", " ", 
    RowBox[{"10", " ", "72"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.5746823375925207`*^9, 3.574682399914988*^9}, {
  3.574682497818943*^9, 
  3.5746825624722767`*^9}},ExpressionUUID->"51889a06-8d3f-4545-ad7c-\
