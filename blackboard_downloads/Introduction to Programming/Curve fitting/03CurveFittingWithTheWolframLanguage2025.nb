Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"6247f443-ec3b-49a2-9adc-2533f2978933"],

Cell[CellGroupData[{

Cell["Nonlinear Model Fitting", "Section",
 CellChangeTimes->{{3.5745044005719633`*^9, 
  3.574504409712223*^9}},ExpressionUUID->"8bb11b48-a07f-4be3-af96-\
1cce11556ce2"],

Cell["\<\
Linear models are fitted using linear algebra, a process that is, in most \
cases, robust and fast. Nonlinear models, on the other hand, require the \
construction of a merit function and then minimizing the merit function based \
on varying a set of parameters present in the model. This process can be slow \
and often requires more attention on the part of the statistician.\
\>", "Text",
 CellChangeTimes->{{3.5745044850869083`*^9, 3.574504634547186*^9}, {
  3.580041129076997*^9, 
  3.5800411489633427`*^9}},ExpressionUUID->"0a0ae0f2-ca77-49d5-82aa-\
a2a5b89ba6ad"],

Cell[TextData[{
 "The Excel file you will use for your first example was obtained from the US \
Department of Energy\[CloseCurlyQuote]s website: ",
 ButtonBox["www.eia.doe.gov/cneaf/electricity/epm/table1_1.html",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://www.eia.doe.gov/cneaf/electricity/epm/table1_1.html"], None}],
 ". It contains data on net power generation by energy source for the years \
1994 through 2008. This dataset has been replaced by a more detailed set of \
files on the current website, but is included in the datasets for the course."
}], "Text",
 CellChangeTimes->{{3.574505085652219*^9, 3.574505149533918*^9}, {
  3.574506014968981*^9, 3.574506015703294*^9}, {3.58004116693321*^9, 
  3.580041203476956*^9}, {3.63223483066219*^9, 
  3.6322348336674967`*^9}},ExpressionUUID->"26fdc1e7-5bff-45a9-9b3c-\
7f055ccdaa82"],

Cell[BoxData[
 RowBox[{"FileNames", "[", "\"\<*.xls\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.574505164408719*^9, 
  3.57450517919808*^9}},ExpressionUUID->"2038aa0f-d527-4ee9-9a91-\
6fe4b9628b0f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"electricData", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<epmxlfile1_1.xls\>\"", ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Data\>\"", ",", "1"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.574505205347787*^9, 3.574505238901173*^9}, {
  3.574505441202291*^9, 
  3.5745054460567017`*^9}},ExpressionUUID->"d291c9e5-d797-4d23-bcec-\
227cfae4b313"],

Cell[BoxData[
 RowBox[{"Dimensions", "[", "electricData", "]"}]], "Input",ExpressionUUID->"384a228c-ac97-409d-88f9-3c433f36b0c7"],

Cell["\<\
You might want to look at the first few rows to get a sense of how it looks \
in the Wolfram Language.\
\>", "Text",
 CellChangeTimes->{{3.6223828350680857`*^9, 
  3.622382842965824*^9}},ExpressionUUID->"f44ee6f3-be28-4522-b7a6-\
e4ad4e328fee"],

Cell[BoxData[
 RowBox[{"Take", "[", 
  RowBox[{"electricData", ",", "5"}], "]"}]], "Input",ExpressionUUID->\
"8057354a-28b8-4b93-a0f6-b3ed2cafeb3f"],

Cell[BoxData[
 RowBox[{"TableView", "[", 
  RowBox[{"electricData", ",", 
   RowBox[{"ImageSize", "\[Rule]", " ", 
    RowBox[{"14", " ", "72"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.574505525940783*^9, 3.57450555937285*^9}, {
  3.5745055907887383`*^9, 
  3.5745056001635647`*^9}},ExpressionUUID->"c4ef4dca-afa0-4d14-9b0a-\
c506382446a1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"90601779-32cf-428b-8328-38b098b16e15"],

Cell[CellGroupData[{

Cell["Excel Spreadsheets: Filtering the Data", "Section",
 CellChangeTimes->{{3.580041220401463*^9, 
  3.580041221129387*^9}},ExpressionUUID->"0f1cc0d9-9f5a-4e41-ab9f-\
5a54fe8a1621"],

Cell["\<\
You will look at renewables up through the year 2010. First, determine the \
number of the column containing the data you want to use.\
\>", "Text",
 CellChangeTimes->{{3.6322348571562643`*^9, 
  3.632234866817325*^9}},ExpressionUUID->"304ee9a4-5de3-413f-922c-\
e5f39910cf66"],

Cell["The information you want is in the ninth column.", "Text",
 CellChangeTimes->{{3.580041246376918*^9, 3.5800412517847157`*^9}, {
  3.6322348708812103`*^9, 
  3.632234871129012*^9}},ExpressionUUID->"f5fbf865-2e3e-4f16-b65e-\
1717c8bddf32"],

Cell[BoxData[
 RowBox[{"Position", "[", 
  RowBox[{"electricData", ",", "\"\<Other Renewables[4]\>\""}], 
  "]"}]], "Input",ExpressionUUID->"dac17ad0-481d-4039-94ab-617b98eaa835"],

Cell["\<\
Referring to your table above, you see you want rows 4 through 57 and columns \
1 and 9.\
\>", "Text",
 CellChangeTimes->{{3.574672766264118*^9, 3.5746727664150963`*^9}, 
   3.580041294993176*^9, {3.632234911782844*^9, 
   3.632234924566309*^9}},ExpressionUUID->"1f8867cf-059c-46e0-a35c-\
450378a4605f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"renewables", "=", 
   RowBox[{"electricData", "[", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"4", ";;", "57"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "9"}], "}"}]}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"TableView", "[", "renewables", "]"}]}], "Input",
 CellChangeTimes->{{3.5745060668095284`*^9, 
  3.5745060677778683`*^9}},ExpressionUUID->"5a19b516-2b49-460a-9976-\
7f12460e414f"],

Cell["\<\
Using pattern matching, convert the strings to numbers and extract only the \
yearly totals.\
\>", "Text",
 CellChangeTimes->{{3.508228291077619*^9, 3.508228305555793*^9}, 
   3.574506168714428*^9, 
   3.632234929494019*^9},ExpressionUUID->"d9e3709a-24d1-4173-b7b7-\
c86b70253d8b"],

Cell[BoxData[
 RowBox[{"yearTots", "=", 
  RowBox[{"Cases", "[", 
   RowBox[{"renewables", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"_", "?", "NumericQ"}], "|", "\"\<Total\>\""}], ",", 
      RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.574506168715003*^9, {3.574506230932575*^9, 
   3.574506237361744*^9}},ExpressionUUID->"c39515c8-e306-4c02-b3ad-\
19a0ffd3b0d3"],

Cell["\<\
Using replacement rules, \[OpenCurlyDoubleQuote]clean up\
\[CloseCurlyDoubleQuote] the rows corresponding to the years 2006, 2007, and \
2008.\
\>", "Text",
 CellChangeTimes->{{3.574672794518976*^9, 3.574672803765607*^9}, 
   3.580041308335267*^9, {3.6322349349095907`*^9, 
   3.632234935413892*^9}},ExpressionUUID->"fda402bd-286a-4cf8-b24d-\
11b7d8b650b7"],

Cell[BoxData[
 RowBox[{"results", "=", 
  RowBox[{"ReplacePart", "[", 
   RowBox[{"yearTots", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "3"}], ",", "1"}], "}"}], "\[Rule]", " ", "2006."}], ",", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "2"}], ",", "1"}], "}"}], "\[Rule]", "2007."}], ",", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "1"}], "}"}], "\[Rule]", "2008."}]}], 
     "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.574506266162421*^9, 
  3.5745062971690397`*^9}},ExpressionUUID->"377b4441-4384-4dfc-bc35-\
7af6e25b3df8"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"28b8e16d-5836-425b-965a-8786fc7e2112"],

Cell[CellGroupData[{

Cell["Looking at the Data", "Section",
 CellChangeTimes->{{3.57450643500622*^9, 
  3.5745064405881023`*^9}},ExpressionUUID->"5ca5a95a-74d2-4d86-a6ec-\
fd514c2c38c0"],

Cell["\<\
Now that you have cleaned up the data, you can look at the form of the data \
and determine a model. Apart from the year 2001, this looks a lot like \
exponential growth.\
\>", "Text",
 CellChangeTimes->{{3.574506445524371*^9, 3.574506478851351*^9}, {
   3.574506518378014*^9, 3.574506544937533*^9}, {3.580041334192031*^9, 
   3.580041354863049*^9}, 3.580223825581058*^9, {3.63223495960693*^9, 
   3.632234964820323*^9}},ExpressionUUID->"38c3218e-9516-43b0-865b-\
d37e1c5b6650"],

Cell[BoxData[
 RowBox[{"dataplot", "=", 
  RowBox[{"ListLinePlot", "[", 
   RowBox[{"results", ",", 
    RowBox[{"Mesh", "\[Rule]", " ", "All"}], ",", 
    RowBox[{"PlotMarkers", "\[Rule]", " ", "Automatic"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.574506483668887*^9, 3.574506504387985*^9}, {
  3.574506587467176*^9, 3.574506615481696*^9}, {3.574506737061947*^9, 
  3.574506744894079*^9}},ExpressionUUID->"da77e67a-856e-4132-9b7a-\
e440f862a73c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"d50f1da3-7f9b-4cba-be37-6c291626d446"],

Cell[CellGroupData[{

Cell["NonlinearModelFit", "Section",
 CellChangeTimes->{{3.574506794317659*^9, 
  3.574506800827299*^9}},ExpressionUUID->"1c13a1cc-825e-4ac6-9013-\
9ac857fe86cc"],

Cell[TextData[{
 "Use ",
 StyleBox[ButtonBox["NonlinearModelFit",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NonlinearModelFit"],
  FontWeight->"Bold"],
 " to see if this gives a reasonable fit to the data. Note the translation of \
the variable by c, to get the curve to fit. Raising ",
 Cell[BoxData[
  FormBox["\[ExponentialE]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "239ddbd6-e893-44c5-813f-73ceb9769da8"],
 " to a large power is going to give misleading information."
}], "Text",
 CellChangeTimes->{{3.5772060104750233`*^9, 3.5772060225526876`*^9}, {
   3.580041389456324*^9, 3.580041390813552*^9}, {3.622305198632719*^9, 
   3.622305213614544*^9}, 
   3.622458932508492*^9},ExpressionUUID->"b37c92bc-9aaa-4100-8070-\
b6a56ecb7ef6"],

Cell[BoxData[
 RowBox[{"?", "NonlinearModelFit"}]], "Input",
 CellChangeTimes->{{3.574506807526965*^9, 
  3.574506815300214*^9}},ExpressionUUID->"b818500f-ed1b-4cc9-8092-\
ef672ea0a2dc"],

Cell["Note the use of start values for the translation value c.", "Text",
 CellChangeTimes->{{3.5745068563793287`*^9, 3.57450687747307*^9}, 
   3.574683984474003*^9, 
   3.577206068181199*^9},ExpressionUUID->"fa3b77d1-1d6c-46cf-8d7c-\
6d8c455b0815"],

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"NonlinearModelFit", "[", 
   RowBox[{"results", ",", 
    RowBox[{"a", "+", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"b", " ", 
       RowBox[{"(", 
        RowBox[{"t", "-", "c"}], ")"}]}]]}], ",", 
    RowBox[{"{", 
     RowBox[{"a", ",", "b", ",", 
      RowBox[{"{", 
       RowBox[{"c", ",", "1990"}], "}"}]}], "}"}], ",", "t"}], 
   "]"}]}]], "Input",ExpressionUUID->"9a2bea8a-1805-4ff7-9e6c-0fa20110dea7"],

Cell[BoxData[
 RowBox[{"model", "[", "\"\<BestFit\>\"", "]"}]], "Input",ExpressionUUID->"ad04708e-ab6d-436d-9a3a-74cbf067acb5"],

Cell["The fit appears to be a good one.", "Text",
 CellChangeTimes->{{3.574506892772797*^9, 
  3.5745069074086447`*^9}},ExpressionUUID->"de236e3c-134b-455c-847c-\
184a0144238f"],

Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"model", "[", "t", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "1993.5", ",", "2008.5"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Pink", ",", "Thick"}], "}"}]}], ",", 
     RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}], ",", 
   "\[IndentingNewLine]", "dataplot"}], "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.574506628554311*^9, 3.574506635368815*^9}, {
  3.5745067094473867`*^9, 3.574506710071299*^9}, {3.574506762790502*^9, 
  3.574506764324902*^9}},ExpressionUUID->"61f5bd73-54f6-4ee3-8f89-\
af8a0a8fa488"]
