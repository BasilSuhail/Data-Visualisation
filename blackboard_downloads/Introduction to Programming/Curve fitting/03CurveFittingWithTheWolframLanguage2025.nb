Cell[CellGroupData[{

Cell["Alternate Models", "Section",
 CellChangeTimes->{{3.574502558415092*^9, 
  3.574502562485944*^9}},ExpressionUUID->"53335798-4a09-41ee-8bd8-\
86baa35985bc"],

Cell["\<\
Having decided on a model, simplify things by constructing a model using only \
the necessary variables.\
\>", "Text",
 CellChangeTimes->{{3.574502566990966*^9, 3.574502579533845*^9}, {
   3.574502617734868*^9, 3.57450264642071*^9}, 3.580040959970099*^9, {
   3.632234779359974*^9, 
   3.632234779773649*^9}},ExpressionUUID->"2ab75f00-1240-427a-b298-\
1dda4d2b0150"],

Cell[BoxData[
 RowBox[{"wtEst3", "=", " ", 
  RowBox[{"LinearModelFit", "[", 
   RowBox[{
    RowBox[{"wrkDat", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", 
       RowBox[{"{", 
        RowBox[{"3", ",", "4", ",", "6"}], "}"}]}], "]"}], "]"}], ",", 
    RowBox[{"Flatten", "[", 
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox["L3", 
        RowBox[{"Range", "[", 
         RowBox[{"0", ",", "2"}], "]"}]], ",", "Ht"}], "}"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"L3", ",", "Ht"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.574502656057993*^9, 
  3.574502720644541*^9}},ExpressionUUID->"97fdad5c-3f05-46a3-b92e-\
d28a0d4c402b"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"wtEst3", "[", "\"\<FitResiduals\>\"", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.574502733885272*^9, 
  3.5745027558269663`*^9}},ExpressionUUID->"e0988ddc-7773-4376-b32e-\
a5e043d6c61d"],

Cell[TextData[{
 "A large adjusted ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["R", "2"], " "}], TraditionalForm]],ExpressionUUID->
  "6afa6126-a0ea-41ac-b0fe-a34b22d377bf"],
 "does not necessarily indicate the Gauss\[Dash]Markov conditions are \
satisfied."
}], "Text",
 CellChangeTimes->{{3.574503268805533*^9, 3.574503325827383*^9}, {
  3.5800409951764708`*^9, 
  3.5800410234622803`*^9}},ExpressionUUID->"60afedbc-ee25-4f5e-bc5d-\
3a9a804d3c05"],

Cell[BoxData[
 RowBox[{"Style", "[", 
  RowBox[{
   RowBox[{"Column", "[", 
