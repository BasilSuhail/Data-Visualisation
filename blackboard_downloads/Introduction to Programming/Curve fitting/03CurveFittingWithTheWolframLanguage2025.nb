    "}"}], ",", 
   RowBox[{"Frame", "\[Rule]", " ", "All"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.574682936822132*^9, 3.574682939440086*^9}, {
   3.574682983644923*^9, 3.574683266101386*^9}, {3.5746833031803837`*^9, 
   3.574683343299754*^9}, 3.574683401275166*^9, {3.5746834338679113`*^9, 
   3.574683646093451*^9}, {3.57468368467948*^9, 3.574683804906548*^9}, {
   3.5750412784935293`*^9, 
