     RowBox[{
      RowBox[{"wtEst3", "[", "\"\<StudentizedResiduals\>\"", "]"}], ",", 
      RowBox[{"NormalDistribution", "[", 
       RowBox[{"\[Mu]", ",", "\[Sigma]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<TestDataTable\>\"", ",", "\"\<FittedDistribution\>\"", 
        ",", "\"\<TestConclusion\>\""}], "}"}]}], "]"}], "]"}], 
   ",", "\"\<Text\>\""}], "]"}]], "Input",
 CellChangeTimes->{{3.574502856984379*^9, 3.5745029174151897`*^9}, {
  3.574502950991835*^9, 3.574502951549765*^9}, {3.5745029985019283`*^9, 
  3.5745030063815193`*^9}, {3.57450307926871*^9, 3.574503093034471*^9}, {
  3.574503157465416*^9, 3.5745032086401253`*^9}, {3.574503578354843*^9, 
