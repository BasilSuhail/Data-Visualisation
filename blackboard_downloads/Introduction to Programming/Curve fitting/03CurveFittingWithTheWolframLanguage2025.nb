Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"17e33b8e-1dee-4d97-be8d-c05e576f4348"],

Cell[CellGroupData[{

Cell[" A Linear Approach", "Section",
 CellChangeTimes->{{3.574680680981542*^9, 
  3.5746806879477177`*^9}},ExpressionUUID->"05630819-c92d-4b77-a5ec-\
7e43bd4de0f9"],

Cell[TextData[{
 "The piecewise model used previously is not a linear model, as it is not \
expressed as a linear combination of basis vectors. If you knew precisely the \
locations of the intersections of the lines, you could write a set of basis \
vectors that would work, but you do not. Take advantage of smoothing splines. \
By using nonuniform knot spacings, you can generate linear ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]], "InlineMath",ExpressionUUID->
  "b79d7d25-0d7c-4d25-a028-6727f9dd7f0c"],
 "-splines (NURBS) that will do what you want, using the Wolfram Language\
\[CloseCurlyQuote]s ",
 StyleBox[ButtonBox["BSplineBasis",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/BSplineBasis"],
  FontWeight->"Bold"],
 " function."
}], "Text",
 CellChangeTimes->{{3.574680732403054*^9, 3.574680820792549*^9}, {
   3.5746808692311974`*^9, 3.5746809025908213`*^9}, {3.574680938445945*^9, 
   3.574681102017577*^9}, 3.5772061625938377`*^9, 3.580042073246985*^9, {
   3.580042116958172*^9, 3.580042155580949*^9}, 3.580223937411078*^9, {
   3.580223988162397*^9, 3.580224044047029*^9}, {3.622305628427618*^9, 
   3.622305691870812*^9}, 3.622382900744323*^9, {3.6224591313809547`*^9, 
   3.6224591383230124`*^9}},ExpressionUUID->"5f002dda-13b0-46a4-aa5c-\
4202a0208654"],

Cell["\<\
Visualize the data again, and pay particular attention to the positions of \
the abrupt changes of direction in the data.\
\>", "Text",
 CellChangeTimes->{{3.574681128225272*^9, 3.574681168848213*^9}, {
   3.580042249146688*^9, 3.5800422493855867`*^9}, 
   3.6224696353867807`*^9},ExpressionUUID->"3a754009-2bda-4036-a679-\
2a2948f92d27"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"filipDat", ",", 
   RowBox[{"GridLines", "\[Rule]", " ", "Automatic"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.574681175336493*^9, 
  3.5746811907451143`*^9}},ExpressionUUID->"126da5d8-2315-432b-930c-\
21d18fcdd28c"],

Cell[TextData[{
 "The data goes approximately from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "9"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "48c4d3e1-f076-4b06-a647-4349eee272f1"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "3"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "deb77688-55e5-40e3-939a-e0a8d6169d64"],
 " with sharp changes in direction around ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "7.2`"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "41214c17-f4c0-49c7-b0a6-8d849d9853e8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "6.1`"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "8764935f-16bb-4065-b6f4-411c389f2f6a"],
 "."
}], "Text",
 CellChangeTimes->{{3.574681220919291*^9, 3.574681277701482*^9}, {
  3.580042306335499*^9, 3.580042306656219*^9}, {3.6224591485847588`*^9, 
  3.622459165868649*^9}},ExpressionUUID->"461070b2-9e1d-458e-b1ee-\
e6eaeeadcabc"],

Cell["Generate the spline basis functions.", "Text",
 CellChangeTimes->{{3.574681462358906*^9, 
  3.574681480728606*^9}},ExpressionUUID->"c74a2fb8-c72e-4559-9b26-\
ad310685f06f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"knts", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "9"}], ",", 
     RowBox[{"-", "7.2"}], ",", 
     RowBox[{"-", "6.1"}], ",", 
     RowBox[{"-", "3"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"splns", "=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"BSplineBasis", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "knts"}], "}"}], ",", "i", ",", "x"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "0", ",", "1"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.574681294237273*^9, 
  3.574681376139887*^9}},ExpressionUUID->"dcf0f3e5-7890-454e-a9d6-\
a361db380863"],

Cell["Visualize the result.", "Text",
 CellChangeTimes->{{3.57468148591217*^9, 
  3.57468149173575*^9}},ExpressionUUID->"cfb2a075-be3e-48e4-9c58-\
8840f2b1ac9f"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{"splns", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "9"}], ",", 
     RowBox[{"-", "3"}]}], "}"}], ",", 
   RowBox[{"GridLines", "\[Rule]", " ", "Automatic"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.574681390607081*^9, 
  3.574681429743784*^9}},ExpressionUUID->"cd836838-9d42-4d8e-824d-\
b0bc1d2e8713"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"f6eec09f-ad2a-4ddc-9427-334e08dea3a7"],

Cell[CellGroupData[{

Cell["A Utility Function and a Fit", "Section",
 CellChangeTimes->{{3.5746815804637337`*^9, 
  3.574681593589241*^9}},ExpressionUUID->"ea87f359-df6b-44dd-8119-\
1a07d6a31114"],

Cell[TextData[{
 "Here is a function that will make things easier. It creates the basis for \
the fit and then applies ",
 StyleBox[ButtonBox["LinearModelFit",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/LinearModelFit"],
  FontWeight->"Bold"],
 " to the data and the basis set. You can use this as a model to create a \
function of your own to handle the sorts of cases you work with most often."
}], "Text",
 CellChangeTimes->{{3.574681605621543*^9, 3.574681652267874*^9}, 
   3.577206172616789*^9, {3.5800424092580767`*^9, 3.5800424384853077`*^9}, {
   3.580224190779595*^9, 3.5802242016654997`*^9}, {3.6223057050872297`*^9, 
   3.622305714978516*^9}},ExpressionUUID->"407e19a0-436c-476b-8841-\
afce72c28211"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SplineModel", "[", 
   RowBox[{"data_", ",", "knots_", ",", 
    RowBox[{"dom", ":", 
     RowBox[{"{", 
      RowBox[{"x_", ",", "xmin_", ",", "xmax_"}], "}"}]}], ",", "bs_List", ",",
     "deg_Integer"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"basis", ",", "allKnots", ",", "n"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"n", "=", 
      RowBox[{
       RowBox[{"Length", "[", "knots", "]"}], "+", "2"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"basis", "=", 
      RowBox[{"bs", "~", "Join", "~", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"BSplineBasis", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"deg", ",", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", "xmin", "}"}], ",", "knots", ",", 
               RowBox[{"{", "xmax", "}"}]}], "]"}]}], "}"}], ",", "i", ",", 
           "x"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", 
           RowBox[{"n", "-", "3"}]}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"data", ",", "basis", ",", "x"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{
  3.5746820862477207`*^9},ExpressionUUID->"04ea510d-bd22-4282-b5d2-\
06bc9a025850"],

Cell["Fit the data.", "Text",
 CellChangeTimes->{{3.574682205014883*^9, 
  3.5746822084943953`*^9}},ExpressionUUID->"c6940965-eff9-49dd-983d-\
03b4ef8155b4"],

Cell[BoxData[
 RowBox[{"smoothFit", "=", 
  RowBox[{"SplineModel", "[", 
   RowBox[{"filipDat", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "7.2"}], ",", 
      RowBox[{"-", "6.1"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "9"}], ",", 
      RowBox[{"-", "3"}]}], "}"}], ",", 
    SuperscriptBox["x", 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", "1"}], "]"}]], ",", "1"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5746821052672377`*^9, 
  3.574682119334504*^9}},ExpressionUUID->"054769a2-c23b-40d0-a3f4-\
024b43b9d63e"]
}, Open  ]]
}, Open  ]],

