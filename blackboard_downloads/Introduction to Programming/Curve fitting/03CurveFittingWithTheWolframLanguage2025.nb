Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"641c35fd-a890-4fdd-bf87-a512c1660bd4"],

Cell[CellGroupData[{

Cell["Fitting Theoretical Models", "Section",
 CellChangeTimes->{{3.5745156543870077`*^9, 
  3.574515662255093*^9}},ExpressionUUID->"871fd417-b580-4628-904d-\
ce5b34fd9319"],

Cell[TextData[{
 "In many disciplines\[Dash]physics, chemistry, and engineering, for example\
\[Dash]one needs to test theoretical models. The Wolfram Language provides a \
very nice framework for doing that sort of thing. For example, a first-order \
approximation to the velocity of a rocket at time ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]], "InlineMath",ExpressionUUID->
  "dc0d7f68-2bb9-4629-aea8-05884095389a"],
 " should satisfy the solution to the differential equation:"
}], "Text",
 CellChangeTimes->{{3.574515691798398*^9, 3.574515764572612*^9}, {
   3.5745157958753443`*^9, 3.574515880825392*^9}, {3.580041501932238*^9, 
   3.580041556105547*^9}, {3.580041588010236*^9, 3.5800415925292673`*^9}, 
   3.580223849511405*^9, {3.622382863657496*^9, 3.622382871692624*^9}, {
   3.6224589490751057`*^9, 
   3.622458968361978*^9}},ExpressionUUID->"5fe7e76a-32a8-4797-9d54-\
baa134957d39"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    FractionBox[
     StyleBox["dv",
      FontSlant->"Italic"], 
     StyleBox["dt",
      FontSlant->"Italic"]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[Beta]", " ", "s"}], 
      RowBox[{
       SubscriptBox["m", "0"], "\[Minus]", 
       RowBox[{"\[Beta]", " ", "t", " "}]}]], "\[Minus]", "g"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    SubscriptBox["v", "0"], "=", "0"}]}], TraditionalForm]], "Text",
 CellChangeTimes->{{3.5745159395121193`*^9, 3.574516049294113*^9}, {
   3.574516097660942*^9, 3.574516178155155*^9}, {3.622469101357067*^9, 
   3.622469116555518*^9}, {3.622469178997698*^9, 3.622469181259261*^9}, 
   3.622469480912709*^9, 3.622469893986992*^9, {3.622469978131933*^9, 
   3.622470008880024*^9}, {3.622470060342648*^9, 3.6224700721404257`*^9}, {
   3.622472535347628*^9, 3.622472683187334*^9}, {3.6224727321869335`*^9, 
   3.622472753044134*^9}, 3.622472794726491*^9, {3.62247286160069*^9, 
   3.6224730276552386`*^9}, {3.622562864984652*^9, 3.622562865493453*^9}, {
   3.622562925141635*^9, 3.622562934633963*^9}},
 TextAlignment->Center,ExpressionUUID->"5148b54d-3007-46e7-9889-65ab001075fd"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]], "InlineMath",ExpressionUUID->
  "9c25dc87-77bd-4144-be2a-b68aee2fb437"],
 " is acceleration due to gravity, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "0"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "80b1aaa0-0e88-49c5-bb99-1a200c66ea1c"],
 " is initial mass, ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]], "InlineMath",ExpressionUUID->
  "c56cec02-3626-438a-8896-b3ebe890132f"],
 " is exhaust velocity, and ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "a46b66cd-68fc-4f12-bc7d-b997d5b14672"],
 " is fuel consumption."
}], "Text",
 CellChangeTimes->{{3.622469234300742*^9, 3.622469286721045*^9}, {
   3.622469321288767*^9, 3.62246933194108*^9}, 
   3.6224698739919643`*^9},ExpressionUUID->"a3f6c1ed-a0e7-4eb4-9bae-\
e4b1e18f88ae"],

Cell[TextData[{
 "This model has a symbolic solution, so you could take that approach, but \
more sophisticated models may not have a symbolic solution. You can \
illustrate that situation and assume there is no symbolic solution available. \
Confidence is assumed for estimates of all the parameters except for ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "58146bf8-a76a-4b86-89b3-b7173f345ca5"],
 ". You can attempt to estimate ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "90f505ed-afff-4ea0-bd4c-0cd1f37ba64a"],
 " from observed (in this case simulated) data."
}], "Text",
 CellChangeTimes->{{3.574516255960846*^9, 3.574516346565818*^9}, {
   3.574516403989689*^9, 3.57451653956909*^9}, {3.5800417051596203`*^9, 
   3.580041727189763*^9}, {3.5802238705197144`*^9, 3.58022387096595*^9}, 
   3.632235870860175*^9},ExpressionUUID->"6c02d0f9-c551-4c9c-a29a-\
ecbcdaacb8af"],

Cell["Bring in your data.", "Text",
 CellChangeTimes->{{3.5745166085210533`*^9, 3.574516615591178*^9}, 
   3.6322358756258497`*^9},ExpressionUUID->"ba77597b-74d9-4801-94a1-\
f6b187398c47"],

Cell[BoxData[
 RowBox[{"FileNames", "[", "\"\<*.dat\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.57451663900394*^9, 3.574516650703594*^9}, {
  3.574516746861292*^9, 
  3.5745167472289248`*^9}},ExpressionUUID->"d674093f-1a3b-447b-af1a-\
2f3398469278"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rcktDat", "=", " ", 
   RowBox[{"Import", "[", "\"\<rcktDat.dat\>\"", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.5745167612698812`*^9, 3.574516808043118*^9}, 
   3.574517233889352*^9},ExpressionUUID->"ae2d0776-2e2f-49cd-9efd-\
17930dfacc10"],

Cell[BoxData[
 RowBox[{"Dimensions", "[", "rcktDat", "]"}]], "Input",
 CellChangeTimes->{{3.5745168140273323`*^9, 
  3.57451682156325*^9}},ExpressionUUID->"614fdca7-1d1b-4553-b216-\
6be344fbf942"],

Cell[BoxData[
 RowBox[{"InputForm", "/@", 
  RowBox[{"rcktDat", "[", 
   RowBox[{"[", 
    RowBox[{";;", "3"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.574516842664218*^9, 3.574516851810845*^9}, {
  3.574517194123784*^9, 
  3.5745172154581337`*^9}},ExpressionUUID->"06ddce1a-b740-4324-90b2-\
97942df47c56"],

Cell[BoxData[
 RowBox[{"rcktDat", "=", 
  RowBox[{"Flatten", "[", 
   RowBox[{
    RowBox[{"rcktDat", "/.", 
     RowBox[{"{", 
      RowBox[{"str_String", "\[RuleDelayed]", " ", 
       RowBox[{"ToExpression", "@", 
        RowBox[{"StringSplit", "[", 
         RowBox[{"str", ",", "\"\<,\>\""}], "]"}]}]}], "}"}]}], ",", "1"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.574517280388726*^9, 3.574517354086685*^9}, {
  3.574517472075526*^9, 3.574517630191543*^9}, {3.5745177758550463`*^9, 
  3.5745177950274963`*^9}, {3.574517862659707*^9, 
  3.574517917384624*^9}},ExpressionUUID->"c71cf133-697c-46d2-91cc-\
1686214ec0cd"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"c6f019ec-ea47-4af8-a735-ba99b72857ef"],

Cell[CellGroupData[{

Cell["Fitting Theoretical Models", "Section",
 CellChangeTimes->{{3.574518089718223*^9, 
  3.574518100027025*^9}},ExpressionUUID->"3b418c5e-23c6-4fcd-b50e-\
dbf7057cc998"],

Cell[TextData[{
 "Begin by creating a ",
 StyleBox[ButtonBox["ParametricFunction",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ParametricFunction"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.574518572560833*^9, 3.574518588062974*^9}, 
   3.57720612038972*^9, {3.622305440300445*^9, 
   3.622305455931445*^9}},ExpressionUUID->"d2627782-8637-4524-ace0-\
86b9222f217c"],

Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{"ParametricNDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["v", "\[Prime]",
         MultilineFunction->None], "[", "t", "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", "9.8`"}], "+", 
        FractionBox[
         RowBox[{"700", " ", "\[Beta]"}], 
         RowBox[{"10000", "-", 
          RowBox[{"t", " ", "\[Beta]"}]}]]}]}], ",", 
      RowBox[{
       RowBox[{"v", "[", "0", "]"}], "\[Equal]", "0"}]}], "}"}], ",", "v", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "60"}], "}"}], ",", 
    RowBox[{"{", "\[Beta]", "}"}]}], "]"}]}]], "Input",ExpressionUUID->\
"bb0727a9-0f0e-42d5-a240-fcea956bb5ff"],

Cell[TextData[{
 "Use the parametric function in ",
 StyleBox[ButtonBox["NonlinearModelFit",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NonlinearModelFit"],
  FontWeight->"Bold"],
 ". Note the positions of the parameter ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "982bfbeb-c19b-466e-8b83-901e156c5027"],
 " and the variable ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]], "InlineMath",ExpressionUUID->
  "f10c90f2-4163-453d-bb2e-8b383221caf6"],
 "."
}], "Text",
 CellChangeTimes->{{3.5745186193826103`*^9, 3.57451863251793*^9}, {
   3.574518739898943*^9, 3.574518768730098*^9}, 3.577206123869795*^9, {
