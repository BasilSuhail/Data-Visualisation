Cell[CellGroupData[{

Cell["Piecewise Models", "Section",
 CellChangeTimes->{{3.574678416112908*^9, 
  3.5746784224924803`*^9}},ExpressionUUID->"09c87ba8-6f4d-4843-817e-\
1de7355e1a53"],

Cell["\<\
Many of the datasets included with the course come from the government agency \
NIST.\
\>", "Text",
 CellChangeTimes->{{3.574678622849008*^9, 3.574678697285439*^9}, 
   3.580041892394658*^9},ExpressionUUID->"f8356a43-4d13-4c81-a863-\
18f59c533f73"],

Cell[TextData[ButtonBox["www.itl.nist.gov/div898/strd/general/dataarchive.\
html",
 BaseStyle->"Hyperlink",
 ButtonData:>{
   URL["http://www.itl.nist.gov/div898/strd/general/dataarchive.html"], 
   None}]], "Subitem",
 CellDingbat->None,
 CellChangeTimes->{
  3.5746787053807917`*^9},ExpressionUUID->"0ba6a59f-82d3-4f96-82c4-\
8d3c5c472433"],

Cell["\<\
The data in the set used here was collected by A. Filippelli at NIST, but no \
information is provided as to what was measured. The NIST site does indicate \
the set was obtained from observation, and is not a generated set.\
\>", "Text",
 CellChangeTimes->{
  3.574678583426879*^9, {3.574678804932343*^9, 3.5746788660011883`*^9}, 
   3.580041915682555*^9, {3.6223055087612143`*^9, 3.622305509575041*^9}, {
   3.6224590279913197`*^9, 
   3.6224590285457373`*^9}},ExpressionUUID->"88bf9989-46bc-4952-9e3e-\
85d57e43306e"],

