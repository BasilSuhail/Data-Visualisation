         ",", "\"\<Text\>\""}], "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
         RowBox[{"StringForm", "[", 
          RowBox[{"\"\<Adjusted R squared `1`\>\"", ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{"smoothFit", "[", "\"\<AdjustedRSquared\>\"", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"5", ",", "6"}], "}"}]}], "]"}]}], "]"}], 
         ",", "\"\<Text\>\""}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"pcwsMdl", "[", "\"\<FitResiduals\>\"", "]"}], ",", 
         RowBox[{"PlotLabel", "\[Rule]", " ", 
