Cell[CellGroupData[{

Cell["Fitting a Linear Model", "Section",
 CellChangeTimes->{{3.574114789196525*^9, 
  3.574114795299457*^9}},ExpressionUUID->"fa25f87f-8e0c-4641-9669-\
71ec035fb789"],

Cell["\<\
Your first opportunity to put your function to the test. This is a list of \
the data files working directory.\
\>", "Text",
 CellChangeTimes->{{3.574114837581251*^9, 3.5741148533866034`*^9}, {
  3.574496356393961*^9, 3.5744963966807947`*^9}, {3.632234245291184*^9, 
  3.6322342487447433`*^9}},ExpressionUUID->"bafeb45e-3cc1-416f-8a1f-\
d723d859d32c"],

Cell[BoxData[
 RowBox[{"NiceTable", "[", 
  RowBox[{"FileNames", "[", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.574114811843225*^9, 
  3.5741148238045063`*^9}},ExpressionUUID->"541e860b-2b1c-4389-94ac-\
ae3de01e9d4e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"8f9a053d-1947-4529-8780-c3d1cd227e44"],

Cell[CellGroupData[{

Cell["Import the Data", "Section",
 CellChangeTimes->{{3.574114875230433*^9, 3.574114878590362*^9}, 
   3.574115196032618*^9},ExpressionUUID->"e9443229-fe2a-435a-8cef-\
41c63940a49e"],

Cell["\<\
This brings in the data and arranges it according to species. \
\>", "Text",
 CellChangeTimes->{{3.574114887390745*^9, 3.574114904358383*^9}, 
   3.5741151960330153`*^9, {3.574496464095224*^9, 3.574496493134637*^9}, {
   3.580040633312669*^9, 
   3.580040636415156*^9}},ExpressionUUID->"dee687ff-eafd-44c2-834e-\
fe70830accf1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fshDat", "=", 
   RowBox[{"GatherBy", "[", 
    RowBox[{
     RowBox[{"Import", "[", 
      RowBox[{"\"\<fishdata.txt\>\"", ",", "\"\<Table\>\""}], "]"}], ",", 
     "First"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.574114909338085*^9, 3.574114961580284*^9}, {
   3.574115103468276*^9, 3.5741151051147738`*^9}, 
   3.5741151960335197`*^9},ExpressionUUID->"be99688b-89a4-46d3-9a04-\
2c3f45a9cd62"],

Cell["\<\
This gives you a count of the various species. The last listed has the \
largest number of observations, so you can work with that.\
\>", "Text",
 CellChangeTimes->{{3.574496507310375*^9, 3.5744965213820887`*^9}, {
   3.5744965980218487`*^9, 3.574496626787125*^9}, 3.580040658816084*^9, {
   3.63223428592922*^9, 
   3.6322342931103888`*^9}},ExpressionUUID->"babc243f-1334-48a1-bbb8-\
88c363afce58"],

Cell[BoxData[
 RowBox[{"Map", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"First", "[", 
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
      RowBox[{"Length", "[", "#", "]"}]}], "}"}], "&"}], ",", "fshDat"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.57411496826933*^9, 3.574115004907393*^9}, 
   3.574115196036139*^9},ExpressionUUID->"e9f1a4b8-b891-407d-a569-\
e9a6c75fd47e"],

Cell["\<\
This gets the data for the last listed species and drops the species index, \
leaving only the working data.\
\>", "Text",
 CellChangeTimes->{{3.574496633975686*^9, 3.574496679481823*^9}, 
   3.580040666334323*^9},ExpressionUUID->"4719eac0-379c-4c26-ab25-\
438efc01f659"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fshDat", "[", 
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "All", ",", 
     RowBox[{"2", ";;"}]}], "]"}], "]"}], "//", "Short"}]], "Input",
 CellChangeTimes->{{3.574115250356256*^9, 
  3.574115285764599*^9}},ExpressionUUID->"15f2037d-ea2a-4ae5-aa41-\
77e8a24d8693"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"3468700f-abdc-48c3-94e2-e081a217f893"],

Cell[CellGroupData[{

Cell["Formatting the Data", "Section",
 CellChangeTimes->{{3.574496744852371*^9, 3.574496751408409*^9}, {
  3.574497739928976*^9, 
  3.5744977500075912`*^9}},ExpressionUUID->"433e6a1c-9180-42a5-8b90-\
c40cfc3502f4"],

Cell[TextData[{
 "This is the same dataset you used in the first notebook of the course. The \
column headings are species, weight, length 1, length 2, length 3, height, \
thickness. You have already eliminated the species index. You will estimate \
the weight of a fish from its physical dimensions. Therefore, the other \
issues you need to adjust are moving the weight to the end of the list and \
dealing with the height and weight. Height and weight are given as a percent \
of the third length, L3. You do this using ",
 StyleBox[ButtonBox["ReplaceAll",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ReplaceAll"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.574496867323578*^9, 3.574497123831191*^9}, 
   3.5772058595377007`*^9, {3.580040685568224*^9, 3.580040711166605*^9}, {
   3.5800407599337683`*^9, 3.580040787741004*^9}, {3.632234332279922*^9, 
   3.6322343469722652`*^9}, {3.632234392642536*^9, 
   3.632234441453957*^9}},ExpressionUUID->"781be7d1-1c47-439e-aca7-\
69f50240bdf0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"wrkDat", "=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"fshDat", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "All", ",", 
        RowBox[{"2", ";;"}]}], "]"}], "]"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "wt_", ",", "L1_", ",", "L2_", ",", "L3_", ",", "ht_", ",", "thk_"}], 
        "}"}], "\[RuleDelayed]", " ", 
       RowBox[{"{", 
        RowBox[{"L1", ",", "L2", ",", "L3", ",", 
         RowBox[{"ht", " ", 
          RowBox[{"L3", "/", "100"}]}], ",", 
         RowBox[{"thk", " ", 
          RowBox[{"L3", "/", "100"}]}], ",", "wt"}], "}"}]}], "}"}]}], 
    ")"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.574115250356256*^9, 3.5741153905115232`*^9}, {
  3.5741154243389673`*^9, 
  3.574115459684136*^9}},ExpressionUUID->"21b1d7b3-276c-4440-a3b6-\
3a789632da0b"],

Cell[TextData[{
 "Begin by looking at the weight as a function of the ",
 Cell[BoxData[
  FormBox["L3", $CellContext`MR]],ExpressionUUID->
  "445a5b60-91c9-4ba6-b0c6-3dd4a4b0b277"],
 " value."
}], "Text",
 CellChangeTimes->{{3.574497144486403*^9, 3.57449719009284*^9}, 
   3.577205869282778*^9, 
   3.632234445729154*^9},ExpressionUUID->"a8cf3998-6446-43d6-940d-\
6c0e4db19376"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"wrkDat", "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", 
       RowBox[{"-", "1"}]}], "}"}]}], "]"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.5741155183675013`*^9, 3.574115529130734*^9}, {
  3.574115575615367*^9, 
  3.574115586806817*^9}},ExpressionUUID->"920c9dee-a479-43af-a372-\
eb3c71f71a95"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"db7a94c3-670c-40f4-a767-a4fdb345d480"],

Cell[CellGroupData[{

Cell["Fitting the Data", "Section",
 CellChangeTimes->{{3.5744972500056143`*^9, 
  3.574497256531371*^9}},ExpressionUUID->"8e26a24b-24d4-4479-a6ae-\
2a6d02866502"],

Cell[BoxData[
 RowBox[{"?", "LinearModelFit"}]], "Input",
 CellChangeTimes->{{3.5744972923631973`*^9, 
  3.57449729913105*^9}},ExpressionUUID->"b1983ff8-105a-4c42-9ece-\
6b5ee82cfe78"],

Cell["\<\
This fits the data to a cubic polynomial. Give the fitted model a name for \
use in subsequent investigations.\
\>", "Text",
 CellChangeTimes->{{3.574497263139873*^9, 3.574497285331064*^9}, {
  3.574497340499401*^9, 3.574497340649673*^9}, {3.574497383248187*^9, 
  3.574497415023428*^9}, {3.632234475847549*^9, 
  3.632234486316608*^9}},ExpressionUUID->"fda3942e-72d4-4337-b564-\
7b4ffcab321f"],

Cell[BoxData[
 RowBox[{"wtEst1", "=", 
  RowBox[{"LinearModelFit", "[", 
   RowBox[{
    RowBox[{"wrkDat", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", 
       RowBox[{"{", 
        RowBox[{"3", ",", 
         RowBox[{"-", "1"}]}], "}"}]}], "]"}], "]"}], ",", 
    SuperscriptBox["x", 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", "3"}], "]"}]], ",", "x"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5741154810393*^9, 3.574115498698224*^9}, {
   3.57411559594335*^9, 3.574115624326818*^9}, 
   3.574497358501102*^9},ExpressionUUID->"b34052ca-cf27-4724-975e-\
e64ae3bd74b8"],

Cell["Visualize the fit.", "Text",
 CellChangeTimes->{{3.5744974254640217`*^9, 
  3.574497430735421*^9}},ExpressionUUID->"d17ff7cb-a40b-4def-bf4e-\
67ee6ca0ba46"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"wtEst1", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "8", ",", "48"}], "}"}], ",", 
   RowBox[{"Epilog", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{"Point", "[", 
      RowBox[{"wrkDat", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{"3", ",", 
           RowBox[{"-", "1"}]}], "}"}]}], "]"}], "]"}], "]"}], "}"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.574115634076379*^9, 
  3.574115705483819*^9}},ExpressionUUID->"56a3738a-d9f6-4c61-9774-\
ced39abd7b1e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"a27c41c6-5e1b-41f3-be6a-f43ed57b1b37"],

Cell[CellGroupData[{

Cell["Getting Information about the Fit", "Section",
 CellChangeTimes->{{3.5744974491772223`*^9, 3.5744974639506283`*^9}, 
   3.5800408168292427`*^9},ExpressionUUID->"cd804064-1c7a-460f-8374-\
37120c318834"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["FittedModel",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/FittedModel"],
  FontWeight->"Bold"],
 " contains a great deal of information. You can get a list of what is \
available using \[OpenCurlyDoubleQuote]Properties\[CloseCurlyDoubleQuote] as \
an argument to the model."
}], "Text",
 CellChangeTimes->{{3.5744974752478333`*^9, 3.5744975302288513`*^9}, {
  3.577205886765415*^9, 3.577205896773682*^9}, {3.632234510405738*^9, 
  3.63223455088139*^9}},ExpressionUUID->"30ad97f2-2ef9-4cc0-9909-\
f599650cee63"],

Cell[BoxData[
 RowBox[{"Framed", "[", 
  RowBox[{
   RowBox[{"NiceTable", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"#", ",", "14", ",", "\"\<Text\>\""}], "]"}], "&"}], "/@", 
     RowBox[{"wtEst1", "[", "\"\<Properties\>\"", "]"}]}], "]"}], ",", 
   RowBox[{"RoundingRadius", "\[Rule]", " ", "12"}], ",", 
   RowBox[{"FrameMargins", "\[Rule]", " ", "15"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.5741157285843487`*^9, 3.5741157449353333`*^9}, {
   3.574497543181094*^9, 3.5744975485807734`*^9}, {3.574674134839808*^9, 
   3.57467414089755*^9}, 3.5746741720725822`*^9, 3.5746744055535707`*^9, {
   3.5746749966449137`*^9, 3.574675036745542*^9}, {3.574675080496773*^9, 
   3.57467511091928*^9}},ExpressionUUID->"4d70a1e5-962b-4363-81b2-\
be8d0db2ee0d"],

Cell["\<\
Look at the ANOVA table and adjusted R-squared values for your fit.\
\>", "Text",
 CellChangeTimes->{{3.574497798663603*^9, 3.5744978248213654`*^9}, {
  3.5746751546314507`*^9, 3.574675162620782*^9}, {3.5802237419926157`*^9, 
  3.580223742247006*^9}, {3.632234547233645*^9, 
  3.632234559736865*^9}},ExpressionUUID->"f0e448f5-3842-4f2a-8108-\
03081eaff5b4"],

Cell[BoxData[
 RowBox[{"wtEst1", "[", 
  RowBox[{"{", 
   RowBox[{"\"\<ANOVATable\>\"", ",", "\"\<AdjustedRSquared\>\""}], "}"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.574115759751979*^9, 
  3.574115801631776*^9}},ExpressionUUID->"f8268a8f-a36d-42e3-ad2e-\
189f322601c0"],

Cell[TextData[{
 "Visualize the fit with mean prediction bands. If the join of the function \
with the prediction bands is used directly in the ",
 StyleBox[ButtonBox["Plot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Plot"],
  FontWeight->"Bold"],
 " function, it will have to be wrapped in ",
 StyleBox[ButtonBox["Evaluate",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Evaluate"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.574497835100936*^9, 3.57449792725882*^9}, {
   3.5772059140672913`*^9, 3.577205917515894*^9}, 3.580223755319927*^9, {
   3.632234569952384*^9, 
   3.6322345942437983`*^9}},ExpressionUUID->"5af71cc4-1119-49a7-a8a3-\
2b8fce4155d8"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"expr", "=", " ", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"wtEst1", "[", "x", "]"}], "}"}], ",", 
       RowBox[{"wtEst1", "[", "\"\<MeanPredictionBands\>\"", "]"}]}], "]"}]}],
     "}"}], ",", 
   RowBox[{"Plot", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "8", ",", "48"}], "}"}], ",", 
     RowBox[{"Epilog", "\[Rule]", " ", 
      RowBox[{"{", 
       RowBox[{"Point", "[", 
        RowBox[{"wrkDat", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", 
           RowBox[{"{", 
            RowBox[{"3", ",", 
             RowBox[{"-", "1"}]}], "}"}]}], "]"}], "]"}], "]"}], "}"}]}], ",", 
     RowBox[{"Filling", "\[Rule]", " ", 
      RowBox[{"{", 
       RowBox[{"2", "\[Rule]", " ", 
        RowBox[{"{", "3", "}"}]}], "}"}]}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.57411583335773*^9, 
  3.574116032256115*^9}},ExpressionUUID->"8ba72136-5ae0-4463-b7da-\
cbc2a8107133"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"4b0701a9-fcc3-4c5b-a3d8-f5abcf173d14"],

Cell[CellGroupData[{

Cell["Alternate Models", "Section",
 CellChangeTimes->{{3.574497975090172*^9, 
  3.57449798041779*^9}},ExpressionUUID->"28c065a2-2b34-469d-a918-\
ec34515991cb"],

Cell["\<\
In the previous example, you selected two columns from the data and a single \
predictor variable for the model. You can use the full dataset and give a \
select set of basis vectors for your model.\
\>", "Text",
 CellChangeTimes->{{3.5745003800232153`*^9, 3.57450050338663*^9}, {
  3.580040883898766*^9, 3.5800408946171227`*^9}, {3.6322346185364447`*^9, 
  3.6322346262855597`*^9}},ExpressionUUID->"25b85f44-269d-4730-b521-\
00fb84e6c8e0"],

Cell["Fit the same model as before, using the full dataset.", "Text",
 CellChangeTimes->{{3.5745005144742603`*^9, 3.57450053052983*^9}, 
   3.5800409025529327`*^9, 
   3.6325095345872307`*^9},ExpressionUUID->"21e76774-8c4b-40b4-baf4-\
930ab14df94b"],

Cell[BoxData[
 RowBox[{"wtEst2", "=", 
  RowBox[{"LinearModelFit", "[", 
   RowBox[{"wrkDat", ",", 
    SuperscriptBox["L3", 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", "3"}], "]"}]], ",", 
    RowBox[{"{", 
     RowBox[{"L1", ",", "L2", ",", "L3", ",", "Ht", ",", "Thck"}], "}"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.5744980194273367`*^9, 3.574498098975614*^9}, {
  3.574500788052578*^9, 
  3.5745007892046947`*^9}},ExpressionUUID->"6476bab1-52f1-4727-8735-\
36009af195e2"],

Cell["\<\
Note the only difference is the way in which you ask for the result.\
\>", "Text",
 CellChangeTimes->{{3.574500541873575*^9, 3.574500599767983*^9}, {
  3.622305028759059*^9, 
  3.622305029063016*^9}},ExpressionUUID->"e73e160b-15c9-4d2b-ad1a-\
35c57d6794c4"],

Cell[BoxData[
 RowBox[{"Column", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"wtEst1", "[", "L3", "]"}], ",", 
    RowBox[{"wtEst2", "[", 
     RowBox[{"L1", ",", "L2", ",", "L3", ",", "Ht", ",", "Thck"}], "]"}]}], 
   "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.574498105938689*^9, 3.574498192677371*^9}, {
  3.574498229204459*^9, 3.5744982446365223`*^9}, {3.574500793964696*^9, 
  3.574500794788652*^9}},ExpressionUUID->"9f075a00-1c5c-497f-9fce-\
d573fb2ca9f8"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"c4b2788e-4a88-4b9d-8631-e237cc69df7b"],

Cell[CellGroupData[{

Cell["Alternate Models", "Section",
 CellChangeTimes->{{3.574500642631023*^9, 
  3.5745006466145353`*^9}},ExpressionUUID->"6c0d7688-42f1-4f04-8a0c-\
df051a82257a"],

Cell[TextData[{
 "Using the information from the previous slide, you can fit several models \
at the same time using the ",
 StyleBox[ButtonBox["Table",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Table"],
  FontWeight->"Bold"],
 " function. Assigning a name to the list will allow you to get diagnostics \
for the various fits."
}], "Text",
 CellChangeTimes->{{3.574500665893959*^9, 3.574500672301814*^9}, {
   3.574502052175449*^9, 3.574502212991612*^9}, 3.577205929272284*^9, 
   3.580040922011023*^9, {3.632234646358753*^9, 3.632234654487761*^9}, {
   3.6322347079239388`*^9, 
   3.63223471920094*^9}},ExpressionUUID->"96e3e438-4519-4f1b-8ddd-\
ddabcebe7466"],

Cell[BoxData[
 RowBox[{"multiFit", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{
