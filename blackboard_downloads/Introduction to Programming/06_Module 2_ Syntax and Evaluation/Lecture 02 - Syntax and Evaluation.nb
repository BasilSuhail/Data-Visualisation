   RowBox[{"a", "=", "b"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.645511396163367*^9, 
  3.64551141232352*^9}},ExpressionUUID->"75ee893c-a72d-47a4-a6b7-\
e964b228b2b0"],

Cell["\<\
Once the variable has a meaning, it will change color.  Anything that is \
recognized by the Wolfram system behaves that way.\
\>", "Text",
 CellChangeTimes->{{3.6455116277541947`*^9, 3.645511651041649*^9}, {
  3.668315939227244*^9, 
  3.668315944776969*^9}},ExpressionUUID->"404bc347-9823-4d69-a414-\
8f1e2432fa50"],

Cell["\<\
Once the assignment has been made, it will automatically be replaced with the \
assigned value every time the symbol is used.\
\>", "Text",
 CellChangeTimes->{{3.614332083855304*^9, 3.6143321544279547`*^9}, {
  3.614948844715786*^9, 
  3.614948856259158*^9}},ExpressionUUID->"3b702c7a-cf6d-440d-b242-\
