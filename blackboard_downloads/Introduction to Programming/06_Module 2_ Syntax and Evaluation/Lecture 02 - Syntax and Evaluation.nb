Cell[CellGroupData[{

Cell["Expressions", "Section",
 CellChangeTimes->{{3.643624458850933*^9, 
  3.643624460179108*^9}},ExpressionUUID->"fb284d7c-37e8-49ef-b375-\
5136e19d73e9"],

Cell[TextData[{
 "The name of a function or command in the Wolfram language is an ",
 StyleBox["Expression",
  FontWeight->"Bold"],
 ".  The structure of an expression is this:"
}], "Text",
 CellChangeTimes->{{3.643626002838129*^9, 3.643626036252493*^9}, {
  3.64362661222541*^9, 
  3.64362662820795*^9}},ExpressionUUID->"af18c472-53b9-4d1f-8d2b-\
174b1d28de5e"],

Cell["Head[argument1, argument2 ...]", "Program",
 CellChangeTimes->{{3.643626633773725*^9, 3.6436266725537653`*^9}},
 FontSize->24,ExpressionUUID->"25fe2fd6-ea54-447e-980a-e868839223c7"],

Cell["The three main features of an expression:", "Text",
 CellChangeTimes->{{3.643626897069912*^9, 3.643626910469119*^9}, {
  3.643626987306776*^9, 
  3.643626993090797*^9}},ExpressionUUID->"ec7b65c2-a005-4f9d-905b-\
24a258287a5f"],

Cell[CellGroupData[{

Cell["The Head.", "Item",
 CellChangeTimes->{{3.643626999515953*^9, 
  3.643627007610347*^9}},ExpressionUUID->"bf6cd646-1a60-432d-a087-\
039d4d663601"],

Cell["\<\
The head is the name of the expression (for example Integrate), and usually \
describes what the function does.  All the words are capitalised, a format \
called CamelCase.\
\>", "Subitem",
 CellChangeTimes->{{3.643626729189237*^9, 3.643626756051059*^9}, {
  3.643626865722381*^9, 3.643626876606994*^9}, {3.643626980483158*^9, 
  3.643626982963078*^9}},ExpressionUUID->"029ba41c-f3c1-48ee-a753-\
d1a24b939988"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Square brackets.", "Item",
 CellChangeTimes->{{3.643626999515953*^9, 
  3.643627031298973*^9}},ExpressionUUID->"b8da5a90-4d2f-4490-9ee3-\
5bacaf98db8f"],

Cell["All expressions use square brackets straight after the head.", "Subitem",
 CellChangeTimes->{{3.643627017785521*^9, 
  3.643627028889638*^9}},ExpressionUUID->"e1e8b479-c862-4f61-9335-\
4a41f26533ee"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comma separated arguments.", "Item",
 CellChangeTimes->{{3.643626999515953*^9, 
  3.643627042081168*^9}},ExpressionUUID->"edf7d244-303a-4ad4-bd2e-\
e200f25e161f"],

Cell["\<\
Put the arguments inside the square brackets, and separate them with commas.\
\>", "Subitem",
 CellChangeTimes->{{3.643627078048681*^9, 3.6436270976554747`*^9}, {
  3.810206885025817*^9, 
  3.8102068850260143`*^9}},ExpressionUUID->"3d550aac-5666-4b64-9c7a-\
77fbeadef988"]
}, Open  ]],

Cell["\<\
There are some functions such as N which do not use full words. \
\>", "Item",
 CellChangeTimes->{{3.643627078048681*^9, 3.6436270976554747`*^9}, {
  3.810206888297203*^9, 
  3.810206908791456*^9}},ExpressionUUID->"c953fec9-41bd-4f70-8fc5-\
522f7c1e273a"],

Cell[TextData[{
 "The final part of an expression is how to evaluate it!  Unlike the Wolfram \
Alpha query, you must press ",
 StyleBox["\[ShiftKey]\[EnterKey]",
  FontSize->24],
 StyleBox[" ",
  FontSize->18],
 "to evaluate the cell."
}], "Text",
 CellChangeTimes->{{3.643627127135009*^9, 
  3.643627166380925*^9}},ExpressionUUID->"ce970dee-b44c-4bae-b6cb-\
6bffcaced108"],

