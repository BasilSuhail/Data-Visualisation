947e097181bd"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox["1", "9"], " ", 
   RowBox[{"(", 
    RowBox[{"3", "+", "7"}], ")"}], " ", "8"}], TraditionalForm]], "Output",
 CellChangeTimes->{
  3.657369285981188*^9, {3.657370346398271*^9, 
   3.657370354649061*^9}},ExpressionUUID->"931ebeac-2ab3-4fbe-b4e7-\
