  3.645511362429755*^9}},ExpressionUUID->"53410982-2315-4586-afac-\
076d5d64571f"],

Cell["This is the equivalent of using \[OpenCurlyQuote]=\[CloseCurlyQuote]", \
"Text",
 CellChangeTimes->{{3.645511366717288*^9, 
  3.645511386201725*^9}},ExpressionUUID->"cc64402a-d32e-421d-9566-\
d3a4240260f7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"a", "=", "2"}], ";"}]], "Input",
 CellChangeTimes->{{3.6455113892550797`*^9, 3.645511389730435*^9}, 
   3.657368813818845*^9},ExpressionUUID->"a8e0ac00-fb12-4cbf-bd22-\
da7cc6acd83c"],

Cell[BoxData["a"], "Input",
 CellChangeTimes->{{3.6455113914170237`*^9, 
  3.645511392853531*^9}},ExpressionUUID->"3857c426-232a-49e1-861a-\
a497f382caa3"],

Cell["\<\
Note that the semicolon after a = 2 suppresses the output to the screen.\
\>", "Text",
 CellChangeTimes->{{3.65736881779921*^9, 3.657368843471449*^9}, 
   3.810208090697647*^9},ExpressionUUID->"a62f3180-4a32-41ee-ae31-\
