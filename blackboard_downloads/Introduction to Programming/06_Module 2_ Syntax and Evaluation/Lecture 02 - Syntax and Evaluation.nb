Cell["Options", "Section",
 CellChangeTimes->{{3.645511272454775*^9, 
  3.645511273253503*^9}},ExpressionUUID->"5868cc67-2e5f-4bcb-90d1-\
c8308fe3b677"],

Cell[TextData[{
 "Some functions have named optional arguments, which are called options in \
",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ". These are given in the form of a rule ",
 StyleBox["name\[Rule]value", "Program"],
 ". "
}], "Text",
 CellChangeTimes->{{3.625768631781088*^9, 3.625768732675602*^9}, {
  3.625768782492803*^9, 3.6257687968119597`*^9}, {3.6257691602738247`*^9, 
  3.625769172889694*^9}, {3.637939455386013*^9, 
  3.6379394693305235`*^9}},ExpressionUUID->"3e84039e-53a5-4bda-9abc-\
cae95cdfa14f"],

Cell[TextData[{
 "For example, to specify the image size of a plot, use the option ",
 StyleBox[ButtonBox["ImageSize",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ImageSize"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.625768734355775*^9, 3.625768752060411*^9}, {
  3.6257688043080063`*^9, 
  3.625768825375474*^9}},ExpressionUUID->"9da8dfa9-d631-4b12-be60-\
e1c5ff8c8ce8"],

