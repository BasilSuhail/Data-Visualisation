Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"59d520f3-93ab-4df7-a947-a2cd09e6e25b"],

Cell[CellGroupData[{

Cell["Basic Arithmetic", "Section",
 CellChangeTimes->{{3.613925608693695*^9, 
  3.613925614853345*^9}},ExpressionUUID->"06e5581c-9d01-4ea2-9fbe-\
2df884577e5b"],

Cell[TextData[{
 "In general, arithmetic in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " is performed in the same way as in all computer algebra systems."
}], "Text",
 CellChangeTimes->{{3.559903926006233*^9, 3.559903982388598*^9}, {
  3.559904988158255*^9, 3.559904999017911*^9}, {3.56803753362116*^9, 
  3.568037546163741*^9}},ExpressionUUID->"dac33492-da52-4ef6-aca6-\
949400f20c0a"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     RowBox[{
      StyleBox["x", "TI"], "+", 
      StyleBox["y", "TI"], "+", 
      StyleBox["z", "TI"]}], "\<\"add\"\>"},
    {
     RowBox[{"-", 
      StyleBox["x", "TI"]}], "\<\"minus\"\>"},
    {
     RowBox[{
      StyleBox["x", "TI"], "-", 
      StyleBox["y", "TI"]}], "\<\"subtract\"\>"},
    {
     InterpretationBox["\<\"\!\(\*
StyleBox[\\\"\\\\\\\"x y z\\\\\\\"\\\", \\\"TI\\\", StripOnInput->False]\) or \
\!\(\* StyleBox[\\\"\\\\\\\"x*y*z\\\\\\\"\\\", \\\"TI\\\", \
StripOnInput->False]\)\"\>",
      StringForm["`1` or `2`", 
       Style["x y z", "TI"], 
       Style["x*y*z", "TI"]],
      Editable->False], "\<\"multiply\"\>"},
    {
     InterpretationBox["\<\"\\!\\(\\*StyleBox[\\\"\\\\\\\"x\[ThinSpace]/\
\[ThinSpace]y\\\\\\\"\\\", \\\"TI\\\", Rule[StripOnInput, False]]\\)\"\>",
      StringForm["`1`", 
       Style["x\[ThinSpace]/\[ThinSpace]y", "TI"]],
      Editable->False], "\<\"divide\"\>"},
    {
     InterpretationBox["\<\"\\!\\(\\*StyleBox[\\\"\\\\\\\"x\\\\\\\"\\\", \
\\\"TI\\\", Rule[StripOnInput, False]]\\)^\\!\\(\\*StyleBox[\\\"\\\\\\\"y\\\\\
\\\"\\\", \\\"TI\\\", Rule[StripOnInput, False]]\\)\"\>",
      StringForm["`1`^`2`", 
       Style["x", "TI"], 
       Style["y", "TI"]],
      Editable->False], "\<\"power\"\>"},
    {
     InterpretationBox["\<\"\\!\\(\\*StyleBox[\\\"\\\\\\\"x\\\\\\\"\\\", \
\\\"TI\\\", Rule[StripOnInput, False]]\\)(\\!\\(\\*StyleBox[\\\"\\\\\\\"y\\\\\
\\\"\\\", \\\"TI\\\", Rule[StripOnInput, False]]\\)\[VeryThinSpace]+\
\[VeryThinSpace]\\!\\(\\*StyleBox[\\\"\\\\\\\"z\\\\\\\"\\\", \\\"TI\\\", \
Rule[StripOnInput, False]]\\))\"\>",
      StringForm["`1`(`2`\[VeryThinSpace]+\[VeryThinSpace]`3`)", 
       Style["x", "TI"], 
       Style["y", "TI"], 
       Style["z", "TI"]],
      Editable->False], "\<\"grouping\"\>"}
   },
   AutoDelete->False,
   BaseStyle->{FontFamily -> "Times"},
   GridBoxAlignment->{"Columns" -> {{Left}}},
   GridBoxBackground->{"Columns" -> {{
        RGBColor[1, 1, 0.85]}}},
   GridBoxDividers->{
    "ColumnsIndexed" -> {1 -> GrayLevel[0.5]}, "RowsIndexed" -> {2 -> {
         Thickness[Tiny], 
         GrayLevel[0.85]}, 3 -> {
         Thickness[Tiny], 
         GrayLevel[0.85]}, 4 -> {
         Thickness[Tiny], 
         GrayLevel[0.85]}, 5 -> {
         Thickness[Tiny], 
         GrayLevel[0.85]}, 6 -> {
         Thickness[Tiny], 
         GrayLevel[0.85]}, 7 -> {
         Thickness[Tiny], 
         GrayLevel[0.85]}}},
   GridBoxFrame->{"Columns" -> False, "Rows" -> {{True}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
   GridBoxSpacings->{"Columns" -> {{2}}, "Rows" -> {{0.8}}}],
  "Grid"]], "DisplayFormula",
 CellChangeTimes->{{3.637938871404973*^9, 3.637938876463713*^9}},
 ShowStringCharacters->
  False,ExpressionUUID->"7210bea1-e492-40e4-97be-d7c719fef672"],

Cell[CellGroupData[{

Cell["Breakout Rooms", "Subsection",
 CellChangeTimes->{{3.810207915971355*^9, 
  3.810207918416118*^9}},ExpressionUUID->"757175d2-7c4c-46cf-afa4-\
c806870a9065"],

Cell["\<\
Suppose that a bacterium doubles every 20 minutes. How many bacteria do you \
have after a week? (Compare that to the number of atoms in the Universe - \
natural language input!)\
\>", "Text",
 CellChangeTimes->{{3.810207921419366*^9, 
  3.810207992464291*^9}},ExpressionUUID->"744d8fea-06c0-40e3-8b12-\
6e06988dec0c"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"baed51c6-c71e-4de1-a6d1-f187509d8dd1"],

Cell[CellGroupData[{

Cell["Basic Arithmetic", "Section",
 CellChangeTimes->{{3.613925608693695*^9, 
  3.613925614853345*^9}},ExpressionUUID->"7a8cd174-558b-421a-ab82-\
ee3d06b72419"],

Cell[CellGroupData[{

Cell["Multiplication", "Subsection",
 CellChangeTimes->{{3.562868926454133*^9, 
  3.56286893225065*^9}},ExpressionUUID->"7b255325-bfc8-4a9b-b49d-\
dd7b4f4635e9"],

Cell[TextData[{
 "Multiplication can be entered either with the ",
 Cell[BoxData[
  FormBox["*", TraditionalForm]],ExpressionUUID->
  "2b60718d-9284-4547-9fe9-928cdf01087c"],
 " operator or by placing factors next to one another."
}], "Text",
 CellChangeTimes->{
  3.563788549037581*^9, 3.615724723092031*^9, {3.615726754872268*^9, 
   3.615726757497262*^9}, 3.615726829426318*^9},
 CellTags->
  "Getting Started",ExpressionUUID->"0f89bd10-f980-4c44-88ab-d75a0a0ba2e1"],

Cell[BoxData[
 RowBox[{"2", "*", "3"}]], "Input",
 CellTags->
  "Getting Started",ExpressionUUID->"57a71f62-3802-442c-90e9-93da310bbbea"],

Cell[TextData[{
 "When you type a single space between two numbers, ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " will automatically convert that space to a traditional-looking \
multiplication symbol."
}], "Text",
 CellTags->
  "Getting Started",ExpressionUUID->"52a26eac-7d3d-4a8d-ac7e-b0f7cf679632"],

Cell[BoxData[
 RowBox[{"2", " ", "3"}]], "Input",
 CellTags->
  "Getting Started",ExpressionUUID->"cb79ba26-558c-4451-ada4-897de4dca24b"],

Cell[TextData[{
 "If you write an expression with a number followed by a symbol, ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " will interpret this as multiplication. It is a good idea, however, to use \
explicit spaces to indicate multiplication."
}], "Text",
 CellChangeTimes->{{3.5680375746819153`*^9, 3.568037576825082*^9}},
 CellTags->
  "Getting Started",ExpressionUUID->"c67c17ee-f0c3-46a8-bf6a-a51e8947dceb"],

Cell[BoxData[
 RowBox[{"2", "x"}]], "Input",
 CellTags->
  "Getting Started",ExpressionUUID->"19958870-62de-4f43-b3b9-dc3579e01052"],

Cell[BoxData["xy"], "Input",
 CellChangeTimes->{{3.564227487666707*^9, 
  3.564227488001707*^9}},ExpressionUUID->"aa9f5aeb-e6b1-4326-a15e-\
0b63884f2967"],

Cell[BoxData[
 RowBox[{"x", " ", "y"}]], "Input",
 CellChangeTimes->{{3.5642274895547066`*^9, 
  3.564227490241707*^9}},ExpressionUUID->"4b2db54e-0b06-4e0e-8fcf-\
a7ca5bbd231f"],

Cell[TextData[{
 "Note that two symbols written together must have an explicit space between \
them for the expression to be interpreted as multiplication. ",
 StyleBox["xy", "MR"],
 " is a symbol containing two characters; ",
 StyleBox["x y", "MR"],
 " is the product of two single-letter symbols."
}], "Text",
 CellTags->
  "Getting Started",ExpressionUUID->"27dfb9ec-4e0b-4785-a767-f0c554d64ac9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Exercises", "Subsection",
