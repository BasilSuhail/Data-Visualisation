Cell[CellGroupData[{

Cell[TextData[ButtonBox["Streams",
 BaseStyle->"Link",
 ButtonData->"paclet:ref/Streams"]], "Subsection",
 CellChangeTimes->{{3.637649465310731*^9, 3.6376494713021593`*^9}, {
  3.637649734458076*^9, 3.63764975345186*^9}, {3.637943298043532*^9, 
  3.6379433070061154`*^9}},ExpressionUUID->"fadd3755-5baf-42fb-aa08-\
6c6b8a54298f"],

Cell[TextData[{
 "Streams are a much lower-level way of dealing with importing and exporting \
data. A stream can be opened to a file, then data can be added within the \
file. This is more flexible than ",
 StyleBox[ButtonBox["Export",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Export"],
  FontWeight->"Bold"],
 " because ",
 StyleBox[ButtonBox["Streams",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Streams"],
  FontWeight->"Bold"],
 " can access inside the file, whereas ",
 StyleBox[ButtonBox["Export",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Export"],
  FontWeight->"Bold"],
 " can only overwrite an existing file."
}], "Text",
 CellChangeTimes->{{3.637650158498827*^9, 3.63765017412092*^9}, {
  3.637650337179008*^9, 3.637650383389933*^9}, {3.637943318252473*^9, 
  3.637943406801353*^9}},ExpressionUUID->"9bdbcf08-a971-4368-a0da-\
a7aa1b5ca8f4"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

