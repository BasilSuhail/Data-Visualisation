Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"879ba6f0-c383-4070-b811-71368821e285"],

Cell[CellGroupData[{

Cell["Expressions", "Section",
 CellChangeTimes->{{3.643624458850933*^9, 
  3.643624460179108*^9}},ExpressionUUID->"d8283cae-af1c-4a1f-b6e7-\
b0e120964fc5"],

Cell["\<\
There are a lot of ways the Wolfram language can be formatted, but behind \
these is always an expression.  Let\[CloseCurlyQuote]s look at some examples.\
\
\>", "Text",
 CellChangeTimes->{{3.645335305456567*^9, 3.645335326102675*^9}, {
   3.645335392284685*^9, 3.645335401060336*^9}, 3.645335852584146*^9, {
   3.645874795691392*^9, 
   3.645874814817285*^9}},ExpressionUUID->"87f32a94-4a50-4555-8d03-\
3cd0a586ce47"],

Cell[BoxData[
 RowBox[{"1", "+", "1"}]], "Input",
 CellChangeTimes->{{3.645335402894727*^9, 
  3.645335403572985*^9}},ExpressionUUID->"23179852-d67c-4371-8d7a-\
ab6b49537adb"],

Cell["This is a shorthand for ", "Text",
 CellChangeTimes->{{3.645335408485247*^9, 
  3.64533541393989*^9}},ExpressionUUID->"9815f067-9562-45e6-b9f2-\
4bfdb726ada0"],

Cell[BoxData[
 RowBox[{"Plus", "[", 
  RowBox[{"1", ",", "1"}], "]"}]], "Input",
 CellChangeTimes->{{3.645335415582148*^9, 
  3.64533541942869*^9}},ExpressionUUID->"1c82340a-9c11-4c50-a390-\
d74f6aa8ba72"],

Cell["and you can get to that by using the tool FullForm.  ", "Text",
 CellChangeTimes->{{3.645335424299664*^9, 3.64533545690674*^9}, 
   3.657366349384877*^9},ExpressionUUID->"312bbf72-1790-4dd9-8117-\
96680cd83b59"],

Cell[CellGroupData[{

Cell["FullForm", "Subsection",
 CellChangeTimes->{{3.6573663547825546`*^9, 
  3.657366357821162*^9}},ExpressionUUID->"af7fb7e8-22c8-4ea0-b2af-\
e12de3ced60f"],

Cell["Let\[CloseCurlyQuote]s try it:", "Text",
 CellChangeTimes->{
  3.657366352808861*^9},ExpressionUUID->"cba321c8-f287-4a03-bc6c-\
44db88809d6b"],

Cell[BoxData[
 RowBox[{"FullForm", "[", 
  RowBox[{"1", "+", "1"}], "]"}]], "Input",
 CellChangeTimes->{{3.645335445141121*^9, 
  3.6453354479879637`*^9}},ExpressionUUID->"c7b7b8eb-4fea-49d8-8dff-\
133a2f01dea1"],

Cell["\<\
This will give an unexpected result because of the way the Wolfram language \
evaluates.  The inside of the brackets happens first, then the outside.  So \
the sequence of FullForm[1+1] is that 1+1 evaluates to get 2, then we get the \
FullForm of that.  To stop it there is tool called Hold, which stops \
evaluation:\
\>", "Text",
 CellChangeTimes->{{3.645335459354512*^9, 3.645335529008653*^9}, {
  3.6683158463043547`*^9, 
  3.668315849675814*^9}},ExpressionUUID->"ee112df0-50b2-4c79-b31e-\
6eb264b2387a"],

Cell[BoxData[
 RowBox[{"FullForm", "[", 
  RowBox[{"Hold", "[", 
   RowBox[{"1", "+", "1"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.645335532155658*^9, 
  3.64533553816117*^9}},ExpressionUUID->"7c4bb551-2211-48e4-9d38-\
0b464817313d"],

Cell["And now we can see the real structure of 1+1.  ", "Text",
 CellChangeTimes->{{3.6453355419281*^9, 3.64533555059971*^9}, {
   3.645335863126226*^9, 3.645335872973913*^9}, 
   3.6453359139966516`*^9},ExpressionUUID->"269cc87d-617b-4619-a1d5-\
e4e1d0da5c07"],

Cell["\<\
The example above uses nested expressions (an expression as the argument to \
another expression).  This can be done with lots of types of objects.\
\>", "Text",
 CellChangeTimes->{{3.645336106179637*^9, 
  3.645336145773788*^9}},ExpressionUUID->"bc2d5d1d-7bfd-483e-ab68-\
1a41e2600223"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Exercises", "Subsection",
 CellChangeTimes->{{3.563797913705751*^9, 3.5637979361437674`*^9}, 
   3.56431015917061*^9, {3.63749318627993*^9, 
   3.637493187766001*^9}},ExpressionUUID->"47cd229d-8500-4c4e-97d9-\
03f2f1c80308"],

Cell["Find the FullForm of the following expressions", "Text",
 CellChangeTimes->{{3.65736805972211*^9, 
  3.65736806815316*^9}},ExpressionUUID->"7a320f1a-0665-48a2-8202-\
52aaf3ad7edd"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["a=b", "Input"]], "ItemNumbered",
 CellChangeTimes->{{3.625497296042621*^9, 3.625497305660241*^9}, 
   3.637942523852414*^9, {3.657368036890511*^9, 3.657368037377877*^9}, {
   3.657368402286794*^9, 
   3.657368408893685*^9}},ExpressionUUID->"88408a3d-2023-4dca-8abd-\
4b5b7eb05470"],

Cell[BoxData[
 ButtonBox["\<\"Solution\"\>",
  Appearance->Automatic,
  ButtonFunction:>NotebookPut[
    Notebook[{
      Cell["FullForm[Hold[a=b]]", "Input"]}]],
  Evaluator->Automatic,
  Method->"Preemptive"]], "Output",
 CellChangeTimes->{
  3.6573680061483192`*^9, 3.6573681318585567`*^9, {3.657368435508447*^9, 
   3.657368456469508*^9}},ExpressionUUID->"05a499df-8aaa-4b9d-9884-\
bf35aba9a027"]
}, Open  ]],

