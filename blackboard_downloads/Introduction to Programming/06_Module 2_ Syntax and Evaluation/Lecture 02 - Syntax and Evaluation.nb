Cell[CellGroupData[{

Cell["Lists", "Section",
 CellChangeTimes->{{3.614336516063374*^9, 
  3.614336516845924*^9}},ExpressionUUID->"6c9a0943-585e-4059-b66f-\
798a7cc1d729"],

Cell[TextData[{
 "Lists are ubiquitous in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ". They are used to represent lists, sets, vectors, and matrices, as well as \
to specify bounds of regions and iterators.   Lists are denoted by braces \
(curly brackets)"
}], "Text",
 CellChangeTimes->{{3.614336899905789*^9, 3.614336923983344*^9}, {
   3.614337072799021*^9, 3.614337083814287*^9}, {3.614337124659896*^9, 
   3.6143371735612593`*^9}, {3.6143373756140428`*^9, 3.614337385637434*^9}, {
   3.614949158052016*^9, 3.6149491670744743`*^9}, 3.615033496761208*^9, {
   3.615728492586603*^9, 3.615728494413831*^9}, {3.657366913754017*^9, 
   3.657366928334041*^9}},ExpressionUUID->"e506e09f-4dad-4f76-acc2-\
2fabd2c6fc8b"],

Cell[CellGroupData[{

Cell["Examples", "Subsection",
 CellChangeTimes->{{3.615033492659094*^9, 
  3.615033493768755*^9}},ExpressionUUID->"49c3466d-f851-4463-b168-\
e60168e913f2"],

Cell["They are used to define vectors (ordered sets of numbers).", "Text",
 CellChangeTimes->{{3.614337759648251*^9, 3.614337761128145*^9}, 
   3.615728501407662*^9, {3.810318965519125*^9, 
   3.81031898466546*^9}},ExpressionUUID->"9b045f45-3dac-46c5-9304-\
c917b851ab2a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"a", ",", "b", ",", "c"}], "}"}], "+", " ", 
  RowBox[{"{", 
   RowBox[{"2", ",", "3", ",", "4"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.614337401631904*^9, 
  3.61433741534833*^9}},ExpressionUUID->"6de9e5b4-027f-4201-ab13-\
880dffd49121"],

Cell["\<\
Regions when you plot things or compute solutions over a region.\
\>", "Text",
 CellChangeTimes->{{3.614337774007244*^9, 3.6143377753352337`*^9}, {
   3.614344289018265*^9, 3.6143442896723137`*^9}, 3.61572850230105*^9, {
   3.810318990189603*^9, 
   3.8103190130274277`*^9}},ExpressionUUID->"6c09cd29-7cee-4903-9922-\
edf2b49c2875"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Sinc", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{"-", "2"}], " ", "\[Pi]"}], ",", 
     RowBox[{"3", " ", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.614337470983605*^9, 
  3.614337507322942*^9}},ExpressionUUID->"6e6c6590-c48e-4c94-903a-\
25892a0b829a"],

Cell["They are used in Iterators:", "Text",
