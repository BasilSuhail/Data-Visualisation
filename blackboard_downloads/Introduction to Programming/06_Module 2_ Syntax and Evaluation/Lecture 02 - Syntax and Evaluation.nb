  3.614337879746578*^9}},ExpressionUUID->"d33769e8-5c98-4048-b8f6-\
3339830e8ac9"],

Cell["\<\
Sets can be denoted as lists. Note that lists actually have an order to them, \
and sets do not.\
\>", "Text",
 CellChangeTimes->{{3.614337837717064*^9, 3.614337838451881*^9}, 
   3.615728505541118*^9, {3.8103190324956827`*^9, 
   3.810319051592683*^9}},ExpressionUUID->"01c9ff5e-71f0-499f-a4e6-\
820cc4ad4357"],

Cell[BoxData[
 RowBox[{"MemberQ", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", ",", "b", ",", "c", ",", "d", ",", "e"}], "}"}], ",", "c"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.614337674828457*^9, 
  3.6143377356902127`*^9}},ExpressionUUID->"621e0ec1-95cd-4d9e-a6ad-\
0c53d8d46500"],

Cell["Here is a set of three matrices:", "Text",
 CellChangeTimes->{{3.8103186101151733`*^9, 
  3.810318631654117*^9}},ExpressionUUID->"36d61d5d-be80-4d55-af45-\
7fc96283fb28"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mat3colours", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{"1", ",", 
     RowBox[{"{", 
      RowBox[{"100", ",", "100", ",", "3"}], "}"}]}], "]"}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.810318620411491*^9, 3.810318663449763*^9}},
 CellLabel->
  "In[349]:=",ExpressionUUID->"6f4fb6cf-48d6-4524-9ff6-72c307d0e51f"],

Cell["We can now represent that as an image:", "Text",
 CellChangeTimes->{{3.81031869314395*^9, 
  3.8103187019188623`*^9}},ExpressionUUID->"29b1c783-41f8-476b-a541-\
d4c852aea079"],

Cell[BoxData[
 RowBox[{"Image", "[", "mat3colours", "]"}]], "Input",
 CellChangeTimes->{{3.810318666607396*^9, 3.810318669845488*^9}},
 CellLabel->
  "In[350]:=",ExpressionUUID->"b4873e91-01ac-46ac-8e24-00bdc35fa5a8"],

Cell["If we have one more dimension we can plot a cube:", "Text",
 CellChangeTimes->{{3.81031870599159*^9, 
  3.81031872171937*^9}},ExpressionUUID->"cced43ed-efe3-428c-86d3-\
27d97ba78888"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mat4cube", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{"1", ",", 
     RowBox[{"{", 
      RowBox[{"10", ",", "10", ",", "10", ",", "3"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.810318730716711*^9, 3.810318737592053*^9}},
 CellLabel->
  "In[351]:=",ExpressionUUID->"cc1c179a-0911-4453-a815-889417cd9986"],

Cell["Let\[CloseCurlyQuote]s plot it:", "Text",
 CellChangeTimes->{{3.810318764710788*^9, 
  3.810318769855319*^9}},ExpressionUUID->"f01d447c-ac4f-4c16-ba7c-\
24e1fbe92556"],

Cell[BoxData[
