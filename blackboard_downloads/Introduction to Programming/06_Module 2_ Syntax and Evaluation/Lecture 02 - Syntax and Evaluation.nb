Cell[CellGroupData[{

Cell["Defining a function", "Section",
 CellChangeTimes->{{3.645512070301631*^9, 
  3.645512072756299*^9}},ExpressionUUID->"26532937-b94b-4753-9a3c-\
b98d7312ad05"],

Cell[TextData[{
 "Defining a function requires the use of ",
 StyleBox[ButtonBox["Blank",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Blank"],
  FontWeight->"Bold"],
 " (_) to indicate values that will vary from evaluation to evaluation. The \
form of the function should follow the same rules as built-in functions, with \
the exception that capitalization is not required."
}], "Text",
 CellChangeTimes->{{3.614333320890126*^9, 3.614333425780386*^9}, 
   3.614344258574811*^9, 3.614949105261032*^9, {3.615728399948208*^9, 
   3.615728428625809*^9}},ExpressionUUID->"895d1c8e-8aa8-4654-9ade-\
dbecab568733"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fun", "[", "x_", "]"}], ":=", " ", 
  RowBox[{
   SuperscriptBox["x", "2"], "+", " ", 
   RowBox[{"Cos", "[", "x", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.614333432897107*^9, 
  3.614333455907475*^9}},ExpressionUUID->"65aa4c44-40cf-4bd9-9e47-\
342987041d6a"],

Cell[BoxData[
 RowBox[{"fun", "[", "7.35", "]"}]], "Input",
 CellChangeTimes->{{3.6143334644396977`*^9, 
  3.614333469882649*^9}},ExpressionUUID->"30163712-8905-4570-af03-\
7752a10cd3a0"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"fun", "[", "i", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"i", ",", 
     RowBox[{"RandomReal", "[", 
      RowBox[{"22", ",", "14"}], "]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.614333486015558*^9, 
  3.614333554261692*^9}},ExpressionUUID->"3fe7181a-c9e2-4895-bc16-\
5217a594088d"],

Cell[TextData[{
 "Again, ",
 StyleBox[ButtonBox["Information",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Information"],
  FontWeight->"Bold"],
 " can be used to find values associated with a symbol, and ",
 StyleBox[ButtonBox["Clear",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Clear"],
  FontWeight->"Bold"],
 " can be used to clear the assignments."
}], "Text",
 CellChangeTimes->{{3.6143335888684597`*^9, 3.614333656580151*^9}, {
   3.614333712692301*^9, 3.614333731083164*^9}, 3.614344268637319*^9, 
   3.6149491304687343`*^9, 3.615728408932178*^9, {3.615728441066048*^9, 
   3.615728456128355*^9}, {3.615827530714629*^9, 
   3.61582754695768*^9}},ExpressionUUID->"37cf9412-3dd2-4ca7-8650-\
93464c099522"],

Cell[BoxData[
 RowBox[{"?", "fun"}]], "Input",
 CellChangeTimes->{{3.614333628934985*^9, 
  3.6143336328094068`*^9}},ExpressionUUID->"1df700ea-f8d2-4966-b080-\
73c5cc0cd34d"],

Cell[BoxData[
 RowBox[{"Clear", "[", "fun", "]"}]], "Input",
 CellChangeTimes->{{3.614333738993394*^9, 
  3.614333741819083*^9}},ExpressionUUID->"20ef8ead-0d3c-4570-a710-\
2257d5677f37"],

Cell[BoxData[
 RowBox[{"?", "fun"}]], "Input",
 CellChangeTimes->{{3.614333754040944*^9, 
  3.614333755202551*^9}},ExpressionUUID->"3fe7180a-6e54-41f7-900e-\
f11b5705773b"],

Cell["\<\
You can also define functions of more than one Variable like so:\
\>", "Text",
 CellChangeTimes->{{3.810318323931072*^9, 
  3.810318337510171*^9}},ExpressionUUID->"021b9f78-7d57-4ef2-a122-\
48903d8fa5bf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fun2d", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Cos", "[", 
    RowBox[{
     RowBox[{"x", "^", "2"}], "+", 
     RowBox[{"y", "^", "2"}]}], "]"}], 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "0.1"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"y", "^", "2"}]}], ")"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.81031834000809*^9, 3.810318372541459*^9}, {
  3.810318422353347*^9, 3.810318428635143*^9}},
 CellLabel->
  "In[342]:=",ExpressionUUID->"20e13ceb-e0c2-4361-940e-35e2a270a5d0"],

Cell["This can be evaluated:", "Text",
 CellChangeTimes->{{3.810318388082719*^9, 
  3.810318393725339*^9}},ExpressionUUID->"dfefd92a-0c8c-4c5d-a05c-\
22db67112efb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fun2d", "[", 
  RowBox[{"3", ",", "4"}], "]"}]], "Input",
 CellChangeTimes->{{3.810318396185543*^9, 3.810318431439225*^9}},
 CellLabel->
  "In[343]:=",ExpressionUUID->"bca487f5-0750-4116-bf81-03f289c8b587"],

Cell[BoxData["0.08136288144781785`"], "Output",
 CellChangeTimes->{{3.810318400688764*^9, 3.810318431806409*^9}},
 CellLabel->
  "Out[343]=",ExpressionUUID->"c3b99d03-9f5e-4613-91ce-104aadaa761c"]
}, Open  ]],

Cell["and plotted", "Text",
 CellChangeTimes->{{3.810318403572686*^9, 
  3.810318405897021*^9}},ExpressionUUID->"4bdb1c05-c71e-4918-8721-\
41b9766329c0"],

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{"fun2d", "[", 
    RowBox[{"x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "6"}], ",", "6"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "6"}], ",", "6"}], "}"}], ",", 
   RowBox[{"PlotPoints", "\[Rule]", "60"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.810318407894559*^9, 3.8103184724777803`*^9}},
 CellLabel->
  "In[346]:=",ExpressionUUID->"ae1e3322-5a3d-4c74-9957-28a8e60aed68"],

Cell["Sometimes a delayed set and a set can be used together:", "Text",
 CellChangeTimes->{{3.810322086464694*^9, 
  3.810322108684428*^9}},ExpressionUUID->"63077f9d-d02a-444f-851e-\
0571eb59f3a3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"F", "[", "1", "]"}], ":=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"F", "[", "2", "]"}], ":=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"F", "[", "n_", "]"}], ":=", 
  RowBox[{
   RowBox[{"F", "[", "n", "]"}], "=", 
   RowBox[{
    RowBox[{"F", "[", 
     RowBox[{"n", "-", "1"}], "]"}], "+", 
    RowBox[{"F", "[", 
     RowBox[{"n", "-", "2"}], "]"}]}]}]}]}], "Input",
 CellChangeTimes->{{3.810322110551073*^9, 3.8103221673700867`*^9}},
 CellLabel->
  "In[443]:=",ExpressionUUID->"d50bb197-b207-433f-8ab5-6ca0c5804ba2"],

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{"F", "/@", 
   RowBox[{"Range", "[", "31", "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.810322169511241*^9, 3.810322193235835*^9}, {
  3.8103223260011177`*^9, 3.810322335318636*^9}, {3.810322369188045*^9, 
  3.81032236931433*^9}},
 CellLabel->
  "In[468]:=",ExpressionUUID->"44fb413a-778f-480f-bbd1-b4a862b0341c"],

Cell[BoxData[
 RowBox[{"?", "F"}]], "Input",
 CellChangeTimes->{{3.810322214997952*^9, 3.810322228309894*^9}},
 CellLabel->
  "In[452]:=",ExpressionUUID->"f95f475a-8f6f-4acd-8e70-e467668945b2"],

Cell["The following program will be much slower", "Text",
 CellChangeTimes->{{3.810322383340911*^9, 
  3.810322389217293*^9}},ExpressionUUID->"0274f222-1b81-43ae-be64-\
1b72e41203a1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"G", "[", "1", "]"}], ":=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G", "[", "2", "]"}], ":=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G", "[", "n_", "]"}], ":=", 
  RowBox[{
   RowBox[{"G", "[", 
    RowBox[{"n", "-", "1"}], "]"}], "+", 
   RowBox[{"G", "[", 
    RowBox[{"n", "-", "2"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.810322248083509*^9, 3.810322256880494*^9}},
 CellLabel->
  "In[453]:=",ExpressionUUID->"c83d16c6-30a1-45c4-a2b0-7c9ea5b68de3"],

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{"G", "/@", 
   RowBox[{"Range", "[", "31", "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.810322270588854*^9, 3.8103223159817877`*^9}, {
  3.810322361167059*^9, 3.810322361297128*^9}},
 CellLabel->
  "In[467]:=",ExpressionUUID->"63ea2e7b-e3d9-4002-9d06-28e3126679e9"],

Cell["\<\
We will discuss this further when we talk about efficient and fast coding. By \
the way, none of this is necessary:\
\>", "Text",
 CellChangeTimes->{{3.810322393882725*^9, 
  3.810322432803157*^9}},ExpressionUUID->"84b0484b-9337-4395-94ce-\
914d77b2f67d"],

Cell[BoxData[
 RowBox[{"Fibonacci", "[", 
  RowBox[{"Range", "[", "31", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.810322434107873*^9, 3.810322438990284*^9}},
 CellLabel->
  "In[469]:=",ExpressionUUID->"038c2a10-5518-417c-9672-1365088735ba"],

Cell[CellGroupData[{

Cell["Pure functions", "Subsection",
 CellChangeTimes->{{3.81032247043518*^9, 
  3.810322481562419*^9}},ExpressionUUID->"588fc3cb-8b6b-44ac-b8a1-\
43f29909a606"],

Cell["\<\
Remember that we can also do pure functions, i.e. functions without a name \
and with anonymous variables. We start with the standard function:\
\>", "Text",
 CellChangeTimes->{{3.810322483361392*^9, 
  3.81032254221314*^9}},ExpressionUUID->"ca2d828e-19d1-48e2-b590-\
fe225eb3f85b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fun", "[", "x_", "]"}], ":=", " ", 
  RowBox[{
   SuperscriptBox["x", "2"], "+", " ", 
   RowBox[{"Cos", "[", "x", "]"}]}]}]], "Input",ExpressionUUID->"0bc041aa-\
e65a-4b80-bfea-0c57bcef7855"],

Cell["\<\
Then we only take the right hand side (thereby losing the name of the \
function)\
\>", "Text",
 CellChangeTimes->{{3.81032254515134*^9, 
  3.810322568471719*^9}},ExpressionUUID->"5e05f356-4dc0-4385-8f84-\
b6f2186210bb"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["x", "2"], "+", " ", 
  RowBox[{"Cos", "[", "x", "]"}]}]], "Input",ExpressionUUID->"5b57c374-cb09-\
49bb-8fd4-65b465d40a60"],

Cell["We then substitute the x by #", "Text",
 CellChangeTimes->{{3.810322575666397*^9, 
  3.810322583024355*^9}},ExpressionUUID->"9ec614fa-4c8a-4b05-9b24-\
b4f2416641e4"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["#", "2"], "+", " ", 
  RowBox[{"Cos", "[", "#", "]"}]}]], "Input",
 CellChangeTimes->{{3.8103225884111*^9, 
  3.810322593519397*^9}},ExpressionUUID->"e9ca9d30-3baa-42e7-a610-\
95d246019efb"],

Cell["And finally finish it off with an &", "Text",
 CellChangeTimes->{{3.8103225966550827`*^9, 
  3.810322603245285*^9}},ExpressionUUID->"86c37c6c-5aeb-4fc5-bcf7-\
3bfe8333160d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["#", "2"], "+", " ", 
   RowBox[{"Cos", "[", "#", "]"}]}], "&"}]], "Input",
 CellChangeTimes->{
  3.8103226077674093`*^9},ExpressionUUID->"7be8aaf2-06df-4595-8798-\
a13ae6282f7f"],

Cell["We can then apply that function:", "Text",
 CellChangeTimes->{{3.810322610560958*^9, 
  3.810322615709622*^9}},ExpressionUUID->"e9aee917-a069-476d-b9fb-\
1c68a6cbb70d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SuperscriptBox["#", "2"], "+", " ", 
    RowBox[{"Cos", "[", "#", "]"}]}], "&"}], "[", "0.456", "]"}]], "Input",
 CellChangeTimes->{{3.810322620883924*^9, 3.810322624839144*^9}},
 CellLabel->
  "In[470]:=",ExpressionUUID->"74b04f27-0b21-452b-ae55-59e438a6c56e"],

Cell[BoxData["1.1057571168075224`"], "Output",
 CellChangeTimes->{3.810322625323031*^9},
 CellLabel->
  "Out[470]=",ExpressionUUID->"d83cbeae-fd5d-4aad-9f3e-df674e70635c"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SuperscriptBox["#", "2"], "+", " ", 
    RowBox[{"Cos", "[", "#", "]"}]}], "&"}], " ", "/@", " ", 
  RowBox[{"RandomReal", "[", 
   RowBox[{"1", ",", "10"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.810322637668268*^9, 3.810322648492565*^9}},
 CellLabel->
  "In[471]:=",ExpressionUUID->"7d77c8bb-160c-4234-8d4d-98ff22a70bd4"],

Cell["You can also define pure functions with two inputs:", "Text",
 CellChangeTimes->{{3.810322960469878*^9, 
  3.810322969546521*^9}},ExpressionUUID->"68cb269f-7725-482e-9475-\
486b26e24419"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fun2d", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Cos", "[", 
    RowBox[{
     RowBox[{"x", "^", "2"}], "+", 
     RowBox[{"y", "^", "2"}]}], "]"}], 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "0.1"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"y", "^", "2"}]}], ")"}]}], "]"}]}]}]], "Input",ExpressionUUID->\
"98e6721d-2b15-4751-80ed-d0a9ffdfba30"],

Cell["Take the rhs:", "Text",
 CellChangeTimes->{{3.810322989472158*^9, 
  3.810322993954919*^9}},ExpressionUUID->"3c75c4ac-bf1c-4913-8bd5-\
e183ac769e58"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Cos", "[", 
   RowBox[{
    RowBox[{"x", "^", "2"}], "+", 
    RowBox[{"y", "^", "2"}]}], "]"}], 
  RowBox[{"Exp", "[", 
   RowBox[{
    RowBox[{"-", "0.1"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"x", "^", "2"}], "+", 
      RowBox[{"y", "^", "2"}]}], ")"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.8103229872193003`*^9},ExpressionUUID->"7ccebd40-3c98-4366-8fa9-\
9b9f71b316ac"],

Cell["Substitute the variable by \[OpenCurlyDoubleQuote]numbered\
\[CloseCurlyDoubleQuote] #", "Text",
 CellChangeTimes->{{3.810322999336025*^9, 
  3.810323011046898*^9}},ExpressionUUID->"d97ee472-a4fa-4669-8362-\
5b857322ee90"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Cos", "[", 
   RowBox[{
    RowBox[{"#1", "^", "2"}], "+", 
    RowBox[{"#2", "^", "2"}]}], "]"}], 
  RowBox[{"Exp", "[", 
   RowBox[{
    RowBox[{"-", "0.1"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"#1", "^", "2"}], "+", 
      RowBox[{"#2", "^", "2"}]}], ")"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.810323016262076*^9, 
  3.810323030112585*^9}},ExpressionUUID->"94d24130-ed56-4bad-acbf-\
338c3d73ccba"],

Cell["and finish off with an &", "Text",
 CellChangeTimes->{{3.810323034541206*^9, 
  3.810323042005762*^9}},ExpressionUUID->"9f690108-3aed-44ba-99c9-\
608319bddfdc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Cos", "[", 
    RowBox[{
     RowBox[{"#1", "^", "2"}], "+", 
     RowBox[{"#2", "^", "2"}]}], "]"}], 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "0.1"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"#1", "^", "2"}], "+", 
       RowBox[{"#2", "^", "2"}]}], ")"}]}], "]"}]}], "&"}]], "Input",
 CellChangeTimes->{3.810323046888481*^9},
 CellLabel->
  "In[478]:=",ExpressionUUID->"ced8ae86-dfd7-4344-b56a-534bcbe9d7f2"],

Cell["Apply the function", "Text",
 CellChangeTimes->{{3.810323059082652*^9, 
  3.8103230632136393`*^9}},ExpressionUUID->"9f9d65fa-a020-43c9-a6ab-\
aa0eb91d1710"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Cos", "[", 
     RowBox[{
      RowBox[{"#1", "^", "2"}], "+", 
      RowBox[{"#2", "^", "2"}]}], "]"}], 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "0.1"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"#1", "^", "2"}], "+", 
        RowBox[{"#2", "^", "2"}]}], ")"}]}], "]"}]}], "&"}], "[", 
  RowBox[{"4", ",", "3"}], "]"}]], "Input",
 CellChangeTimes->{{3.810323068268278*^9, 3.810323072043847*^9}},
 CellLabel->
  "In[479]:=",ExpressionUUID->"07593803-ae5d-4660-a937-93113500fc4a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Alternative definition", "Subsection",
 CellChangeTimes->{{3.810322669995525*^9, 
  3.81032267605825*^9}},ExpressionUUID->"f36f2062-df12-4761-b3ba-\
424809ac5664"],

Cell["\<\
We can also use the function Function to define functions: (what a nice \
sentence!)\
\>", "Text",
 CellChangeTimes->{{3.810322677262855*^9, 
  3.810322698253645*^9}},ExpressionUUID->"97d88053-4281-4181-a00c-\
0b4218fdf4b2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Function", "[", 
   RowBox[{"u", ",", 
    RowBox[{
     SuperscriptBox["u", "2"], "+", " ", 
