   3.615728503133087*^9, {3.810319016310988*^9, 
   3.810319022738824*^9}},ExpressionUUID->"93cd26cf-397c-4347-b8bc-\
2594ebce90f2"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   SuperscriptBox["i", "2"], ",", 
   RowBox[{"{", 
    RowBox[{"i", ",", "1", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.614337544692274*^9, 
  3.614337565515975*^9}},ExpressionUUID->"cbeb09a6-8618-42c8-a584-\
3730f74fcc74"],

Cell["and in matrices:", "Text",
 CellChangeTimes->{{3.614337803781659*^9, 3.614337806269627*^9}, 
   3.6157285046701803`*^9, {3.810319025008765*^9, 
   3.810319029614396*^9}},ExpressionUUID->"2a966120-84be-4815-a04c-\
fd819c8adcbe"],

Cell[BoxData[
 RowBox[{"MatrixForm", "[", 
  RowBox[{"mat", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"i", "+", "j"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "4"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.6143375827692637`*^9, 3.614337645512911*^9}, {
