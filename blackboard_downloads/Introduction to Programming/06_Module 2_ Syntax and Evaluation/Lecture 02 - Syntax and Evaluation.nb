Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["Part ",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Part"],
  FontWeight->"Bold"],
 "function is a powerful tool for operating on lists and expressions. It \
should be a part of every user\[CloseCurlyQuote]s set of tools."
}], "Text",
 CellChangeTimes->{{3.614340100340318*^9, 3.614340130682786*^9}, {
   3.614340291555249*^9, 3.6143403221839848`*^9}, 3.6143443138694077`*^9, {
