3323b96859eb"],

Cell[CellGroupData[{

Cell["Examples", "Subsection",
 CellChangeTimes->{{3.61503368789531*^9, 
  3.615033689286993*^9}},ExpressionUUID->"ffb89650-805b-4a55-91d8-\
8bc022f7787b"],

Cell["\<\
First, create a one-dimensional list to work with. This generates a list of \
the integers 1 through 28, taking every third number.\
\>", "Text",
 CellChangeTimes->{3.614949302035529*^9},
 CellTags->
  "Basic Operations",ExpressionUUID->"8714cc99-ba64-4c16-ba8d-643879c8891e"],

Cell[BoxData[
 RowBox[{"vec", "=", 
  RowBox[{"Range", "[", 
   RowBox[{"1", ",", "28", ",", "3"}], "]"}]}]], "Input",
 CellTags->
  "Basic Operations",ExpressionUUID->"972a1923-0123-4959-b916-798b1c11f1f6"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["Part ",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Part"],
  FontWeight->"Bold"],
 "function is used to extract elements from a list. This gives the third \
element from the list ",
 StyleBox["vec", "MR"],
 "."
}], "Text",
 CellChangeTimes->{{3.615728629945614*^9, 3.615728634159313*^9}},
 CellTags->
  "Basic Operations",ExpressionUUID->"b578109b-9854-45ff-b292-8f0c0df69604"],

Cell[BoxData[
 RowBox[{"Part", "[", 
  RowBox[{"vec", ",", "3"}], "]"}]], "Input",
 CellTags->
  "Basic Operations",ExpressionUUID->"701dd332-3814-4692-98e5-0d3d439890c2"],

Cell["\<\
You can also work from the tail end of the list by using negative indices.\
\>", "Text",
 CellTags->
  "Basic Operations",ExpressionUUID->"a10ac0e0-193a-42d1-9a19-8752a31e587c"],

Cell[BoxData[
 RowBox[{"Part", "[", 
  RowBox[{"vec", ",", 
   RowBox[{"-", "1"}]}], "]"}]], "Input",
 CellTags->
  "Basic Operations",ExpressionUUID->"54af877e-5fc7-4e24-85e8-7cf93c60dc80"],

Cell[TextData[{
 "This extracts the first five elements from ",
 StyleBox["vec", "MR"],
 "."
}], "Text",
 CellTags->
  "Basic Operations",ExpressionUUID->"32b856f6-87a5-40d5-a3e9-d22d1075b27f"],

Cell[BoxData[
 RowBox[{"Part", "[", 
  RowBox[{"vec", ",", 
   RowBox[{"Range", "[", "5", "]"}]}], "]"}]], "Input",
 CellTags->
  "Basic Operations",ExpressionUUID->"c4260065-31fb-4cdf-8be0-eaf4554b8d8d"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

