 RowBox[{"x", ":=", "2"}]], "Input",
 CellChangeTimes->{{3.645511613241137*^9, 
  3.645511622619273*^9}},ExpressionUUID->"cad0a558-5298-44ae-b846-\
a0ac80088a63"],

Cell["\<\
No output is returned when the assignment is made. However, when the function \
or symbol is evaluated, a different value might be returned. Here is an \
assignment to a symbol where the output is intended to be different each \
time. \
\>", "Text",
 CellChangeTimes->{
  3.645511611152948*^9},ExpressionUUID->"f50e9665-2616-4f01-95d0-\
a478c1b69def"],

Cell[BoxData[
 RowBox[{"rand", ":=", " ", 
  RowBox[{"RandomReal", "[", "]"}]}]], "Input",
 CellChangeTimes->{{3.6143331806536007`*^9, 
  3.614333215875399*^9}},ExpressionUUID->"ef95bd23-f31d-4d05-b351-\
6e52f69422a6"],

Cell[BoxData[
 RowBox[{"rand1", "=", 
  RowBox[{"RandomReal", "[", "]"}]}]], "Input",
