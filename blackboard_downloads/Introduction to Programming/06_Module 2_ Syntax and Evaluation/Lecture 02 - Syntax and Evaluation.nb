Cell[CellGroupData[{

Cell["Shorthands: quick guide", "Section",
 CellChangeTimes->{{3.6436275087300787`*^9, 3.64362751324052*^9}, {
  3.657367036912755*^9, 
  3.657367046729198*^9}},ExpressionUUID->"397c096a-d0b6-44ec-8154-\
ccc52560adfe"],

Cell["\<\
When you start to get more familiar with the Wolfram Language, you will begin \
using shorthands to make your code more concise.  Here are some of the most \
common shorthands and what they mean.  You don\[CloseCurlyQuote]t need to \
worry about using them straight away, but you will probably see them in code. \
 Don\[CloseCurlyQuote]t forget, if you don\[CloseCurlyQuote]t understand \
something you can use FullForm or the Documentation.\
\>", "Text",
 CellChangeTimes->{{3.6455090234367447`*^9, 
  3.645509094169709*^9}},ExpressionUUID->"c910e1f3-5db0-4900-b5c4-\
62054b594748"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Grid", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "\"\<;\>\"", ",", "\"\<Plus[2,2];\>\"", ",", 
        "\"\<Suppresses Output\>\""}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\\\"\\\"\>\"", ",", "\"\<\\\"A string\\\"\>\"", ",", 
        "\"\<String\>\""}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"\"\<{}\>\"", ",", "\"\<{1,2,3}\>\"", ",", "\"\<List\>\""}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"\"\<@\>\"", ",", "\"\<Sin@2\>\"", ",", "\"\<Prefix\>\""}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"\"\<//\>\"", ",", "\"\<2//Sin\>\"", ",", "\"\<Postfix\>\""}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<[[]]\>\"", ",", "\"\<{1,2,3}[[1]]\>\"", ",", "\"\<Part\>\""}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\[Rule]\>\"", ",", "\"\<a\[Rule]b\>\"", ",", "\"\<Rule\>\""}], 
       "}"}]}], "}"}], ",", 
    RowBox[{"BaseStyle", "\[Rule]", "\"\<Text\>\""}], ",", 
    RowBox[{"Alignment", "\[Rule]", "Left"}], ",", 
    RowBox[{"Spacings", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1"}], "}"}]}]}], "]"}], 
  "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.645510196021175*^9, 3.645510293133142*^9}, {
   3.6455104722635202`*^9, 3.6455105917654543`*^9}, {3.645510881269625*^9, 
   3.645510918851457*^9}, {3.645510949282661*^9, 3.645510959752346*^9}, 
   3.64551103856128*^9, {3.645514292244413*^9, 3.6455143085297537`*^9}, {
   3.64587485587414*^9, 3.645874872712175*^9}, {3.646025335471227*^9, 
   3.64602533862845*^9}},ExpressionUUID->"c06af6f3-9085-419c-bc08-\
74a38ca8ad75"],

