Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"f9e50164-4b20-4996-961a-45d60d474314"],

Cell[CellGroupData[{

Cell["Levels in Lists", "Section",
 CellChangeTimes->{{3.6143411420966682`*^9, 
  3.614341155113138*^9}},ExpressionUUID->"ae0103f9-9be4-4414-b20a-\
2b23c0efc5de"],

Cell["\<\
Lists are a great way to learn about levels in expressions. First, create an \
array to work with.\
\>", "Text",
 CellChangeTimes->{{3.614341290097545*^9, 3.6143413603256474`*^9}, 
   3.614344344846966*^9},ExpressionUUID->"0c02c192-116e-4218-a423-\
07ce5392a0f2"],

Cell[BoxData[
 RowBox[{"MatrixForm", "[", 
  RowBox[{"mat", "=", " ", 
   RowBox[{"Partition", "[", 
    RowBox[{
     RowBox[{"CharacterRange", "[", 
      RowBox[{"\"\<a\>\"", ",", "\"\<l\>\""}], "]"}], ",", "3"}], "]"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.614341369009531*^9, 3.614341476368352*^9}, {
  3.657367450873487*^9, 
  3.657367451809503*^9}},ExpressionUUID->"00f71bcb-9c61-475b-a392-\
43b887fece88"],

Cell[TextData[{
 "Look at the levels using ",
 StyleBox[ButtonBox["TreeForm",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/TreeForm"],
  FontWeight->"Bold"],
 ". The elements are at the second level."
}], "Text",
 CellChangeTimes->{{3.6143414958618393`*^9, 3.614341508805219*^9}, {
  3.6143415398591547`*^9, 3.614341550210847*^9}, {3.6157286752667837`*^9, 
  3.615728675353661*^9}},ExpressionUUID->"0624cfa4-4083-4ba2-95f1-\
6e018e88fd27"],

Cell[BoxData[
 RowBox[{"TreeForm", "[", "mat", "]"}]], "Input",
 CellChangeTimes->{{3.614341511341564*^9, 3.614341518197578*^9}, {
  3.657367329945848*^9, 
  3.6573673479534206`*^9}},ExpressionUUID->"d89f1f22-21d0-47b0-9813-\
45a346b23d28"],

Cell["\<\
Get the second column by asking for the second part in all the rows.\
\>", "Text",
 CellChangeTimes->{{3.614341582226207*^9, 
  3.614341609287616*^9}},ExpressionUUID->"924cb2e5-6094-4d3a-a9f2-\
0024643eb778"],

Cell[BoxData[
 RowBox[{"mat", "[", 
  RowBox[{"[", 
   RowBox[{"All", ",", "2"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.614341619326659*^9, 
  3.614341625775538*^9}},ExpressionUUID->"338e509f-421b-4557-b9be-\
ab1a4f5dee7d"],

Cell["Get the elements in the third position of rows 2 and 3.", "Text",
 CellChangeTimes->{{3.614341647237378*^9, 
  3.61434167291606*^9}},ExpressionUUID->"150bc81e-5296-4a0b-9e04-\
52a30075f093"],

Cell[BoxData[
 RowBox[{"mat", "[", 
  RowBox[{"[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"2", ",", "3"}], "}"}], ",", "3"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.614341678931553*^9, 
  3.6143416916437263`*^9}},ExpressionUUID->"1456f590-e3f2-4199-bc09-\
74efe80dc87a"],

Cell["Replace the second row with randomly selected integers.", "Text",
 CellChangeTimes->{{3.614341814707958*^9, 3.614341844658362*^9}, {
  3.614341921775278*^9, 
  3.614341937485121*^9}},ExpressionUUID->"4dd41c7a-c17e-48eb-a4ae-\
886c1e4c197b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mat", "[", 
   RowBox[{"[", "2", "]"}], "]"}], "=", 
  RowBox[{"RandomInteger", "[", 
   RowBox[{"5", ",", "3"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.6143418589297256`*^9, 3.61434189148853*^9}, {
  3.65736744547467*^9, 3.657367448305455*^9}, {3.657367556740466*^9, 
  3.657367557125716*^9}},ExpressionUUID->"8ef1a9bf-83ed-4d51-921f-\
7acae4d71f33"],

Cell[BoxData[
 RowBox[{"MatrixForm", "[", "mat", "]"}]], "Input",
 CellChangeTimes->{{3.614341897783823*^9, 
  3.6143419029038267`*^9}},ExpressionUUID->"b33e6b52-5252-465e-bf42-\
5e1bc46d2ac7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"389a5361-5534-4c17-b364-708c06b10d2c"],

Cell[CellGroupData[{

Cell["Levels in Expressions", "Section",
 CellChangeTimes->{{3.614285427858781*^9, 3.6142854477320232`*^9}, 
   3.615727927341803*^9, {3.623694019411354*^9, 
   3.623694026056997*^9}},ExpressionUUID->"b11ae511-b9b3-4e8b-8e89-\
392a7c7d2270"],

Cell[TextData[{
 "Expressions can be seen as trees, and doing so will make it easier to \
determine levels and to take advantage of the power obtained from ",
 StyleBox[ButtonBox["Part",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Part"],
  FontWeight->"Bold"],
 " and related functions. ",
 StyleBox[ButtonBox["Defer",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Defer"],
  FontWeight->"Bold"],
 " is used here to keep the plot from evaluating."
}], "Text",
 CellChangeTimes->{{3.614285466437055*^9, 3.614285529073382*^9}, {
   3.614285622303423*^9, 3.614285628287943*^9}, {3.614285698509922*^9, 
   3.614285709589159*^9}, {3.614285946868758*^9, 3.614285963973881*^9}, 
   3.614344187820809*^9, 3.614344398281592*^9, {3.615727936736467*^9, 
   3.6157279876630387`*^9}},ExpressionUUID->"cec658d3-7698-4a25-ac7b-\
6d08da64b8ee"],

Cell[BoxData[
 RowBox[{"TreeForm", "[", 
  RowBox[{
   RowBox[{"Defer", "[", "Plot", "]"}], "[", 
   RowBox[{
    RowBox[{"Sin", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", " ", 
      RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.6142855340875397`*^9, 3.614285604751294*^9}, {
  3.614285636652438*^9, 
  3.614285689260648*^9}},ExpressionUUID->"27064c76-7446-4d21-a03a-\
69e5e6e37728"],

Cell[TextData[{
 "The head of the expression is at level one, and the levels are counted from \
the top down in the tree. Thus the symbol ",
 Cell[BoxData[
  FormBox["\[Pi]", TraditionalForm]],ExpressionUUID->
  "0eccaac4-f510-4947-bfb8-1b6760759129"],
 " is at level three in the expression. Here is the address of the symbol ",
 Cell[BoxData[
  FormBox["\[Pi]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "255f072d-f0dd-432f-9468-bf3829da70c7"],
 " in the preceding expression."
}], "Text",
 CellChangeTimes->{{3.614285735383985*^9, 3.614285807803651*^9}, {
   3.614285974287878*^9, 3.614286002032033*^9}, {3.615728024921315*^9, 
   3.6157280384458933`*^9}, 3.615728109412228*^9, {3.615729676414997*^9, 
   3.615729678708814*^9}, {3.615729725050359*^9, 3.615729732730225*^9}, 
   3.615729811720372*^9, {3.637939435339845*^9, 
   3.637939437293411*^9}},ExpressionUUID->"9c32340b-d432-4e7a-98f3-\
9c4c3a8e5ce2"],

Cell[BoxData[
 RowBox[{"Position", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Defer", "[", "Plot", "]"}], "[", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", " ", 
       RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}], ",", "\[Pi]"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.6142855340875397`*^9, 3.614285604751294*^9}, {
  3.614285636652438*^9, 3.614285689260648*^9}, {3.6142860194063997`*^9, 
  3.614286032965368*^9}},ExpressionUUID->"dc00cac1-9688-4c55-8ce1-\
b47984dcc471"],

Cell[TextData[{
 "Understanding the structure of expressions can make it easy to modify \
existing expressions. Here ",
 StyleBox[ButtonBox["ReplacePart ",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ReplacePart"],
  FontWeight->"Bold"],
 "is used to change the plot interval."
}], "Text",
 CellChangeTimes->{{3.614286199317071*^9, 3.61428624618433*^9}, {
  3.614331492562624*^9, 3.614331546166224*^9}, {3.61433158298761*^9, 
  3.61433158299382*^9}, {3.615728060428814*^9, 
  3.6157280787536087`*^9}},ExpressionUUID->"b6f94e23-be03-4f80-a625-\
ed744fd43dbe"],

Cell[BoxData[
 RowBox[{"ReplacePart", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Defer", "[", "Plot", "]"}], "[", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", " ", 
       RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", "3", ",", "2"}], "}"}], "\[Rule]", " ", 
     "\[ExponentialE]"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.6142861297022467`*^9, 
  3.614286174159087*^9}},ExpressionUUID->"be5cd845-e5b7-41c6-a929-\
bf9dfe984d92"],

Cell["\<\
The arrow in this section is a shorthand for Rule.  Rule transforms the left \
hand side into the right hand side, and is used in various different contexts.\
\>", "Text",
 CellChangeTimes->{{3.645508573034856*^9, 3.645508601528719*^9}, {
  3.6455089842942*^9, 
  3.64550898719667*^9}},ExpressionUUID->"dd7e12cc-b0f3-48f6-91c6-\
f16a7002dddf"],

