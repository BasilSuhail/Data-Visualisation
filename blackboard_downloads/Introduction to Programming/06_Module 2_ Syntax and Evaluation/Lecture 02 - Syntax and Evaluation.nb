7b79071aa1ad"],

Cell[BoxData[
 ButtonBox["\<\"Solution\"\>",
  Appearance->Automatic,
  ButtonFunction:>NotebookPut[
    Notebook[{
      Cell["Written out in Full Form:", "Text"], 
      Cell["Times[x,Times[y,Power[5,-1]]]", "Input"], 
      Cell["Or in a more shorthand way:", "Text"], 
      Cell["x*y/5", "Input"]}]],
  Evaluator->Automatic,
  Method->"Preemptive"]], "Output",
