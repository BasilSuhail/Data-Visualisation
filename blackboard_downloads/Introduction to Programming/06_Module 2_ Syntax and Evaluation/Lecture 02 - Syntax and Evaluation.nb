Cell[TextData[StyleBox["Total@{1,2,3}", "Input"]], "ItemNumbered",
 CellChangeTimes->{{3.625497296042621*^9, 3.625497305660241*^9}, 
   3.637942523852414*^9, {3.657368036890511*^9, 3.657368043025672*^9}, 
   3.657368121042029*^9},ExpressionUUID->"42a685f5-6289-46b0-8029-\
08f0cb4dfa97"],

Cell[BoxData[
 ButtonBox["\<\"Solution\"\>",
  Appearance->Automatic,
  ButtonFunction:>NotebookPut[
    Notebook[{
      Cell["FullForm[Hold[Total@{1,2,3}]]", "Input"]}]],
  Evaluator->Automatic,
  Method->"Preemptive"]], "Output",
 CellChangeTimes->{3.6573680061483192`*^9, 
  3.6573681318585567`*^9},ExpressionUUID->"9e3a80cc-604e-4f87-97a0-\
0ef40b158077"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

