Cell[CellGroupData[{

Cell["Geologic Data", "Section",
 CellChangeTimes->{{3.572879351187417*^9, 
  3.5728793559364443`*^9}},ExpressionUUID->"bbfb94bc-376c-40d2-9d19-\
c0321e5d2a1b"],

Cell[TextData[{
 "The Wolfram Language",
 StyleBox[" ",
  FontSlant->"Italic"],
 "provides powerful tools for creating mixture distributions."
}], "Text",
 CellChangeTimes->{{3.572879375717017*^9, 3.572879409354968*^9}, {
  3.622382726982209*^9, 
  3.6223827296278353`*^9}},ExpressionUUID->"e2687cd5-77a2-4a93-80a4-\
370440a11c9e"],

Cell[BoxData[
 RowBox[{"ofDist2", "=", 
  RowBox[{"EstimatedDistribution", "[", 
   RowBox[{"wait", ",", 
    RowBox[{"MixtureDistribution", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"p1", ",", "p2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", 
         RowBox[{"m1", ",", "s1"}], "]"}], ",", 
        RowBox[{"NormalDistribution", "[", 
         RowBox[{"m2", ",", "s2"}], "]"}]}], "}"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.572706084011676*^9, 3.5727060872142153`*^9}, {
   3.572706124736571*^9, 3.572706247145879*^9}, {3.572706280308176*^9, 
   3.572706284466569*^9}, {3.572706462343397*^9, 3.572706465606978*^9}, 
   3.572706506665064*^9, {3.572706553355239*^9, 3.572706571496331*^9}, {
   3.572706940175898*^9, 3.572707028336489*^9}, {3.572707071274151*^9, 
   3.57270708481876*^9}, {3.572707183061532*^9, 3.5727071899410267`*^9}, {
   3.572707254198363*^9, 3.572707264598392*^9}, {3.572710306888473*^9, 
   3.572710315692893*^9}, {3.572866108186383*^9, 3.572866130553196*^9}, {
   3.572866163130505*^9, 
   3.572866198795138*^9}},ExpressionUUID->"036f4e8d-fd8d-4c09-80c4-\
94979a92d839"],

Cell["\<\
You can visualize the fit for your distribution and the data.\
\>", "Text",
 CellChangeTimes->{{3.572879464023962*^9, 3.572879493256114*^9}, {
  3.622303145039432*^9, 
  3.622303148405421*^9}},ExpressionUUID->"4c6fe0d8-084c-40bc-8b55-\
4cd43d266b41"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Histogram", "[", 
     RowBox[{"wait", ",", "25", ",", "\"\<PDF\>\""}], "]"}], ",", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"PDF", "[", 
       RowBox[{"ofDist2", ",", "x"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "34", ",", "100"}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", " ", "Red"}]}], "]"}]}], "}"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.572706295630427*^9, 3.572706368260145*^9}, {
  3.572712524374462*^9, 3.572712568302764*^9}, {3.572866151227693*^9, 
  3.5728661518658*^9}, {3.572866219229877*^9, 
  3.572866221891343*^9}},ExpressionUUID->"76b8b127-d8d1-45ea-aafe-\
5c356f860094"],

Cell[BoxData[
 RowBox[{"Probability", "[", 
  RowBox[{
   RowBox[{"x", "<", " ", "60"}], ",", 
   RowBox[{"x", "\[Distributed]", 
    RowBox[{"NormalDistribution", "[", 
     RowBox[{"54.61485582978792`", ",", "5.871219055137422`"}], "]"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.5740106312955217`*^9, 
  3.57401067659944*^9}},ExpressionUUID->"60a075d9-5ffe-400e-8178-\
f572035725f4"],

Cell[BoxData[
 RowBox[{"Probability", "[", 
  RowBox[{
   RowBox[{"x", "<", " ", "60"}], ",", 
   RowBox[{"x", "\[Distributed]", 
    RowBox[{"NormalDistribution", "[", 
     RowBox[{"80.09106843474524`", ",", "5.867734836974281`"}], "]"}]}]}], 
  "]"}]], "Input",
