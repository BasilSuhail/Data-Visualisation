       RowBox[{"Style", "[", 
        RowBox[{"\"\<Description\>\"", ",", "\"\<Text\>\"", ",", "Bold"}], 
        "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
         RowBox[{"ExampleData", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\"\<Statistics\>\"", ",", "\"\<OldFaithful\>\""}], "}"}],
            ",", "\"\<LongDescription\>\""}], "]"}], ",", "\"\<Text\>\""}], 
        "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<Column Headings\>\"", ",", "\"\<Text\>\"", ",", "Bold"}],
         "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
         RowBox[{"ExampleData", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\"\<Statistics\>\"", ",", "\"\<OldFaithful\>\""}], "}"}],
            ",", "\"\<ColumnHeadings\>\""}], "]"}], ",", "\"\<Text\>\""}], 
        "]"}]}], "}"}], ",", 
     RowBox[{"Dividers", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"None", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", "\[Rule]", 
           RowBox[{"Directive", "[", 
            RowBox[{"Thick", ",", "Red"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"-", "2"}], "\[Rule]", 
           RowBox[{"Directive", "[", 
