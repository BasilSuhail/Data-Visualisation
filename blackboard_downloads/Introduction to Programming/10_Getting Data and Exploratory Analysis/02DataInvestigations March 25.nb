}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"9e985bcf-9ae6-4033-82cf-cd21e2dc8b85"],

Cell[CellGroupData[{

Cell["Prussian Army Corps Data: Discrete", "Section",
 CellChangeTimes->{{3.572697106303929*^9, 3.572697120350626*^9}, {
   3.5727006202451873`*^9, 3.572700624647828*^9}, 
   3.572880128363978*^9},ExpressionUUID->"1487b301-72b3-4074-a450-\
8399e3a34f9a"],

Cell["\<\
This is a historically important dataset, as it introduces the use of \
distributions into analysis. From 1875 through 1894 the Russian mathematician \
Ladislaus J. Bortkiewicz collected data from 10 Prussian army corps, \
recording how many occurrences of getting kicked by a horse led to the \
injured person\[CloseCurlyQuote]s death.\
\>", "Text",
 CellChangeTimes->{{3.572697183504362*^9, 3.5726972948572283`*^9}, 
   3.572697366231687*^9, {3.580039250496242*^9, 
   3.580039287374353*^9}},ExpressionUUID->"9bc328f8-6971-4535-a9f6-\
208b7fbabb39"],

Cell["\<\
The data is given as frequency data. The first element of each ordered pair \
gives the number of deaths, and the second the frequency of observing that \
value.\
\>", "Text",
 CellChangeTimes->{{3.572697416436802*^9, 3.572697497380439*^9}, 
   3.5802232168475237`*^9},ExpressionUUID->"21a97afd-f665-418b-bc0c-\
3ad23bf79316"],

Cell[BoxData[
 RowBox[{"poissonDat", "=", 
  RowBox[{"Import", "[", 
   RowBox[{"\"\<PrussianArmyCorpData.txt\>\"", ",", "\"\<Table\>\""}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.572277662463351*^9, 3.57227769107547*^9}, {
  3.5722784829625607`*^9, 3.572278486642628*^9}, {3.572697127929194*^9, 
  3.5726971339291687`*^9}, {3.572697174140231*^9, 
  3.572697174689743*^9}},ExpressionUUID->"1bb34ba2-c797-4965-970b-\
61149533724c"],

Cell["There are 200 observations in all.", "Text",
 CellChangeTimes->{{3.572697507557548*^9, 
  3.572697516932631*^9}},ExpressionUUID->"4a5ff4b4-160e-4b4d-a157-\
5003331a6d2c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"poissonDat", "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", "2"}], "]"}], "]"}], "//", "Total"}]], "Input",
 CellChangeTimes->{{3.572279077699511*^9, 
  3.572279091685125*^9}},ExpressionUUID->"32495b37-122d-4c96-bbca-\
de100f9eb1ce"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["DistributionFitTest",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/DistributionFitTest"],
  FontWeight->"Bold"],
 " requires the listing of all observations and not frequency data. This is \
easily accomplished by using ",
 StyleBox[ButtonBox["Apply",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Apply"],
  FontWeight->"Bold"],
 " and ",
 StyleBox[ButtonBox["ConstantArray",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ConstantArray"],
  FontWeight->"Bold"],
 " with each of the ordered pairs. Note this approach is reasonable here \
because the observations are categorical and not numerical measurements. In \
general, measurement data cannot be reconstructed from frequency data."
}], "Text",
 CellChangeTimes->{{3.572697663400949*^9, 3.572697775472884*^9}, {
   3.572941123089417*^9, 3.5729411695381527`*^9}, {3.572941328828669*^9, 
   3.572941358229207*^9}, 3.573980080130871*^9, {3.577205466405403*^9, 
   3.577205473284223*^9}, {3.63164535516562*^9, 
   3.631645400668253*^9}},ExpressionUUID->"bfe6fc13-4966-48e2-9ec9-\
c29fd32f2006"],

Cell[BoxData[
 RowBox[{"pDat", "=", 
  RowBox[{"DistributionFitTest", "[", 
   RowBox[{
    RowBox[{"Flatten", "[", 
     RowBox[{"(", 
      RowBox[{"Apply", "[", 
       RowBox[{"ConstantArray", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "109"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "65"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"2", ",", "22"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"3", ",", "3"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"4", ",", "1"}], "}"}]}], "}"}], ",", 
        RowBox[{"{", "1", "}"}]}], "]"}], ")"}], "]"}], ",", 
    RowBox[{"PoissonDistribution", "[", "\[Nu]", "]"}], ",", 
    "\"\<HypothesisTestData\>\""}], "]"}]}]], "Input",
 CellChangeTimes->{{3.572277921318118*^9, 3.572277986793692*^9}, {
  3.572278144872847*^9, 3.572278159821589*^9}, {3.572697788221539*^9, 
  3.5726978092049413`*^9}},ExpressionUUID->"17d8cd58-402a-40b4-8464-\
4676858a3431"],

Cell["\<\
The test data table reveals a high likelihood for the Poisson distribution.\
\>", "Text",
 CellChangeTimes->{{3.572697890021328*^9, 
  3.572697919947752*^9}},ExpressionUUID->"03638c1e-d7e6-4d77-a84b-\
e2a22c895f11"],

Cell[BoxData[
 RowBox[{"pDat", "[", "\"\<TestDataTable\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.57227819331978*^9, 
  3.572278205412033*^9}},ExpressionUUID->"eaf759c2-f92a-47d6-824b-\
51fe36ecd3fb"],

Cell["This scales the frequencies to fall in the interval [0,1].", "Text",
 CellChangeTimes->{{3.57269800169516*^9, 3.572698046670017*^9}, 
   3.580039319519358*^9},ExpressionUUID->"64c0fd03-4fb8-4828-ba8a-\
cfc1a0db0236"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"sclDat", "=", " ", "poissonDat"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"sclDat", "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", "2"}], "]"}], "]"}], "=", 
  RowBox[{
   RowBox[{"poissonDat", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}], "/", "200"}]}]}], "Input",
 CellChangeTimes->{{3.572279103678721*^9, 3.572279115645892*^9}, {
  3.572697940981051*^9, 
  3.572697953650361*^9}},ExpressionUUID->"da9e9f35-8d57-4cf9-909d-\
ae5bb43e3b29"],

Cell["\<\
You can visualize the fitted distribution together with the scaled data.\
\>", "Text",
 CellChangeTimes->{{3.572698090014291*^9, 3.572698113494701*^9}, {
  3.631645408624323*^9, 
  3.631645408925824*^9}},ExpressionUUID->"18c7024c-def7-4015-b2ef-\
f531dd567603"],

Cell[TextData[{
 "The option ",
 StyleBox[ButtonBox["Prolog",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Prolog"],
  FontWeight->"Bold"],
 " can be used to create the data values prior to generating the image of the \
distribution."
}], "Text",
 CellChangeTimes->{{3.57288566058492*^9, 3.5728857196955953`*^9}, 
   3.5772054986740847`*^9, {3.631645412285788*^9, 
   3.6316454201816*^9}},ExpressionUUID->"00120b7a-2ff0-42ac-bc93-\
c30ccdd64758"],

Cell[BoxData[
 RowBox[{"dPlt", "=", 
  RowBox[{"DiscretePlot", "[", 
   RowBox[{
    RowBox[{"PDF", "[", 
     RowBox[{
      RowBox[{"pDat", "[", "\"\<FittedDistribution\>\"", "]"}], ",", "t"}], 
     "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "5"}], "}"}], ",", 
    RowBox[{"PlotMarkers", "\[Rule]", " ", "Automatic"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Prolog", "\[Rule]", " ", 
     RowBox[{"{", 
      RowBox[{"Red", ",", 
       RowBox[{"PointSize", "[", "Large", "]"}], ",", 
       RowBox[{"Point", "[", "sclDat", "]"}]}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.572278238816205*^9, 3.572278319951556*^9}, {
   3.572278359408782*^9, 3.572278393383966*^9}, {3.572278496341466*^9, 
   3.572278560084296*^9}, {3.572278641595145*^9, 3.572278742499044*^9}, {
   3.572278879781847*^9, 3.572278884586664*^9}, {3.572279224319563*^9, 
   3.57227927312253*^9}, 3.572698076920826*^9, {3.572941452469162*^9, 
   3.572941513959366*^9}, 
   3.572941544604505*^9},ExpressionUUID->"2dbd3dec-5ee8-408b-9d21-\
7daf0262e678"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"poissonDat", ",", "pDat", ",", "SclDat"}], "]"}]], "Input",
 CellChangeTimes->{{3.572943052677205*^9, 
  3.572943084548869*^9}},ExpressionUUID->"42f3b013-c882-41ef-b89c-\
cfe9ee73fe1a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"1f2e6d74-f4fb-4aed-9891-e29e7bbd9dc7"],

Cell[CellGroupData[{

Cell["Weather Data: Continuous", "Section",
 CellChangeTimes->{{3.572700783311512*^9, 
  3.572700791722636*^9}},ExpressionUUID->"da4335e6-cacc-4971-8c18-\
63392d5ea6f6"],

Cell[TextData[{
 "In this example, information from ",
 StyleBox[ButtonBox["WeatherData",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/WeatherData"],
  FontWeight->"Bold"],
 " is used to investigate the feasibility of using wind to generate \
electricity for central Illinois. "
}], "Text",
 CellChangeTimes->{
  3.572701094939999*^9, 3.572701133681587*^9, 3.572885751155064*^9, {
   3.577205513520889*^9, 3.577205529082736*^9}, {3.622302533207438*^9, 
   3.6223025427673693`*^9}, {3.6224581049336424`*^9, 
   3.622458120587368*^9}},ExpressionUUID->"9edef59d-c2eb-4219-a9b8-\
4c41b6badc9c"],

Cell["Find the name of a weather station near Bloomington, IL.", "Text",ExpressionUUID->"9de0cbb1-8d69-482b-997f-2d24de531337"],

Cell[BoxData[
 RowBox[{"WeatherData", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<Bloomington\>\"", ",", "\"\<Illinois\>\""}], "}"}], ",", 
   "\"\<StationName\>\""}], "]"}]], "Input",
 CellChangeTimes->{{3.500886829931927*^9, 3.500886869423236*^9}, {
  3.500886972370963*^9, 
  3.500886978816545*^9}},ExpressionUUID->"6adc9565-7626-480e-a156-\
d70ea22f8df4"],

Cell["\<\
Get the average daily wind speed for the area beginning in the year 2000.\
\>", "Text",
 CellChangeTimes->{{3.500887691635268*^9, 
  3.5008877384338713`*^9}},ExpressionUUID->"cbd75f61-5ded-4ed0-a139-\
30e6ddb7ebf7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"wsData", "=", 
   RowBox[{"WeatherData", "[", 
    RowBox[{"\"\<KBMI\>\"", ",", "\"\<MeanWindSpeed\>\"", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"2000", ",", "1", ",", "1"}], "}"}], ",", 
       RowBox[{"Date", "[", "]"}], ",", "\"\<Day\>\""}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.500887031749962*^9, 3.500887083850607*^9}, {
  3.500887749166108*^9, 
  3.500887759237588*^9}},ExpressionUUID->"40ecb8ad-0365-4248-8fd6-\
b1067cd7d8a3"],

Cell[BoxData[
 RowBox[{"WeatherData", "[", 
  RowBox[{
  "\"\<KBMI\>\"", ",", "\"\<MeanWindSpeed\>\"", ",", "\"\<Units\>\""}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.500892317453417*^9, 
  3.500892320227844*^9}},ExpressionUUID->"45e59d76-b90c-4b35-8dfa-\
0d383b3a8e54"],

Cell["This is a reasonably large dataset of ordered pairs.", "Text",
 CellChangeTimes->{{3.57294100654396*^9, 3.57294102551759*^9}, 
   3.580039348638996*^9},ExpressionUUID->"0a163e65-3c80-41e5-9d08-\
20a2a6be942a"],

Cell[BoxData[
 RowBox[{"Dimensions", "[", "wsData", "]"}]], "Input",
 CellChangeTimes->{{3.572940971086354*^9, 
  3.572940998012711*^9}},ExpressionUUID->"53f9bc7e-73dd-4a40-b1ad-\
5ee57305fb8c"],

Cell[TextData[{
 "The data has come into the program as a ",
 StyleBox[ButtonBox["TimeSeries",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/TimeSeries"],
  FontWeight->"Bold"],
 " object. "
}], "Text",
 CellChangeTimes->{{3.617116059244747*^9, 3.6171160931196547`*^9}, {
  3.631645479725909*^9, 
  3.631645479777261*^9}},ExpressionUUID->"2b17ead2-fa55-4541-ac6c-\
91d0621348e0"],

Cell[BoxData["wsData"], "Input",
 CellChangeTimes->{{3.617116048394034*^9, 
  3.6171160499711947`*^9}},ExpressionUUID->"90f921d6-2623-4b9a-b59f-\
0442dbfade87"],

Cell[BoxData[
 RowBox[{"wsData", "[", "\"\<Properties\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.61711550241907*^9, 
  3.617115526365306*^9}},ExpressionUUID->"3bf4228d-3055-4d43-9b29-\
868cea3f782c"],

Cell[BoxData[
 RowBox[{"wData", "=", 
  RowBox[{"wsData", "[", "\"\<Path\>\"", "]"}]}]], "Input",
 CellChangeTimes->{{3.617115475655478*^9, 3.617115497122083*^9}, {
  3.617115539774262*^9, 
  3.617115543037977*^9}},ExpressionUUID->"b7f1327b-f443-4955-9211-\
09123ba3407a"],

Cell[BoxData[
 RowBox[{"Take", "[", 
  RowBox[{"wData", ",", "5"}], "]"}]], "Input",
 CellChangeTimes->{{3.5800394095700502`*^9, 3.580039450739506*^9}, 
   3.617115462360353*^9, 
   3.6171155511591253`*^9},ExpressionUUID->"79a96475-c2df-41c5-8da6-\
c32f9d6ef355"],

Cell["\<\
The entries are ordered pairs consisting of the date and the average wind \
speed for the day. You will need to extract the speeds from the data.\
\>", "Text",
 CellChangeTimes->{{3.631645497171967*^9, 
  3.6316454974672313`*^9}},ExpressionUUID->"de36642f-9834-4511-a116-\
c6b424280fff"],

Cell[TextData[{
 "Use the ",
 StyleBox[ButtonBox["Part",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Part"],
  FontWeight->"Bold"],
 " function to get a list of the daily average speeds, convert to new units, \
and visualize the data in a histogram."
}], "Text",
 CellChangeTimes->{{3.5772055400636787`*^9, 3.577205546140512*^9}, {
  3.631645485420442*^9, 
  3.631645492531172*^9}},ExpressionUUID->"ac128125-674f-4a1a-91f7-\
9180c732fea4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"wndData", "=", 
   RowBox[{"1000", " ", 
    RowBox[{
     RowBox[{"wData", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}], "/", 
     SuperscriptBox["60", "2"]}]}]}], ";"}], "\n", 
 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"histplotpdf", ",", "histplotcdf"}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Histogram", "[", 
       RowBox[{"wndData", ",", "45", ",", "\"\<PDF\>\""}], "]"}], ",", 
      RowBox[{"Histogram", "[", 
       RowBox[{"wndData", ",", "45", ",", "\"\<CDF\>\""}], "]"}]}], "}"}]}], 
   ",", 
   RowBox[{"ImageSize", "\[Rule]", " ", "Large"}]}], "]"}]}], "Input",
 CellChangeTimes->{
  3.572702920579695*^9, {3.572702974850342*^9, 3.572703029496923*^9}, {
   3.572885877318836*^9, 3.572885886357115*^9}, {3.572885922797658*^9, 
   3.572885959712307*^9}, {3.61711559374187*^9, 3.617115599844797*^9}, 
   3.61711563895013*^9},ExpressionUUID->"26ba26e5-de78-4c33-b901-\
7f900b070adc"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"e93e508a-e7d0-45d1-ae2a-cd5fef54208b"],

Cell[CellGroupData[{

Cell["Weather Data", "Section",
 CellChangeTimes->{{3.572701347340774*^9, 
  3.572701349740839*^9}},ExpressionUUID->"24950aa4-4501-490c-9513-\
841633416506"],

Cell[TextData[{
 "Since wind speed can be assumed to vary continuously, estimate a \
distribution for observations using the ",
 StyleBox[ButtonBox["SmoothKernelDistribution ",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SmoothKernelDistribution"],
  FontWeight->"Bold"],
 "function. "
}], "Text",
 CellChangeTimes->{{3.577205557808166*^9, 3.577205572016315*^9}, {
   3.632233595869772*^9, 3.63223364168778*^9}, 
   3.632508179900094*^9},ExpressionUUID->"bd17df28-e5fb-4046-a466-\
29f215ed36bc"],

Cell["\<\
Find an estimated distribution and visualize the results. This assumes the \
data comes from a continuous distribution.\
\>", "Text",
 CellChangeTimes->{{3.500889832731764*^9, 3.500889867050887*^9}, {
   3.5009968609698057`*^9, 3.500996865367896*^9}, {3.572885983773909*^9, 
   3.572886006852174*^9}, 
   3.580039519578459*^9},ExpressionUUID->"faa8264b-1f54-46d4-9c6e-\
be48c0f4c1b5"],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[ScriptCapitalD]", "e"], "=", 
  RowBox[{"SmoothKernelDistribution", "[", "wndData", "]"}]}]], "Input",
 CellChangeTimes->{{3.572861912825464*^9, 
  3.572861913662856*^9}},ExpressionUUID->"06121b22-6ce7-4d56-89fa-\
9558d4f7d575"],

Cell["\<\
While the ability to estimate a distribution is a valuable tool in \
statistical analysis, one must take care how the distribution will be used. \
It is possible for estimated distributions to take very tiny negative values \
in the tails. Estimated distributions of this sort behave in a manner similar \
to interpolating functions and can have unexpected wiggles.\
\>", "Text",
 CellChangeTimes->{{3.572701652418126*^9, 3.572701764722221*^9}, {
  3.572701895974721*^9, 3.572701956469676*^9}, {3.572702207963841*^9, 
  3.572702299242981*^9}, {3.580039549945454*^9, 
  3.580039551304195*^9}},ExpressionUUID->"52703220-41be-4a2f-bf0d-\
8281a3708cfe"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{"histplotpdf", ",", "\[IndentingNewLine]", 
    RowBox[{"estplot", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"PDF", "[", 
        RowBox[{
         SubscriptBox["\[ScriptCapitalD]", "e"], ",", "x"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "13"}], "}"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Red"}], "}"}]}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.572703078699288*^9, 3.572703079250177*^9}, {
  3.572861928902144*^9, 
  3.572861930356749*^9}},ExpressionUUID->"ab05672a-5f34-490a-b81d-\
db141db57d69"],

Cell[TextData[{
 "You can get an estimate of the support interval for the distribution using \
the ",
 StyleBox[ButtonBox["FindRoot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/FindRoot"],
  FontWeight->"Bold"],
 " function. It appears from the graph that the density function gets very \
close to zero around 13, so use that as a start value."
}], "Text",
 CellChangeTimes->{{3.572861523244798*^9, 3.572861594803334*^9}, {
   3.572861818601742*^9, 3.572861833631337*^9}, 3.577205581505664*^9, {
   3.58003959138476*^9, 3.580039618766876*^9}, {3.6322336606232157`*^9, 
   3.632233690725355*^9}},ExpressionUUID->"39ec09b5-3f32-453b-89fc-\
edf99d0b5ee2"],

Cell["\<\
Having derived the probability density function, you also have the cumulative \
distribution function.\
\>", "Text",
 CellChangeTimes->{{3.572886038207614*^9, 3.572886080085591*^9}, 
   3.580039634935923*^9, {3.632233697292889*^9, 
   3.632233697566283*^9}},ExpressionUUID->"4ff7d641-64fd-428c-9ae2-\
c7e0c4368b56"],

Cell[BoxData[
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"CDF", "[", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalD]", "e"], ",", "x"}], "]"}], "\[Equal]", 
    "1"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "13.5"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.572861767565661*^9, 3.572861792929041*^9}, {
  3.572861935701887*^9, 
  3.572861936595655*^9}},ExpressionUUID->"79edeb81-842e-477a-bd03-\
1bb60efd843d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"db35424c-ee65-47fd-89fc-1cc8a5fd2cd2"],

Cell[CellGroupData[{

Cell["Weather Data", "Section",
 CellChangeTimes->{{3.5727025987171087`*^9, 
  3.572702601368005*^9}},ExpressionUUID->"52130a16-1653-45a4-9973-\
92443c4b348d"],

Cell[TextData[{
 "An alternate approach would be to assume you know something of the type of \
distribution with which to model your data. Use an ",
 StyleBox[ButtonBox["ExtremeValueDistribution",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ExtremeValueDistribution"],
  FontWeight->"Bold"],
 ". Named distributions will remain non-negative throughout the support \
interval."
}], "Text",
 CellChangeTimes->{{3.572701383021233*^9, 3.572701394803804*^9}, {
   3.572701966261746*^9, 3.57270201858224*^9}, 3.572880183939227*^9, {
