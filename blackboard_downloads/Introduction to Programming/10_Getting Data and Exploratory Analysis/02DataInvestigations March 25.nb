52d08e59277b"],

Cell[BoxData[
 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Show", "[", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{"histplotpdf", ",", "\[IndentingNewLine]", 
        RowBox[{"estplot", "=", " ", 
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"PDF", "[", 
            RowBox[{
             SubscriptBox["\[ScriptCapitalD]", "p"], ",", "x"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "0", ",", "14"}], "}"}], ",", 
           RowBox[{"PlotStyle", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"Thick", ",", "Red"}], "}"}]}]}], "]"}]}]}], 
       "\[IndentingNewLine]", "}"}], "]"}], ",", 
     RowBox[{"Show", "[", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{"histplotcdf", ",", "\[IndentingNewLine]", 
        RowBox[{"estplot", "=", " ", 
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"CDF", "[", 
            RowBox[{
             SubscriptBox["\[ScriptCapitalD]", "p"], ",", "x"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "0", ",", "14"}], "}"}], ",", 
           RowBox[{"PlotStyle", "\[Rule]", 
