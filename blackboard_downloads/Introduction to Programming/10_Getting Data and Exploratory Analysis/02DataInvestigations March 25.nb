Cell[CellGroupData[{

Cell["Geologic Data", "Section",
 CellChangeTimes->{{3.5728790247509727`*^9, 
  3.5728790322841673`*^9}},ExpressionUUID->"0c310016-036d-4738-bbd0-\
dd85f31c04a8"],

Cell["\<\
Look for patterns in the data. The scales are very different, as can be seen \
from the values on the horizontal axes.\
\>", "Text",
 CellChangeTimes->{{3.5728790759475117`*^9, 3.572879141765123*^9}, {
  3.58004003415843*^9, 
  3.580040045516901*^9}},ExpressionUUID->"1d6f0f6a-8966-4b8d-a2af-\
b22809c4fcea"],

Cell[BoxData[
 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Histogram", "[", 
      RowBox[{"dur", ",", "12", ",", "\"\<PDF\>\"", ",", 
       RowBox[{
       "ChartElementFunction", "\[Rule]", " ", "\"\<GlassRectangle\>\""}], 
       ",", 
       RowBox[{"PlotLabel", "\[Rule]", " ", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Duration\>\"", ",", "\"\<Text\>\""}], "]"}]}]}], "]"}], 
     ",", 
     RowBox[{"Histogram", "[", 
      RowBox[{"wait", ",", "12", ",", "\"\<PDF\>\"", ",", 
       RowBox[{
       "ChartElementFunction", "\[Rule]", " ", "\"\<GlassRectangle\>\""}], 
       ",", 
       RowBox[{"PlotLabel", "\[Rule]", " ", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Waiting Time\>\"", ",", "\"\<Text\>\""}], "]"}]}]}], 
      "]"}]}], "}"}], ",", 
   RowBox[{"ImageSize", "\[Rule]", " ", "Large"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.57270460139821*^9, 3.5727046137086563`*^9}, {
   3.572865424853466*^9, 3.572865450932177*^9}, {3.572865604304847*^9, 
   3.572865605703475*^9}, {3.572865645377921*^9, 3.572865729552282*^9}, {
   3.572886598707556*^9, 3.572886605314865*^9}, 3.572939830320445*^9, {
   3.572939880073053*^9, 3.57293990389017*^9}, {3.572939986955023*^9, 
   3.572940007607007*^9}, {3.572941845153023*^9, 
   3.572941906562386*^9}},ExpressionUUID->"66be8b10-6d49-4e92-ade4-\
c7fef5ab8e12"],

Cell["Perform a linear rescaling and translation of the data.", "Text",
 CellChangeTimes->{{3.572879174785652*^9, 
  3.572879195719778*^9}},ExpressionUUID->"f8ba0a11-9619-4689-9f39-\
6f938849d5ed"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sclData1", "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"dat1", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Min", "[", "#", "]"}], ",", 
            RowBox[{"Max", "[", "#", "]"}]}], "}"}], "&"}], "[", "dur", 
         "]"}]}], ",", 
       RowBox[{"dat2", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Min", "[", "#", "]"}], ",", 
            RowBox[{"Max", "[", "#", "]"}]}], "}"}], "&"}], "[", "wait", 
         "]"}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"Rescale", "[", 
        RowBox[{"#", ",", "dat1", ",", "dat2"}], "]"}], "&"}], "/@", 
      "dur"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.57286588770431*^9, 3.572865914390294*^9}, {
  3.57286596005704*^9, 
  3.572865962935485*^9}},ExpressionUUID->"7dedff9b-210b-430b-884c-\
d721c80ac10c"],

Cell[TextData[{
 "Using ",
 StyleBox[ButtonBox["PairedHistogram",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/PairedHistogram"],
  FontWeight->"Bold"],
 " lets you see that the patterns are very similar for the two lists."
}], "Text",
 CellChangeTimes->{{3.572879230627202*^9, 3.572879268729096*^9}, 
   3.577205721252851*^9, {3.5800400698056097`*^9, 3.5800400705883512`*^9}, {
   3.632233984448474*^9, 
   3.632234003737821*^9}},ExpressionUUID->"e528374c-2226-4c48-bb55-\
3506be38243c"],

Cell[BoxData[
 RowBox[{"PairedHistogram", "[", 
  RowBox[{"sclData1", ",", "wait", ",", "12", ",", "\"\<PDF\>\"", ",", 
   RowBox[{"ChartElementFunction", "\[Rule]", " ", "\"\<GlassRectangle\>\""}],
    ",", 
   RowBox[{"ChartLabels", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{
