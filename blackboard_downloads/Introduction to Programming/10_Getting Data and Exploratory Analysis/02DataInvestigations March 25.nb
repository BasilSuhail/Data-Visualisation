Cell[CellGroupData[{

Cell["Maryland Pick 3 Lottery", "Section",
 CellChangeTimes->{
  3.5729406097098*^9},ExpressionUUID->"1661c2f4-7cfe-43b2-b88c-b91af1196a36"],

Cell[TextData[{
 "In the previous slide, you visually inspected the data to see if it \
appeared consistent with coming from a population having a uniform \
distribution. Now test that directly. ",
 StyleBox[ButtonBox["DistributionFitTest",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/DistributionFitTest"],
  FontWeight->"Bold"],
 " can be used to determine if your assumptions about the fairness of the \
lottery are reasonable."
}], "Text",
 CellChangeTimes->{{3.5726963930681047`*^9, 3.572696453499203*^9}, 
   3.572860159019119*^9, {3.5729407261591187`*^9, 3.5729408289004097`*^9}, 
   3.577205330620984*^9, 3.580039161924259*^9, {3.6316452853029623`*^9, 
   3.631645309213305*^9}},ExpressionUUID->"ea86bf22-d0b8-4251-b989-\
7c51c213b761"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["DistributionFitTest",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/DistributionFitTest"],
  FontWeight->"Bold"],
 " with the argument \[OpenCurlyDoubleQuote]HypothesisTestData\
\[CloseCurlyDoubleQuote] returns a test data object that can be used to get \
more information."
}], "Text",
 CellChangeTimes->{{3.572885462021173*^9, 3.572885530780211*^9}, {
   3.577205334941435*^9, 3.577205343083164*^9}, 3.5802231953002987`*^9, {
   3.631645320055326*^9, 3.631645334521434*^9}, 3.632508137501707*^9, 
   3.632663986682138*^9},ExpressionUUID->"03b38bb1-24bd-437e-9192-\
8cb5248d0cf4"],

Cell[BoxData[
 RowBox[{"ftTst", "=", " ", 
  RowBox[{"DistributionFitTest", "[", 
   RowBox[{"lotDat", ",", 
    RowBox[{"UniformDistribution", "[", 
     RowBox[{"{", 
      RowBox[{"0", ",", "999"}], "}"}], "]"}], ",", 
    "\"\<HypothesisTestData\>\""}], "]"}]}]], "Input",
 CellChangeTimes->{{3.572275434053795*^9, 3.57227549623944*^9}, {
  3.572275580547162*^9, 3.572275591184846*^9}, {3.572696362139576*^9, 
  3.572696363571815*^9}},ExpressionUUID->"c44d639a-f4e5-453c-8e0c-\
891036624664"],

Cell["Here are the properties available from the test.", "Text",
 CellChangeTimes->{{3.57269647228438*^9, 3.572696492395915*^9}, {
  3.572885535758*^9, 
  3.5728855396841993`*^9}},ExpressionUUID->"d2fb547d-d370-45dd-aeed-\
3cfae848aae9"],

Cell[BoxData[
 RowBox[{"ftTst", "[", "\"\<Properties\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.572275511091035*^9, 
  3.572275555984557*^9}},ExpressionUUID->"f250ee92-ed9e-4637-91cb-\
537099823d16"],

Cell["\<\
The automatic test is based on the structure of the data and the choice of \
distribution. Other tests are available but may not return values relevant to \
the situation.\
\>", "Text",
 CellChangeTimes->{{3.572696590336398*^9, 3.5726966663991127`*^9}, {
  3.572697839667249*^9, 
  3.572697846738657*^9}},ExpressionUUID->"c366f9c8-cb9a-41fe-bc5c-\
37659f7808bf"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"ftTst", "[", "\"\<TestDataTable\>\"", "]"}], ",", "\"\<  \>\"", 
   ",", 
   RowBox[{"ftTst", "[", 
    RowBox[{"\"\<TestDataTable\>\"", ",", "All"}], "]"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.5722756493772173`*^9, 3.5722757023228207`*^9}, {
