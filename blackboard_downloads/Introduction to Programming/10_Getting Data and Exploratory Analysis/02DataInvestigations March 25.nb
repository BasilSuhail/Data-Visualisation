Cell[CellGroupData[{

Cell["Maryland Pick 3 Lottery: Discrete", "Section",
 CellChangeTimes->{{3.572276652139078*^9, 3.57227668705789*^9}, {
  3.572700633482959*^9, 
  3.5727006808985863`*^9}},ExpressionUUID->"4a912e38-8af3-4ef2-b69b-\
ec82ade71ab7"],

Cell["\<\
The lottery.txt file contains information on the Maryland Pick 3 lottery. The \
winning numbers are returned as three-digit numbers from 000 to 999.\
\>", "Text",
 CellChangeTimes->{{3.5726918896621943`*^9, 3.572691940047673*^9}, {
   3.572695884445765*^9, 3.5726959206170397`*^9}, 3.5800390679097447`*^9, 
   3.580223106985123*^9},ExpressionUUID->"ef8d19ef-e3b0-42b1-ae42-\
46442672cc71"],

Cell[BoxData[
 RowBox[{
  RowBox[{"lotDat", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<lottery.txt\>\"", ",", "\"\<List\>\""}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.5722749579550943`*^9, 
  3.57227507978426*^9}},ExpressionUUID->"14f7424f-22fa-40ca-972f-\
e65248392e28"],

Cell[TextData[{
 StyleBox[ButtonBox["Dimensions",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Dimensions"],
  FontWeight->"Bold"],
 " is a good function to use to make sure the data is what you expect. The ",
 StyleBox[ButtonBox["Part",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Part"],
  FontWeight->"Bold"],
 " function reveals the form of the observations."
}], "Text",
 CellChangeTimes->{{3.5726959353324833`*^9, 3.572695982274125*^9}, {
  3.572696056275119*^9, 3.572696093308223*^9}, {3.577205148921472*^9, 
  3.577205167393244*^9}, {3.5800390847090693`*^9, 3.580039085523639*^9}, {
  3.631645150602498*^9, 
  3.631645177169611*^9}},ExpressionUUID->"160890a4-c571-49a2-ad0a-\
a787594738db"],

Cell[BoxData[
 RowBox[{"Column", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Dimensions", "[", "lotDat", "]"}], ",", "\"\<  \>\"", ",", 
    RowBox[{"lotDat", "[", 
     RowBox[{"[", 
      RowBox[{";;", "5"}], "]"}], "]"}]}], "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.572275084882218*^9, 3.572275090736435*^9}, {
  3.572696005828655*^9, 3.572696024324853*^9}, {3.573979730316655*^9, 
  3.573979769060701*^9}},ExpressionUUID->"c380d75c-7798-49c0-ad71-\
85a9f586dd30"],

Cell[TextData[{
 "You can use ",
 StyleBox[ButtonBox["Tally",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Tally"],
  FontWeight->"Bold"],
 " together with ",
 StyleBox[ButtonBox["Select",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Select"],
  FontWeight->"Bold"],
 " to find out if any numbers were multiple winners. ",
 StyleBox[ButtonBox["Select",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Select"],
  FontWeight->"Bold"],
 " uses a function to extract values from an array."
}], "Text",
 CellChangeTimes->{{3.572696101715581*^9, 3.572696140413148*^9}, {
  3.573979690817626*^9, 3.573979711193495*^9}, {3.577205178907474*^9, 
  3.577205186509087*^9}, {3.631645179939793*^9, 
  3.631645216313647*^9}},ExpressionUUID->"098752f2-6a83-44d5-ab24-\
f3f8d2ca9f64"],

Cell[BoxData[
 RowBox[{"Select", "[", 
  RowBox[{
   RowBox[{"Tally", "[", "lotDat", "]"}], ",", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"#", "[", 
       RowBox[{"[", "2", "]"}], "]"}], ">", "1"}], "&"}], ")"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.572276739363744*^9, 
  3.572276786061739*^9}},ExpressionUUID->"bf717b33-f489-404c-9ec2-\
10c518d58a82"],

Cell[TextData[{
 "If the lottery is fair, you would expect the winning numbers to come from a \
uniform distribution defined on the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"0", ",", "999"}], "}"}], $CellContext`MR]],ExpressionUUID->
  "87b9f4d9-216b-4d0a-b205-2872b7ce7138"],
 "."
}], "Text",
 CellChangeTimes->{{3.572696197750311*^9, 3.572696248911311*^9}, {
  3.5728853889794207`*^9, 3.572885393849464*^9}, {3.577205200410139*^9, 
  3.577205220324005*^9}, {3.580039109573794*^9, 3.580039117314556*^9}, {
  3.631645220527322*^9, 
  3.631645220784811*^9}},ExpressionUUID->"c9124ed8-feea-4c7b-952d-\
1c61b8a5cd03"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Histogram", "[", 
    RowBox[{"lotDat", ",", "10"}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DistributionChart", "[", "lotDat", "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"BoxWhiskerChart", "[", "lotDat", "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"QuantilePlot", "[", 
    RowBox[{"lotDat", ",", 
     RowBox[{"UniformDistribution", "[", 
      RowBox[{"{", 
       RowBox[{"0", ",", "999"}], "}"}], "]"}]}], "]"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.572275096185122*^9, 3.572275103577076*^9}, {
  3.572275150620048*^9, 3.572275151431943*^9}, {3.572276402619165*^9, 
  3.572276441155525*^9}, {3.572276492114967*^9, 3.572276492849903*^9}, {
  3.572696172004146*^9, 3.572696175976285*^9}, {3.573979809614645*^9, 
  3.573979818926185*^9}},ExpressionUUID->"f75bc0cc-77b8-42f5-accd-\
353aae14af1c"],

Cell[TextData[{
 "There are many functions in the Wolfram Language for getting descriptive \
statistics. The ",
 StyleBox[ButtonBox["Through",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Through"],
  FontWeight->"Bold"],
 " function allows you to apply a number of functions to the same argument. \
",
 StyleBox[ButtonBox["N",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/N"],
  FontWeight->"Bold"],
 " converts exact values to numerical approximations."
}], "Text",
 CellChangeTimes->{{3.5726963122511063`*^9, 3.5726963362970467`*^9}, {
  3.572885409172095*^9, 3.572885438394486*^9}, {3.57397984886871*^9, 
  3.57397988274063*^9}, {3.5772052993306723`*^9, 3.577205312215459*^9}, {
  3.6223022396029677`*^9, 3.6223022649522552`*^9}, {3.622382639195005*^9, 
  3.622382642383725*^9}, {3.622458072016552*^9, 
  3.62245807227777*^9}},ExpressionUUID->"bcd38918-0ffd-4ce5-b8c3-\
4877a27a4fcd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Through", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "Mean", ",", "Median", ",", "Variance", ",", "StandardDeviation"}], 
     "}"}], "[", "lotDat", "]"}], "]"}], "//", "N"}]], "Input",
 CellChangeTimes->{{3.572275243656378*^9, 3.572275296956105*^9}, {
  3.572696342682848*^9, 
  3.5726963440912323`*^9}},ExpressionUUID->"57e2e4a1-8d71-45e2-bebe-\
7b241da03707"]
}, Open  ]]
}, Open  ]],

