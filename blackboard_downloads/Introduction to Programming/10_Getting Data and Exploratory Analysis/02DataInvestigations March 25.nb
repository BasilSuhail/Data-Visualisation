Cell[TextData[{
 "Estimate the distribution parameters and construct the distribution. You \
will see in the next section that you can use the ",
 StyleBox[ButtonBox["Estimated Distribution",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/EstimatedDistribution"],
  FontWeight->"Bold"],
 " function to get the distribution directly."
}], "Text",
 CellChangeTimes->{{3.5008921151281543`*^9, 3.500892142998997*^9}, {
