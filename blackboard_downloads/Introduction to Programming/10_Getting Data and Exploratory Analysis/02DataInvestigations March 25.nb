Cell["Files and File Names", "Section",
 CellChangeTimes->{{3.572691137340128*^9, 
  3.572691143736129*^9}},ExpressionUUID->"284a3bed-8bcc-409d-81ab-\
94a1085b4eaf"],

Cell["\<\
It is possible to have a selection of cells evaluated when you first start to \
work with a notebook. This is done by setting the properties for a cell or \
group of cells. Choose Cell Properties from the Cell menu and click \
Initialization Cell or Initialization Group. Now whenever you open that \
notebook and do any evaluation, you will be asked to allow the initialization \
to happen before any other evaluations take place. That has been done in this \
notebook to set the directory for the session. The initialization cell has \
been placed at the end of the notebook so the user does not have to see the \
cell unless they wish to.\
\>", "Text",
 CellChangeTimes->{{3.572691152345883*^9, 3.572691452926235*^9}, {
   3.572691489819159*^9, 3.5726915117034683`*^9}, {3.572691666599947*^9, 
   3.5726917208916407`*^9}, {3.577205013116076*^9, 3.577205015907176*^9}, 
   3.580039024806098*^9, {3.622382615404896*^9, 3.622382620825057*^9}, {
   3.622458026562392*^9, 
   3.622458031770582*^9}},ExpressionUUID->"8c688b7f-9f22-4351-8b54-\
24d4fed25bc5"],

Cell["This returns the location of the current working directory.", "Text",
 CellChangeTimes->{{3.572691737300185*^9, 
  3.5726917536043253`*^9}},ExpressionUUID->"b2d6505e-b0c8-433c-a5b4-\
cdda556b0cba"],

Cell[BoxData[
 RowBox[{"Directory", "[", "]"}]], "Input",
 CellChangeTimes->{{3.572276953961441*^9, 
  3.572276956640279*^9}},ExpressionUUID->"3e45c07a-6fbc-43ce-b86d-\
51d62362a379"],

Cell[TextData[{
 "Using the ",
 StyleBox[ButtonBox["FileNames",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/FileNames"],
  FontWeight->"Bold"],
 " function with no arguments will return all of the files and folders in the \
current working directory. Use ",
 StyleBox[ButtonBox["Grid",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Grid"],
  FontWeight->"Bold"],
 " and ",
 StyleBox[ButtonBox["Partition",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Partition"],
  FontWeight->"Bold"],
 " to make the list easier to read."
}], "Text",
 CellChangeTimes->{{3.57269176840492*^9, 3.572691806645299*^9}, {
  3.572691838663535*^9, 3.572691849109993*^9}, {3.57397958817846*^9, 
  3.573979616247292*^9}, {3.577205117369589*^9, 3.577205125025519*^9}, {
  3.631645040119883*^9, 
  3.631645079533097*^9}},ExpressionUUID->"742845b6-274a-45d2-87eb-\
eb913a499c7e"],

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"Partition", "[", 
    RowBox[{
     RowBox[{"FileNames", "[", "]"}], ",", "4", ",", "4", ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", 
       RowBox[{"-", "1"}]}], "}"}], ",", "\"\<\>\""}], "]"}], ",", 
   RowBox[{"Alignment", "\[Rule]", " ", "Left"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.572274906836565*^9, 3.572274912606995*^9}, {
  3.5739794766176643`*^9, 
  3.573979553600851*^9}},ExpressionUUID->"c3d11797-b752-43be-9069-\
