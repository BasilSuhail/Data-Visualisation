      "\[IndentingNewLine]", "]"}]}], "}"}], ",", 
   RowBox[{"ImageSize", "\[Rule]", " ", "Large"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.572703121331291*^9, 3.572703184259737*^9}, {
  3.572703260814839*^9, 3.572703310856522*^9}, {3.572861985056022*^9, 
  3.5728619925427113`*^9}},ExpressionUUID->"5c4611cb-7491-4556-90b9-\
9edf6eb06cde"],

Cell[TextData[{
 "If you assume the generator you are using for your analysis here requires \
3.5 m/s wind speed to generate electricity, you can use the ",
 StyleBox[ButtonBox["Probability",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Probability"],
  FontWeight->"Bold"],
 " function to estimate what proportion of time the generator will be \
contributing to the grid."
}], "Text",
 CellChangeTimes->{{3.572702476031822*^9, 3.572702493318597*^9}, 
   3.58003978755785*^9, 3.580223278452448*^9, {3.580223387307847*^9, 
   3.580223388809125*^9}, {3.632233761803808*^9, 3.632233772798735*^9}, {
   3.632233894531493*^9, 
   3.632233906269298*^9}},ExpressionUUID->"9b0c22d6-a694-4f78-9fde-\
95a2990a4adf"],

Cell["\<\
Based on the data distribution, compute the probability that wind speed is \
greater than a threshold of 3.5 m/s; i.e., estimate the probability that the \
generator is contributing on a given day.\
\>", "Text",
 CellChangeTimes->{{3.5727025529610786`*^9, 3.57270255666327*^9}, {
   3.572703348621446*^9, 3.57270336526121*^9}, {3.580039828755157*^9, 
   3.5800398449454618`*^9}, 
   3.580223415229948*^9},ExpressionUUID->"f20e9f46-ec7e-40cd-aaa6-\
7b8981d3496d"],

Cell[BoxData[
 RowBox[{"Probability", "[", 
  RowBox[{
   RowBox[{"x", ">", "3.5"}], ",", 
   RowBox[{"x", "\[Distributed]", 
    SubscriptBox["\[ScriptCapitalD]", "p"]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.572862009567354*^9, 
  3.5728620099724703`*^9}},ExpressionUUID->"fb74879c-9f01-4e34-96fd-\
448c9a7e9198"],

Cell[TextData[{
 "This leads to a larger support interval for the distribution than you got \
with the ",
 StyleBox[ButtonBox["SmoothKernelDistribution",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SmoothKernelDistribution"],
  FontWeight->"Bold"],
 " function. In general, named distributions allow working with higher \
precision and are more sensitive to small changes in the arguments to the \
functions."
}], "Text",
 CellChangeTimes->{{3.572862715554104*^9, 3.572862740729899*^9}, {
   3.57286277412057*^9, 3.5728628545859*^9}, 3.577205694862754*^9, 
   3.580223439490789*^9, {3.632233777651046*^9, 3.632233795204666*^9}, {
   3.632233919250285*^9, 
   3.63223391972161*^9}},ExpressionUUID->"7578cf8d-2e1a-46df-b4c6-\
aa47e30771ac"],

Cell[BoxData[
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"CDF", "[", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalD]", "p"], ",", "x"}], "]"}], "\[Equal]", 
    "1"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "13.5"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.572862596881977*^9, 
  3.572862598239538*^9}},ExpressionUUID->"0d32ce23-9e4e-4fa1-8fd2-\
06afabc8a68d"],

Cell[TextData[{
 "Checking properties of the distribution ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalD]", "p"], TraditionalForm]], "InlineMath",
  ExpressionUUID->"61a9120e-aa6e-411b-9ce1-d0d2a75ca44e"],
 ", you see that the values are consistent with those of the data."
}], "Text",
 CellChangeTimes->{{3.5729393827101383`*^9, 3.572939449020465*^9}, {
  3.58003991441844*^9, 3.580039918983926*^9}, {3.622458291991217*^9, 
  3.622458309183887*^9}},ExpressionUUID->"d2404e14-cd59-4064-8ff0-\
eb94bd737b74"],

