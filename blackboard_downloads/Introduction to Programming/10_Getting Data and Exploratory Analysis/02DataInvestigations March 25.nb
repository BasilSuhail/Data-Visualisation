Cell[CellGroupData[{

Cell["Geologic Distribution", "Section",
 CellChangeTimes->{{3.5728795622024407`*^9, 
  3.572879569560158*^9}},ExpressionUUID->"c474430c-d259-4494-b3ff-\
033be173e615"],

Cell["\<\
It is important to understand that many calculations are required to \
determine these distributions. In the case of the eruption duration data, you \
see that the histogram is much more ragged and the left peak is skewed. Based \
on how the data was collected, it is not surprising that relative errors \
would be larger for the duration values than for the waiting times. You \
obtain the following result after some time. As can be seen from the plots, \
the calculated distribution appears convincing.\
\>", "Text",
 CellChangeTimes->{{3.572879734039295*^9, 3.572879929071198*^9}, 
   3.572880211148225*^9, 3.572942090332279*^9, {3.572943761345262*^9, 
   3.5729438222393208`*^9}, 3.57398072286915*^9, {3.5800401039817*^9, 
   3.580040140714596*^9}, {3.580223477769312*^9, 3.580223478351728*^9}, {
   3.632234034246891*^9, 
   3.63223404613161*^9}},ExpressionUUID->"bc853a99-e5ee-495a-9248-\
327b6a84a58c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ofDist1", "=", "\n", 
   RowBox[{"MixtureDistribution", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1.0513720343818684`", ",", "1.824654824520609`"}], "}"}], ",", 
     
     RowBox[{"{", 
      RowBox[{
       RowBox[{"DavisDistribution", "[", 
        RowBox[{
        "3.345893079763159`", ",", "6.068407253394212`", ",", 
         "1.400263311906277`"}], "]"}], ",", 
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"4.303179023859618`", ",", "0.39741314842028286`"}], "]"}]}], 
      "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.572869179495941*^9, 3.572869183090338*^9}, {
  3.572879621232126*^9, 
  3.572879660581769*^9}},ExpressionUUID->"db3a5b04-afcc-4692-8c9d-\
bf0a12f2c7d1"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Histogram", "[", 
     RowBox[{"dur", ",", "25", ",", "\"\<PDF\>\""}], "]"}], ",", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"PDF", "[", 
       RowBox[{"ofDist1", ",", "x"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "6"}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", " ", "Red"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", " ", "All"}]}], "]"}]}], "}"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.57277217020425*^9, 3.572772208416189*^9}, {
   3.572773746842444*^9, 3.572773747006488*^9}, 3.572869369271294*^9, {
   3.572869408698268*^9, 3.572869422720087*^9}, 3.572870330005199*^9, {
   3.572870367434772*^9, 3.572870374266272*^9}, 3.5728704156807003`*^9, 
   3.572870459152271*^9, {3.572870529518094*^9, 3.572870530923992*^9}, {
   3.572879697946879*^9, 
   3.572879703279008*^9}},ExpressionUUID->"5c79d490-02d3-432d-8643-\
ea3b8e4eb2f4"],

Cell["\<\
It is important to realize where the distribution being tested comes from. \
The same framework that was used to create the distribution is now being used \
to evaluate the goodness of fit.\
\>", "Text",
 CellChangeTimes->{{3.572879992490691*^9, 3.572880074400404*^9}, {
  3.622303188531704*^9, 
  3.622303192771158*^9}},ExpressionUUID->"27670ce0-93e2-4ba9-8ecb-\
6001f8694806"],

Cell[BoxData[
 RowBox[{"DistributionFitTest", "[", 
  RowBox[{"dur", ",", "ofDist1", ",", "\"\<TestDataTable\>\""}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.572874087858609*^9, 3.572874119631071*^9}, {
  3.572879964525382*^9, 
  3.572879978813739*^9}},ExpressionUUID->"05f3e335-685e-4962-96d0-\
0fbecc1fcee9"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"dur", ",", "wait", ",", "ofDist1", ",", "ofDist2"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.572886694123367*^9, 
  3.5728867333383303`*^9}},ExpressionUUID->"69d47ddd-143c-4e4c-917b-\
3ac860eee62f"]
}, Open  ]]
}, Open  ]],

