  FormBox["\[Mu]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "2eb5c2f5-ba65-468a-b280-888a95bf0262"],
 " and standard deviation ",
 Cell[BoxData[
  FormBox["\[Sigma]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "1650d71f-7729-4b36-a375-36d595a6428a"],
 ". The symbol ",
 Cell[BoxData[
  FormBox["\[Distributed]", TraditionalForm]],ExpressionUUID->
  "ffdb6502-42cf-4d18-958f-1981f9b1e17e"],
