  "]"}]], "Input",ExpressionUUID->"db53cfb2-b7ed-4575-ac8c-7a6459760436"],

Cell[TextData[{
 StyleBox[ButtonBox["NSolve",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NSolve"],
  FontWeight->"Bold"],
 " attempts to find a numerical approximation to the solution of the system \
of equations."
}], "Text",
 CellChangeTimes->{{3.606558826409774*^9, 3.606558828306847*^9}, {
   3.6065588793505993`*^9, 3.606558908135152*^9}, 3.614952337281889*^9, 
