   3.6109839724354596`*^9},ExpressionUUID->"6864f33c-b22b-47ed-a5cc-\
f75371619c1b"],

Cell["\<\
A KdV equation is an integrable PDE that admits soliton solutions. The \
following commands simulate the collision of two solitons with different \
speeds numerically. It takes some time for the simulation to complete.\
\>", "Text",
 CellChangeTimes->{{3.610983943571161*^9, 3.6109839837069902`*^9}, {
   3.610984121554138*^9, 3.610984160193977*^9}, {3.610984242858227*^9, 
   3.610984279585782*^9}, {3.610984310665557*^9, 3.610984313936757*^9}, {
   3.610984354929148*^9, 3.610984435112748*^9}, {3.6119328659988265`*^9, 
   3.6119329159504194`*^9}, {3.6119334187800093`*^9, 3.611933424659421*^9}, {
   3.614952422987687*^9, 3.6149524674334383`*^9}, 3.61503750320021*^9, {
   3.615740304325732*^9, 3.615740304725628*^9}, {3.615740350891378*^9, 
   3.6157403515471168`*^9}},ExpressionUUID->"470933d8-561d-4430-bcf3-\
a0917f08fd14"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}], ",", "t"}], "]"}], "+", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "3"}], "}"}]}], "]"}], "+", 
     RowBox[{"3", 
      RowBox[{"D", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"u", "[", 
          RowBox[{"x", ",", "t"}], "]"}], "2"], ",", "x"}], "]"}]}]}], 
    "\[Equal]", "0"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pbc", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{
        RowBox[{"-", "15"}], ",", "t"}], "]"}], "\[Equal]", 
      RowBox[{"u", "[", 
       RowBox[{"15", ",", "t"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox["u", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"1", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{
        RowBox[{"-", "15"}], ",", "t"}], "]"}], "\[Equal]", 
      RowBox[{
       SuperscriptBox["u", 
