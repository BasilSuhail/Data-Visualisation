Cell[CellGroupData[{

Cell["How Numbers Work in the Wolfram Language ", "Section",
 CellChangeTimes->{{3.562932115262251*^9, 3.562932121524785*^9}, {
  3.6085575318066015`*^9, 3.6085575488212643`*^9}, {3.614339771127781*^9, 
  3.6143397780954785`*^9}, {3.614339809384607*^9, 3.614339818744542*^9}, {
  3.615739203846359*^9, 
  3.615739208346023*^9}},ExpressionUUID->"76b1cf20-96a8-4fc0-8a23-\
9d0438ace309"],

Cell[CellGroupData[{

Cell["Numbers in the Wolfram Language", "Subsection",
 CellChangeTimes->{{3.5618017458010283`*^9, 3.561801764109617*^9}, {
   3.562865394502983*^9, 3.562865406015101*^9}, {3.562930941257785*^9, 
   3.562930943435539*^9}, {3.563867389829905*^9, 3.563867394123258*^9}, {
   3.604164104031564*^9, 3.604164110647564*^9}, {3.608557757597139*^9, 
   3.608557765788958*^9}, 3.6143397888445535`*^9, {3.614339824105078*^9, 
   3.614339832377906*^9}, {3.615739218229122*^9, 
   3.615739218697529*^9}},ExpressionUUID->"72a02536-5169-4f37-bb24-\
b7727b242100"],

Cell[TextData[{
 "To provide the highest computing power, ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " allows three types of numbers: exact, high precision, and machine \
precision. Each of these types both adds power and poses challenges for the \
user. Since the lowest-precision number in a calculation determines the \
precision of the answer, it would seem reasonable to always use exact \
numbers. That can be very computationally expensive. "
}], "Text",
 CellChangeTimes->{{3.5629321258927317`*^9, 3.562932197825217*^9}, 
   3.5642171335978203`*^9, {3.564313840125504*^9, 3.5643138538814783`*^9}, {
   3.565028372144257*^9, 3.565028372240118*^9}, {3.604163787939564*^9, 
   3.604163946529564*^9}, {3.6058079265097933`*^9, 3.605807944119194*^9}, 
   3.608557741557535*^9, {3.608557772269606*^9, 3.608557778277207*^9}, {
   3.614339802424911*^9, 3.614339805688237*^9}, {3.6146158988544707`*^9, 
   3.6146160708899*^9}, {3.614616149568359*^9, 3.614616159063303*^9}, {
   3.614617245340606*^9, 3.614617319321108*^9}, {3.61495156336019*^9, 
   3.61495159326091*^9}, 3.615037216721931*^9, {3.615739226883791*^9, 
   3.6157392453791537`*^9}, {3.615828781701789*^9, 
   3.61582878818013*^9}},ExpressionUUID->"63824c6f-0877-479b-bbd4-\
fb165266c41f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples", "Subsection",
