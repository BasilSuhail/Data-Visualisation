   3.608645750820304*^9, 3.608645756388531*^9}, {3.6086458340625877`*^9, 
   3.608645836031375*^9}, {3.608646059140235*^9, 
   3.6086460665407147`*^9}},ExpressionUUID->"8a80e3f4-1250-4659-8609-\
6787afcbb9a0"],

