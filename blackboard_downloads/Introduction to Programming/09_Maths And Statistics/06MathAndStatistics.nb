Cell[TextData[{
 StyleBox[ButtonBox["Interpolation",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Interpolation"],
  FontWeight->"Bold"],
 " is used in the output of ",
 StyleBox[ButtonBox["NDSolve",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NDSolve"],
  FontWeight->"Bold"],
 " to represent the solution."
}], "Text",
 CellChangeTimes->{{3.608647328295955*^9, 3.608647364905615*^9}, {
   3.608647433892513*^9, 3.608647435003624*^9}, 3.614952619833886*^9, 
   3.615037542958172*^9, {3.615740726679312*^9, 3.615740746954454*^9}, 
   3.615829252276394*^9},ExpressionUUID->"3af02b33-fd44-4210-a9b7-\
ac46fada49e5"],

Cell[BoxData[
 RowBox[{"NDSolve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"x", "''"}], "[", "t", "]"}], "\[Equal]", 
      RowBox[{"-", 
       RowBox[{"x", "[", "t", "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"x", "[", "0", "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{
      RowBox[{
