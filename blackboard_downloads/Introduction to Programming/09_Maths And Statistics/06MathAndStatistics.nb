aa20aa89196f"],

Cell[BoxData[
 RowBox[{"roots", "=", 
  RowBox[{"NSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"z", "+", 
         RowBox[{"Sin", "[", "z", "]"}]}], "]"}], "\[Equal]", 
       RowBox[{"Cos", "[", 
        RowBox[{"z", "+", 
         RowBox[{"Cos", "[", "z", "]"}]}], "]"}]}], ",", 
      RowBox[{
       RowBox[{"-", "3"}], "<", 
       RowBox[{"Re", "[", "z", "]"}], "<", "3"}], ",", 
      RowBox[{
       RowBox[{"-", "3"}], "<", 
       RowBox[{"Im", "[", "z", "]"}], "<", "3"}]}], "}"}], ",", "z"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.601777319380769*^9, 3.60177731964578*^9}, {
