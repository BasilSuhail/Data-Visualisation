e27c5bcad14e"],

Cell[TextData[{
 "There is a difference between calling ",
 StyleBox[ButtonBox["NSolve",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NSolve"],
  FontWeight->"Bold"],
 " and having ",
 StyleBox[ButtonBox["N",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/N"],
  FontWeight->"Bold"],
 " act on the result of a ",
 StyleBox[ButtonBox["Solve",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Solve"],
  FontWeight->"Bold"],
 " function."
}], "Text",
 CellChangeTimes->{{3.636476381975491*^9, 3.636476399416291*^9}, {
  3.63794583547637*^9, 
  3.6379458752460575`*^9}},ExpressionUUID->"d41b7b5c-16fd-4128-8c47-\
3bae9df3228c"],

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"x", "^", "5"}], "-", 
      RowBox[{"2", "x"}], "+", "3"}], "\[Equal]", "0"}], ",", "x"}], "]"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.636476400882691*^9, 
  3.636476414314292*^9}},ExpressionUUID->"c3f23a62-4b99-4d26-a7b3-\
daf0773e107b"],

Cell[TextData[{
 "While not apparent from the last output, ",
 StyleBox["N[Solve[...", "MR"],
 " first calculates the ",
 StyleBox[ButtonBox["Solve",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Solve"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.636476421615091*^9, 3.636476443845092*^9}, 
