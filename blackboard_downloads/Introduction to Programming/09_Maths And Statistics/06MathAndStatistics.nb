  3.615037222504093*^9}},ExpressionUUID->"e516e992-bc6f-4cc2-88a6-\
756118229c53"],

Cell[CellGroupData[{

Cell["Exact", "Subsubsection",
 CellChangeTimes->{{3.615037220365949*^9, 3.615037222504093*^9}, {
  3.651376391675312*^9, 
  3.651376399907054*^9}},ExpressionUUID->"ee8e5909-4170-4d20-9ab2-\
385e7d51463f"],

Cell[TextData[{
 "This example uses exact arithmetic. Note how complicated the result has \
become after only two iterations of the ",
 StyleBox["newton",
  FontWeight->"Bold"],
 " function."
}], "Text",
 CellChangeTimes->{{3.6146171841698523`*^9, 3.614617219498795*^9}, {
   3.614617328945828*^9, 3.614617370380267*^9}, 3.614951602556143*^9, {
   3.615037254774905*^9, 3.615037257486403*^9}, 3.615037363650337*^9, 
   3.615739255866115*^9, 
   3.6158288003153667`*^9},ExpressionUUID->"5c10f026-0501-4415-b1d9-\
0c440c971f87"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", " ", 
  RowBox[{
   SuperscriptBox["x", "2"], "+", " ", 
   RowBox[{"2", " ", "x"}], " ", "-", "3"}]}]], "Input",
 CellChangeTimes->{{3.614616976104671*^9, 
  3.614617025967547*^9}},ExpressionUUID->"0ce7e616-f5d9-4658-84b9-\
fe4acd00486d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"newton", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"f", ",", "x0"}], "}"}], ",", 
     RowBox[{"x0", "-", 
      RowBox[{
       RowBox[{"f", "[", "x0", "]"}], "/", 
       RowBox[{
        RowBox[{"f", "'"}], "[", "x0", "]"}]}]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{
  3.61461704131349*^9},ExpressionUUID->"9e9a5189-8773-4616-9fe5-78bbdadd4646"],

Cell[BoxData[
 RowBox[{"Nest", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"newton", "[", 
     RowBox[{"f", ",", "#"}], "]"}], "&"}], ",", 
   SqrtBox["2"], ",", "2"}], "]"}]], "Input",
 CellChangeTimes->{{3.614617047796161*^9, 3.614617073611267*^9}, {
  3.6146171078373017`*^9, 
  3.6146171756179*^9}},ExpressionUUID->"f5d9b915-2741-490a-8a0b-b23323b12f99"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

