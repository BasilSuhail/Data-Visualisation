Cell[CellGroupData[{

Cell["Machine", "Subsubsection",
 CellChangeTimes->{{3.615037220365949*^9, 3.615037222504093*^9}, {
  3.651376391675312*^9, 
  3.65137641013844*^9}},ExpressionUUID->"c843e8dc-11c0-4a70-a40f-\
405c34fb5c9f"],

Cell[TextData[{
 "Machine-precision numbers have roughly 16 places of precision, and this can \
lead to large round-off errors, as is shown in this example. The difficulty \
here arises from the ",
 StyleBox[ButtonBox["LegendreP",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/LegendreP"],
  FontWeight->"Bold"],
 " function, which with these arguments leads to a very high-degree \
polynomial and causes round-off errors to become very large."
}], "Text",
 CellChangeTimes->{{3.614617382957094*^9, 3.614617461178052*^9}, {
  3.614617501965876*^9, 3.614617576193597*^9}, {3.6149516591792593`*^9, 
  3.614951695975436*^9}, {3.615739271137474*^9, 3.615739306239867*^9}, {
  3.615828864607095*^9, 
  3.615828864689908*^9}},ExpressionUUID->"56f3f2f5-30fa-42ef-9620-\
f79f555b810f"],

Cell[CellGroupData[{

Cell[BoxData["$MachinePrecision"], "Input",
 CellChangeTimes->{{3.614617799683383*^9, 
  3.614617808617874*^9}},ExpressionUUID->"7fd76dab-d211-4e41-b3ee-\
179aaca5ca3d"],

Cell[BoxData["15.954589770191003`"], "Output",
 CellChangeTimes->{
  3.614617809856263*^9},ExpressionUUID->"b236f6d5-358f-4ea3-be02-\
e59c550e6907"]
}, Open  ]],

Cell["\<\
This is a very large error, yet it is a correct result based on the values \
given to the computer.\
\>", "Text",
 CellChangeTimes->{{3.61461783257758*^9, 3.614617880524719*^9}, {
   3.614623517992395*^9, 3.614623519413858*^9}, {3.614623563682281*^9, 
   3.614623564640847*^9}, 3.614951703751276*^9, {3.6150372788829823`*^9, 
   3.615037279570958*^9}, 
   3.61573931455899*^9},ExpressionUUID->"44c0367d-a364-4878-81f0-\
2dcd4f42d89b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"L60", "=", 
   RowBox[{"LegendreP", "[", 
    RowBox[{"60", ",", 
     RowBox[{"Cos", "[", 
      RowBox[{"10", " ", 
       RowBox[{"Pi", "/", "180"}]}], "]"}]}], "]"}]}], ";"}]], "Input",Express\
ionUUID->"5fc6b39e-8dfb-40fd-a988-c6ed5334d4a9"],

Cell[BoxData[
 RowBox[{"L60", "-", 
  RowBox[{"N", "[", "L60", "]"}]}]], "Input",
 CellChangeTimes->{{3.614616206891695*^9, 3.614616238933415*^9}, {
  3.614616285732465*^9, 
  3.614616306545473*^9}},ExpressionUUID->"7bc70e42-0d9d-49cf-89bd-\
1d1a465d89bc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", "5"}], "*", "6"}], "-", "1"}], ",", 
   RowBox[{
    RowBox[{".2", "*", "6"}], "-", "1"}]}], "}"}]], "Input",
