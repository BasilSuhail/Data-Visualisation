  3.615739208346023*^9}},ExpressionUUID->"f45fb443-5cd8-4ef8-bc5b-\
604b8203d1f7"],

Cell[CellGroupData[{

Cell["Examples", "Subsection",
 CellChangeTimes->{{3.615037220365949*^9, 
  3.615037222504093*^9}},ExpressionUUID->"1db28323-13da-47b4-a29d-\
75c2dbd8d792"],

Cell[CellGroupData[{

Cell["High", "Subsubsection",
 CellChangeTimes->{{3.615037220365949*^9, 3.615037222504093*^9}, {
  3.651376391675312*^9, 
  3.6513764392249937`*^9}},ExpressionUUID->"71db812b-a2b7-4887-acb7-\
e5151a469642"],

Cell["\<\
This example shows how high-precision numbers can be used to eliminate such \
large errors. Changing the precision to 24 places in place of the default \
value of 16 gives a good answer.\
\>", "Text",
 CellChangeTimes->{{3.614617603770871*^9, 3.614617657366599*^9}, {
  3.614617700665365*^9, 3.614617744700188*^9}, {3.614951717366535*^9, 
  3.614951732325458*^9}, {3.615037283498805*^9, 
  3.615037283914812*^9}},ExpressionUUID->"7f5309e2-cb88-44db-9747-\
17501e92adc4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"L60", "-", 
    RowBox[{"N", "[", 
     RowBox[{"L60", ",", "24"}], "]"}]}], ",", 
   RowBox[{"N", "[", 
    RowBox[{"L60", ",", "24"}], "]"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.614617688162609*^9, 3.614617689665501*^9}, {
  3.614617923202746*^9, 
  3.6146179498877788`*^9}},ExpressionUUID->"841bb03a-7e26-4bb0-86a0-\
3429cc041591"],

Cell[TextData[{
 "The precision of a number can be set using ",
 StyleBox[ButtonBox["SetPrecision",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SetPrecision"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.614618023997727*^9, 3.614618046543363*^9}, 
   3.614951756852096*^9, {3.6150372895385313`*^9, 3.615037289604511*^9}, {
   3.61573933826305*^9, 
   3.615739338335783*^9}},ExpressionUUID->"2307ba68-30e5-4b54-884f-\
ea17ee21f697"],

Cell[BoxData[
 RowBox[{"SetPrecision", "[", 
  RowBox[{"L60", ",", "30"}], "]"}]], "Input",
 CellChangeTimes->{{3.614618052019356*^9, 3.614618096699751*^9}, {
  3.614618254582457*^9, 
  3.61461825488601*^9}},ExpressionUUID->"4cbf8522-210c-4972-9d43-\
b2bfa66147e2"],

Cell["\<\
Even something as simple as changing the order of evaluation can lead to \
problems.\
\>", "Text",
 CellChangeTimes->{{3.614618356075047*^9, 3.614618381996717*^9}, 
   3.614951761100093*^9, {3.615037293522292*^9, 
   3.615037293644329*^9}},ExpressionUUID->"0b6e731e-dc5d-4581-bd44-\
fac6d2175c65"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "=", 
   RowBox[{"(", 
    RowBox[{"x", 
     RowBox[{"(", 
      RowBox[{
       SqrtBox[
        RowBox[{"x", "+", "1"}]], "-", 
       SqrtBox["x"]}], ")"}]}], ")"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.639115691662408*^9, 3.639115741364228*^9}, {
   3.6391160147554502`*^9, 3.639116027209583*^9}, {3.639116257471142*^9, 
   3.639116278852932*^9}, 
   3.639116587109626*^9},ExpressionUUID->"dcd978d0-b855-4052-98c0-\
fbd02546a881"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"(", 
    FractionBox["x", 
     RowBox[{
      SqrtBox[
       RowBox[{"x", "+", "1"}]], "+", 
      SqrtBox["x"]}]], ")"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.639116021562286*^9, 3.639116028668524*^9}, {
   3.639116198760545*^9, 3.63911620128252*^9}, {3.639116288996953*^9, 
   3.63911629890871*^9}, 
   3.639116588340755*^9},ExpressionUUID->"d1febdce-c3a4-4f31-9350-\
f3da14010013"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Apart", "[", "f", "]"}], ",", 
   RowBox[{"Apart", "[", "g", "]"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.639116702322632*^9, 3.63911670504253*^9}, {
  3.6391167755347633`*^9, 
  3.639116846925168*^9}},ExpressionUUID->"d0dd76c1-aa5d-4138-b05f-\
3c55cd31f3b2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"f", "/.", 
     RowBox[{"x", "\[Rule]", "500."}]}], ")"}], "-", 
   RowBox[{"(", 
    RowBox[{"g", "/.", 
     RowBox[{"x", "\[Rule]", "500."}]}], ")"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.639116038871484*^9, 3.639116081626442*^9}, {
  3.639116209172947*^9, 3.639116221296082*^9}, {3.6391162664885902`*^9, 
  3.639116268839346*^9}, {3.639116382202818*^9, 
  3.639116397234289*^9}},ExpressionUUID->"3be8bdbc-792c-4687-98ed-\
02d682c3774c"],

Cell["\<\
When doing arithmetic with computers, it is important to check the results.\
\>", "Text",
 CellChangeTimes->{{3.614618592722329*^9, 3.614618620636167*^9}, 
   3.615739351101097*^9},ExpressionUUID->"1cb9ca18-7f97-4b32-bbab-\
09b242d1da59"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->{
  "SlideShowHeader", 
   "numeric"},ExpressionUUID->"58a04e08-2c63-433e-960a-8dddb436061c"],

Cell[CellGroupData[{

Cell[TextData[{
 "Numerics in ",
 StyleBox["Mathematica",
  FontSlant->"Italic"]
}], "Section",
 CellChangeTimes->{{3.6364761582714915`*^9, 
  3.636476164137091*^9}},ExpressionUUID->"bd2d85f8-50a9-4b2f-a2b2-\
abb314911dd6"],

Cell[TextData[{
 "In additional to symbolic math, ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " has a large numerical suite of functions built into it. A seemingly simple \
function, which is in fact quite complex, is ",
 StyleBox[ButtonBox["N",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/N"],
  FontWeight->"Bold"],
 ". It can be used to force a numerical approximation to an exact number. "
}], "Text",
 CellChangeTimes->{{3.636476188644691*^9, 3.6364762761606913`*^9}, {
  3.637945726965174*^9, 
  3.637945758616468*^9}},ExpressionUUID->"5b9e43d9-09b9-43fe-9d56-\
180adfcc5e2a"],

Cell[BoxData[
 RowBox[{"N", "[", "Pi", "]"}]], "Input",
 CellChangeTimes->{{3.636476238533491*^9, 
  3.6364762414818916`*^9}},ExpressionUUID->"a59dd950-6bef-4d93-abe2-\
e891097edd0b"],

Cell["\<\
Examples of symbolic expressions and their numeric counterparts will be shown.\
\>", "Text",
 CellChangeTimes->{{3.657371849905789*^9, 
  3.657371883455103*^9}},ExpressionUUID->"f6be4179-0d85-4363-81c0-\
6c140e97fad7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->{
  "SlideShowHeader", 
   "symbolic"},ExpressionUUID->"ef5217cb-d740-4c1a-97d2-b370935da1ba"],

Cell[CellGroupData[{

Cell["Algebraic Manipulation", "Section",
 CellChangeTimes->{{3.562932115262251*^9, 3.562932121524785*^9}, {
  3.6085575318066015`*^9, 3.6085575488212643`*^9}, {3.6085584912584224`*^9, 
  3.608558505801422*^9}, {3.608558586012423*^9, 
  3.608558587091422*^9}},ExpressionUUID->"df475f9c-e6de-435e-b2f7-\
fc3190a3b062"],

Cell["\<\
The Wolfram Language has native support of algebraic manipulation, which \
allows users to operate directly on mathematical expressions.\
\>", "Text",
 CellChangeTimes->{{3.6085585641894226`*^9, 3.6085586356724224`*^9}, {
   3.608558677150422*^9, 3.608558744057423*^9}, {3.614339887180385*^9, 
   3.614339889915659*^9}, {3.6149518627770243`*^9, 3.614951863110961*^9}, 
   3.615739370573491*^9},ExpressionUUID->"1cdee7ef-05f6-4f5c-a521-\
0751a5026303"],

Cell[TextData[{
 "Here is a polynomial in two variables, ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "7621da47-b9a0-4062-80c8-481501ee6841"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "95f8223f-74e9-46f1-b455-e44430ef7cbb"],
 "."
}], "Text",
 CellChangeTimes->{{3.608558809709422*^9, 3.6085588577864237`*^9}, 
   3.614951881470161*^9, 
   3.637945307658803*^9},ExpressionUUID->"b6ccb178-4402-4af9-b125-\
36668ad94f07"],

Cell[BoxData[
 RowBox[{
  RowBox[{"poly", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"4", 
        RowBox[{"x", "^", "2"}]}], "+", "y"}], ")"}], "^", "2"}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"x", "-", "1"}], ")"}], "^", "3"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.6085588670224233`*^9, 
  3.6085588802994227`*^9}},ExpressionUUID->"00a1c453-5ccd-4572-a2d8-\
6176e83d8703"],

Cell[TextData[{
 StyleBox[ButtonBox["Expand",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Expand"],
  FontWeight->"Bold"],
 " can be used to expand the polynomial."
}], "Text",
 CellChangeTimes->{{3.6085589134874225`*^9, 3.6085589605084224`*^9}, {
   3.6109691646407347`*^9, 3.6109691646437364`*^9}, {3.614622156880198*^9, 
   3.614622157606745*^9}, 3.6149518871740913`*^9, 
   3.615037385728356*^9},ExpressionUUID->"21dc220a-2eaa-453e-a461-\
0e60708a3231"],

Cell[BoxData[
 RowBox[{"t", "=", 
  RowBox[{"Expand", "[", "poly", "]"}]}]], "Input",ExpressionUUID->"190ba3f4-\
9a53-452f-a37a-f7e9d0360026"],

Cell["\<\
Polynomial terms obtained can be collected with the assigned symbol, and the \
coefficients could be obtained easily.\
\>", "Text",
 CellChangeTimes->{{3.608558976810423*^9, 3.608559021640423*^9}, {
   3.608559055189423*^9, 3.6085591144344225`*^9}, {3.614622166897921*^9, 
   3.614622167375349*^9}, 3.614951893477502*^9, 3.6150373890535994`*^9, 
   3.61573938462521*^9},ExpressionUUID->"169afcea-17fd-40de-a1a6-\
a817c2ffaf1c"],

Cell[BoxData[
 RowBox[{"Collect", "[", 
  RowBox[{"t", ",", "x"}], "]"}]], "Input",ExpressionUUID->"641b7466-3b46-\
4d8c-bf70-4b35273d2271"],

Cell[BoxData[
 RowBox[{"Coefficient", "[", 
  RowBox[{"t", ",", "x", ",", "1"}], "]"}]], "Input",
 CellChangeTimes->{{3.610901227446944*^9, 
  3.610901228842867*^9}},ExpressionUUID->"974c00a5-0859-4ce3-bbfc-\
df436bb25219"],

Cell[BoxData[
 RowBox[{"CoefficientList", "[", 
  RowBox[{"t", ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.610901231620742*^9, 
  3.610901244694915*^9}},ExpressionUUID->"9d71a68b-8bbb-46d5-9caa-\
e702ff533538"],

Cell["Factor the expanded polynomial.", "Text",
 CellChangeTimes->{{3.608559175231423*^9, 3.608559230559435*^9}, {
   3.614622175834261*^9, 3.614622176711931*^9}, 3.614951896477318*^9, 
   3.615037392333474*^9},ExpressionUUID->"f155bef5-7e3c-4919-8d0a-\
00c08a696b2c"],

Cell[BoxData[
 RowBox[{"Factor", "[", "t", "]"}]], "Input",
 CellChangeTimes->{{3.6085592386752462`*^9, 
  3.6085592408084598`*^9}},ExpressionUUID->"0685ffe3-6fd7-4fb0-abdf-\
c9b68376254e"],

Cell[TextData[{
 "Evaluate the numerical value by ",
 StyleBox[ButtonBox["ReplaceAll ",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/ReplaceAll"],
  FontWeight->"Bold"],
 "and ",
 StyleBox[ButtonBox["Rule",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Rule"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.608559295937972*^9, 3.608559310906469*^9}, {
   3.610969183920623*^9, 3.6109691949329844`*^9}, 3.614951900885503*^9, 
   3.615037394821905*^9},ExpressionUUID->"73d898b8-5a7f-4db4-ad21-\
2e73c8dcbe8c"],

Cell[BoxData[
 RowBox[{"poly", "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"x", "\[Rule]", "0"}], ",", 
    RowBox[{"y", "\[Rule]", "2"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.60652610408448*^9, 
  3.6065261378633385`*^9}},ExpressionUUID->"ebda8567-456d-4f61-b207-\
15dc32809a0a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"cd557457-7d79-44c8-8925-53225b5e9627"],

Cell[CellGroupData[{

Cell["Equation Solving", "Section",
 CellChangeTimes->{{3.562932115262251*^9, 3.562932121524785*^9}, {
   3.6085575318066015`*^9, 3.6085575488212643`*^9}, {3.6085584912584224`*^9, 
   3.608558505801422*^9}, {3.608558586012423*^9, 3.608558587091422*^9}, {
   3.6085594318305597`*^9, 3.608559448175194*^9}, {3.608559595164891*^9, 
   3.608559597277103*^9}, {3.608560295629931*^9, 3.608560310454414*^9}, {
   3.614622293455442*^9, 3.6146222959115257`*^9}, 
   3.657371355228307*^9},ExpressionUUID->"e19c935a-392f-4775-9010-\
ca99f0c19aa1"],

Cell[CellGroupData[{

Cell["Solve", "Subsection",
 CellChangeTimes->{{3.657371356770288*^9, 
  3.657371359862706*^9}},ExpressionUUID->"107b864c-0ff5-440f-b821-\
19804780e91a"],

Cell["\<\
The Wolfram Language includes a number of functions for solving equations and \
inequalities that utilize identical syntax.\
\>", "Text",
 CellChangeTimes->{{3.5630163137601233`*^9, 3.563016448576934*^9}, {
   3.563871854454359*^9, 3.563871858225559*^9}, {3.564217270809998*^9, 
   3.564217271834201*^9}, {3.568140893840445*^9, 3.568140898690702*^9}, {
   3.608559650342409*^9, 3.6085596535907335`*^9}, {3.6085596856719418`*^9, 
   3.608559691320506*^9}, 3.61433989802847*^9, {3.61462222366698*^9, 
   3.614622225683094*^9}, {3.6149519123964586`*^9, 
   3.614951914196422*^9}},ExpressionUUID->"f9e422d7-2e62-4500-87c3-\
e4015a5dcb08"],

Cell[TextData[{
 StyleBox[ButtonBox["Solve",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Solve"],
  FontWeight->"Bold"],
 " is used primarily for solving systems of algebraic equations provided as a \
list in the first argument. Variables are specified as the second argument."
}], "Text",
 CellChangeTimes->{{3.563016488767212*^9, 3.563016562332299*^9}, {
   3.563016677195154*^9, 3.5630166986401453`*^9}, {3.563016737056508*^9, 
   3.563016737358599*^9}, {3.568140909667893*^9, 3.568140914011976*^9}, {
   3.608559729601334*^9, 3.6085598043078036`*^9}, {3.610991286938024*^9, 
   3.610991316561825*^9}, {3.614951934891638*^9, 3.614951939187673*^9}, 
   3.615037401343534*^9},ExpressionUUID->"58947a50-b366-485d-88ee-\
8c0dab3261ed"],

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"]}], "\[Equal]", "1"}], ",", 
     RowBox[{"y", "\[Equal]", 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["x", "2"]}], "-", 
       FractionBox["3", "2"]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.5630165651087937`*^9, 3.563016575147176*^9}, {
  3.56301661082411*^9, 
  3.563016618975635*^9}},ExpressionUUID->"79ecb584-adc3-4912-ac0f-\
b2d47a37deea"],

Cell[TextData[{
 StyleBox[ButtonBox["Solve",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Solve"],
  FontWeight->"Bold"],
 " can also be provided with a series of inequalities."
}], "Text",
 CellChangeTimes->{
  3.60855988888126*^9, {3.6109913377439866`*^9, 3.610991352469827*^9}, 
   3.614951944187242*^9, 
   3.61573942577761*^9},ExpressionUUID->"b323622b-6f11-4008-ba04-\
4adfc5a137d7"],

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["x", "2"], "-", 
      RowBox[{"3", 
       SuperscriptBox["y", "2"]}]}], "\[Equal]", "1"}], "&&", 
    RowBox[{"x", ">", "0"}], "&&", 
    RowBox[{"y", ">", "0"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y"}], "}"}], ",", "Integers"}], "]"}]], "Input",
 CellChangeTimes->{{3.5630170848770733`*^9, 
  3.56301709455807*^9}},ExpressionUUID->"31f93714-3e8e-4efe-a91b-\
05272bb0014e"],

Cell[TextData[{
 "The output of ",
 StyleBox[ButtonBox["Solve",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/Solve"],
  FontWeight->"Bold"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "is a list of rules. It could be used with ",
 StyleBox[ButtonBox["ReplaceAll",
  BaseStyle->"Link",
  ButtonData->"paclet://ref/ReplaceAll"],
  FontWeight->"Bold"],
 " to replace the variables in the corresponding solutions."
}], "Text",
 CellChangeTimes->{{3.6085599152078924`*^9, 3.608560045628933*^9}, {
   3.610991361928149*^9, 3.6109914114002247`*^9}, 3.614951949507165*^9, 
   3.615037412037044*^9, {3.61573948323112*^9, 
   3.61573948349224*^9}},ExpressionUUID->"b7663d91-a5d6-4617-8077-\
c7dd9c41d7b1"],

Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"w", "^", "2"}], "-", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "w"}], "+", "z"}], "\[Equal]", "0"}], ",", 
    "w"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5630205394274197`*^9, 3.563020596813047*^9}, {
  3.60856006009438*^9, 3.608560065805951*^9}, {3.608560557315216*^9, 
  3.608560572297216*^9}},ExpressionUUID->"d1a255ae-61c5-46b0-8321-\
517d396dac48"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"w", "^", "2"}], "-", 
   RowBox[{"3", "w"}]}], "/.", 
  RowBox[{"sol", "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.563020583738767*^9, 3.563020603699611*^9}, {
  3.6085600733347034`*^9, 3.608560086935064*^9}, {3.608560578215216*^9, 
  3.608560583855216*^9}},ExpressionUUID->"a2d92633-4be5-4fb7-b684-\
ab3ccfd1f027"],

Cell[TextData[{
 "Local behavior of the solution could be obtained by ",
 StyleBox[ButtonBox["Series",
