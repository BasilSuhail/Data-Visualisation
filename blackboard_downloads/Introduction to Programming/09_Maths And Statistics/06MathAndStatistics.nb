4b5cb63f3f26"],

Cell[TextData[{
 StyleBox[ButtonBox["NMaximize",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NMaximize"],
  FontWeight->"Bold"],
 " and ",
 StyleBox[ButtonBox["NMinimize",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/NMinimize"],
  FontWeight->"Bold"],
 " are functions that search for global extrema of the function under given \
constraints."
}], "Text",
 CellChangeTimes->{{3.608646508378971*^9, 3.608646540804213*^9}, {
   3.608646685576689*^9, 3.6086467748126116`*^9}, {3.608646878575987*^9, 
