   3.615829123873356*^9},ExpressionUUID->"831ecf5b-d548-415e-8d3a-\
f88723a9ca2f"],

Cell["\<\
A Lorenz system is a simplified model of atmospheric convection that exhibits \
chaotic motion.\
\>", "Text",
 CellChangeTimes->{{3.610983793869088*^9, 3.6109838929072995`*^9}, {
   3.6149523928630047`*^9, 3.614952400708559*^9}, 3.61503749865039*^9, {
   3.61574027567907*^9, 
   3.615740276172728*^9}},ExpressionUUID->"50b81073-1fc3-490f-b303-\
c7a25cb2436b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eqs", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["x", "\[Prime]",
        MultilineFunction->None], "[", "t", "]"}], "\[Equal]", 
      RowBox[{
       RowBox[{"-", "3"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], "-", 
         RowBox[{"y", "[", "t", "]"}]}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox["y", "\[Prime]",
        MultilineFunction->None], "[", "t", "]"}], "\[Equal]", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         RowBox[{"x", "[", "t", "]"}]}], " ", 
        RowBox[{"z", "[", "t", "]"}]}], "+", 
       RowBox[{"26.5", " ", 
        RowBox[{"x", "[", "t", "]"}]}], "-", 
       RowBox[{"y", "[", "t", "]"}]}]}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox["z", "\[Prime]",
        MultilineFunction->None], "[", "t", "]"}], "\[Equal]", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], " ", 
        RowBox[{"y", "[", "t", "]"}]}], "-", 
       RowBox[{"z", "[", "t", "]"}]}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ics", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "[", "0", "]"}], "\[Equal]", 
      RowBox[{"z", "[", "0", "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{
      RowBox[{"y", "[", "0", "]"}], "\[Equal]", "1"}]}], "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.60658372807474*^9, 
  3.60658377364174*^9}},ExpressionUUID->"4111199a-5e2e-4547-9e5d-\
3ca0f082373e"],

Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"eqs", ",", "ics"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "200"}], "}"}], ",", 
    RowBox[{"MaxSteps", "\[Rule]", "\[Infinity]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.585332517683439*^9, 3.5853325178024397`*^9}, {
   3.5885220619205513`*^9, 3.588522062483607*^9}, {3.5885221085222096`*^9, 
   3.588522114273784*^9}, 3.601523378687656*^9, {3.601812801905374*^9, 
   3.601812821177301*^9}, {3.606564586968597*^9, 3.606564595211421*^9}, {
   3.6065837804747396`*^9, 3.60658378880274*^9}},
 CellID->16549,ExpressionUUID->"d432c7ae-1990-4ab6-9745-e7d33776c61b"],

