given data values."
}], "Text",
 CellChangeTimes->{{3.608645880134009*^9, 3.608645885968342*^9}, {
   3.6086459270658245`*^9, 3.6086459975719233`*^9}, 3.614952610596594*^9, 
   3.615037535160551*^9, {3.6157406963314962`*^9, 
   3.615740696399228*^9}},ExpressionUUID->"f27fb04f-c57b-47b8-a66c-\
