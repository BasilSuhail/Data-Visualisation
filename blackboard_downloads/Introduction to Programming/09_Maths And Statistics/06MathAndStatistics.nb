      RowBox[{"Re", "[", "z", "]"}], ",", 
      RowBox[{"Im", "[", "z", "]"}]}], "}"}], "/.", "roots"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", " ", 
    RowBox[{"PointSize", "[", "Large", "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.601777319380769*^9, 3.60177731964578*^9}, {
