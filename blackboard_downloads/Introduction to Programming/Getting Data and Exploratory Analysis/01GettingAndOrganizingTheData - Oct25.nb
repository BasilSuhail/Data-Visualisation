Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"61958262-f849-4ff0-908b-e9314785552d"],

Cell[CellGroupData[{

Cell["Cleaning Up the Data", "Section",
 CellChangeTimes->{{3.572261515968816*^9, 
  3.572261526930423*^9}},ExpressionUUID->"6081329c-48c5-426b-a3e8-\
9d71b7fef2e4"],

Cell[TextData[{
 "You can use some string manipulations to make things work. Break a string \
into usable parts using ",
 StyleBox[ButtonBox["StringSplit",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/StringSplit"],
  FontWeight->"Bold"],
 ". After breaking the string up, rearrange the terms in the expression and \
reassemble them in a usable form through repeated use of ",
 StyleBox[ButtonBox["ReplaceAll",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ReplaceAll"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.5722615406595984`*^9, 3.572261612097159*^9}, {
   3.5722630270696483`*^9, 3.572263101341097*^9}, 3.573223368047204*^9, 
   3.573978916588591*^9, {3.577202331600691*^9, 3.577202372199977*^9}, 
   3.580032053322791*^9, {3.631644316573867*^9, 
   3.631644375777169*^9}},ExpressionUUID->"851f05d8-e7ad-444f-bfbf-\
8a589c47cf3f"],

Cell["Checking on the abbreviations used for the months.", "Text",
 CellChangeTimes->{{3.5722632135373087`*^9, 
  3.572263229735656*^9}},ExpressionUUID->"791b7c73-474d-409b-856d-\
10cdfccb085a"],

Cell[BoxData[
 RowBox[{"DeleteDuplicates", "[", 
  RowBox[{"stkDat", "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.5722622438222427`*^9, 3.572262250808961*^9}, {
  3.572263239219561*^9, 
  3.572263249937586*^9}},ExpressionUUID->"5bda8e87-bcfd-46f4-b7a3-\
51140156908c"],

Cell["\<\
Experimenting with a single row of the data. Begin by splitting the year and \
value.\
\>", "Text",
 CellChangeTimes->{{3.572263123326219*^9, 3.572263136302199*^9}, {
   3.572263998508725*^9, 3.572264023572999*^9}, 
   3.631644389440041*^9},ExpressionUUID->"8c77946c-80c6-4e14-a180-\
d9a42b2d5d3d"],

Cell[BoxData[
 RowBox[{"res", "=", 
  RowBox[{
   RowBox[{"stkDat", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a_String", ",", "b_", ",", "c_String"}], "}"}], 
     "\[RuleDelayed]", " ", 
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", 
        RowBox[{"StringSplit", "[", 
         RowBox[{"c", ",", "\"\<,\>\""}], "]"}]}], "}"}], "]"}]}], 
    "}"}]}]}]], "Input",
 CellChangeTimes->{{3.572261658454211*^9, 3.572261726176689*^9}, {
  3.572261758219551*^9, 3.5722618549145193`*^9}, {3.572262297309276*^9, 
  3.572262314418522*^9}, {3.572262425556299*^9, 3.572262562797961*^9}, {
  3.572262596909192*^9, 3.5722626456712003`*^9}, {3.572262702552659*^9, 
  3.572262752650581*^9}, {3.572262873080887*^9, 3.572262946135728*^9}, {
  3.572262990752038*^9, 3.572262995183275*^9}, {3.57226394523134*^9, 
  3.572263956445804*^9}},ExpressionUUID->"d900f5ad-688e-4ac0-aada-\
b55b859829d8"],

Cell["\<\
Now take the result from applying the first set of rules and rearrange the \
terms into a usable form with a second set of rules.\
\>", "Text",
 CellChangeTimes->{{3.572264033156918*^9, 3.572264067781884*^9}, {
   3.5722641790212092`*^9, 3.572264205384185*^9}, 3.573978924340609*^9, {
   3.6316443950636177`*^9, 
   3.6316443955355577`*^9}},ExpressionUUID->"76683038-adb1-4af1-88b5-\
00346bcad139"],

Cell[BoxData[
 RowBox[{"res", "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a_", ",", "b_", ",", "c_", ",", "d_"}], "}"}], "\[RuleDelayed]",
     " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"ToExpression", "@", 
       RowBox[{"DateList", "[", 
        RowBox[{"StringJoin", "[", 
         RowBox[{"c", ",", "\"\</\>\"", ",", 
          RowBox[{"a", "/.", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\"\<Jul\>\"", "\[Rule]", " ", "\"\<7\>\""}], ",", 
             RowBox[{"\"\<Aug\>\"", "\[Rule]", " ", "\"\<8\>\""}], ",", 
             RowBox[{"\"\<Sep\>\"", "\[Rule]", " ", "9"}]}], "}"}]}], ",", 
          "\"\</\>\"", ",", 
          RowBox[{"ToString", "[", "b", "]"}]}], "]"}], "]"}]}], ",", 
      RowBox[{"ToExpression", "[", "d", "]"}]}], "}"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.572261658454211*^9, 3.572261726176689*^9}, {
  3.572261758219551*^9, 3.5722618549145193`*^9}, {3.572262297309276*^9, 
  3.572262314418522*^9}, {3.572262425556299*^9, 3.572262562797961*^9}, {
  3.572262596909192*^9, 3.5722626456712003`*^9}, {3.572262702552659*^9, 
  3.572262752650581*^9}, {3.572262873080887*^9, 3.572262946135728*^9}, {
  3.572262990752038*^9, 3.572262995183275*^9}, {3.57226394523134*^9, 
  3.572263960118987*^9}, {3.572264933282131*^9, 3.572264934399866*^9}, {
  3.5722650447701387`*^9, 3.572265045457687*^9}, {3.572265275121215*^9, 
  3.572265281365003*^9}},ExpressionUUID->"3ac9c9ae-257e-4183-b5b8-\
febc36ed2141"],

Cell["\<\
You can easily assign a name to the rules you have created to make them \
easier to use, with a number of datasets sharing a given form. Use of the \
second set of rules will follow the application of the first set.\
\>", "Text",
 CellChangeTimes->{{3.5722637188567038`*^9, 3.57226377108849*^9}, {
  3.572264227440274*^9, 3.572264247745263*^9}, {3.580032078154586*^9, 
  3.5800320982179537`*^9}, {3.631644402111796*^9, 
  3.6316444086870413`*^9}},ExpressionUUID->"5abb7e0e-792c-49d4-bf2f-\
9dd63e9612b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rules1", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a_String", ",", "b_", ",", "c_String"}], "}"}], 
     "\[RuleDelayed]", " ", 
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", 
        RowBox[{"StringSplit", "[", 
         RowBox[{"c", ",", "\"\<,\>\""}], "]"}]}], "}"}], "]"}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.572263781602197*^9, 3.572263791951167*^9}, {
  3.57226451573738*^9, 
  3.572264560992695*^9}},ExpressionUUID->"73cf6e56-bf96-4c2e-ab36-\
84b38c2109a8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rules2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a_", ",", "b_", ",", "c_", ",", "d_"}], "}"}], 
     "\[RuleDelayed]", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ToExpression", "@", 
        RowBox[{"DateList", "[", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"c", ",", "\"\</\>\"", ",", 
           RowBox[{"a", "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\"\<Jul\>\"", "\[Rule]", " ", "\"\<7\>\""}], ",", 
              RowBox[{"\"\<Aug\>\"", "\[Rule]", " ", "\"\<8\>\""}], ",", 
              RowBox[{"\"\<Sep\>\"", "\[Rule]", " ", "\"\<9\>\""}]}], "}"}]}],
            ",", "\"\</\>\"", ",", 
           RowBox[{"ToString", "[", "b", "]"}]}], "]"}], "]"}]}], ",", 
       RowBox[{"ToExpression", "[", "d", "]"}]}], "}"}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.572263781602197*^9, 3.572263791951167*^9}, {
  3.57226451573738*^9, 3.572264557913082*^9}, {3.5722649482885237`*^9, 
  3.572264949247697*^9}, {3.572265053778517*^9, 3.572265054850378*^9}, {
  3.572265295006783*^9, 
  3.572265299174111*^9}},ExpressionUUID->"a6309940-64e2-46d2-b72c-\
c0decbfb158e"],

Cell["Fix all the data at once.", "Text",
 CellChangeTimes->{{3.5722633228733797`*^9, 3.57226332854516*^9}, {
  3.5722636269500427`*^9, 
  3.572263630630286*^9}},ExpressionUUID->"139cce31-512d-4fc5-be76-\
2d1f33c737aa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{"stkDat2", "=", 
    RowBox[{
     RowBox[{"stkDat", "/.", "rules1"}], "/.", "rules2"}]}], ")"}], "//", 
  "Short"}]], "Input",
 CellChangeTimes->{{3.572263331622582*^9, 3.572263362304443*^9}, {
  3.572263586244313*^9, 3.572263616185083*^9}, {3.572264138564197*^9, 
  3.572264149362299*^9}, {3.57226433489954*^9, 3.572264338308036*^9}, {
  3.57226457257794*^9, 3.572264575760167*^9}, {3.572264981406535*^9, 
  3.572264985567046*^9}, {3.572265387798705*^9, 3.572265420198478*^9}, {
  3.572265492888483*^9, 3.5722655011828747`*^9}, {3.572265543624644*^9, 
  3.572265591529357*^9}, {3.572265787386655*^9, 
  3.572265824166586*^9}},ExpressionUUID->"8222a945-9f6b-4e15-a6f2-\
48e8fcc0428a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"1603c7fc-220f-4e04-aa99-bfffde1fec96"],

Cell[CellGroupData[{

Cell["Replacing Missing or Incorrect Data", "Section",
 CellChangeTimes->{{3.572510233278285*^9, 3.572510255563554*^9}},
 CellTags->
  "SelectFishData",ExpressionUUID->"fb3409dd-05fd-4104-9723-58f88589e2c5"],

Cell[TextData[{
 "While this is certainly not an appropriate approach in all cases, there are \
situations where it is a reasonable thing to do. The file breamData.csv \
contains an example. This file contains a subset of data collected in Finland \
in the early twentieth century. Begin by bringing the data into the Wolfram \
Language and formatting it using ",
 StyleBox["TableView",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.572510245916135*^9, 3.572510297748297*^9}, {
   3.573315917916918*^9, 3.573316004999151*^9}, {3.573316123490313*^9, 
   3.573316159547317*^9}, 3.577202693704156*^9, 3.5800321519776373`*^9, {
   3.622296965310443*^9, 3.622296968626876*^9}, {3.622382389727498*^9, 
   3.622382396206953*^9}},ExpressionUUID->"81b825eb-669b-464e-a8d3-\
4fa3fb392760"],

Cell[BoxData[
 RowBox[{"FileNames", "[", "\"\<*.csv\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.573315856922288*^9, 3.57331586142234*^9}, {
  3.573315897519186*^9, 
  3.573315904260964*^9}},ExpressionUUID->"51963d83-0e46-41d8-ba8e-\
633e54eef99c"],

Cell["\<\
The breamData.csv file consists of information about 159 fish taken from Lake \
Laengelmavesi, Finland. The data included seven species, and this file \
contains the information on one of the most frequent species.\
\>", "Text",
 CellChangeTimes->{{3.573471485784218*^9, 3.573471510176966*^9}, {
