e0cc3446b68d"],

Cell[TextData[StyleBox["Here, get the first six rows from the file. Numerical \
data begins in the sixth row of the array.", "Text"]], "Text",
 CellChangeTimes->{{3.573465956387935*^9, 3.573466034157804*^9}, {
  3.580031559360266*^9, 3.580031564309948*^9}, {3.631643919439043*^9, 
  3.6316439203348823`*^9}},ExpressionUUID->"b2581ba3-47a1-48a1-aa08-\
