Cell["Importing Data: Excel-XLSX", "Section",
 CellChangeTimes->{
  3.573467802295506*^9},ExpressionUUID->"5bea998d-da4e-4f6d-a79e-\
86d41907baf1"],

Cell[TextData[{
 StyleBox[ButtonBox["Part",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Part"],
  FontWeight->"Bold"],
 " keeps the structure but takes everything. This leads to ordered pairs of \
strings and empty strings from empty cells in the original spreadsheet."
}], "Text",
 CellChangeTimes->{{3.57346783099146*^9, 3.5734679459917793`*^9}, 
   3.577201981035075*^9, {3.631644091241201*^9, 
   3.63164409935585*^9}},ExpressionUUID->"2948bda3-24de-4e6e-81eb-\
80899810afd5"],

Cell[BoxData[
 RowBox[{"data", "[", 
  RowBox[{"[", 
   RowBox[{
    RowBox[{"6", ";;"}], ",", 
    RowBox[{"2", ";;", "3"}]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.573466961033867*^9, 
  3.573466981507127*^9}},ExpressionUUID->"d72b6dfc-042a-4683-9911-\
ae3282d60488"],

Cell[TextData[{
 "If you are more specific with what you want, ",
 StyleBox[ButtonBox["Cases",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Cases"],
  FontWeight->"Bold"],
 " will give numerical ordered pairs and maintain the structure."
}], "Text",
 CellChangeTimes->{{3.573467083780654*^9, 3.5734671299933987`*^9}, 
   3.577201991362624*^9, 3.580147188372986*^9, {3.62229414730756*^9, 
