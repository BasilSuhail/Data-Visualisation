Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"308d9f22-7af6-41f2-922b-e5f367ba0683"],

Cell[CellGroupData[{

Cell["Manipulating the Data: Excel-XLSX", "Section",
 CellChangeTimes->{{3.573467694806151*^9, 3.573467713291117*^9}, {
  3.573470908522791*^9, 
  3.573470913677424*^9}},ExpressionUUID->"14036b89-90c8-47fa-9425-\
13b02abd9b82"],

Cell["\<\
Here are the first four elements of the sixth row, together with the \
associated data types. While it may seem to be overkill to look at such \
things, many users overlook these details and then wonder why they do not get \
answers.\
\>", "Text",
 CellChangeTimes->{{3.573466071006408*^9, 3.573466179160433*^9}, {
  3.58003163093382*^9, 3.580031653012314*^9}, {3.631643945680018*^9, 
  3.631643950397559*^9}},ExpressionUUID->"179aa63d-0667-494d-b5f8-\
ad0579062e1f"],

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"data", "[", 
     RowBox[{"[", 
      RowBox[{"6", ",", 
       RowBox[{";;", "4"}]}], "]"}], "]"}], ",", 
    RowBox[{"Head", "/@", 
     RowBox[{"data", "[", 
      RowBox[{"[", 
       RowBox[{"6", ",", 
        RowBox[{";;", "4"}]}], "]"}], "]"}]}]}], "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.5732179104142647`*^9, 3.573217937018621*^9}, {
  3.573217972674769*^9, 3.573218002550811*^9}, {3.5732181430542307`*^9, 
  3.573218191098767*^9}},ExpressionUUID->"d7f37e02-f0ec-4d82-9861-\
f6b700a0ed70"],

Cell["\<\
This gets the second element from the first eight rows and then checks to see \
which are numeric. \
\>", "Text",
 CellChangeTimes->{{3.5734662317692423`*^9, 3.5734662643457603`*^9}, {
  3.573721045132649*^9, 3.5737210465923996`*^9}, {3.580031663899707*^9, 
  3.580031664708081*^9}},ExpressionUUID->"bb03456a-b0e0-469b-a681-\
c4051baa2c48"],

Cell[BoxData[
 RowBox[{"Position", "[", 
  RowBox[{
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{";;", "8"}], ",", "2"}], "]"}], "]"}], ",", 
   RowBox[{"_", "?", "NumericQ"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.5732183483457627`*^9, 
  3.5732184146130443`*^9}},ExpressionUUID->"ce181436-688c-4a4f-97bf-\
6b1468bc7e1e"],

Cell[TextData[{
 "You can use the ",
 StyleBox[ButtonBox["Extract",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Extract"],
  FontWeight->"Bold"],
 " function together with the ",
 StyleBox[ButtonBox["Position",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Position"],
  FontWeight->"Bold"],
 " function to get the values that are numeric."
}], "Text",
 CellChangeTimes->{{3.573466280026219*^9, 3.573466300762566*^9}, {
  3.573466341803144*^9, 3.573466360811591*^9}, {3.57720189652843*^9, 
  3.5772019000446663`*^9}, {3.631643965469195*^9, 
  3.6316439907433767`*^9}},ExpressionUUID->"cd5b9967-f6c2-48be-9fb5-\
cd0c1df3704c"],

Cell["The numeric values are in the second column.", "Text",
 CellChangeTimes->{{3.573466428452697*^9, 3.573466440373025*^9}, {
  3.580031691860319*^9, 
  3.580031692379047*^9}},ExpressionUUID->"358b791e-45f3-4e0c-ae01-\
d949094d5e46"],

Cell[BoxData[
 RowBox[{"Extract", "[", 
  RowBox[{
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", 
   RowBox[{"Position", "[", 
    RowBox[{
     RowBox[{"data", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", 
     RowBox[{"_", "?", "NumericQ"}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.573218449554356*^9, 
  3.573218494782268*^9}},ExpressionUUID->"81f6c890-e599-47d5-902c-\
615e711f02eb"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"20444a3c-4306-481d-a173-22bb43f9293b"],

Cell[CellGroupData[{

Cell["Importing Data: Excel-XLSX", "Section",
 CellChangeTimes->{{3.573467737901903*^9, 
  3.573467752948031*^9}},ExpressionUUID->"8c7d02f0-367d-40bb-ad38-\
47154dc1c549"],

Cell[TextData[{
 "An alternate approach uses ",
 StyleBox[ButtonBox["Part",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Part"],
  FontWeight->"Bold"],
 " and ",
 StyleBox[ButtonBox["Cases",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Cases"],
  FontWeight->"Bold"],
 " to get the same values. ",
 StyleBox[ButtonBox["Cases",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Cases"],
  FontWeight->"Bold"],
 " requires knowing something about level specifications in expressions, and \
elements not at the top level of an expression may not be found."
}], "Text",
 CellChangeTimes->{{3.573466495652101*^9, 3.573466524358539*^9}, {
   3.5734666366647177`*^9, 3.573466711522058*^9}, {3.577201932074946*^9, 
   3.577201935636107*^9}, 3.577201966227972*^9, {3.631644006949006*^9, 
   3.631644039179403*^9}},ExpressionUUID->"260f5278-7fed-406f-a6df-\
4106e0b3f05c"],

Cell[BoxData[
 RowBox[{"Cases", "[", 
  RowBox[{
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", 
   RowBox[{"_", "?", "NumericQ"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.573466549734416*^9, 
  3.573466596801938*^9}},ExpressionUUID->"87e2859a-2a90-4e0c-8b0f-\
9316da5274a8"],

Cell["\<\
To get values in the second and third columns, you need to specify levels.\
\>", "Text",
 CellChangeTimes->{{3.573466773643408*^9, 3.5734668007312117`*^9}, 
   3.580031723476834*^9, {3.631644049984724*^9, 
   3.631644050200382*^9}},ExpressionUUID->"8a110f6b-94b3-42d9-9183-\
de998962440d"],

Cell[BoxData[
 RowBox[{"Cases", "[", 
  RowBox[{
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3"}], "}"}]}], "]"}], "]"}], ",", 
   RowBox[{"_", "?", "NumericQ"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.573466549734416*^9, 3.573466596801938*^9}, {
  3.57346672126229*^9, 
  3.573466755060219*^9}},ExpressionUUID->"78416c05-008d-40f2-b5a7-\
c869f1a5dea4"],

Cell[TextData[{
 "The numerical values are at the second level, so specifying any integer \
greater than 1 will work. Note that ",
 StyleBox[ButtonBox["Cases",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Cases"],
  FontWeight->"Bold"],
 " does not preserve the data structure."
}], "Text",
 CellChangeTimes->{{3.573466819163866*^9, 3.573466869876745*^9}, {
   3.573466908853361*^9, 3.573466933142037*^9}, 3.577201972155014*^9, {
   3.580031745298869*^9, 3.580031763401425*^9}, 
   3.631644061458147*^9},ExpressionUUID->"68f1c0d8-2162-4a73-87ed-\
2390a41bb288"],

Cell[BoxData[
 RowBox[{"Cases", "[", 
  RowBox[{
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3"}], "}"}]}], "]"}], "]"}], ",", 
   RowBox[{"_", "?", "NumericQ"}], ",", "2"}], "]"}]], "Input",
