 RowBox[{"TableView", "[", 
  RowBox[{
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{";;", "6"}], "]"}], "]"}], ",", 
   RowBox[{"ImageSize", "\[Rule]", " ", "1200"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.573217458530437*^9, 3.573217488851344*^9}, {
  3.573217578437911*^9, 3.573217600612494*^9}, {3.573217744401511*^9, 
  3.573217754023902*^9}, {3.573217802699049*^9, 
  3.573217854825625*^9}},ExpressionUUID->"63c6cf3f-02ca-41d4-aa6c-\
