Cell[CellGroupData[{

Cell["Importing Data: Comma- or Tab-Separated Values ", "Section",
 CellChangeTimes->{{3.572254538221219*^9, 3.57225454205244*^9}, {
   3.5734712481036882`*^9, 3.573471269124423*^9}, {3.5800318532654543`*^9, 
   3.580031858231058*^9}, 
   3.580217716906458*^9},ExpressionUUID->"88fdca54-d171-4f0d-98b8-\
de64f0537255"],

Cell[CellGroupData[{

Cell["Comma- or Tab-Separated Values", "Subsection",
 CellChangeTimes->{{3.572254548868926*^9, 3.572254561436851*^9}, {
   3.577202000869389*^9, 3.577202005188673*^9}, {3.580031873329661*^9, 
   3.580031878054779*^9}, 
   3.580217721342798*^9},ExpressionUUID->"67c2685a-1cb6-47af-8b29-\
a6988a80c515"],

Cell[TextData[{
 "This is a less well-defined area, as some files will have the extension ",
 ButtonBox["CSV",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Format/CSV"],
 " or ",
 ButtonBox["TSV",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Format/TSV"],
 ", but more often the extension will be ",
 ButtonBox[".txt",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Format/Text"],
 " or .dat. In some cases the best approach is to include a second argument \
of \[OpenCurlyDoubleQuote]Table\[CloseCurlyDoubleQuote] or \
\[OpenCurlyDoubleQuote]List\[CloseCurlyDoubleQuote] to ensure the data is \
formatted correctly on import. Experience will teach when to use the format \
argument and when it is not necessary."
}], "Text",
 CellChangeTimes->{{3.572260814249333*^9, 3.572260939993057*^9}, {
   3.572509974093165*^9, 3.572509981690977*^9}, {3.573721195918004*^9, 
   3.573721235652679*^9}, {3.577202011951426*^9, 3.577202075097075*^9}, {
   3.5772021842690473`*^9, 3.577202187490365*^9}, {3.577202219940762*^9, 
   3.57720222662853*^9}, 3.5800318911836777`*^9, 3.580031933774598*^9, {
   3.580147215439978*^9, 3.5801472391659207`*^9}, {3.6316442286000834`*^9, 
   3.6316442413839483`*^9}},ExpressionUUID->"e51c5bc6-2b22-4637-9cc5-\
e9e4eeb71fff"],

Cell[TextData[{
 "Check to see what ",
 ButtonBox["CSV",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Format/CSV"],
 " files are present."
}], "Text",
 CellChangeTimes->{{3.572261145373029*^9, 3.572261167652338*^9}, 
   3.577202256302507*^9},ExpressionUUID->"d1bbe82e-67df-482a-96d6-\
50cd2762d073"],

Cell[BoxData[
 RowBox[{"FileNames", "[", "\"\<*.csv\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.572260950316493*^9, 
  3.5722609641790643`*^9}},ExpressionUUID->"969ff728-42b2-47b0-94bb-\
d0a9f964d3df"],

Cell["Import the stock data.", "Text",
 CellChangeTimes->{{3.572261187916894*^9, 
  3.572261193508978*^9}},ExpressionUUID->"d120159d-f676-46a5-bdb7-\
8d3790eb7782"],

