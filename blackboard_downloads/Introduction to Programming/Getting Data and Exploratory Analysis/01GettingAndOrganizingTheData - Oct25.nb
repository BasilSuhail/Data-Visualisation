 RowBox[{
  RowBox[{"(", 
   RowBox[{"stkDat", "=", 
    RowBox[{"Import", "[", 
     RowBox[{"\"\<stockdata.csv\>\"", ",", "\"\<Table\>\""}], "]"}]}], ")"}], 
  "//", "Short"}]], "Input",
 CellChangeTimes->{{3.572260985007032*^9, 
  3.572261050732808*^9}},ExpressionUUID->"3a066a14-b7b8-4ed9-8230-\
75ef1e8cee66"],

Cell["Check the dimensions.", "Text",
 CellChangeTimes->{{3.572261198829179*^9, 
  3.572261203389184*^9}},ExpressionUUID->"2ebe884c-8f04-47ab-8b30-\
46b01b360c2c"],

Cell[BoxData[
 RowBox[{"Dimensions", "[", "stkDat", "]"}]], "Input",
 CellChangeTimes->{{3.572261056643101*^9, 
  3.572261062516797*^9}},ExpressionUUID->"a4443190-bb8a-4307-a824-\
233e7e2f7324"],

Cell[TextData[{
 "This does not seem to conform to what you see above, as it would seem there \
are four elements in each row. Check to see what is going on by putting a row \
in ",
 StyleBox[ButtonBox["InputForm",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/InputForm"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.572261211918181*^9, 3.5722613255512*^9}, {
   3.5772022647878857`*^9, 3.577202275195403*^9}, 3.580032007724883*^9, {
   3.631644180596451*^9, 3.631644193984511*^9}, {3.631644264862645*^9, 
   3.631644271110357*^9}},ExpressionUUID->"9d70df48-4db5-482b-a3b1-\
8df8e9b62931"],

Cell[BoxData[
 RowBox[{
  RowBox[{"stkDat", "[", 
   RowBox[{"[", "1", "]"}], "]"}], "//", "InputForm"}]], "Input",
 CellChangeTimes->{{3.572261097711093*^9, 
  3.572261112933576*^9}},ExpressionUUID->"058b4291-0bba-4320-a97e-\
f80cc9ecd8a9"],

Cell[TextData[{
 "The year and the value of the stock are returned as a single string. You \
can clean this up using rules and the ",
 StyleBox[ButtonBox["ReplaceAll",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ReplaceAll"],
  FontWeight->"Bold"],
 " function."
}], "Text",
 CellChangeTimes->{{3.572261392617795*^9, 3.5722615018912888`*^9}, 
   3.5737212759751678`*^9, {3.577202293805185*^9, 3.577202305398396*^9}, {
   3.631644197179657*^9, 3.6316442072696877`*^9}, {3.631644278366046*^9, 
   3.631644278637354*^9}},ExpressionUUID->"926736ca-c0c5-4a89-bca9-\
5584d06f76f5"]
