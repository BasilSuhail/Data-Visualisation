Cell[CellGroupData[{

Cell["Determining a Replacement Value", "Section",
 CellChangeTimes->{{3.573721531046061*^9, 
  3.573721541261653*^9}},ExpressionUUID->"00785c5f-0bbf-47e7-95fe-\
358b687040c5"],

Cell["The column headings of the original file were as follows.", "Text",
 CellChangeTimes->{{3.573484956341121*^9, 3.573484990838006*^9}, 
   3.632507677878386*^9},ExpressionUUID->"470a373d-99a7-48d8-92ee-\
b685764cee66"],

Cell[BoxData[
 RowBox[{"breamDat", "[", 
  RowBox[{"[", 
   RowBox[{"-", "1"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.573484918319709*^9, 
  3.573484930038865*^9}},ExpressionUUID->"08d0ef5b-871a-464b-aefe-\
7c9be4bf7ae5"],

Cell[TextData[{
 "You have eliminated the first column, so you have ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"wt", ",", "L1", ",", "L2", ",", "L3", ",", "ht", ",", "thck"}], 
    "}"}], $CellContext`MR]],ExpressionUUID->
  "e4da662f-cc7e-497f-8d0b-742be1005466"],
 " in each row. The original file gives the height and thickness as a percent \
of ",
 Cell[BoxData[
  FormBox["L3", $CellContext`MR]],ExpressionUUID->
  "1b9ed110-6d5d-4eac-8386-c9a8b0f7e90b"],
 ", so you will use that value in your calculations."
}], "Text",
 CellChangeTimes->{{3.57348500774219*^9, 3.573485088583807*^9}, {
  3.573485151712507*^9, 3.573485203017513*^9}, {3.573493060997421*^9, 
  3.573493062266726*^9}, {3.577203840711158*^9, 3.57720387095326*^9}, {
  3.580032422594976*^9, 3.580032425401391*^9}, {3.631644520764099*^9, 
  3.631644534824888*^9}},ExpressionUUID->"7fc24f2f-a1f0-4aa4-8d25-\
5c75a22a28d8"],

Cell["\<\
Get the information from the first and fourth columns, and delete the row \
with the missing value.\
\>", "Text",
 CellChangeTimes->{{3.573485247379321*^9, 3.573485296315077*^9}, 
   3.631644540904422*^9},ExpressionUUID->"1aa9a613-9070-45ab-9ce1-\
c322579f9901"],

Cell[BoxData[
 RowBox[{"fullRows", "=", 
  RowBox[{"Delete", "[", 
   RowBox[{
    RowBox[{"breamDat2", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "4"}], "}"}]}], "]"}], "]"}], ",", "14"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.573485339696868*^9, 
  3.573485376223234*^9}},ExpressionUUID->"65b58983-3dcf-4633-bef2-\
2d3c1d44f7fd"],

Cell["\<\
Next, transpose the data to have it in column form, and then divide the first \
column by the second.\
\>", "Text",
 CellChangeTimes->{{3.573485399560154*^9, 3.57348541107757*^9}, {
   3.57348706696562*^9, 3.5734870916849813`*^9}, 3.580032485282429*^9, {
   3.631644544744224*^9, 
   3.631644553687786*^9}},ExpressionUUID->"bd9e56ba-151e-4b28-b12a-\
93ebc114ab3a"],

Cell[BoxData[
 RowBox[{"cols", "=", 
  RowBox[{"Transpose", "[", "fullRows", "]"}]}]], "Input",
 CellChangeTimes->{{3.573487161591313*^9, 
  3.573487183936461*^9}},ExpressionUUID->"cef40ae5-1500-4bcb-ab29-\
c52773d43dff"],

Cell[BoxData[
 RowBox[{"rats", "=", 
  RowBox[{"Apply", "[", 
   RowBox[{"Divide", ",", "cols"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5734871925289598`*^9, 
  3.573487233063851*^9}},ExpressionUUID->"0b990924-9225-4e76-8d6d-\
9474b2fa1dc8"],

Cell[TextData[{
 "This gives an average scaling factor relating the ",
 Cell[BoxData[
  FormBox["L3", $CellContext`MR]],ExpressionUUID->
  "be71b340-73f8-4891-934e-7d6295fcb669"],
 " dimension to the weight. "
}], "Text",
 CellChangeTimes->{{3.5734872761476183`*^9, 3.573487322889051*^9}, 
   3.577203900736628*^9},ExpressionUUID->"d0be2983-064c-4132-ac63-\
1533a4fa52f0"],

Cell[BoxData[
 RowBox[{"mn", "=", 
  RowBox[{"Mean", "[", "rats", "]"}]}]], "Input",
 CellChangeTimes->{{3.573318428813695*^9, 3.573318442754581*^9}, {
  3.5733184910051126`*^9, 3.573318550262409*^9}, {3.5733185964248953`*^9, 
  3.573318605152508*^9}, {3.5733186656265388`*^9, 3.573318681259001*^9}, {
  3.57331875364441*^9, 3.573318761452573*^9}, {3.573319082189335*^9, 
  3.57331908333808*^9}, {3.573487240137426*^9, 
  3.573487241217864*^9}},ExpressionUUID->"f27bf647-9d24-4145-8b33-\
64873fa4e395"],

Cell[TextData[{
 "Replace the N/A in the fourteenth row with the scaled value of ",
 Cell[BoxData[
  FormBox["L3", $CellContext`MR]],ExpressionUUID->
  "34cf17cd-495e-4226-b481-4150dc01f457"],
 " in that row."
}], "Text",
 CellChangeTimes->{{3.573487347818151*^9, 3.5734873848742523`*^9}, 
   3.577203929088763*^9, {3.580032513599607*^9, 
   3.580032518543589*^9}},ExpressionUUID->"7c324e8c-4e2d-4e0d-8af7-\
05fc7da90ce0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"breamDat2", "[", 
   RowBox[{"[", 
    RowBox[{"14", ",", "1"}], "]"}], "]"}], "=", 
  RowBox[{"N", "@", 
   RowBox[{"Round", "[", 
    RowBox[{"mn", " ", 
     RowBox[{"breamDat2", "[", 
      RowBox[{"[", 
       RowBox[{"14", ",", "4"}], "]"}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.5733190471173906`*^9, 3.5733191168756127`*^9}, {
  3.5733191807169533`*^9, 
  3.5733192012607408`*^9}},ExpressionUUID->"095a69af-ccc1-4081-a7c1-\
de554b81f562"],

Cell[BoxData[
 RowBox[{"TableView", "[", 
  RowBox[{"breamDat2", ",", 
   RowBox[{"ImageSize", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{"750", ",", "500"}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.573319128179247*^9, 
  3.573319165614146*^9}},ExpressionUUID->"f12b750b-5e2b-4602-800d-\
aafc23077154"]
