Cell[CellGroupData[{

Cell["Organizing Files", "Section",
 CellChangeTimes->{{3.572271990458034*^9, 3.572271996319758*^9}, 
   3.57397886898416*^9},ExpressionUUID->"b64613bb-2145-4823-bf1e-\
17534636f754"],

Cell[CellGroupData[{

Cell["Defining a Path", "Subsection",
 CellChangeTimes->{{3.572256428075194*^9, 
  3.572256431984587*^9}},ExpressionUUID->"04d13430-7453-4a73-94b0-\
44ba08276628"],

Cell[TextData[{
 "You can use ",
 StyleBox[ButtonBox["FileNameJoin",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/FileNameJoin"],
  FontWeight->"Bold"],
 " to create a path for your computer that you can use in defining a function \
to get files using only the file name. You may find a function ",
 StyleBox[ButtonBox["ToFileName",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ToFileName"],
  FontWeight->"Bold"],
 " in some documentation examples, but you should use ",
 StyleBox[ButtonBox["FileNameJoin",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/FileNameJoin"],
  FontWeight->"Bold"],
 ". The older ",
 StyleBox[ButtonBox["ToFileName",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ToFileName"],
  FontWeight->"Bold"],
 " has been replaced."
}], "Text",
 CellChangeTimes->{{3.5722573608522*^9, 3.572257434053492*^9}, {
   3.572509902681224*^9, 3.572509904094261*^9}, {3.573213579964053*^9, 
   3.573213707611375*^9}, {3.577201429895431*^9, 3.5772014449760737`*^9}, 
   3.5772014917608433`*^9, 3.580030891720973*^9, {3.622293678214429*^9, 
   3.622293740944936*^9}, {3.622382240382709*^9, 3.622382253411712*^9}, {
   3.622383082933924*^9, 
   3.6223830834828243`*^9}},ExpressionUUID->"f6d150a5-f6ee-4967-86d2-\
bca65488390c"],

Cell["Define the path.", "Text",
 CellChangeTimes->{{3.572257493510109*^9, 3.5722574965546484`*^9}, 
   3.580031033092041*^9},ExpressionUUID->"eb2d0160-0156-4cde-830d-\
ade1ca1432f9"],

Cell[BoxData[
 RowBox[{"myPath", "=", " ", 
  RowBox[{"FileNameJoin", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<DataDir\>\""}], "}"}],
    "]"}]}]], "Input",
 CellChangeTimes->{{3.572257443240239*^9, 
  3.572257473701651*^9}},ExpressionUUID->"f29ba706-d8dc-4d36-a3b6-\
8bc2fd1c10da"],

Cell["Define a function to get files.", "Text",
 CellChangeTimes->{{3.572257504395741*^9, 
  3.572257513443898*^9}},ExpressionUUID->"8f816a53-15ce-4019-b7bf-\
b316099802dc"],

Cell[BoxData[
 RowBox[{
