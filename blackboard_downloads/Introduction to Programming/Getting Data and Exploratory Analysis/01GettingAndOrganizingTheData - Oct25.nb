Cell[CellGroupData[{

Cell["Checking the File", "Section",
 CellChangeTimes->{{3.573214037876679*^9, 
  3.573214048793353*^9}},ExpressionUUID->"5de067f9-eefc-43b5-8c94-\
e3080f78697e"],

Cell[TextData[{
 "The Wolfram Language",
 StyleBox[" ",
  FontSlant->"Italic"],
 "contains an undocumented function, ",
 StyleBox["TableView",
  FontWeight->"Bold"],
 ", that is very useful for looking at the form of smaller files. You can use \
it to investigate the data you have imported."
}], "Text",
 CellChangeTimes->{{3.573214060210988*^9, 3.573214140083061*^9}, 
   3.577201741173923*^9, {3.577201781041584*^9, 3.577201803456039*^9}, {
   3.631643805632524*^9, 3.6316438193559303`*^9}, {3.632507487056356*^9, 
   3.632507506557754*^9}},ExpressionUUID->"4e6df645-d5b9-480e-a018-\
61d787d95afb"],

Cell["\<\
This gives an idea of the size of the file: one sheet with 15 rows and three \
columns.\
\>", "Text",
 CellChangeTimes->{{3.573214164507824*^9, 3.573214206035904*^9}, {
  3.580031434394374*^9, 3.580031435601119*^9}, {3.622293890020361*^9, 
  3.6222938903642063`*^9}},ExpressionUUID->"c72b2ecb-aa1b-4479-8aee-\
bbce634b4bf1"],

Cell[BoxData[
 RowBox[{"Dimensions", "[", "dataFull", "]"}]], "Input",
 CellChangeTimes->{{3.573214143861928*^9, 3.573214150281468*^9}, {
  3.5737208075233936`*^9, 
  3.57372080831347*^9}},ExpressionUUID->"6b744259-d1eb-457f-b9c8-\
ec203971d5c1"],

Cell[TextData[{
 "In its current form, ",
 StyleBox["TableView",
  FontWeight->"Bold"],
 " will not automatically expand cells or use word wrapping to display the \
full contents of a cell, but the columns can be expanded to display the full \
contents."
}], "Text",
 CellChangeTimes->{{3.573214327982854*^9, 3.573214407967141*^9}, 
   3.577201822039942*^9, 3.580031485753309*^9, {3.631643747873807*^9, 
   3.631643783477579*^9}, 
   3.632507530430395*^9},ExpressionUUID->"1460e656-caf1-4a5a-9460-\
cdeb255c9822"],

Cell[BoxData[
 RowBox[{"TableView", "[", 
  RowBox[{"dataFull", "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.573214210505636*^9, 3.573214219115657*^9}, {
  3.573720816441718*^9, 
  3.573720817209684*^9}},ExpressionUUID->"e5fb7075-22fd-4731-afa6-\
f9a2d3862e86"],

