Cell[CellGroupData[{

Cell["Temporal Data", "Section",
 CellChangeTimes->{{3.573547989979658*^9, 
  3.57354799566216*^9}},ExpressionUUID->"e2fb3309-7e8c-479a-b351-\
9ef7d2935464"],

Cell[TextData[{
 StyleBox[ButtonBox["TemporalData",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/TemporalData"],
  FontWeight->"Bold"],
 ", ",
 StyleBox[ButtonBox["EventData",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/EventData"],
  FontWeight->"Bold"],
 ", and ",
 StyleBox[ButtonBox["WeightedData",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/WeightedData"],
  FontWeight->"Bold"],
 " are essentially wrappers you can use on your data to allow the data to \
provide additional information and to work with other functions. The examples \
here show how you can visualize the stock data without doing a lot of \
reorganizing or restructuring of the data."
}], "Text",
 CellChangeTimes->{{3.573548395218124*^9, 3.573548519599788*^9}, {
   3.573548598760814*^9, 3.573548615753174*^9}, {3.577204033559732*^9, 
   3.5772040392461863`*^9}, 3.580032608160371*^9, {3.631644677598461*^9, 
   3.631644725135663*^9}},ExpressionUUID->"7b5269b1-51ff-42e5-8d5e-\
e1c95dd756aa"],

Cell[TextData[{
 "Some answers may not be what you expect. Times are returned as absolute \
times, and these are the times used in functions like ",
 StyleBox[ButtonBox["ListPlot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ListPlot"],
  FontWeight->"Bold"],
 " to locate points and ticks."
}], "Text",
 CellChangeTimes->{{3.572269189156616*^9, 3.572269228523738*^9}, {
   3.572269270420672*^9, 3.572269294252961*^9}, 3.577204072868662*^9, {
   3.6316447328550863`*^9, 
   3.631644740501732*^9}},ExpressionUUID->"e0ddbe9f-c827-4194-8c51-\
2757c4cde3d1"],

Cell[BoxData[
 RowBox[{"td1", "[", "\"\<PathTimes\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.5722666182586527`*^9, 
  3.572266626932147*^9}},ExpressionUUID->"c60dbac2-6276-4b31-b100-\
8cfe22184c27"],

Cell[TextData[{
 "Use the ",
 StyleBox[ButtonBox["FindDivisions",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/FindDivisions"],
  FontWeight->"Bold"],
 " function to determine where to place ticks."
}], "Text",
 CellChangeTimes->{{3.573548712565612*^9, 3.5735487303873262`*^9}, 
   3.577204093987692*^9, {3.631644749552472*^9, 
   3.631644760897657*^9}},ExpressionUUID->"fd65aad4-0cfc-42ea-869f-\
83295669d5d3"],

Cell[BoxData[
 RowBox[{"divs", "=", 
  RowBox[{"FindDivisions", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"td1", "[", "\"\<PathTimes\>\"", "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"-", "1"}]}], "}"}], "]"}], "]"}], ",", "4"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.5735459873524647`*^9, 
  3.573546045213551*^9}},ExpressionUUID->"3781b39d-0cdb-4841-88dc-\
93a1484139a9"],

Cell[TextData[{
 "Combine the locations with labels obtained from ",
 StyleBox[ButtonBox["DateString",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/DateString"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.573548751351603*^9, 3.57354877882205*^9}, 
   3.577204096979356*^9, {3.631644766431623*^9, 
   3.631644779006312*^9}},ExpressionUUID->"7f024b28-549d-4b24-bc6e-\
b42586e71f7f"],

Cell[BoxData[
 RowBox[{"dateTcks", "=", 
  RowBox[{"Transpose", "[", 
   RowBox[{"{", 
    RowBox[{"divs", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"DateString", "[", 
        RowBox[{"#", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<MonthName\>\"", ",", "\"\< \>\"", ",", "\"\<Day\>\""}],
           "}"}]}], "]"}], "&"}], "/@", "divs"}]}], "}"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.573546053712206*^9, 3.573546072483542*^9}, {
  3.573546175926661*^9, 3.5735462851842947`*^9}, {3.573546329699279*^9, 
  3.573546338602685*^9}},ExpressionUUID->"815c7d11-76bb-4061-86f3-\
88f60745aafa"],

Cell[TextData[{
 "Use ",
 StyleBox[ButtonBox["AbsoluteTime",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/AbsoluteTime"],
  FontWeight->"Bold"],
 " to locate ticks in ",
 StyleBox[ButtonBox["ListPlot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ListPlot"],
  FontWeight->"Bold"],
 ". Ticks are specified in the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"location", ",", " ", "label"}], "}"}], $CellContext`MR]],
  ExpressionUUID->"a78253d9-34d3-48a2-aa9c-5c937c657e86"],
 ". "
}], "Text",
 CellChangeTimes->{{3.572269624516097*^9, 3.572269638739407*^9}, {
   3.572272915446496*^9, 3.572272976050257*^9}, {3.572273011671502*^9, 
   3.5722730116895037`*^9}, {3.577204150412773*^9, 3.57720416750965*^9}, 
   3.577204201092744*^9, {3.63164478268685*^9, 3.631644792265786*^9}, {
   3.632507712462201*^9, 
   3.63250771462798*^9}},ExpressionUUID->"dc52af0b-fbae-4c07-b2f0-\
d75c313ec568"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"td1", ",", 
   RowBox[{"Ticks", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{"dateTcks", ",", "Automatic"}], "}"}]}], ",", 
   RowBox[{"Joined", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{"False", ",", "False", ",", "True"}], "}"}]}], ",", 
   RowBox[{"Filling", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{"1", "\[Rule]", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.572269383183542*^9, 3.572269535907992*^9}, {
  3.573546348405132*^9, 3.573546351445384*^9}, {3.573546389004541*^9, 
  3.573546405334025*^9}, {3.573546779722689*^9, 
  3.573546794962276*^9}},ExpressionUUID->"8e6f1a2f-c5ea-4a7a-8dd9-\
d8ce8778b929"],

Cell[TextData[{
 "Of course in this example you could have used ",
 StyleBox[ButtonBox["DateListPlot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/DateListPlot"],
  FontWeight->"Bold"],
 " to obtain a similar visualization, but you would have had to work much \
harder to get the other information."
}], "Text",
 CellChangeTimes->{{3.573548975496367*^9, 3.573549040304959*^9}, 
   3.577204215671295*^9, {3.631644804662016*^9, 
   3.631644834307746*^9}},ExpressionUUID->"5fc2c497-e47b-46ce-af54-\
b2f293b28b24"],

Cell[BoxData[
 RowBox[{"DateListPlot", "[", 
  RowBox[{"stkDat2", ",", 
   RowBox[{"Joined", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{"False", ",", "False", ",", "True"}], "}"}]}], ",", 
   RowBox[{"Filling", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{"1", "\[Rule]", " ", 
      RowBox[{"{", "2", "}"}]}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.5735488537478867`*^9, 
  3.573548916968969*^9}},ExpressionUUID->"d3b55214-7617-43a3-ac13-\
fdc16776e7f9"]
}, Open  ]]
}, Open  ]],

