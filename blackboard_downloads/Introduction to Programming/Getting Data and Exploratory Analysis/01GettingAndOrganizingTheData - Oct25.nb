Cell[CellGroupData[{

Cell["Exporting Data", "Section",
 CellChangeTimes->{{3.573549381074111*^9, 
  3.5735493851189117`*^9}},ExpressionUUID->"365f4d8c-2b96-4786-8c89-\
341b093b8dc6"],

Cell[TextData[{
 "The Wolfram Language supports exporting to a large variety of file types, \
including Excel, comma-separated values, and tab-separated values. ",
 StyleBox[ButtonBox["Export",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Export"],
  FontWeight->"Bold"],
 " will always create a new file of the designated type. It is not possible \
in current versions of the Wolfram Language to write to an existing file. If \
you have imported data from an Excel file, done some analysis on the data \
from that file, and you want the results in the original file, you will have \
to export to a new file and combine the results using Excel."
}], "Text",
 CellChangeTimes->{{3.5738929702587357`*^9, 3.573892989695822*^9}, {
   3.573893047566568*^9, 3.573893099143287*^9}, {3.573893131455951*^9, 
   3.573893289314913*^9}, 3.577204274800247*^9, {3.580032669661396*^9, 
   3.5800326839554253`*^9}, 3.5801473116508417`*^9, {3.580147344818696*^9, 
   3.580147351906792*^9}, {3.6222973344429693`*^9, 3.622297342132739*^9}, {
   3.622382517987467*^9, 3.622382530880908*^9}, 
   3.622394887302463*^9},ExpressionUUID->"d8ccc9de-c935-4c20-9cf6-\
6253379b71f9"],

Cell[TextData[{
 "The syntax for ",
 StyleBox[ButtonBox["Export",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Export"],
  FontWeight->"Bold"],
 " is essentially the same as for ",
 StyleBox[ButtonBox["Import",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Import"],
  FontWeight->"Bold"],
 ", with the exception that you must include the contents of the new file as \
a second argument to ",
 StyleBox[ButtonBox["Export",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Export"],
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.573893370780182*^9, 3.57389342777315*^9}, {
   3.573894405938375*^9, 3.573894421567474*^9}, {3.5772043039795103`*^9, 
   3.577204316334202*^9}, 3.580032722139571*^9, {3.6316448822370667`*^9, 
   3.631644915791668*^9}},ExpressionUUID->"9b21b862-924e-475e-bc22-\
9e0986e7adab"],

Cell[BoxData[
 RowBox[{"Export", "[", 
  RowBox[{
  "\"\<filename.csv\>\"", ",", "fileContents", ",", "elems", ",", "opts"}], 
  "]"}]], "DisplayFormula",
 CellChangeTimes->{{3.5738935238487263`*^9, 3.5738935702963552`*^9}, {
  3.573893700360115*^9, 
  3.5738937027158136`*^9}},ExpressionUUID->"1ac34354-8997-4f0c-a082-\
3de7c88aebe9"],

Cell[TextData[{
 "You can find more information about exporting data in the tutorial ",
 ButtonBox["Importing and Exporting Data",
  BaseStyle->"Link",
  ButtonData->"paclet:tutorial/ImportingAndExportingData"],
 ". You should realize that ",
 StyleBox[ButtonBox["Export",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Export"],
  FontWeight->"Bold"],
 " will overwrite an existing file if the name is the same as the file you \
are exporting to. Some users find it handy to incorporate a date string in \
the name of the exported file to ensure that does not happen."
}], "Text",
 CellChangeTimes->{{3.573894427823107*^9, 3.573894477026689*^9}, {
   3.573977373109096*^9, 3.573977512588048*^9}, {3.577204346927835*^9, 
   3.577204443759508*^9}, 3.5772045179957857`*^9, 
   3.6316448911249847`*^9},ExpressionUUID->"b19bfcfc-1227-4806-acf6-\
eac7047119bc"],

Cell["Here is a file you worked with earlier.", "Text",
 CellChangeTimes->{{3.573976616093988*^9, 3.573976628012555*^9}, {
  3.631644925527482*^9, 
  3.631644925823186*^9}},ExpressionUUID->"faba97d9-f29a-4544-a34e-\
54b3ca095f1e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<table_1_14_a.xlsx\>\"", ",", 
     RowBox[{"{", 
      RowBox[{"\"\<XLSX\>\"", ",", "\"\<Data\>\"", ",", "1"}], "}"}]}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"cb6effad-a0a9-492f-be14-\
0311973d5907"],

Cell["\<\
This gets the numerical data from the second and third columns together with \
the column headings.\
\>", "Text",
 CellChangeTimes->{{3.573976703736531*^9, 
  3.573976792287373*^9}},ExpressionUUID->"03535ff8-3c90-4f70-88a4-\
bef97caffb73"],

Cell[BoxData[
 RowBox[{"wrkDat", "=", 
  RowBox[{"Join", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"data", "[", 
      RowBox[{"[", 
       RowBox[{"5", ",", 
        RowBox[{"{", 
         RowBox[{"2", ",", "3"}], "}"}]}], "]"}], "]"}], "}"}], ",", 
    RowBox[{"Cases", "[", 
     RowBox[{
      RowBox[{"data", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"6", ";;"}], ",", 
         RowBox[{"2", ";;", "3"}]}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"_", "?", "NumericQ"}], ",", 
        RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}]}], "]"}]}]], "Input",\

 CellChangeTimes->{
  3.573976754963819*^9, {3.573976843843639*^9, 
   3.573976929251966*^9}},ExpressionUUID->"8974081c-61af-4501-9f69-\
ba02e62c20cf"],

Cell["\<\
This exports the above data to a file called cleanDat:Wed 3 Apr 2013 \
06:33:42.xlsx. You have created a folder called Exports to contain the \
generated files. The file name may display differently on different operating \
systems because of the use of the date string, but the file should work as \
expected.\
\>", "Text",
 CellChangeTimes->{{3.573977098886387*^9, 3.573977137509297*^9}, {
   3.573978433214782*^9, 3.573978436115623*^9}, {3.573978475485363*^9, 
   3.573978540149376*^9}, {3.573978628566912*^9, 3.573978661183571*^9}, 
   3.580147369498507*^9, {3.631644932909944*^9, 3.631644933719096*^9}, {
   3.632663945257849*^9, 
   3.632663951353153*^9}},ExpressionUUID->"33fb8871-2de4-4500-b937-\
a4063b8dc27c"],

Cell[BoxData[
 RowBox[{"Export", "[", 
  RowBox[{
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<Exports\>\"", ",", 
      RowBox[{"StringJoin", "[", 
       RowBox[{"\"\<cleanDat:\>\"", ",", 
        RowBox[{"DateString", "[", "]"}], ",", "\"\<.xlsx\>\""}], "]"}]}], 
     "}"}], "]"}], ",", "wrkDat"}], "]"}]], "Input",
 CellChangeTimes->{{3.573977143265209*^9, 3.573977194776452*^9}, {
  3.573977231522686*^9, 3.573977242777371*^9}, {3.573977523558669*^9, 
  3.57397755574273*^9}, {3.573977588335567*^9, 
  3.57397761698404*^9}},ExpressionUUID->"6b73ed17-9527-4078-8bb0-\
51f0b6f43c47"]
}, Open  ]]
}, Open  ]],

