  3.573471383678502*^9}},ExpressionUUID->"a9fdac86-9006-4cae-87a1-\
181f4f5e7433"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"pos", ",", "#", ",", 
     RowBox[{"Head", "[", "#", "]"}]}], "}"}], "&"}], "/@", 
  RowBox[{"Extract", "[", 
   RowBox[{"breamDat2", ",", 
    RowBox[{"pos", "=", 
     RowBox[{"Position", "[", 
      RowBox[{"breamDat2", ",", 
       RowBox[{"NA", "|", "\"\<NA\>\""}]}], "]"}]}]}], "]"}]}]], "Input",
