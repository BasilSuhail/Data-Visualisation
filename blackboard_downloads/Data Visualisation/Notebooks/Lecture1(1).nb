  RowBox[{"wealthUS", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"CountryData", "[", 
        RowBox[{"\"\<UnitedStates\>\"", ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", "\"\<GDPPerCapita\>\"", "}"}], ",", "y"}], "}"}]}], 
        "]"}]}], "}"}], ",", "\n", "                 ", 
     RowBox[{"{", 
      RowBox[{"y", ",", " ", "1910", ",", "2015", ",", "5"}], "}"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"wealthIndia", ",", " ", "wealthChina", ",", " ", "wealthUS"}], 
    "}"}], ",", "\n", "             ", 
   RowBox[{"PlotLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
     "\"\<India\>\"", ",", " ", "\"\<China\>\"", ",", " ", "\"\<US\>\""}], 
     "}"}]}]}], "]"}]}], "Code",
