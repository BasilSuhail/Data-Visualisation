Cell[TextData[{
 "Now we can use ",
 StyleBox["countryPlot",
  FontWeight->"Bold"],
 " to quickly explore the relationship between many quantities. Use the \
command ",
 StyleBox["CountryData[\[OpenCurlyDoubleQuote]Properties\
\[CloseCurlyDoubleQuote]]", "CodeText",
  FontWeight->"Bold"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "to see which quantities are available in Mathematica\[CloseCurlyQuote]s \
country database."
}], "Text",
 CellChangeTimes->{{3.787638440784663*^9, 3.787638556320136*^9}, {
  3.787638634201263*^9, 3.7876386390155582`*^9}, {3.820318847870377*^9, 
  3.8203188489168854`*^9}},ExpressionUUID->"090f8ded-dfd0-405f-9c6c-\
464864dbdc9e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Scatter plots with multiple datasets", "Subsection",
 CellChangeTimes->{{3.7875984740052905`*^9, 
  3.787598489548856*^9}},ExpressionUUID->"a132de2a-1788-41df-80b9-\
fca3a17e0399"],

Cell[TextData[{
 "We can plot multiple data sets in the same scatterplot using ",
 StyleBox["ListPlot",
  FontWeight->"Bold"],
 " or ",
 StyleBox["ListLogPlot",
  FontWeight->"Bold"],
 ". So let us divide our set of countries into European and non-European, and \
plot each set with a different colour. This way we will be able to see where \
European countries are located in the plot."
}], "Text",
 CellChangeTimes->{{3.787595793754676*^9, 3.7875958372138495`*^9}, {
   3.787595874388126*^9, 3.7875958750329595`*^9}, {3.7875961553089814`*^9, 
   3.787596199277012*^9}, {3.78759630660413*^9, 3.787596339743493*^9}, {
   3.787596378276331*^9, 3.787596397117603*^9}, 
   3.787598494228344*^9},ExpressionUUID->"d6fcd0be-8b9c-417b-b28e-\
19a474968e0b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"european", " ", "=", " ", 
   RowBox[{"Select", "[", 
    RowBox[{"countriesM", ",", " ", 
     RowBox[{
      RowBox[{"SameQ", "[", 
       RowBox[{
        RowBox[{"CountryData", "[", 
         RowBox[{"#", ",", "\"\<Continent\>\""}], "]"}], ",", "\n", 
        "\t\t\t\t\t ", 
        RowBox[{"EntityClass", "[", 
         RowBox[{"\"\<Country\>\"", ",", "\"\<Europe\>\""}], "]"}]}], "]"}], 
      "&"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"euLiteracy", " ", "=", " ", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CountryData", "[", 
       RowBox[{"#", ",", " ", "\"\<LiteracyFraction\>\""}], "]"}], "&"}], ",",
      " ", "european"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"euWealth", " ", "=", " ", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"CountryData", "[", 
        RowBox[{"#", ",", " ", "\"\<GDPPerCapita\>\""}], "]"}], "&"}], ",", 
      " ", "european"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"noneuCountries", " ", "=", " ", 
   RowBox[{"Complement", "[", 
    RowBox[{"countriesM", ",", "european"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"noneuCountries", " ", "=", " ", 
   RowBox[{"Select", "[", 
    RowBox[{"countriesM", ",", " ", 
     RowBox[{
      RowBox[{"Not", "@", 
       RowBox[{"SameQ", "[", 
        RowBox[{
         RowBox[{"CountryData", "[", 
          RowBox[{"#", ",", "\"\<Continent\>\""}], "]"}], ",", "\n", 
         "\t\t\t\t\t ", 
         RowBox[{"EntityClass", "[", 
          RowBox[{"\"\<Country\>\"", ",", "\"\<Europe\>\""}], "]"}]}], 
        "]"}]}], "&"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"noneuLiteracy", " ", "=", " ", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CountryData", "[", 
       RowBox[{"#", ",", " ", "\"\<LiteracyFraction\>\""}], "]"}], "&"}], ",",
      " ", "noneuCountries"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"noneuWealth", " ", "=", " ", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CountryData", "[", 
       RowBox[{"#", ",", " ", "\"\<GDPPerCapita\>\""}], "]"}], "&"}], ",", 
     " ", "noneuCountries"}], "]"}]}], ";"}]}], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.7875964017574043`*^9, 3.787596437493878*^9}, {
   3.787596494165934*^9, 3.787596703960865*^9}, {3.7875968128607473`*^9, 
   3.7875970473729663`*^9}, {3.7875971287695847`*^9, 3.787597351927869*^9}, {
   3.787597402616735*^9, 3.7875974183330765`*^9}, 3.787976891670533*^9, {
   3.7879769373978696`*^9, 3.7879769435245147`*^9}, {3.914994376071845*^9, 
   3.9149943854874444`*^9}, {3.91499442320794*^9, 3.9149944560364904`*^9}, {
   3.9149945659161186`*^9, 3.9149945848353424`*^9}, {3.914994623839635*^9, 
   3.914994749462453*^9}, {3.914994780273221*^9, 3.9149947808275633`*^9}, 
   3.9149955283391747`*^9, {3.9149956792561827`*^9, 3.914995715879092*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"72408a2a-00d2-436c-8707-a03553698899"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLogPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"euLiteracy", ",", " ", 
        RowBox[{"euWealth", "/", "1000.0"}]}], "}"}], "]"}], ",", "\n", 
     "\t\t\t ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"noneuLiteracy", ",", " ", 
        RowBox[{"noneuWealth", "/", "1000.0"}]}], "}"}], "]"}]}], "}"}], ",", 
   "\n", "\t", 
   RowBox[{"PlotLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Europe\>\"", ",", "\"\<non-Europe\>\""}], "}"}]}], ",", 
   "\n", "\t", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<literacy\>\"", ",", "\"\<GDP per capita [x 1000]\>\""}], 
     "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[67]:=",ExpressionUUID->"03418f3c-21df-48c6-836b-d55c6b4ab41c"],

