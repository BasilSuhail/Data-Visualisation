Cell[TextData[{
 "If we want to plot mortality rate versus inflation, we would need to repeat \
most of this, creating variables ",
 StyleBox["mortality, inflation, ",
  FontWeight->"Bold"],
 "etc. Surely there is a way to automate out all this drudgery!\n\nIndeed \
there is a way: we can create a function that makes the scatter plot for any \
two given quantities. Here is a first version:"
}], "Text",
 CellChangeTimes->{{3.7876014636786857`*^9, 3.787601683579844*^9}, {
  3.787975774702324*^9, 
  3.7879757790196533`*^9}},ExpressionUUID->"ba69314a-a458-42a9-846d-\
f4d12c2fdbe1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"countryPlot", "[", 
   RowBox[{"xname_", ",", "yname_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", "\n", "\t", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"countriesM", ",", " ", "x", ",", " ", "y"}], "}"}], ",", "\n", 
    "\t", "\n", "\t", 
    RowBox[{
     RowBox[{"countriesM", " ", "=", " ", 
      RowBox[{"CountryData", "[", "\"\<Countries\>\"", "]"}]}], ";", "\n", 
     "\t", 
     RowBox[{"x", " ", "=", " ", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"CountryData", "[", 
          RowBox[{"#", ",", " ", "xname"}], "]"}], "&"}], ",", " ", 
        "countriesM"}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"y", " ", "=", " ", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"CountryData", "[", 
          RowBox[{"#", ",", " ", "yname"}], "]"}], "&"}], ",", " ", 
        "countriesM"}], "]"}]}], ";", "\n", "\t", "\n", "\t", 
     RowBox[{"ListPlot", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y"}], "}"}], "]"}], "]"}]}]}], "\n", 
   "]"}]}]], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.787601697957872*^9, 3.7876019328518624`*^9}, {
   3.7876019989902744`*^9, 3.7876020263730555`*^9}, {3.7876021700803795`*^9, 
   3.787602179493393*^9}, {3.7879757958616343`*^9, 3.7879758305881743`*^9}, {
   3.7879760459327464`*^9, 3.78797605670032*^9}, 3.8203200165664144`*^9},
 CellLabel->
  "In[183]:=",ExpressionUUID->"e3dff0bd-084b-42e8-8ff1-b0bbcec89b1f"],

Cell["\<\
Let us see if we can recover our original plot using this function:\
\>", "Text",
 CellChangeTimes->{{3.7876020466195393`*^9, 
  3.787602075363714*^9}},ExpressionUUID->"a16381f6-d520-4b9c-9278-\
1d64f8c8fb77"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"countryPlot", "[", 
  RowBox[{"\"\<LiteracyFraction\>\"", ",", " ", "\"\<GDPPerCapita\>\""}], 
  "]"}]], "Code",
