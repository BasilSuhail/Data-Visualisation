Cell[TextData[{
 "We can use this plot to compare child to adult population within each \
country, but we lost the ability to compare populations between different \
countries. When we have a quantity that is made up of a number of \
contributions (total population = adults + children), the ",
 StyleBox["stacked bar chart",
  FontWeight->"Bold"],
 " is a good choice:"
}], "Text",
 CellChangeTimes->{{3.787577069345524*^9, 
  3.7875772339712*^9}},ExpressionUUID->"f88298d8-cde4-466e-9c37-11840e1c3f31"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"popsAdult", "/", "1000000.0"}], ",", "\n", "\t", 
      RowBox[{"popsChildren", "/", "1000000.0"}]}], "}"}], "]"}], ",", " ", 
   "\n", "\t", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"countries", ",", "None"}], "}"}]}], ",", "\n", "\t", 
   RowBox[{"ChartLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Adults\>\"", ",", "\"\<Children\>\""}], "}"}]}], ",", "\n", 
   "\t", 
   RowBox[{"BarOrigin", "\[Rule]", "Left"}], ",", "\n", "\t", 
   RowBox[{"ChartLayout", "\[Rule]", "\"\<Stacked\>\""}], ",", "\n", "\t", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<Comparing populations\>\""}], ",", 
   "\n", "\t", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<country\>\"", ",", "\"\<pop [millions]\>\""}], "}"}]}]}], 
  "]"}]], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.787577237960855*^9, 3.787577247737493*^9}, {
  3.7875774679424467`*^9, 3.787577491866271*^9}},
 CellLabel->
  "In[165]:=",ExpressionUUID->"e0491473-f933-40b3-a225-12ce4d3c8cc2"],

