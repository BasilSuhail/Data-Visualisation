 RowBox[{
  RowBox[{"popIndia", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"CountryData", "[", 
        RowBox[{"\"\<India\>\"", ",", " ", 
