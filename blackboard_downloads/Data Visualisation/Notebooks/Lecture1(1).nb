Cell["\<\
Notice how awkward this is! It is almost never a good idea to label grouped \
bar charts like this. It is even worse in our original plot of the \
populations. The information about the year is repeated needlessly for every \
country. We can use the colour coding instead: blue means 2020 population, \
orange means 1950 population. Let us put this information in a legend:\
\>", "Text",
 CellChangeTimes->{{3.820323892145082*^9, 
  3.8203239125758734`*^9}},ExpressionUUID->"1aca7d69-9a8c-4136-8c08-\
bf0f03a8390c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"pops1950", "/", "1000000.0"}], ",", 
      RowBox[{"popsNow", "/", "1000000.0"}]}], "}"}], "]"}], ",", " ", "\n", 
   "\t", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"countries", ",", "None"}], "}"}]}], ",", "\n", "\t", 
   RowBox[{"ChartLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<1950\>\"", ",", "\"\<2020\>\""}], "}"}]}], ",", "\n", "\t", 
   
   RowBox[{"BarOrigin", "\[Rule]", "Left"}], ",", "\n", "\t", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<Comparing populations\>\""}], ",", 
   "\n", "\t", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<country\>\"", ",", "\"\<pop [millions]\>\""}], "}"}]}]}], 
  "]"}]], "Code",
