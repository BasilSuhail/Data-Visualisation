Cell[TextData[{
 "Now if you hover the mouse over the point ",
 StyleBox["{2,2}",
  FontWeight->"Bold"],
 ", a tooltip with the text \[OpenCurlyDoubleQuote]this is a tip\
\[CloseCurlyDoubleQuote] will appear. We can do this for every point, with \
customized text for each point:"
}], "Text",
 CellChangeTimes->{{3.7875992547320385`*^9, 3.787599340356372*^9}, {
  3.787599427564911*^9, 
  3.787599449980939*^9}},ExpressionUUID->"13659676-745f-4bef-b7e2-\
671749aa7944"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Tooltip", "[", 
       RowBox[{"#", ",", 
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<x=\>\"", ",", 
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", " ", "\"\< y=,\>\"", ",", 
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]}], "]"}], "&"}], 
     ",", "\n", "\t", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "1"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}]}], "}"}]}], "]"}], ",", " ", 
   RowBox[{"ImageSize", "\[Rule]", "Medium"}]}], "]"}]], "Input",
