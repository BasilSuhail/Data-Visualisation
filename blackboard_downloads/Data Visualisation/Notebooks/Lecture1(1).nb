Cell[TextData[{
 "You now have the ability to compare total populations in different \
countries, and you can still compare child/adult populations within one \
country. You also can easily compare adult populations across different \
countries, but it is more difficult to compare child populations, because \
their bars start at different levels. \n\nA variation of the stacked bar \
chart is useful when you want to compare ",
 StyleBox["proportions",
  FontWeight->"Bold"],
 " of quantities. Using our example of adult/child populations, we may want \
to compare and contrast the proportions of adults versus children across \
countries. In this case, we do not care about the total population, but about \
how each population is divided into adults and children. The ",
 StyleBox["percentile stacked bar chart",
  FontWeight->"Bold"],
 " works like the usual stacked bar chart, but it forces the total heights of \
all bars to be the same:"
}], "Text",
 CellChangeTimes->{{3.7875775063000383`*^9, 3.787577610833385*^9}, {
  3.787578073038725*^9, 
  3.7875783757153397`*^9}},ExpressionUUID->"7f52613b-0ba5-4de5-8672-\
d1c1517481c0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"popsAdult", "/", "1000000.0"}], ",", "\n", "\t", 
      RowBox[{"popsChildren", "/", "1000000.0"}]}], "}"}], "]"}], ",", " ", 
   "\n", "\t", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"countries", ",", "None"}], "}"}]}], ",", "\n", "\t", 
   RowBox[{"ChartLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Adults\>\"", ",", "\"\<Children\>\""}], "}"}]}], ",", "\n", 
   "\t", 
   RowBox[{"BarOrigin", "\[Rule]", "Left"}], ",", "\n", "\t", 
   RowBox[{"ChartLayout", "\[Rule]", "\"\<Percentile\>\""}], ",", "\n", "\t", 
   
   RowBox[{"PlotLabel", "\[Rule]", "\"\<Comparing populations\>\""}], ",", 
   "\n", "\t", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<country\>\"", ",", "\"\<pop [%]\>\""}], "}"}]}]}], 
  "]"}]], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.7875783782951813`*^9, 3.787578392085479*^9}, {
  3.787578470580966*^9, 3.787578473133566*^9}, {3.78757870727042*^9, 
  3.7875787098676443`*^9}},
 CellLabel->
  "In[166]:=",ExpressionUUID->"4531264a-92d3-48b8-aba1-2512b7bb8ac9"],

