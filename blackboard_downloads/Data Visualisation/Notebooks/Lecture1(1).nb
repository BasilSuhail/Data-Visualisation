Cell["\<\
Now we want to do something similar with our scatter plot of countries. The \
tooltip message should be the name of the country, so that by moving the \
mouse over a point we can learn what country it represents:\
\>", "Text",
 CellChangeTimes->{
  3.7876000870873637`*^9, {3.7876001529881516`*^9, 
   3.787600234956547*^9}},ExpressionUUID->"3d8a5bcf-3a31-433a-930e-\
d9a317e24c1c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"countriesM", " ", "=", " ", 
   RowBox[{"CountryData", "[", "\"\<Countries\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"literacy", " ", "=", " ", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CountryData", "[", 
       RowBox[{"#", ",", " ", "\"\<LiteracyFraction\>\""}], "]"}], "&"}], ",",
      " ", "countriesM"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"wealth", " ", "=", " ", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"CountryData", "[", 
        RowBox[{"#", ",", " ", "\"\<GDPPerCapita\>\""}], "]"}], "&"}], ",", 
      " ", "countriesM"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"ttipData", " ", "=", " ", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"literacy", ",", " ", 
      RowBox[{"wealth", "/", "1000.0"}], ",", " ", "countriesM"}], "}"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ttipPts", " ", "=", " ", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Tooltip", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}],
           ",", " ", 
          RowBox[{
          "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
         "}"}], ",", " ", 
        RowBox[{"#", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]}],
        "]"}], "&"}], ",", " ", "ttipData"}], "]"}]}], ";"}], "\n", 
 RowBox[{"ListLogPlot", "[", 
  RowBox[{"ttipPts", ",", "\n", "\t", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<literacy\>\"", ",", "\"\<GDP per capita [x 1000]\>\""}], 
     "}"}]}]}], "]"}]}], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.7876002384701333`*^9, 3.7876003794605618`*^9}, {
   3.7876004680446773`*^9, 3.7876005991180487`*^9}, 3.787977094461855*^9, {
   3.787990805078224*^9, 3.7879908203619204`*^9}, {3.7879909216663647`*^9, 
