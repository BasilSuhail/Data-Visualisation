Cell["\<\
It works! However, if we try to set the axis labels, something goes wrong:\
\>", "Text",
 CellChangeTimes->{{3.787602211414033*^9, 
  3.7876022415963707`*^9}},ExpressionUUID->"614c63fa-f9d9-4a38-9def-\
26cfd239f571"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"countryPlot", "[", 
  RowBox[{
  "\"\<LiteracyFraction\>\"", ",", " ", "\"\<GDPPerCapita\>\"", ",", "\n", 
   "\t", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<literacy\>\"", ",", "\"\<GDP per capita\>\""}], "}"}]}]}], 
  "]"}]], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.787602245501915*^9, 3.787602267451221*^9}, {
  3.787602334188184*^9, 3.787602337964059*^9}},
 CellLabel->
  "In[185]:=",ExpressionUUID->"ddcfda30-9f14-494d-91c4-7f61397ad5a8"],

Cell[BoxData[
 RowBox[{"countryPlot", "[", 
  RowBox[{"\<\"LiteracyFraction\"\>", ",", "\<\"GDPPerCapita\"\>", ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\<\"literacy\"\>", ",", "\<\"GDP per capita\"\>"}], "}"}]}]}], 
  "]"}]], "Output",
 CellChangeTimes->{3.820389410281207*^9},
 CellLabel->
  "Out[185]=",ExpressionUUID->"298ffc6a-05b4-49ca-b0e2-6de91af8d7ff"]
}, Open  ]],

Cell[TextData[{
 "Nothing happens, because our function ",
 StyleBox["countryPlot",
  FontWeight->"Bold"],
 " does not know what to do with the ",
 StyleBox["AxesLabel",
  FontWeight->"Bold"],
 " option. Unlike ",
 StyleBox["ListPlot",
  FontWeight->"Bold"],
 ", our function does not accept options. Let us make it accept all options \
that ",
 StyleBox["ListPlot",
  FontWeight->"Bold"],
 " accepts, and pass these options on to ",
 StyleBox["ListPlot",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.787602347142514*^9, 3.7876024275484333`*^9}, {
  3.7876380485714483`*^9, 
  3.787638086235011*^9}},ExpressionUUID->"95e60f8e-df3b-4f33-bece-\
4aa7afd86d44"],

Cell[BoxData[
 RowBox[{
  RowBox[{"countryPlot", "[", 
   RowBox[{"xname_", ",", "yname_", ",", " ", "\n", "\t\t\t", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "ListPlot", "]"}]}]}], "]"}], " ", ":=", 
  " ", 
  RowBox[{"Module", "[", "\n", "\t", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"countriesM", ",", " ", "x", ",", " ", "y"}], "}"}], ",", "\n", 
    "\t", "\n", "\t", 
    RowBox[{
     RowBox[{"countriesM", " ", "=", " ", 
      RowBox[{"CountryData", "[", "\"\<Countries\>\"", "]"}]}], ";", "\n", 
     "\t", 
     RowBox[{"x", " ", "=", " ", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"CountryData", "[", 
          RowBox[{"#", ",", " ", "xname"}], "]"}], "&"}], ",", " ", 
        "countriesM"}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"y", " ", "=", " ", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"CountryData", "[", 
          RowBox[{"#", ",", " ", "yname"}], "]"}], "&"}], ",", " ", 
        "countriesM"}], "]"}]}], ";", "\n", "\t", "\n", "\t", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y"}], "}"}], "]"}], ",", " ", "opts"}], 
      "]"}]}]}], "\n", "]"}]}]], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.7876380912221537`*^9, 3.7876381751396217`*^9}, {
  3.787975983725357*^9, 3.787976004961142*^9}, {3.787991358790882*^9, 
  3.787991403969343*^9}, {3.787991457377973*^9, 3.787991478772361*^9}, {
  3.788004898062592*^9, 3.788004906802047*^9}},
 CellLabel->"In[77]:=",ExpressionUUID->"2e12af0c-ab50-42db-8bf4-f6ade0b563c4"],

