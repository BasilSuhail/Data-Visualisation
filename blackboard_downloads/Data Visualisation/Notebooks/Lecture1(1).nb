 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"10", ",", "12"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"20", ",", "26"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"40", ",", "48"}], "}"}]}], "}"}], ",", "\n", "\t", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<a\>\"", ",", "\"\<b\>\"", ",", "\"\<c\>\""}], "}"}], ",", 
      
      RowBox[{"{", 
       RowBox[{"\"\<1950\>\"", ",", "\"\<2020\>\""}], "}"}]}], "}"}]}]}], 
  "]"}]], "Code",
