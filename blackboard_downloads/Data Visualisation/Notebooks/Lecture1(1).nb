Cell[CellGroupData[{

Cell["Line plots", "Section",
 CellChangeTimes->{{3.7877734485320263`*^9, 
  3.7877734707855167`*^9}},ExpressionUUID->"a7e05a37-8786-4261-b783-\
ce09ffe77f6b"],

Cell["\<\
In line plots, data points are laid out in a linear sequence. The most common \
application of line plots is to show how some quantity is changing over time:\
\
\>", "Text",
 CellChangeTimes->{{3.7878373398510957`*^9, 
  3.787837486331136*^9}},ExpressionUUID->"37c37c9a-d1c1-4246-bab4-\
5435a62a7be2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"years", ",", "worldPop"}], "}"}], "]"}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Medium"}], ",", "\n", "\t", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<year\>\"", ",", "\"\<population\>\""}], "}"}]}], ",", "\n", 
   "\t", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<World population over time\>\""}]}], 
  "]"}]], "Code",
 InitializationCell->False,
