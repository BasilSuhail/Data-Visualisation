Cell[TextData[{
 "If we have instead a list of numbers for label \[OpenCurlyDoubleQuote]1\
\[CloseCurlyDoubleQuote], and a list of numbers for label \
\[OpenCurlyDoubleQuote]2\[CloseCurlyDoubleQuote], we use the ",
 StyleBox["Transpose",
  FontWeight->"Bold"],
 " function to turn that into a list of pairs, which the ",
 StyleBox["BarChart",
  FontWeight->"Bold"],
 " function demands:"
}], "Text",
 CellChangeTimes->{{3.8203386288713074`*^9, 3.820338661200281*^9}, {
  3.8203387392092485`*^9, 
  3.820338786711484*^9}},ExpressionUUID->"9d0b0894-8b6b-4199-81f4-\
9d7226750756"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Transpose", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"10", ",", "20", ",", "40"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"12", ",", "26", ",", "48"}], "}"}]}], "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.8203386664795337`*^9, 3.8203387343040867`*^9}},
 CellLabel->
  "In[157]:=",ExpressionUUID->"77ba886a-0b8d-445d-b1ac-364e41db7bc6"],

Cell[BoxData[
 RowBox[{"{", 
