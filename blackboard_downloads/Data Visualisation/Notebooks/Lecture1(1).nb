Cell["\<\
Bar charts are also used to compare changes in some quantity. For example, we \
can compare the current population to the population in 1950, and assess how \
population growth differs across these countries. First, let us get the \
population data for 1950.\
\>", "Text",
 CellChangeTimes->{{3.7875720119790077`*^9, 3.787572062316421*^9}, {
  3.787572119175233*^9, 
  3.787572252924244*^9}},ExpressionUUID->"aafe31f9-dda5-4232-8bc8-\
2d5d2455b27f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{"pops1950", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"QuantityMagnitude", ",", "\n", "\t", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"CountryData", "[", 
         RowBox[{"#", ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Population\>\"", ",", " ", "1950"}], "}"}]}], "]"}], 
        "&"}], ",", "\n", "\t", "countriesM"}], "]"}]}], "]"}]}]}]], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.787572255903034*^9, 3.787572363411071*^9}, {
   3.7875724533361063`*^9, 3.7875724682506857`*^9}, {3.787572505989275*^9, 
