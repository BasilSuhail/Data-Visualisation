Cell["\<\
Now if when your mouse goes over a country, its name will pop up in a \
tooltip. This is our first example of making a plot interactive, and it is \
just the tip of the iceberg. We will have much more to say about this in the \
near future.\
\>", "Text",
 CellChangeTimes->{
  3.7876006766467276`*^9, {3.7876007256440997`*^9, 3.787600767235878*^9}, {
   3.7876010793714137`*^9, 
   3.7876011218920565`*^9}},ExpressionUUID->"a7885dba-d6ee-4a77-afee-\
5e0bcd1173cf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Multiple plots", "Subsubsection",
 CellChangeTimes->{{3.787638890995184*^9, 
  3.787638894484499*^9}},ExpressionUUID->"a039984f-5aee-42b8-be28-\
5c1ae51a5a8c"],

Cell["\<\
It is often useful to have a grid of similar charts displayed on the same \
plot (this may take a few minutes to plot):\
\>", "Text",
 CellChangeTimes->{{3.787638911490617*^9, 3.787638957452479*^9}, {
  3.8203215752132654`*^9, 
  3.8203215853949113`*^9}},ExpressionUUID->"0abaf499-0c4d-4e4e-8b05-\
068d6402fa11"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"xs", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
    "\"\<LiteracyRate\>\"", ",", " ", "\"\<MedianAge\>\"", ",", 
     "\"\<GrossInvestment\>\""}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"xsShort", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
    "\"\<lit\>\"", ",", " ", "\"\<age\>\"", ",", " ", "\"\<invest\>\""}], 
    "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ys", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
    "\"\<DeathRateFraction\>\"", ",", " ", "\"\<GDPPerCapita\>\"", ",", " ", 
     "\n", "\t", "\"\<IndustrialProductionGrowth\>\""}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ysShort", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
    "\"\<death\>\"", ",", " ", "\"\<wealth\>\"", ",", " ", "\"\<indust\>\""}],
     "}"}]}], ";"}], "\n", 
 RowBox[{"Grid", "@", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"countryPlot", "[", 
     RowBox[{
      RowBox[{"xs", "\[LeftDoubleBracket]", "m", "\[RightDoubleBracket]"}], 
      ",", " ", 
      RowBox[{"ys", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}], 
      ",", "\n", "\t", 
      RowBox[{"AxesLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
         "xsShort", "\[LeftDoubleBracket]", "m", "\[RightDoubleBracket]"}], 
         ",", " ", 
         RowBox[{
         "ysShort", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}]}], 
        "}"}]}]}], "]"}], ",", "\n", "\t", 
    RowBox[{"{", 
     RowBox[{"m", ",", " ", "1", ",", " ", "3"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"n", ",", " ", "1", ",", " ", "3"}], "}"}]}], "]"}]}]}], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.787644666209867*^9, 3.787644684160336*^9}, {
