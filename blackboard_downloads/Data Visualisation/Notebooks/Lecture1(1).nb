Cell["So how is the death rate related to inflation?", "Text",
 CellChangeTimes->{{3.787638399317279*^9, 
  3.787638420031042*^9}},ExpressionUUID->"b937d4ea-609a-46a0-afe9-\
ab60ca503a3c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"countryPlot", "[", 
  RowBox[{
  "\"\<InflationRate\>\"", ",", " ", "\"\<DeathRateFraction\>\"", ",", "\n", 
   "\t", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<inflation\>\"", ",", "\"\<mortality\>\""}], "}"}]}]}], 
  "]"}]], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.787638352463992*^9, 3.787638384052451*^9}},
 CellLabel->
  "In[188]:=",ExpressionUUID->"7920c3f9-d14c-4fe6-869b-77a312e9a95b"],

