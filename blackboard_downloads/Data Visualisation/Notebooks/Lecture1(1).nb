Cell[TextData[{
 "Now we wrap up one of the points by a ",
 StyleBox["tooltip",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.7875991292519894`*^9, 
  3.7875991711804647`*^9}},ExpressionUUID->"cad0e053-5d71-4e32-afd6-\
a6acb536418a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "1"}], "}"}], ",", " ", 
     RowBox[{"Tooltip", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}], ",", "\"\<this is a tip\>\""}], "]"}],
      ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}]}], "}"}], ",", " ", 
   RowBox[{"ImageSize", "\[Rule]", "Medium"}]}], "]"}]], "Code",
