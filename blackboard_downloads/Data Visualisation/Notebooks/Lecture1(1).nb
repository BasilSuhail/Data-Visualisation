Cell[BoxData[{
 RowBox[{
  RowBox[{"countriesM", " ", "=", " ", 
   RowBox[{"CountryData", "[", "\"\<Countries\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"literacy", " ", "=", " ", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CountryData", "[", 
       RowBox[{"#", ",", " ", "\"\<LiteracyFraction\>\""}], "]"}], "&"}], ",",
      " ", "countriesM"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"wealth", " ", "=", " ", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CountryData", "[", 
       RowBox[{"#", ",", " ", "\"\<GDPPerCapita\>\""}], "]"}], "&"}], ",", 
     " ", "countriesM"}], "]"}]}], ";"}], "\n", 
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"literacy", ",", "wealth"}], "}"}], "]"}], ",", "\n", "    ", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<literacy\>\"", ",", "\"\<GDP per capita\>\""}], "}"}]}]}], 
  "]"}]}], "Code",
