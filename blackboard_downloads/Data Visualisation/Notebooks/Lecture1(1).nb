Cell[CellGroupData[{

Cell["Using tooltips", "Subsubsection",
 CellChangeTimes->{{3.7875989155567493`*^9, 
  3.787598951756971*^9}},ExpressionUUID->"a53da6a3-b77a-46c6-9833-\
5eb6ce19ab95"],

Cell[TextData[{
 "The problem with our scatter plots is that we cannot tell which country \
each point represents. We will solve this problem by using ",
 StyleBox["tooltips",
  FontWeight->"Bold"],
 " instead of plain data.\n\nTo see how this works, let us start with the \
following very simple scatter plot:"
}], "Text",
 CellChangeTimes->{{3.787598958252577*^9, 
  3.787599058884224*^9}},ExpressionUUID->"4d97fdeb-b1b0-4d0e-a166-\
f00f80d4591d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "1"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}]}], "}"}], ",", " ", 
   RowBox[{"ImageSize", "\[Rule]", "Medium"}]}], "]"}]], "Code",
