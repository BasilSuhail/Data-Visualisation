Cell[BoxData[{
 RowBox[{
  RowBox[{"wealthIndia", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"CountryData", "[", 
        RowBox[{"\"\<India\>\"", ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", "\"\<GDPPerCapita\>\"", "}"}], ",", "y"}], "}"}]}], 
        "]"}]}], "}"}], ",", "\n", "                 ", 
     RowBox[{"{", 
      RowBox[{"y", ",", " ", "1910", ",", "2015", ",", "5"}], "}"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"wealthChina", " ", "=", " ", 
   RowBox[{"Table", "[", 
