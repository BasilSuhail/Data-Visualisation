Cell["\<\
We can label each tab by associating the label with the corresponding plot:\
\>", "Text",
 CellChangeTimes->{{3.787645874808598*^9, 
  3.787645897489778*^9}},ExpressionUUID->"f608987c-2b98-43e5-a54b-\
b28c46272008"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TabView", "[", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
     "ysShort", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}], 
     "\[Rule]", 
     RowBox[{"countryPlot", "[", 
      RowBox[{"\"\<LiteracyRate\>\"", ",", " ", 
       RowBox[{"ys", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}], 
