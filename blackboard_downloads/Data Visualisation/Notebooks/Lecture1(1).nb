Cell[TextData[{
 "The data is grouped into three sets of two data points each. The data given \
to ",
 StyleBox["BarChart",
  FontWeight->"Bold"],
 " is not just a list of numbers as before, it is actually a list of lists. \
For that reason, the labels passed to the ",
 StyleBox["ChartLabels",
  FontWeight->"Bold"],
 " option are not just a plain list of labels as before, but ",
 StyleBox["two",
  FontWeight->"Bold"],
 " lists of labels: one for the \[OpenCurlyDoubleQuote]outermost\
\[CloseCurlyDoubleQuote] grouping (",
 StyleBox["a, b, c",
  FontWeight->"Bold"],
 "), and one for the \[OpenCurlyDoubleQuote]innermost\[CloseCurlyDoubleQuote] \
grouping (denoted by the colours blue and orange). We left this second list \
of labels blank by giving it the value ",
 StyleBox["None",
  FontWeight->"Bold"],
 ", so no label for the innermost grouping is displayed in the plot. Let us \
try to label the two cases (blue and orange) \[OpenCurlyDoubleQuote]1\
\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]2\[CloseCurlyDoubleQuote]:"
}], "Text",
 CellChangeTimes->{{3.787573996057362*^9, 3.787574312985881*^9}, {
  3.8120884442135487`*^9, 
  3.8120884476391335`*^9}},ExpressionUUID->"5f754e9a-3905-4c36-9042-\
3e310df0658b"],

Cell[CellGroupData[{

