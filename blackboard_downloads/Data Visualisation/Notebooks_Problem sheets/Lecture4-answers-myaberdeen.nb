Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Challenge", " ", "2"}], "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"countries", " ", "=", " ", 
     RowBox[{"CountryData", "[", "\"\<Countries\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"names", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"CountryData", "[", 
         RowBox[{"#", ",", "\"\<Name\>\""}], "]"}], "&"}], ",", " ", 
       "countries"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"life", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"CountryData", "[", 
         RowBox[{"#", ",", "\"\<LifeExpectancy\>\""}], "]"}], "&"}], ",", " ",
        "countries"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"literacy", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"CountryData", "[", 
         RowBox[{"#", ",", "\"\<LiteracyFraction\>\""}], "]"}], "&"}], ",", 
       " ", "countries"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"popupData", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"PopupWindow", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
            "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",", 
            " ", 
            RowBox[{
            "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
           "}"}], ",", " ", 
          RowBox[{"countryTable", "[", 
           RowBox[{
           "#", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], 
           "]"}]}], "]"}], "&"}], ",", "\n", "\t\t\t\t", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"life", ",", "literacy", ",", "countries"}], "}"}], "]"}]}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ttipData", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Tooltip", "[", 
         RowBox[{
          RowBox[{"#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}],
           ",", " ", 
          RowBox[{
          "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
         "]"}], "&"}], ",", "\n", "               ", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"popupData", ",", " ", "names"}], "}"}], "]"}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"ListPlot", "[", 
    RowBox[{"ttipData", ",", "\n", "\t", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<life exp\>\"", ",", " ", "\"\<literacy\>\""}], "}"}]}]}], 
    "]"}]}]}]], "Code",
