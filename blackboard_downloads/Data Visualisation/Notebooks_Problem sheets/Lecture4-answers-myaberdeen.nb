Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Challenge", " ", "3"}], "*)"}], "\n", "\n", 
  RowBox[{"Manipulate", "[", 
   RowBox[{
    RowBox[{"Module", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "countries", ",", "names", ",", "life", ",", "literacy", ",", 
        "avgLife", ",", "avgLiteracy", ",", "\n", "\t", "pts", ",", 
        "ptsNotMissing", ",", "ptsFiltered"}], "}"}], ",", "\n", "\t", "\n", 
      "\t", 
      RowBox[{
       RowBox[{"countries", " ", "=", " ", 
        RowBox[{"CountryData", "[", "\"\<Countries\>\"", "]"}]}], ";", "\n", 
       "\t", 
       RowBox[{"names", " ", "=", " ", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"CountryData", "[", 
            RowBox[{"#", ",", "\"\<Name\>\""}], "]"}], "&"}], ",", " ", 
          "countries"}], "]"}]}], ";", "\n", "\t", 
       RowBox[{"life", " ", "=", " ", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"CountryData", "[", 
            RowBox[{"#", ",", "\"\<LifeExpectancy\>\""}], "]"}], "&"}], ",", 
          " ", "countries"}], "]"}]}], ";", "\n", "\t", 
       RowBox[{"literacy", " ", "=", " ", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"CountryData", "[", 
            RowBox[{"#", ",", "\"\<LiteracyFraction\>\""}], "]"}], "&"}], ",",
           " ", "countries"}], "]"}]}], ";", "\n", "\n", "\t", 
       RowBox[{"pts", " ", "=", " ", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"life", ",", "literacy"}], "}"}], "]"}]}], ";", "\n", "\t", 
       RowBox[{"ptsNotMissing", " ", "=", " ", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{"pts", ",", " ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"_Missing", ",", " ", "_"}], "}"}], " ", "|", " ", 
           RowBox[{"{", 
            RowBox[{"_", ",", " ", "_Missing"}], "}"}]}]}], "]"}]}], ";", 
       "\n", "\t", 
       RowBox[{"ptsFiltered", " ", "=", " ", 
        RowBox[{"Select", "[", 
         RowBox[{"ptsNotMissing", ",", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"xmin", " ", "<", " ", 
             RowBox[{"QuantityMagnitude", "[", 
              RowBox[{
              "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
              "]"}], " ", "<", " ", "xmax"}], " ", "&&", " ", "\n", "\t\t", 
            RowBox[{"ymin", " ", "<", " ", 
             RowBox[{"QuantityMagnitude", "[", 
              RowBox[{
              "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
              "]"}], " ", "<", " ", "ymax"}]}], " ", "&"}]}], "]"}]}], ";", 
       "\n", "\t\t", "\n", "\t", 
       RowBox[{"avgLife", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Mean", "[", "ptsFiltered", "]"}], "\[LeftDoubleBracket]", 
          "1", "\[RightDoubleBracket]"}], " ", "//", " ", 
         "QuantityMagnitude"}]}], ";", "\n", "\t", 
       RowBox[{"avgLiteracy", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Mean", "[", "ptsFiltered", "]"}], "\[LeftDoubleBracket]", 
          "2", "\[RightDoubleBracket]"}], " ", "//", " ", 
         "QuantityMagnitude"}]}], ";", "\n", "\t", 
       RowBox[{"avgLife", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Mean", "[", "ptsFiltered", "]"}], "\[LeftDoubleBracket]", 
          "1", "\[RightDoubleBracket]"}], " ", "//", " ", 
         "QuantityMagnitude"}]}], ";", "\n", "\t", 
       RowBox[{"avgLiteracy", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Mean", "[", "ptsFiltered", "]"}], "\[LeftDoubleBracket]", 
          "2", "\[RightDoubleBracket]"}], " ", "//", " ", 
         "QuantityMagnitude"}]}], ";", "\n", "\n", "\t", 
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"life", ",", " ", "literacy"}], "}"}], "]"}], ",", "\n", 
         "\t\t", 
         RowBox[{"AxesLabel", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"\"\<life exp\>\"", ",", " ", "\"\<literacy\>\""}], 
           "}"}]}], ",", "\n", "\t\t", 
         RowBox[{"Epilog", "\[Rule]", 
          RowBox[{"{", "\n", "\t\t\t", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"RGBColor", "[", 
               RowBox[{"1", ",", "1", ",", "0", ",", "0.3"}], "]"}], ",", 
              "\n", "\t\t     ", 
              RowBox[{"Rectangle", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"xmin", ",", "ymin"}], "}"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"xmax", ",", "ymax"}], "}"}]}], "]"}]}], "}"}], ",", 
            "\n", "\t\t\t", 
            RowBox[{"Text", "[", 
             RowBox[{
              RowBox[{"Grid", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"\"\<avg life exp: \>\"", ",", " ", "avgLife"}], 
                  "}"}], ",", "\n", "\t\t\t\t      ", 
                 RowBox[{"{", 
                  RowBox[{"\"\<avg literacy: \>\"", ",", " ", "avgLiteracy"}],
                   "}"}]}], "}"}], "]"}], ",", "\n", "\t\t\t     ", 
              RowBox[{"{", 
               RowBox[{"80", ",", "0.15"}], "}"}]}], "]"}]}], "\t", "\n", 
           "\t", "}"}]}]}], "]"}]}]}], "]"}], ",", "\n", "\t", 
    RowBox[{"{", 
