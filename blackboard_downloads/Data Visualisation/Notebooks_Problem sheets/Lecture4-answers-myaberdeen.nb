Cell[CellGroupData[{

Cell[TextData[{
 "\[OpenCurlyDoubleQuote]Easy\[CloseCurlyDoubleQuote] interactivity | Using ",
 StyleBox["Manipulate",
  FontWeight->"Bold"]
}], "Section",
 CellChangeTimes->{{3.788333353216072*^9, 
  3.788333376311427*^9}},ExpressionUUID->"d97038f0-7867-44d3-9a86-\
ae9cb9a1e9a1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Challenge", " ", "1"}], "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"countryTable", "[", "country_", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "neighbours", ",", " ", "neighbLife", ",", " ", "neighbWealth", ",", 
        " ", "neighbNames"}], "}"}], ",", "\n", "\n", "\t", 
      RowBox[{
       RowBox[{"neighbours", " ", "=", " ", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", "country", "}"}], ",", " ", 
          RowBox[{"CountryData", "[", 
           RowBox[{"country", ",", " ", "\"\<BorderingCountries\>\""}], 
           "]"}]}], "]"}]}], ";", "\n", "\t", 
       RowBox[{"neighbNames", " ", "=", " ", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"CountryData", "[", 
            RowBox[{"#", ",", " ", "\"\<Name\>\""}], "]"}], "&"}], ",", " ", 
          "neighbours"}], "]"}]}], ";", "\n", "\t", 
       RowBox[{"neighbLife", " ", "=", " ", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"QuantityMagnitude", "@", 
            RowBox[{"CountryData", "[", 
             RowBox[{"#", ",", " ", "\"\<LifeExpectancy\>\""}], "]"}]}], 
           "&"}], ",", " ", "neighbours"}], "]"}]}], ";", "\n", "\t", 
       RowBox[{"neighbWealth", " ", "=", " ", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"QuantityMagnitude", "@", 
            RowBox[{"CountryData", "[", 
             RowBox[{"#", ",", " ", "\"\<GDPPerCapita\>\""}], "]"}]}], "&"}], 
          ",", " ", "neighbours"}], "]"}]}], ";", "\n", "\t", "\n", "\t", 
       RowBox[{"Grid", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", "\n", "\t\t\t", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "\"\<country\>\"", "}"}], ",", " ", 
              "neighbNames"}], "]"}], ",", "\n", "\t\t\t ", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "\"\<wealth [USD]\>\"", "}"}], ",", " ", 
              "neighbWealth"}], "]"}], ",", "\n", "\t\t\t ", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"{", "\"\<life exp [years]\>\"", "}"}], ",", " ", 
              "neighbLife"}], "]"}]}], "}"}], "]"}], ",", "\n", "\t     ", 
         RowBox[{"Frame", "\[Rule]", "All"}]}], "]"}]}]}], "\t\t\t", "\n", 
     "]"}]}], "\n"}]}]], "Code",
 CellChangeTimes->{{3.7883333814077454`*^9, 3.7883333814127593`*^9}, 
   3.788333575040343*^9, {3.78833365988737*^9, 3.7883338831593924`*^9}, {
