   3.7879777663282957`*^9}},ExpressionUUID->"e7566ad2-a755-41ba-b5cb-\
09ea454745af"],

Cell[TextData[{
 "Create a function that accepts a list of ",
 StyleBox["CountryData",
  FontWeight->"Bold"],
 "\[CloseCurlyQuote]s properties, and creates a TabView of scatter plots of \
literacy versus each of the properties in the list."
}], "ItemNumbered",
 CellChangeTimes->{{3.787687714311097*^9, 3.7876878198889527`*^9}, 
   3.7876878553282123`*^9, {3.7876887503751163`*^9, 3.7876887656238317`*^9}, {
