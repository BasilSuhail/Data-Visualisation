Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Challenge", " ", "1"}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"genLines", "[", 
     RowBox[{
     "lines_", ",", " ", "startPt_", ",", " ", "spacing_", ",", " ", 
      "offset_", ",", " ", 
      RowBox[{"opts", ":", 
       RowBox[{"OptionsPattern", "[", "Style", "]"}]}]}], "]"}], " ", ":=", 
    " \t", "\n", "\t", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"Text", "[", 
         RowBox[{
          RowBox[{"lines", "\[LeftDoubleBracket]", 
           RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}], ",", " ", 
          RowBox[{"startPt", " ", "-", " ", 
           RowBox[{"n", 
            RowBox[{"{", 
             RowBox[{"0", ",", "spacing"}], "}"}]}]}], ",", " ", "offset"}], 
         "]"}], ",", "\n", "\t\t  ", "opts"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"n", ",", " ", "0", ",", " ", 
        RowBox[{
         RowBox[{"Length", "[", "lines", "]"}], "-", "1"}]}], "}"}]}], 
     "]"}]}], "\n", "\t\t  ", "\n", 
   RowBox[{
    RowBox[{"popChina", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"year", ",", " ", 
         RowBox[{
          RowBox[{"CountryData", "[", 
           RowBox[{"\"\<China\>\"", ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "\"\<Population\>\"", "}"}], ",", " ", "year"}], 
             "}"}]}], "]"}], "/", "1000000"}]}], "}"}], ",", "\n", 
       "\t\t\t\t  ", 
       RowBox[{"{", 
        RowBox[{"year", ",", " ", "1950", ",", " ", "2017", ",", " ", "2"}], 
        "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"popIndia", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"year", ",", " ", 
         RowBox[{
          RowBox[{"CountryData", "[", 
           RowBox[{"\"\<India\>\"", ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "\"\<Population\>\"", "}"}], ",", " ", "year"}], 
             "}"}]}], "]"}], "/", "1000000"}]}], "}"}], ",", "\n", 
       "\t\t\t\t  ", 
       RowBox[{"{", 
        RowBox[{"year", ",", " ", "1950", ",", " ", "2017", ",", " ", "2"}], 
        "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"forecastChina", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Last", "@", "popChina"}], "//", "QuantityMagnitude"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"2030", ",", " ", "1500"}], "}"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"forecastIndia", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Last", "@", "popIndia"}], "//", "QuantityMagnitude"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"2030", ",", " ", "1550"}], "}"}]}], "}"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "popChina", ",", " ", "popIndia", ",", " ", "forecastChina", ",", " ", 
       "forecastIndia"}], "}"}], ",", "\n", "\t", 
