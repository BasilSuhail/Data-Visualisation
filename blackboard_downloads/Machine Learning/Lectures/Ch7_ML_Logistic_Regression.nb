 RowBox[{"entropy", "[", "pH", "]"}]], "Input",
 CellChangeTimes->{{3.7821256676891403`*^9, 3.7821256930454264`*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"db914674-f10e-47c3-848d-e9f8e9e19b1c"],

