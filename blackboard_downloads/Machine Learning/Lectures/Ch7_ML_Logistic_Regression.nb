Cell[CellGroupData[{

Cell["Cross-entropy", "Subsubsection",
 CellChangeTimes->{{3.814948976975663*^9, 
  3.8149489838629007`*^9}},ExpressionUUID->"09de16c3-07ab-4f78-8a6d-\
0ea0862a7ecb"],

Cell[TextData[{
 "Consider a training dataset with ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "02127d33-6776-4fbf-b3e7-e2ee92080e78"],
 " examples: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"D", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox["x", 
         RowBox[{"(", "1", ")"}]], ",", 
        SuperscriptBox["y", 
         RowBox[{"(", "1", ")"}]]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox["x", 
         RowBox[{"(", "2", ")"}]], ",", 
        SuperscriptBox["y", 
         RowBox[{"(", "2", ")"}]]}], "}"}], ",", "...", ",", 
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox["x", 
         RowBox[{"(", "N", ")"}]], ",", 
        SuperscriptBox["y", 
         RowBox[{"(", "N", ")"}]]}], "}"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"21569f4e-efa2-4abc-a687-e32321cd56f2"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["y", 
     RowBox[{"(", "n", ")"}]], "\[Element]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1"}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "2cf6c0f6-bb2d-4f6d-b87a-ad5f157cb32b"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "=", "1"}], ",", "2", ",", "...", ",", "N"}], 
   TraditionalForm]],ExpressionUUID->"6fb39426-e476-4d08-b4b1-c17ac9c701a3"],
 "\n\nIn logistic regression, we model an observation for an output variable ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["y", 
    RowBox[{"(", "n", ")"}]], TraditionalForm]],ExpressionUUID->
  "23db4303-3605-43f9-8e9a-9d89801b1135"],
 " with a probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["x", 
        RowBox[{"(", "n", ")"}]], ";", 
       SubscriptBox["w", "0"]}], ",", 
      SubscriptBox["w", "1"]}], ")"}], "=", 
    FractionBox["1", 
     RowBox[{"1", "+", 
      SuperscriptBox["e", 
       RowBox[{
        RowBox[{"-", 
         SubscriptBox["w", "0"]}], "-", 
        RowBox[{
         SubscriptBox["w", "1"], 
         SuperscriptBox["x", 
          RowBox[{"(", "n", ")"}]]}]}]]}]]}], TraditionalForm]],
  ExpressionUUID->"a19391a0-5580-4074-a060-3c0668443c5e"],
 ".  The cross-entropy measures our ignorance about the actual observations ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "0e0f252a-ab46-4aed-8f8f-bda879bb8b78"],
 " when we describe the outcomes with the probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["x", 
       RowBox[{"(", "n", ")"}]], ";", 
      SubscriptBox["w", "0"]}], ",", 
     SubscriptBox["w", "1"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "cb1af455-2d8f-4169-850b-edf724f93f80"],
 ".\n\nThe cross-entropy is defined in a way that looks similar to the \
definition of entropy. \n\nFor the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "31589f3f-d4b6-4422-821f-9c229bd336c7"],
 "-th example, the cross-entropy is:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["CH", 
     RowBox[{"(", "n", ")"}]], "=", 
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["y", 
         RowBox[{"(", "n", ")"}]], 
        RowBox[{"Log", "[", 
         RowBox[{"p", "(", 
          RowBox[{
           RowBox[{
            SuperscriptBox["x", 
             RowBox[{"(", "n", ")"}]], ";", 
            SubscriptBox["w", "0"]}], ",", 
           SubscriptBox["w", "1"]}], ")"}], "]"}]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["y", 
           RowBox[{"(", "n", ")"}]]}], ")"}], " ", 
        RowBox[{"Log", "(", 
         RowBox[{"1", "-", 
          RowBox[{"p", "(", 
           RowBox[{
            RowBox[{
             SuperscriptBox["x", 
              RowBox[{"(", "n", ")"}]], ";", 
             SubscriptBox["w", "0"]}], ",", 
            SubscriptBox["w", "1"]}], ")"}]}], ")"}]}]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"265b92d5-f6b9-4920-b6b1-80b22781dfde"],
 "\n\nThis quantifies the information lost when the observed probability \
distribution ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["y", 
    RowBox[{"(", "n", ")"}]], TraditionalForm]],ExpressionUUID->
  "bdd271e2-d708-475b-892a-23de66838630"],
 " is fitted by the probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["x", 
       RowBox[{"(", "n", ")"}]], ";", 
      SubscriptBox["w", "0"]}], ",", 
     SubscriptBox["w", "1"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "8f923628-1741-4e0a-b5d3-073def9369f9"],
 ".\n\nTo understand the definition of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["CH", 
    RowBox[{"(", "n", ")"}]], TraditionalForm]],ExpressionUUID->
  "af638325-5a0e-41a6-ba71-84c754f2c1e3"],
 " note, for example, that perfect knowledge of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["y", 
    RowBox[{"(", "n", ")"}]], TraditionalForm]],ExpressionUUID->
  "ff2cd995-aa53-4917-b2d6-53b3a37abfa1"],
 " in terms of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["x", 
       RowBox[{"(", "n", ")"}]], ";", 
      SubscriptBox["w", "0"]}], ",", 
     SubscriptBox["w", "1"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "3181f91f-4846-4b89-9600-46aeb55f7a69"],
 ", i.e. the case with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["y", 
     RowBox[{"(", "n", ")"}]], "=", 
    RowBox[{"p", "(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["x", 
        RowBox[{"(", "n", ")"}]], ";", 
       SubscriptBox["w", "0"]}], ",", 
      SubscriptBox["w", "1"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "45b89a01-8d80-43b3-9474-ef0fecf244ad"],
 ", leads to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["CH", 
     RowBox[{"(", "n", ")"}]], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "a00011b7-cada-4ede-bfee-db31269f74ee"],
 ".\n\nThe cost function corresponding to the ",
 StyleBox["mean cross-entropy",
  FontWeight->"Bold"],
 " over all the examples is then:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"J", "(", 
     RowBox[{
      SubscriptBox["w", "0"], ",", 
      SubscriptBox["w", "1"]}], ")"}], "="}], TraditionalForm]],
  FontColor->RGBColor[0, 0, 1],ExpressionUUID->
  "2d6a7f54-ff07-4280-a32b-6a6f925f6e1e"],
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", "1"}], "N"], 
     SuperscriptBox["CH", 
      RowBox[{"(", "n", ")"}]]}], "N"], TraditionalForm]],
  FontColor->RGBColor[0, 0, 1],ExpressionUUID->
  "ce25070b-b9ec-45a5-9cc2-140fad3518ec"]
}], "Text",
 CellChangeTimes->{{3.7817877291982484`*^9, 3.7817877376059465`*^9}, {
   3.781787867289384*^9, 3.7817879967917547`*^9}, {3.7817884361284103`*^9, 
   3.781788470017515*^9}, {3.781788501182231*^9, 3.781788558735276*^9}, {
   3.781788645575222*^9, 3.7817887123559012`*^9}, {3.781788772472694*^9, 
   3.7817888563702974`*^9}, {3.781788983516199*^9, 3.7817890156972246`*^9}, {
   3.7817891403661547`*^9, 3.78178916769178*^9}, {3.7817892165398617`*^9, 
   3.7817892165398617`*^9}, {3.7817892702124457`*^9, 
   3.7817894616412306`*^9}, {3.781789500539033*^9, 3.781789574740285*^9}, {
   3.7817896693975954`*^9, 3.7817898221343174`*^9}, {3.7817898884565086`*^9, 
   3.781790070969386*^9}, {3.814854154197893*^9, 3.814854162233431*^9}, {
   3.81485420525729*^9, 3.814854216264688*^9}, {3.814948988237162*^9, 
   3.814949594927075*^9}, 3.814955527666492*^9, {3.8149555734431343`*^9, 
   3.814955575771365*^9}},ExpressionUUID->"9f08e141-d87c-4cb5-81e0-\
971622520f22"],

Cell[TextData[{
 "The goal is to find the values of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "0"], TraditionalForm]],ExpressionUUID->
  "1f93e8ef-b097-4aeb-a602-7b590ac29247"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "1"], TraditionalForm]],ExpressionUUID->
  "559c4f75-ecbc-4430-a0a5-838de964eba5"],
 " that minimise ",
 Cell[BoxData[
  FormBox[
   RowBox[{"J", "(", 
    RowBox[{
     SubscriptBox["w", "0"], ",", 
     SubscriptBox["w", "1"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "08cfb857-50c9-4353-bcd1-af4409c731c0"],
 ". \n\nWe have introduced the mean cross-entropy for logistic regression \
here but one can define it for any other model where observations are \
described in terms of probabilities. Mean cross-entropy is widely used in \
machine learning as a loss function."
}], "Text",
 CellChangeTimes->{{3.814854556423318*^9, 3.814854681256332*^9}, {
  3.8149496115739517`*^9, 
  3.8149496834528975`*^9}},ExpressionUUID->"a1635007-769d-4758-84a8-\
99e3021147a5"],

Cell["Wolfram Language gives the mean cross-entropy as follows:", "Text",
 CellChangeTimes->{{3.7817900832365923`*^9, 
  3.781790105349286*^9}},ExpressionUUID->"80c03125-ef24-4b9d-b2b1-\
074c425c5504"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Information", "[", 
  RowBox[{"cLogR", ",", "\"\<MeanCrossEntropy\>\""}], "]"}]], "Input",
 CellChangeTimes->{{3.7817801498039*^9, 3.7817801557513905`*^9}},
 CellLabel->"In[45]:=",ExpressionUUID->"cea7253a-cccf-42c2-b60b-6621bfe972b7"],

Cell[BoxData[
 InterpretationBox[
  TemplateBox[{"0.21", "0.05"},
   "Around"],
  Around[0.20983350122946928`, 0.05076452748392869]]], "Output",
 CellChangeTimes->{3.7817801573705215`*^9, 3.781784941520149*^9, 
  3.78178824924144*^9, 3.814955693667268*^9, 3.907310441702024*^9},
 CellLabel->"Out[45]=",ExpressionUUID->"6b6a00dd-3959-46fe-b87e-e2f438e2787f"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Generalisation of logistic regression for ",
 StyleBox["K",
  FontSlant->"Italic"],
 " classes - Multinomial logistic regression"
}], "Section",
 CellChangeTimes->{{3.781715207087906*^9, 3.7817152219817734`*^9}, {
  3.781715475419368*^9, 3.7817154811804824`*^9}, {3.9391910477512474`*^9, 
  3.939191050860321*^9}, {3.939195487812113*^9, 
  3.939195496219351*^9}},ExpressionUUID->"fc659388-f97a-40e1-bc0d-\
35e5db93691b"],

Cell[TextData[{
 "The logistic regression method can be extended for classification within ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]],ExpressionUUID->
  "133a6e84-b950-49cb-92d8-cc9af28408ff"],
 " classes, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["C", 
       RowBox[{"1", ","}]], 
      SubscriptBox["C", "2"]}], ",", "...", ",", 
     SubscriptBox["C", "K"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "b3f4ac5f-71cb-413b-9ecc-cc8275bb7bc8"],
 " using ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "2615e840-eeec-4364-97b9-bcb0f701b7e5"],
 " features,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["x",
     FontWeight->"Bold"], " ", "=", " "}], TraditionalForm]],ExpressionUUID->
  "29625c24-7298-4667-a0b5-3a49b77657fd"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"], ",", "...", ",", 
     SubscriptBox["x", "M"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "2cd3b4d6-9fab-48c5-a845-9ef72d35009d"],
 "\n\nIn this case, the probability of the ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "33fbdf22-fade-4e9b-b501-c73b9a981fd2"],
 "-th class is \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["p", "k"], "(", 
     StyleBox["x",
      FontWeight->"Bold"], ")"}], "=", 
    FractionBox[
     RowBox[{"exp", "(", 
      RowBox[{
       SubsuperscriptBox["w", "0", 
        RowBox[{"(", "k", ")"}]], "+", 
       RowBox[{
        SuperscriptBox[
         StyleBox["w",
          FontWeight->"Bold"], 
         RowBox[{"(", "k", ")"}]], 
        StyleBox["x",
         FontWeight->"Bold"]}]}], ")"}], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "1"}], "K"], 
      RowBox[{"exp", "(", 
       RowBox[{
        SubsuperscriptBox["w", "0", 
         RowBox[{"(", "j", ")"}]], "+", 
        RowBox[{
         SuperscriptBox[
          StyleBox["w",
           FontWeight->"Bold"], 
          RowBox[{"(", "j", ")"}]], 
         StyleBox["x",
          FontWeight->"Bold"]}]}], ")"}]}]]}], TraditionalForm]],
  ExpressionUUID->"0485b3ff-696e-4819-b2a3-88536618347d"],
 ",\n\nwhere ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubsuperscriptBox["w", "0", 
     RowBox[{"(", "k", ")"}]], ",", 
    SuperscriptBox[
     StyleBox["w",
      FontWeight->"Bold"], 
     RowBox[{"(", "k", ")"}]]}], "}"}]],ExpressionUUID->
  "d80d92b4-199e-404e-9204-ae24d534e9c8"],
 " are the coefficients to be fitted for the ",
 StyleBox["k",
  FontSlant->"Italic"],
 "-th class. In particular,\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["w",
      FontWeight->"Bold"], 
     RowBox[{"(", "k", ")"}]], 
    StyleBox["x",
     FontWeight->"Bold"]}], TraditionalForm]],ExpressionUUID->
  "116530cf-62ef-401c-95f4-836257b15cb1"],
 " =",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox[
     RowBox[{" ", "\[Sum]"}], 
     RowBox[{"m", "=", "1"}], "M"], 
    RowBox[{
     SubsuperscriptBox["w", "m", 
      RowBox[{"(", "k", ")"}]], 
     SubscriptBox["x", "m"]}]}], TraditionalForm]],ExpressionUUID->
  "43fea900-959a-4228-aa9b-e06c16868568"],
 " .\n\nThe function ",
 StyleBox["Classify", "CodeText"],
 " can automatically implement logistic regression for an arbitrary number of \
classes and features."
}], "Text",
 CellChangeTimes->{{3.781715153778372*^9, 3.7817151879771333`*^9}, {
   3.781715234554446*^9, 3.78171532369461*^9}, {3.7817154346936193`*^9, 
   3.781715468291295*^9}, {3.7817155051872883`*^9, 3.781715520259428*^9}, 
   3.781715560782503*^9, {3.781715670395949*^9, 3.7817157037214084`*^9}, {
   3.781716343061636*^9, 3.7817164558414783`*^9}, {3.781716557461646*^9, 
   3.7817166490947657`*^9}, {3.781717115184737*^9, 3.7817171482996364`*^9}, {
   3.8149557711005473`*^9, 3.814955781360988*^9}, {3.8149559058154106`*^9, 
   3.814956028554778*^9}},ExpressionUUID->"1c79621b-05ce-421e-b964-\
33e2bc066325"],

Cell[TextData[{
 "As you can see, the proposed expression for the probability in the general \
case (any number of classes, K) is not formally identical to assumed ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["p", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "p(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "faa97cca-3d37-b645-b479-6a06b66291e1"],
 " for the binary case (K=2). However, both forms can be shown to be \
equivalent with an appropriate re-parameterization:\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["w", "TI"], "0", 
          RowBox[{"(", "1", ")"}]], "\[LongEqual]", 
         FractionBox[
          SubscriptBox[
           StyleBox["w", "TI"], "0"], "2"], ",", 
         SubsuperscriptBox[
          StyleBox["w", "TI"], "0", 
          RowBox[{"(", "2", ")"}]], "\[LongEqual]", "-", 
         FractionBox[
          SubscriptBox[
           StyleBox["w", "TI"], "0"], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "w_0^{(1)}=\\frac{w_0}{2}, w_0^{(2)}=-\\frac{w_0}{2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c9756b3b-d782-264e-9a9a-17083752ccee"],
 " \nand ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["w", "TB"], 
          RowBox[{"(", "1", ")"}]], "\[LongEqual]", 
         FractionBox[
          SubscriptBox[
           StyleBox["w", "TB"], "1"], "2"], ",", 
         SuperscriptBox[
          StyleBox["w", "TB"], 
          RowBox[{"(", "2", ")"}]], "\[LongEqual]", "-", 
         FractionBox[
          SubscriptBox[
           StyleBox["w", "TB"], "2"], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "{\\bf w}^{(1)}=\\frac{{\\bf w}_1}{2}, {\\bf w}^{(2)}=-\\frac{{\\bf \
w}_2}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d7d292ca-5a72-5b47-9260-eb79d2c727ef"],
 "\n\nSee a formal derivation in the \[OpenCurlyDoubleQuote]Additional \
materials - Papers, etc.\[CloseCurlyDoubleQuote] folder if you are \
interested. None of these considerations are essential for the assessments of \
the course."
}], "Text",
 CellChangeTimes->{{3.9391952367505016`*^9, 3.9391952435677986`*^9}, {
  3.9391954032234364`*^9, 3.9391955748377743`*^9}, {3.939195614000149*^9, 
  3.939195615026909*^9}, {3.9391956621941833`*^9, 3.93919566508515*^9}, {
  3.9391956995631847`*^9, 3.9391957931428604`*^9}, {3.9391958391480846`*^9, 
  3.9391959494080906`*^9}},ExpressionUUID->"23a6fd29-50ba-d646-9871-\
52f3774cb29a"]
}, Open  ]]
}, Open  ]]
},
