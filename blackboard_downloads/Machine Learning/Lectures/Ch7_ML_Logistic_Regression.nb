    "0.17`", ",", "\<\"NA\"\>", ",", "1", ",", "97", ",", "1", 
     ",", "\<\"NA\"\>"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
    "0.17`", ",", "\<\"NA\"\>", ",", "1", ",", "106", ",", "1", 
