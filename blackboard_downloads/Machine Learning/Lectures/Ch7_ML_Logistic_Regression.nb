Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"p", "(", "x", ")"}], "=", 
   FractionBox["1", 
    RowBox[{"1", "+", 
     SuperscriptBox["e", 
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["w", "0"]}], "-", 
       RowBox[{
        SubscriptBox["w", "1"], "x"}]}]]}]]}], TraditionalForm]],
 FontSize->24,ExpressionUUID->"343c4cd4-d425-4db2-9aaa-dc8e13bdf631"]], "Text",
 CellChangeTimes->{
  3.782114895015052*^9},ExpressionUUID->"2ad68b75-bfea-47a2-ae1a-\
fd6dfccbaeff"],

Cell[TextData[{
 "Mathematica gives the function as \n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", "x", ")"}], "=", 
    FractionBox["1", 
     RowBox[{"1", "+", 
      RowBox[{"a", " ", 
       SuperscriptBox["e", 
        RowBox[{
         RowBox[{"-", 
          SubscriptBox["w", "1"]}], "x"}]]}]}]]}], TraditionalForm]],
  FontSize->24,ExpressionUUID->"3b1aea5e-6c50-4e96-90b4-7d38451b9009"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", 
    SuperscriptBox["e", 
     RowBox[{"-", 
      SubscriptBox["w", "0"]}]]}], TraditionalForm]],ExpressionUUID->
  "a378a91e-2ea5-4373-b086-5063f983604f"],
 ". Therefore, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", "0"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "ln"}], " ", "a"}], "=", 
     RowBox[{"-", 
      RowBox[{"Log", "[", "a", "]"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "b2fde8bd-334f-4e8f-8d2c-140ed8087a84"],
 " ."
}], "Text",
 CellChangeTimes->{{3.8149528916415977`*^9, 3.814952986480793*^9}, {
  3.8149530261928167`*^9, 
  3.814953062003462*^9}},ExpressionUUID->"84ab008b-1dbf-4499-b275-\
095dd6c5bb60"],

Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{"-", 
          SubscriptBox[
           StyleBox["w", "TI"], "0"], "-", 
          SubscriptBox[
           StyleBox["w", "TI"], "1"], 
          StyleBox["x", "TI"]}]], "\[LongEqual]", 
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{"-", 
          SubscriptBox[
           StyleBox["w", "TI"], "0"]}]], 
       SuperscriptBox[
        StyleBox["e", "TI"], 
        RowBox[{"-", 
          SubscriptBox[
           StyleBox["w", "TI"], "1"], 
          StyleBox["x", "TI"]}]]}], TraditionalForm], "errors" -> {}, "input" -> 
   "e^{-w_0-w_1x}=e^{-w_0}e^{-w_1x}", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellChangeTimes->{
  3.9073093694006996`*^9},ExpressionUUID->"b4c63507-25d1-41f5-926d-\
d0eec629f7a8"],

