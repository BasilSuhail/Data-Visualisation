Cell[TextData[{
 StyleBox["Conclusion:",
  FontWeight->"Bold"],
 " Linear regression does not work well to predict a binary dependent \
variable ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "2c493647-eff9-456c-a5d0-82e64d1da761"],
 ". ",
 StyleBox["One should fit a different function!",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.781704443722963*^9, 3.7817044754252553`*^9}, 
   3.7817045608552055`*^9},ExpressionUUID->"06891321-e7a0-46fb-96d0-\
b93b40f99f7e"]
}, Open  ]],

