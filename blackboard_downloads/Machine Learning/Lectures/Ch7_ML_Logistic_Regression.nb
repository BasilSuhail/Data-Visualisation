Cell[CellGroupData[{

Cell[TextData[{
 "Probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "=", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "04181962-d3f2-4f76-841f-28af4eb9527e"]
}], "Subsubsection",
 CellChangeTimes->{{3.7817222087040157`*^9, 3.78172223636423*^9}, {
  3.781725866788519*^9, 3.781725869335717*^9}, {3.781780070739339*^9, 
  3.781780081076842*^9}},ExpressionUUID->"be3e751e-edf8-4d5f-b8dd-\
fa5d99f41974"],

Cell[TextData[{
 "What is the age at which the probability of menarche is 1/2? This estimates \
a transition between \[OpenCurlyDoubleQuote]unlikely menarche\
\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]likely menarche\
\[CloseCurlyDoubleQuote].\n\n",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{
     RowBox[{"p", "(", "x", ")"}], "=", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"1", "+", 
        SuperscriptBox["e", 
         RowBox[{
          RowBox[{"-", 
           SubscriptBox["w", "0"]}], "-", 
          RowBox[{
           SubscriptBox["w", "1"], "x"}]}]]}]], "=", 
      RowBox[{
       RowBox[{
        FractionBox["1", "2"], "\[DoubleRightArrow]", 
        SuperscriptBox["e", 
         RowBox[{
          RowBox[{"-", 
           SubscriptBox["w", "0"]}], "-", 
          RowBox[{
           SubscriptBox["w", "1"], "x"}]}]]}], "=", 
       RowBox[{
        RowBox[{"1", "\[DoubleRightArrow]", 
         RowBox[{
          SubscriptBox["w", "0"], "+", 
          RowBox[{
           SubscriptBox["w", "1"], "x"}]}]}], "=", 
        RowBox[{
         RowBox[{"0", "\[DoubleRightArrow]", 
          StyleBox["x",
           FontWeight->"Bold"]}], 
         StyleBox["=",
          FontWeight->"Bold"], 
         StyleBox[
          RowBox[{"-", 
           FractionBox[
            SubscriptBox["w", "0"], 
            SubscriptBox["w", "1"]]}],
          FontWeight->"Bold"]}]}]}]}]}],
    FontSize->18], TraditionalForm]],
  FontSize->24,ExpressionUUID->"9fe02b1a-c6af-4a86-b52d-8d87b4eb5419"]
}], "Text",
 CellChangeTimes->{{3.781725873525761*^9, 3.7817259260974874`*^9}, {
  3.7817259745456734`*^9, 3.7817260834255276`*^9}, {3.781726158288025*^9, 
  3.781726163034544*^9}},ExpressionUUID->"999f1b80-0271-4005-bbf1-\
6ffd007a37f1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"-", 
  FractionBox["w0", "w1"]}]], "Input",
 CellChangeTimes->{{3.7817261435321608`*^9, 3.7817261683629065`*^9}},
 CellLabel->"In[31]:=",ExpressionUUID->"74ebaa73-aa00-4982-b624-cab963511d81"],

Cell[BoxData["13.337138569674371`"], "Output",
 CellChangeTimes->{{3.781726152781075*^9, 3.7817261689097013`*^9}, 
   3.7817882137077513`*^9, 3.7821156136841817`*^9, 3.8149532373588786`*^9, 
   3.9073092195927773`*^9},
 CellLabel->"Out[31]=",ExpressionUUID->"77ef12af-cf2a-48d2-a466-d117ba94eeee"]
}, Open  ]],

Cell["\<\
One can also find a numerical solution for x using the logistic function:\
\>", "Text",
 CellChangeTimes->{{3.781726184208993*^9, 3.781726201096354*^9}, {
  3.7817263094781246`*^9, 
  3.78172632301229*^9}},ExpressionUUID->"bf34331e-b3b4-4c88-9db8-\
8ce69b33e454"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"LogisticSigmoid", "[", 
     RowBox[{"w0", "+", 
      RowBox[{"w1", " ", "x"}]}], "]"}], "\[Equal]", "0.5"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "15"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.7817069617805233`*^9, 3.7817069905640774`*^9}, {
  3.781771335307782*^9, 3.7817713356394496`*^9}, {3.7821157419574957`*^9, 
  3.782115747873473*^9}},
 CellLabel->"In[32]:=",ExpressionUUID->"ee61cdfe-e21e-48a6-927d-6048098a5d4b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"x", "\[Rule]", "13.337138569674371`"}], "}"}]], "Output",
 CellChangeTimes->{{3.78170698332305*^9, 3.78170699089824*^9}, {
   3.7817713360933175`*^9, 3.781771347755601*^9}, 3.782115649636981*^9, 
   3.7821157486890345`*^9, 3.8149532884589453`*^9, 3.907309244739854*^9},
 CellLabel->"Out[32]=",ExpressionUUID->"4d489b89-3133-41ef-89df-9dee623f181b"]
}, Open  ]],

Cell["Or using the function given by the classifier", "Text",
 CellChangeTimes->{{3.781771289636731*^9, 
  3.7817713047795267`*^9}},ExpressionUUID->"639674a5-3471-4ea5-b04d-\
53d2db74f828"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"temp", "[", "x", "]"}], "[", "1", "]"}], "\[Equal]", "0.5"}], 
   ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "15"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.7817713068288136`*^9, 3.781771332931885*^9}, {
  3.782116155041377*^9, 3.7821161551919775`*^9}, {3.8149533619048414`*^9, 
  3.81495337248726*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"607fa365-daf4-4409-9082-9091a3b6fb15"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"x", "\[Rule]", "13.337138569674371`"}], "}"}]], "Output",
 CellChangeTimes->{{3.781771320148283*^9, 3.7817713498565764`*^9}, 
   3.782115788984445*^9, 3.7821158226534386`*^9, 3.7821161556678677`*^9, {
   3.814953363762748*^9, 3.8149533728013797`*^9}, 3.907309300025988*^9},
 CellLabel->"Out[33]=",ExpressionUUID->"42e469ae-fe61-4b5d-8dce-128884b499dc"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["How well does the model fit the data?", "Subsection",
 CellChangeTimes->{
  3.814949883920169*^9},ExpressionUUID->"a7ee6ff5-a698-41ea-8cb6-\
431d0845b318"],

Cell[CellGroupData[{

Cell["Comparing to the moving average of observations", "Subsubsection",
 CellChangeTimes->{{3.7817154121933503`*^9, 3.781715427301623*^9}, {
  3.78171743020927*^9, 3.781717437595883*^9}, {3.8149498915088825`*^9, 
  3.8149499025437117`*^9}},ExpressionUUID->"6f55b3e2-5733-42f7-8b54-\
362e1e7386d8"],

Cell["\<\
We can compare the estimate of the probability of menarche as a function of \
the age by using moving averages of the data. 

Let us  consider first the fit to the training data, train:\
\>", "Text",
 CellChangeTimes->{{3.7817174535473723`*^9, 3.7817175307987976`*^9}, {
  3.8149536329234304`*^9, 
  3.814953696420688*^9}},ExpressionUUID->"4f4f8dff-765d-4c5b-856b-\
2eb478ecc1c4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"LogisticSigmoid", "[", 
      RowBox[{"w0", "+", 
       RowBox[{"w1", " ", "x"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "35"}], "}"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}], ",", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"MovingAverage", "[", 
      RowBox[{
       RowBox[{"Sort", "[", "train", "]"}], ",", "50"}], "]"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", " ", 
      RowBox[{"{", 
       RowBox[{"5", ",", "30"}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"PointSize", "[", "Small", "]"}]}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<age\>\"", ",", "\"\<menarche (Y/N)\>\""}], "}"}]}]}], 
    "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.781717366340168*^9, 3.7817173715961647`*^9}, {
  3.781717415468989*^9, 3.781717417754051*^9}, {3.7821160917992477`*^9, 
