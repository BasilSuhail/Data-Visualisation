Cell[CellGroupData[{

Cell["Loss (or cost) function - Mean cross-entropy", "Subsection",
 CellChangeTimes->{{3.7817800966559453`*^9, 
  3.781780116526636*^9}},ExpressionUUID->"42a1d6dc-6647-4ed7-b943-\
121ede9eacb0"],

Cell[TextData[{
 "The classical mean square distance,\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"J", "(", 
     RowBox[{
      SubscriptBox["w", "0"], ",", 
      StyleBox["w",
       FontWeight->"Bold"]}], ")"}], "=", 
    FractionBox["1", 
     RowBox[{"2", "N"}]]}], TraditionalForm]],ExpressionUUID->
  "47051eea-569a-4a6e-8eff-c82392273dfe"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"n", "=", "1"}], "N"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"f", "(", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           StyleBox["x",
            FontWeight->"Bold"], 
           RowBox[{"(", "n", ")"}]], ";", 
          SubscriptBox["w", "0"]}], ",", 
         StyleBox["w",
          FontWeight->"Bold"]}], ")"}], "-", 
       SuperscriptBox["y", 
        RowBox[{"(", "n", ")"}]]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"9c788731-bec9-442c-ba1f-4a44de713008"],
 " ,\n\nused as a cost function for linear regression is ",
 StyleBox["not suitable for logistic regression",
  FontWeight->"Bold"],
 " in general (it does not have a single minimum). \n\n",
 StyleBox["Mean cross-entropy",
  FontWeight->"Bold"],
 " is a ",
 StyleBox["more appropriate",
  FontWeight->"Bold"],
 " cost function for logistic regression.\n\nBefore introducing the \
cross-entropy, let us try to understand ",
 StyleBox["entropy",
  FontWeight->"Bold"],
 " within the context of probability distributions."
}], "Text",
 CellChangeTimes->{{3.7817877291982484`*^9, 3.7817877376059465`*^9}, {
  3.781787867289384*^9, 3.7817879967917547`*^9}, {3.7817884361284103`*^9, 
  3.781788470017515*^9}, {3.781788501182231*^9, 3.781788558735276*^9}, {
  3.781788645575222*^9, 3.7817887123559012`*^9}, {3.781788772472694*^9, 
  3.7817888563702974`*^9}, {3.781788983516199*^9, 3.7817890156972246`*^9}, {
  3.7817891403661547`*^9, 3.78178916769178*^9}, {3.7817892165398617`*^9, 
  3.7817892165398617`*^9}, {3.7817892702124457`*^9, 3.7817894616412306`*^9}, {
  3.781789500539033*^9, 3.781789574740285*^9}, {3.7817896693975954`*^9, 
  3.7817898221343174`*^9}, {3.7817898884565086`*^9, 3.781790070969386*^9}, {
  3.814854154197893*^9, 3.814854162233431*^9}, {3.81485420525729*^9, 
  3.814854216264688*^9}, {3.814854726786746*^9, 3.814854789559701*^9}, {
  3.814947589283185*^9, 
  3.8149476023197207`*^9}},ExpressionUUID->"40dddc3f-60bf-44eb-802a-\
bc153ec85716"],

Cell[CellGroupData[{

Cell["Entropy ", "Subsubsection",
 CellChangeTimes->{{3.814854743799891*^9, 
  3.814854748646556*^9}},ExpressionUUID->"e2467b68-ff09-482a-91de-\
7b7820f3dbde"],

Cell[TextData[{
 "Within the context of experiments involving randomness, entropy gives an \
idea of our lack of knowledge about the outcome of experiment. In this \
context, entropy is a measure of our ignorance about the random outcome.\n\n\
For example, for most ",
 StyleBox["lotteries",
  FontWeight->"Bold"],
 " it is so unlikely to win that we are almost certain that we will not win \
if we play. The ",
 StyleBox["entropy",
  FontWeight->"Bold"],
 " associated with the experiment \[OpenCurlyDoubleQuote]play the lottery\
\[CloseCurlyDoubleQuote] ",
 StyleBox["is low",
  FontWeight->"Bold"],
 " since we do not ignore much about the outcome - we know that it is very \
likely not to win.\n\nIn contrast, if we toss a fair coin, we are quite \
uncertain about the outcome: It could be heads or tails with equal \
probability so it is not easy to predict the outcome.\n\nFor a fair six-sided \
dice, we are even more uncertain since there are more possible outcomes.\n\n\
In general, if the outcome of an experiment can be defined in terms of a \
discrete random variable ",
 StyleBox["X",
  FontSlant->"Italic"],
 " taking ",
 StyleBox["K",
  FontSlant->"Italic"],
 " discrete values {",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"], ",", "...", ",", 
     SubscriptBox["x", "K"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "d5775df7-f0c8-4c27-897e-c59095db9eab"],
 " with probability distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["p", "1"], ",", 
     SubscriptBox["p", "2"], ",", "...", ",", " ", 
     SubscriptBox["p", "K"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "43596e67-ce54-4ace-8ed4-76799e279c39"],
 ", the entropy is defined as\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["p", "1"], 
           RowBox[{"Log", "[", 
            SubscriptBox["p", "1"], "]"}]}], "+", 
          RowBox[{
           SubscriptBox["p", "2"], 
           RowBox[{"Log", "[", 
            SubscriptBox["p", "2"], "]"}]}], "+"}], "..."}], "+", 
        RowBox[{
         SubscriptBox["p", "K"], 
         RowBox[{"Log", "[", 
          SubscriptBox["p", "K"], "]"}]}]}], ")"}]}], "=", 
     RowBox[{"-", 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"i", "=", "1"}], "k"], 
       RowBox[{
        SubscriptBox["p", "i"], 
        RowBox[{"Log", "[", 
         SubscriptBox["p", "i"], "]"}]}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"e18b3a0e-009a-462c-bc8d-500989443fdf"],
 "\n"
}], "Text",
 CellChangeTimes->{{3.8149476400741873`*^9, 3.8149476927399664`*^9}, {
  3.8149477479094367`*^9, 3.8149479654533925`*^9}, {3.814948003808978*^9, 
  3.8149481317347784`*^9}, {3.814948162180758*^9, 3.814948188767803*^9}, {
  3.8149482993122106`*^9, 3.814948389761611*^9}, {3.8149484980066147`*^9, 
  3.814948564145762*^9}, {3.8149486204475164`*^9, 
  3.8149486315609493`*^9}},ExpressionUUID->"2e4618fa-16f8-42ab-b5d2-\
77f6207b9e0e"],

Cell[TextData[{
 StyleBox["Aside on the logarithm function (denoted as ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"ln", " ", "x"}], "=", 
    RowBox[{
     RowBox[{"ln", " ", "x"}], " ", "=", " ", 
     RowBox[{"log", " ", "x"}]}]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"9c46f631-93d0-47a8-b29f-595b5348e328"],
 StyleBox[").",
  FontWeight->"Bold"],
 " In case you don\[CloseCurlyQuote]t know the natural logarithm function \
very well , it makes sense to look at its behaviour as a function of ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "5447080d-9dde-44ab-8b50-014f404ecf50"],
 " on a plot. "
}], "Text",
 CellChangeTimes->{{3.813591897517944*^9, 3.8135920210130606`*^9}, {
  3.813592090682605*^9, 3.8135921461426926`*^9}, {3.8148542433362083`*^9, 
  3.814854299448613*^9}, {3.8149548651197147`*^9, 
  3.8149548707646885`*^9}},ExpressionUUID->"7d21fe2e-5a90-4ec8-b6db-\
3c6b2471708b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Log", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "5"}], "}"}]}], "]"}]], "Input",
