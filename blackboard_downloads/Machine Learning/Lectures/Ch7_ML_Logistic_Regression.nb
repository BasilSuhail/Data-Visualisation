Cell[TextData[{
 "Linear regression assumes\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{
     SubscriptBox["w", "0"], "+", 
     RowBox[{
      SubscriptBox["w", "1"], "x"}]}]}], TraditionalForm]],ExpressionUUID->
  "c6922d0c-04e9-458b-a729-34a925993f98"],
 "+\[Epsilon]\n\nHow does it work here?"
}], "Text",
