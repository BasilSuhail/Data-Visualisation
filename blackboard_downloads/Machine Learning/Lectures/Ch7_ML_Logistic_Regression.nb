Cell[CellGroupData[{

Cell["Testing with test data", "Subsubsection",
 CellChangeTimes->{
  3.814950007085642*^9},ExpressionUUID->"ab8c4438-2ae4-40b3-a178-\
2f1765a68f72"],

Cell["\<\
Despite the fact that we only used 25% of the data to train the classifier, \
it is quite accurate when applied to test data.\
\>", "Text",
 CellChangeTimes->{{3.781725367737128*^9, 3.7817253776295195`*^9}, {
  3.781725412150732*^9, 3.781725418036804*^9}, {3.781725459874344*^9, 
  3.7817254681964445`*^9}, {3.7817255211082115`*^9, 
  3.781725536576368*^9}},ExpressionUUID->"7dc8faaf-b797-4bbf-af09-\
5fb87bb16b4c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cmLogR", "=", 
  RowBox[{"ClassifierMeasurements", "[", 
   RowBox[{"cLogR", ",", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"test", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "1"}], "]"}], "]"}], "\[Rule]", 
       RowBox[{"test", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "2"}], "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{"Length", "[", "test", "]"}]}], "}"}]}], "]"}]}], 
   "]"}]}]], "Input",
