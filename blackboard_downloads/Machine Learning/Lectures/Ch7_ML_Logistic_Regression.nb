Cell[TextData[{
 "Mathematically speaking, the natural logarithm is the inverse of the \
exponential function ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", "x"], TraditionalForm]],ExpressionUUID->
  "b96cd6e2-3d79-47bd-92f0-0c252329933e"],
 " since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"log", "(", 
     SuperscriptBox["e", "x"], ")"}], "=", "x"}], TraditionalForm]],
  ExpressionUUID->"fbf88862-624e-4488-925e-56625ea59c89"]
}], "Text",
 CellChangeTimes->{
  3.814854288250462*^9},ExpressionUUID->"21087afb-e33a-44dd-b7a7-\
2a55220d6d9e"],

Cell[TextData[{
 StyleBox["Entropy for the lottery",
  FontWeight->"Bold",
  FontVariations->{"Underline"->True}],
 "\nTwo outcomes (win, not win) with probabilities ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "win"], "\[TildeEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"54c73559-5aca-45e0-8b77-e25159324565"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", 
     RowBox[{"not", " ", "win"}]], "\[TildeEqual]", "1."}], TraditionalForm]],
  ExpressionUUID->"a214bd0c-4447-4813-8f7d-bbbddc6f8ab9"],
 " \n\nThe entropy is then \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox["p", "win"], 
         RowBox[{"Log", "[", 
          SubscriptBox["p", "win"], "]"}]}], "+", 
        RowBox[{
         SubscriptBox["p", 
          RowBox[{"not", " ", "win"}]], 
         RowBox[{"Log", "[", 
          SubscriptBox["p", 
           RowBox[{"not", " ", "win"}]], "]"}]}]}], ")"}]}], "\[TildeEqual]", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{"0", "+", 
        RowBox[{"1", "\[Times]"}]}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "db613146-5ccd-4a63-8745-17761d534815"],
 "Log[1])=0\n\nSo out ignorance about the outcome is low...\n\n",
 StyleBox["Entropy for a coin",
  FontWeight->"Bold",
  FontVariations->{"Underline"->True}],
 " (not necessarily fair). \nTwo outcomes (Heads, Tails) with probabilities ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "Heads"], TraditionalForm]],ExpressionUUID->
  "f6f06f78-e41e-4a5f-b83c-216c18228321"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "Tails"], TraditionalForm]],ExpressionUUID->
  "18d3de56-43e3-4d59-946c-e7f1db4305f9"],
 ", respectively.\n\nThe entropy is defined as:"
}], "Text",
 CellChangeTimes->{
  3.8135922199902945`*^9, {3.8135922607595243`*^9, 3.813592307956977*^9}, {
   3.814948641334529*^9, 3.814948923156722*^9}, 3.8149549218808823`*^9, {
   3.8149549965773335`*^9, 
   3.8149549965773335`*^9}},ExpressionUUID->"ded10d4f-afef-4878-ac8c-\
29fdd485f1bb"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox["p", "Heads"], 
         RowBox[{"Log", "[", 
          SubscriptBox["p", "Heads"], "]"}]}], "+", 
        RowBox[{
         SubscriptBox["p", "Tails"], 
         RowBox[{"Log", "[", 
          SubscriptBox["p", "Tails"], "]"}]}]}], ")"}]}], "=", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox["p", "Heads"], 
         RowBox[{"Log", "[", 
          SubscriptBox["p", "Heads"], "]"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SubscriptBox["p", "Heads"]}], ")"}], 
         RowBox[{"Log", "[", 
          RowBox[{"1", "-", 
           SubscriptBox["p", "Heads"]}], "]"}]}]}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"3c31494d-a326-4dde-8450-bd3bc86dfcb8"],
 "\n\nHere, I used ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "Tails"], "=", 
    RowBox[{"1", "-", 
     SubscriptBox["p", "Heads"]}]}], TraditionalForm]],ExpressionUUID->
  "6890b6e4-8fe2-4e0c-b4e7-12f07f668063"],
 ".\n\nOne can program this with Mathematica:"
}], "Text",
 CellChangeTimes->{{3.782125436215301*^9, 3.7821255771638756`*^9}, {
  3.813592179072235*^9, 3.8135922808569098`*^9}, {3.8149489259784203`*^9, 
  3.8149489648672523`*^9}},ExpressionUUID->"9918cd5c-421c-46c0-99be-\
920118f07350"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"entropy", "[", "p_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"p", "==", "0"}], "||", 
      RowBox[{"p", "\[Equal]", "1"}]}], ",", "0", ",", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"p", " ", 
         RowBox[{"Log", "[", "p", "]"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "p"}], ")"}], " ", 
         RowBox[{"Log", "[", 
          RowBox[{"1", "-", "p"}], "]"}]}]}], ")"}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.782125597347983*^9, 3.7821256783601475`*^9}, {
  3.782126201547526*^9, 3.7821262307122283`*^9}, {3.814955248186773*^9, 
  3.814955250797762*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"e4dee6c2-facc-42d7-8e19-fd5d9115c748"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pH", "=", "0.5"}], ";"}]], "Input",
 CellChangeTimes->{{3.782125586210034*^9, 3.782125590582012*^9}, {
  3.7821256625152893`*^9, 3.7821256648917947`*^9}, {3.782125698618433*^9, 
  3.7821257019222927`*^9}, {3.782126056285637*^9, 3.782126082703515*^9}, {
  3.782126234547231*^9, 3.7821262360723724`*^9}, {3.814949707205472*^9, 
  3.814949709027339*^9}, {3.8149552879092956`*^9, 3.8149552884683027`*^9}, {
  3.907310351484762*^9, 3.907310351963048*^9}},
 CellLabel->"In[42]:=",ExpressionUUID->"40794681-690f-4443-8c94-36064fad37a2"],

