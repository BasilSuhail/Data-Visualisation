Cell["\<\
The data contains the name of features in the heading. I separate the heading \
from the data:\
\>", "Text",
 CellChangeTimes->{{3.781703034203125*^9, 
  3.7817030747366247`*^9}},ExpressionUUID->"eeab9386-f843-45f5-b873-\
83b5aea4756c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"head", "=", 
  RowBox[{"juul", "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.781690744562032*^9, 3.781690794891523*^9}, {
  3.7816937959743547`*^9, 3.781693796519655*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"b3d46721-a3f2-404f-a9ba-60f8366db35f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"age\"\>", ",", "\<\"menarche\"\>", ",", "\<\"sex\"\>", 
   ",", "\<\"igf1\"\>", ",", "\<\"tanner\"\>", ",", "\<\"testvol\"\>"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.7816907954386015`*^9, 3.7816937971779065`*^9, 
  3.7817035810538626`*^9, 3.7821133916232915`*^9, 3.814945249541007*^9, 
  3.8149453200287085`*^9, 3.8149507500267067`*^9, 3.9070543872876434`*^9, 
  3.9073077233704042`*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"92d3d8c3-ec59-4690-ae63-ae40bbadc1c4"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Drop", "[", 
    RowBox[{"juul", ",", "1"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.781691241965849*^9, 3.78169126554146*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"40cca336-6bf0-4371-96b6-fc51fa0afbde"],

Cell[CellGroupData[{

Cell["Dropping missing data", "Subsubsection",
 CellChangeTimes->{{3.7817034726231236`*^9, 3.7817034865901294`*^9}, {
  3.781703546710245*^9, 3.7817035492874393`*^9}, {3.7817256338093777`*^9, 
  3.7817256372554994`*^9}},ExpressionUUID->"ce899954-06bb-43a2-bfbc-\
5e733517785f"],

Cell[TextData[{
 StyleBox["menarche", "CodeText"],
 " is missing for many individuals (for boys and other for which sex is not \
available)"
}], "Text",
 CellChangeTimes->{{3.7817033897321997`*^9, 3.7817034008040924`*^9}, {
  3.78170343994495*^9, 
  3.7817034578406763`*^9}},ExpressionUUID->"26119bb8-b870-4ca9-a898-\
b85f45e7c475"],

Cell[TextData[{
 "We only need rows where data on menarche is available. \n\nMissing values \
are indicated as \[OpenCurlyDoubleQuote]NA\[CloseCurlyDoubleQuote]. One way \
to drop individuals for which ",
 StyleBox["menarche = \[OpenCurlyDoubleQuote]NA\[CloseCurlyDoubleQuote]", 
  "CodeText"],
 " is to \n(i) find the position (row) of individuals with  ",
 StyleBox["menarche = \[OpenCurlyDoubleQuote]NA\[CloseCurlyDoubleQuote]", 
  "CodeText"],
 "\n(ii) select the complement of these positions."
}], "Text",
 CellChangeTimes->{{3.781691782759393*^9, 3.7816917985001774`*^9}, {
  3.7816938068204365`*^9, 3.781693820352383*^9}, {3.7817033747804575`*^9, 
  3.781703379792871*^9}, {3.781703600839859*^9, 3.7817036547718697`*^9}, {
  3.781703690120797*^9, 
  3.7817038129735947`*^9}},ExpressionUUID->"6acdf55b-94d8-4ad0-88ae-\
6c1ff2dd898b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"posmenarche", "=", 
   RowBox[{"Complement", "[", 
    RowBox[{
     RowBox[{"Range", "[", 
      RowBox[{"Length", "[", "data", "]"}], "]"}], ",", 
     RowBox[{"Flatten", "[", 
      RowBox[{"Position", "[", 
       RowBox[{
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", "\"\<NA\>\""}], "]"}],
       "]"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.781691194828359*^9, 3.7816912347336383`*^9}, {
   3.7816913772891984`*^9, 3.7816913786162786`*^9}, {3.781691409926865*^9, 
   3.781691496393401*^9}, {3.7816916442510495`*^9, 3.781691774189458*^9}, {
   3.781691958548747*^9, 3.781691964342949*^9}, 3.781703821956599*^9},
 CellLabel->"In[5]:=",ExpressionUUID->"5642357d-a078-4187-ad78-7141a4aa097a"],

Cell[TextData[{
 "We then build a new list that contains ",
 StyleBox["{age,menarche}:", "CodeText"]
}], "Text",
 CellChangeTimes->{{3.7817038317538424`*^9, 3.7817038998185067`*^9}, {
  3.7817039599593425`*^9, 
  3.781703962420562*^9}},ExpressionUUID->"e39d3d1c-b616-4502-b5f0-\
4e78319adf11"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dataAM", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"data", "[", 
       RowBox[{"[", 
        RowBox[{"posmenarche", ",", "1"}], "]"}], "]"}], ",", 
      RowBox[{
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"posmenarche", ",", "2"}], "]"}], "]"}], "-", "1"}]}], "}"}],
     "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7816919752056503`*^9, 3.781692041083254*^9}, {
  3.781692074406949*^9, 3.781692079126048*^9}, {3.781692133824098*^9, 
  3.7816921339503126`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"d016bce0-a0fd-4da3-947e-c3d0383defc9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dataAM", "//", "Length"}]], "Input",
 CellChangeTimes->{{3.782113589860447*^9, 3.782113591067929*^9}, {
  3.8149511743639*^9, 3.814951175756708*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"6622961c-0f67-4fd8-bedf-1ef1637425d8"],

