  3.7817048325519943`*^9}},ExpressionUUID->"a3f2f31b-aaaf-4115-9ac0-\
31eac2ac9ff1"],

Cell[CellGroupData[{

Cell[TextData[{
 "A Bernoulli distribution is assumed for ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "61d9beab-b490-4907-ad69-56c456a930eb"],
 ":"
}], "ItemParagraph",
 CellChangeTimes->{{3.781704843758006*^9, 
  3.7817048966670785`*^9}},ExpressionUUID->"177ae471-2821-40bc-b99a-\
bacce37b2b03"],

Cell[TextData[{
 "\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "~", 
    RowBox[{"Ber", "(", 
     RowBox[{"p", "(", "x", ")"}], ")"}]}], TraditionalForm]], "Text",
  ExpressionUUID->"8cca27ee-9187-420b-81b8-b04ac3022aab"]
}], "SubsubitemParagraph",
 CellChangeTimes->{{3.7817047472037735`*^9, 3.781704755924485*^9}, {
  3.7817048355836964`*^9, 
  3.7817048367825975`*^9}},ExpressionUUID->"668be0f8-6e5e-4417-bfa5-\
9f89b158874d"]
}, Open  ]],

Cell[TextData[{
 "Note that the probability ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "6881b118-aa6d-4a83-93d6-06812803f320"],
 " depends on the feature ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "077a3bca-807e-47e2-be4b-e31a5afa4720"]
}], "ItemParagraph",
 CellChangeTimes->{{3.781704843758006*^9, 3.7817048531863613`*^9}, {
  3.7817048989555845`*^9, 
  3.781704969985355*^9}},ExpressionUUID->"d5a6de89-c9b8-44cc-bc5a-\
9ef0bb4d841b"]
}, Open  ]],

Cell[TextData[{
 "Typically, a ",
 StyleBox["sigmoidal function",
  FontWeight->"Bold"],
 " is used to describe the dependence of p on x. The ",
 StyleBox["logistic",
  FontWeight->"Bold"],
 " function is the most widely used:"
}], "Item",
 CellChangeTimes->{{3.7817046846587996`*^9, 3.7817047324231462`*^9}, {
  3.781704974502453*^9, 3.7817049879929523`*^9}, {3.781705042193838*^9, 
  3.7817051298531313`*^9}},ExpressionUUID->"d091366b-6f7d-4665-8da1-\
45c393519f90"],

Cell[TextData[{
 "\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\t\t\t", 
    RowBox[{
     RowBox[{"p", "(", "x", ")"}], "=", 
     FractionBox["1", 
      RowBox[{"1", "+", 
       SuperscriptBox["e", 
        RowBox[{
         RowBox[{"-", 
          SubscriptBox["w", "0"]}], "-", 
         RowBox[{
          SubscriptBox["w", "1"], "x"}]}]]}]]}]}], TraditionalForm]],
  FontSize->24,ExpressionUUID->"2e92f370-895a-483c-b333-54ae07694b60"]
}], "Text",
 CellChangeTimes->{{3.781705134247821*^9, 
  3.781705265844926*^9}},ExpressionUUID->"98938b96-99e3-4a51-a68e-\
4ef9288221df"],

Cell[TextData[{
 "The logistic function is already programmed in Wolfram Language. It is the \
function ",
 StyleBox["LogisticSigmoid", "CodeText"],
 ":"
}], "Text",
 CellChangeTimes->{{3.781705398058895*^9, 
  3.7817054826002145`*^9}},ExpressionUUID->"24dcefdc-1c00-46e6-974b-\
a4e4fbbf125d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"LogisticSigmoid", "[", "x", "]"}], "//", 
  "FunctionExpand"}]], "Input",
 CellLabel->"In[75]:=",ExpressionUUID->"fbd7c0ad-dfae-4592-a022-1ad9ba9ca52b"],

Cell[BoxData[
 FractionBox["1", 
  RowBox[{"1", "+", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", "x"}]]}]]], "Output",
 CellChangeTimes->{3.7817054678374376`*^9, 3.814951820781602*^9},
 CellLabel->"Out[75]=",ExpressionUUID->"975992af-11a3-449c-acb9-ee93199be441"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"LogisticSigmoid", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}]], "Input",
