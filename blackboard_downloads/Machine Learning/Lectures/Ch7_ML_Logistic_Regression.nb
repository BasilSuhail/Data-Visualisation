Cell[CellGroupData[{

Cell["Using classify to train a logistic regression model", "Subsection",
 CellChangeTimes->{{3.7817056609158883`*^9, 
  3.781705677802597*^9}},ExpressionUUID->"b7d33950-647e-4971-914b-\
2788700aa9ef"],

Cell["\<\
We will now proceed as usual in classification problems. 
(i) Split the data into training and test sets
(ii) Train a classifier using the training dataset
(iii) Test the performance of the classifier using the test dataset\
\>", "Text",
 CellChangeTimes->{{3.781705702632391*^9, 3.781705716756894*^9}, {
  3.781705825305401*^9, 
  3.7817058884297066`*^9}},ExpressionUUID->"69974f95-0d98-44ff-9224-\
469c40b24900"],

