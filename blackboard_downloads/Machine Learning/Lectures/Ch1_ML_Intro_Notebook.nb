Cell[CellGroupData[{

Cell["Machine learning and programming", "Section",
 CellChangeTimes->{{3.777709962579062*^9, 
  3.777709984051091*^9}},ExpressionUUID->"dc82f07d-1be5-46d0-8312-\
9a1e44de1a2c"],

Cell["\<\
Machine learning involves programming algorithms but it is different to \
traditional programming!!\
\>", "Text",
 CellChangeTimes->{{3.77770999790967*^9, 3.7777100446233063`*^9}},
 FontWeight->"Bold",ExpressionUUID->"41c7c007-42d4-4bf4-b9bf-0c30f2095b56"],

Cell[CellGroupData[{

Cell["Traditional programming to recognise images", "Subsubsection",
 CellChangeTimes->{{3.7777106319702*^9, 3.777710647073194*^9}, 
   3.777710693601157*^9},ExpressionUUID->"9dc07c5d-e353-40ae-94cd-\
9dab753ccea8"],

Cell["Write a simple program to recognise the image of a person", "Text",
 CellChangeTimes->{{3.7777106708648567`*^9, 
  3.7777106893927794`*^9}},ExpressionUUID->"37460fdb-4475-4dbb-90d2-\
8e953903aab3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"images", "=", 
