Cell[CellGroupData[{

Cell["Example: Learning process for the law of free fall", "Section",
 CellChangeTimes->{{3.775051402512979*^9, 3.775051424207795*^9}, {
  3.7750516271196957`*^9, 3.775051630159554*^9}, {3.7750528481767178`*^9, 
  3.7750528668960657`*^9}, {3.775057161570956*^9, 3.77505718166674*^9}, {
  3.775057458114365*^9, 
  3.7750574653785963`*^9}},ExpressionUUID->"47680727-43bd-424f-9d9c-\
2049b22ffbda"],

Cell["\<\
The scientific method is a method of procedure that has characterized natural \
science since the 17th century, consisting in \
\>", "Text",
 CellChangeTimes->{{3.779702276013743*^9, 3.779702423309928*^9}, {
  3.77970247748668*^9, 3.779702531998241*^9}, {3.780579182068607*^9, 
  3.780579221868599*^9}},ExpressionUUID->"7dfd2f34-f1da-426d-8733-\
895d5effbcc7"],

Cell["systematic observation, measurement, and experiment and", "Item",
 CellChangeTimes->{{3.7805792435844564`*^9, 
  3.780579275725249*^9}},ExpressionUUID->"180b9a03-d579-433c-8db5-\
e7559c48aa3f"],

Cell["the formulation, testing, and modification of hypotheses.", "Item",
 CellChangeTimes->{{3.7805792435844564`*^9, 
  3.7805792851627097`*^9}},ExpressionUUID->"bf47ad91-651e-402f-b942-\
d4ea5b50ef5c"],

Cell["\<\

This example illustrates how the law of free fall can be derived from data \
following the scientific method. In fact, the scientific method leading to \
scientific theories can be viewed as a learning process for researchers. \
\>", "Text",
 CellChangeTimes->{{3.780579225518175*^9, 3.7805792409218597`*^9}, {
  3.780579300875387*^9, 
  3.780579308293872*^9}},ExpressionUUID->"571ae7a5-c65a-4ad4-9840-\
e2ad719f0414"],

