Cell["Might require cleaning and reformatting data", "Subitem",
 CellChangeTimes->{{3.776773064637884*^9, 
  3.7767731362997007`*^9}},ExpressionUUID->"ddade4c0-30bc-4678-9bb4-\
805c1600e5b3"],

Cell[CellGroupData[{

Cell["\<\
Get an idea of what we can learn from the data. What questions to ask\
\>", "Subitem",
 CellChangeTimes->{{3.776773064637884*^9, 3.776773157791453*^9}, {
  3.7767768908157873`*^9, 
  3.7767768908281803`*^9}},ExpressionUUID->"558239ff-edbc-45c0-8032-\
a4f42f95eaa7"],

Cell["\<\
Ex. Classify the images, identify groups of similar images, etc.\
\>", "SubitemParagraph",
 CellChangeTimes->{{3.776773064637884*^9, 3.776773157791453*^9}, {
  3.7767769039371443`*^9, 3.776776960712637*^9}, {3.7805793725307026`*^9, 
  3.7805794083756127`*^9}},ExpressionUUID->"306a3db9-6764-487f-a8b0-\
c98bb2747816"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Model training", "Subsection",
 CellChangeTimes->{
  3.776776759547317*^9},ExpressionUUID->"4c1ec8b4-e75b-45c9-85c8-\
2bfac3b7fb1e"],

Cell["Select an appropriate algorithm to learn from the data", "Subitem",
 CellChangeTimes->{{3.776773007885425*^9, 3.776773030724482*^9}, {
  3.776773209217968*^9, 
  3.776773280154234*^9}},ExpressionUUID->"413c344f-84f7-4a48-bfbb-\
f9aee8fd8e98"],

Cell["Algorithm represents the data as a model", "Subitem",
 CellChangeTimes->{{3.776773007885425*^9, 3.776773030724482*^9}, {
  3.776773209217968*^9, 
  3.776773313339897*^9}},ExpressionUUID->"a444b715-f1a5-4cb0-bce1-\
c50bb1abdbfe"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Model evaluation", "Subsection",
 CellChangeTimes->{
  3.776776783498741*^9},ExpressionUUID->"3963d7c1-311c-4238-a342-\
548a76bea662"],

Cell["How well does the algorithm learns?", "Subitem",
 CellChangeTimes->{{3.776773333467195*^9, 
  3.7767733678188343`*^9}},ExpressionUUID->"93d7a680-3421-4265-a769-\
1caf1e521f9c"],

Cell["Possibly using a test dataset", "Subitem",
 CellChangeTimes->{{3.776773333467195*^9, 
  3.776773382061802*^9}},ExpressionUUID->"a134d663-38a0-4646-a421-\
22aa537ae12b"],

Cell["Develop measures to quantify the performance", "Subitem",
 CellChangeTimes->{{3.776773333467195*^9, 
  3.776773404332931*^9}},ExpressionUUID->"09b1e35c-6389-431f-b174-\
5f4cdc1f456c"],

Cell["\tExample: Classify images", "Text",
 CellChangeTimes->{{3.7767777002384853`*^9, 
  3.776777789037098*^9}},ExpressionUUID->"d2434bd5-0b50-416f-b961-\
41d532a1cbdf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{"ImageIdentify", "[", "images", "]"}]}]], "Input",
 CellChangeTimes->{{3.776777006337721*^9, 3.776777031316059*^9}, 
   3.7767776935172777`*^9},
 CellLabel->"In[7]:=",ExpressionUUID->"97dd50ce-97f0-4e2f-830e-563baed8de35"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TemplateBox[{"\"Japanese iris\"", 
     RowBox[{"Entity", "[", 
       RowBox[{"\"Concept\"", ",", "\"IrisKaempferi::8nmjn\""}], "]"}], 
     "\"Entity[\\\"Concept\\\", \\\"IrisKaempferi::8nmjn\\\"]\"", 
     "\"concept\""},
    "Entity"], ",", 
   TemplateBox[{"\"European wildcat\"", 
     RowBox[{"Entity", "[", 
       RowBox[{"\"Concept\"", ",", "\"Catamountain::b5867\""}], "]"}], 
     "\"Entity[\\\"Concept\\\", \\\"Catamountain::b5867\\\"]\"", 
     "\"concept\""},
    "Entity"], ",", 
   TemplateBox[{"\"person\"", 
     RowBox[{"Entity", "[", 
       RowBox[{"\"Concept\"", ",", "\"Person::93r37\""}], "]"}], 
     "\"Entity[\\\"Concept\\\", \\\"Person::93r37\\\"]\"", "\"concept\""},
    "Entity"]}], "}"}]], "Output",
 CellChangeTimes->{3.776777033565323*^9, 3.812792706767887*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"ee1597d3-71b6-4cd0-bfa1-046864ed7d91"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Model improvement", "Subsection",
 CellChangeTimes->{
  3.776776803365528*^9},ExpressionUUID->"ee9f3141-984a-4446-80e1-\
8251b348dbb7"],

Cell["Needed if performance is not good enough", "Subitem",
 CellChangeTimes->{{3.7767734232785463`*^9, 
  3.77677343716011*^9}},ExpressionUUID->"a7611111-5f16-4876-805e-\
7f0b75165af5"],

Cell["Perhaps change the model", "Subitem",
 CellChangeTimes->{{3.7767734232785463`*^9, 
  3.776773455165135*^9}},ExpressionUUID->"9f6fdd52-d6d6-4ede-ab33-\
f2ebf949b21a"],

Cell["Perhaps use additional data", "Subitem",
 CellChangeTimes->{{3.7767734232785463`*^9, 
  3.77677346870402*^9}},ExpressionUUID->"75d942ef-f84d-48e8-b22d-\
372ab50dbae3"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Categories of machine learning", "Section",
 CellChangeTimes->{{3.776772860098812*^9, 3.77677287097471*^9}, {
  3.8128041346695766`*^9, 
  3.8128041448882513`*^9}},ExpressionUUID->"2cc8252c-2311-4736-99b2-\
c5749cba0707"],

Cell[TextData[{
 "There are three main types of machine learning in terms of the ",
 StyleBox["model training step",
  FontWeight->"Bold"],
 " mentioned in the previous section."
}], "Text",
 CellChangeTimes->{{3.8128041711979227`*^9, 3.812804220908124*^9}, {
  3.8128043051206274`*^9, 3.8128043055464907`*^9}, {3.812804342780224*^9, 
  3.8128043527491474`*^9}, {3.8128044997262*^9, 3.812804514729449*^9}, {
  3.8128047440073977`*^9, 3.8128047514245625`*^9}, {3.812805024797058*^9, 
  3.812805030856438*^9}},ExpressionUUID->"18fee2d2-18d9-44ef-ba10-\
cb04194d2192"],

Cell[TextData[{
 StyleBox["Supervised machine learning:",
  FontWeight->"Bold"],
 " The algorithm learns from examples (i.e. labeled data)."
}], "Item",
 CellChangeTimes->{{3.8128042353167953`*^9, 3.812804242217361*^9}, {
  3.8128043556503887`*^9, 3.81280439189047*^9}, {3.81280448193478*^9, 
  3.8128044889440713`*^9}, {3.8128045297298384`*^9, 
  3.812804530226508*^9}},ExpressionUUID->"ac22d85b-b4d9-4102-8087-\
7480ab966941"],

Cell[TextData[{
 StyleBox["Unsupervised machine learning:",
  FontWeight->"Bold"],
 " No teaching. The algorithm has to identify patterns and relationships on \
its own."
}], "Item",
 CellChangeTimes->{{3.8128042353167953`*^9, 3.812804250140149*^9}, {
  3.8128043786428995`*^9, 3.812804378807458*^9}, {3.8128044267817516`*^9, 
  3.8128044775874076`*^9}},ExpressionUUID->"5986ee12-96e5-4e35-ae6d-\
625ded5a4e6f"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Reinforcement learning:",
  FontWeight->"Bold"],
 " "
}], "Item",
 CellChangeTimes->{{3.8128042353167953`*^9, 3.8128042604236813`*^9}, {
  3.812804550268899*^9, 
  3.8128046164644456`*^9}},ExpressionUUID->"41e8acd9-b722-4150-bdc4-\
21f0b18d1263"],

Cell["\<\
The algorithm learns to do something by being rewarded when successful and \
punished when unsuccessful. \
\>", "Subitem",
 CellChangeTimes->{{3.8128042353167953`*^9, 3.8128042604236813`*^9}, {
  3.812804550268899*^9, 
  3.812804622238965*^9}},ExpressionUUID->"301a87af-414d-4ac2-af9b-\
7214cd91e93c"],

Cell["\<\
For example, reinforcement learning is a popular method for computers to \
learn how to play board games or how to interact with an environment that is \
not known in advance (e.g. a maze).\
\>", "Subitem",
 CellChangeTimes->{{3.8128042353167953`*^9, 3.8128042604236813`*^9}, {
  3.812804550268899*^9, 3.8128046303876886`*^9}, {3.8128047956564226`*^9, 
  3.8128048972021675`*^9}, {3.812804968997922*^9, 
  3.812804984403269*^9}},ExpressionUUID->"1346aa66-806e-447a-bd3d-\
50488b42d2ab"],

Cell["It is not so relevant for data science.", "Subitem",
 CellChangeTimes->{{3.8128042353167953`*^9, 3.8128042604236813`*^9}, {
  3.812804550268899*^9, 3.8128046303876886`*^9}, {3.8128047956564226`*^9, 
  3.8128048972021675`*^9}, {3.812804968997922*^9, 
  3.8128050188324995`*^9}},ExpressionUUID->"7b77f429-6f29-4281-8aeb-\
1e71204729ec"]
}, Open  ]],

Cell["\<\
The course will focus on supervised and unsupervised algorithms which are \
more relevant to data science.\
\>", "Text",
 CellChangeTimes->{{3.8128050432981396`*^9, 
  3.8128050730783167`*^9}},ExpressionUUID->"776ab288-adaf-4359-bd27-\
70cd1a137d6f"],

