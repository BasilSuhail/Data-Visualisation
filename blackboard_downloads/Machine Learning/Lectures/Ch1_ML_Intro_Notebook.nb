0db46797789b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tP", "[", "h_", "]"}], ":=", 
   SqrtBox[
    RowBox[{
     FractionBox["2", "9.81"], " ", "h"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tM", "[", "h_", "]"}], ":=", 
   RowBox[{"0.448835", " ", 
