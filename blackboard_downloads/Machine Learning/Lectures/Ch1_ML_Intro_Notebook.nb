Cell[CellGroupData[{

Cell[TextData[StyleBox["Abstraction - A model",
 FontColor:>Dynamic[
   CurrentValue[{StyleHints, "ColorSet", "Display2"}]]]], "Subsection",
 CellChangeTimes->{{3.775055606820574*^9, 3.77505561919606*^9}, 
   3.775466208383526*^9, {3.775466240767651*^9, 
   3.7754662519161797`*^9}},ExpressionUUID->"6e926b93-dc26-4b0d-ad00-\
bdb663aae030"],

Cell[TextData[{
 StyleBox["Physics law:",
  FontWeight->"Bold"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "=", 
    RowBox[{
     FractionBox["1", "2"], 
     SuperscriptBox[
      StyleBox["gt",
       FontSlant->"Italic"], "2"]}]}], TraditionalForm]],ExpressionUUID->
  "80f9cd7e-d5e8-406e-a223-d1bba9d7b920"],
 "        (",
 StyleBox["g",
  FontSlant->"Italic"],
 " = 9.8 ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["m",
     FontSlant->"Plain"], "/", 
    SuperscriptBox[
     StyleBox["s",
      FontSlant->"Plain"], "2"]}], TraditionalForm]],ExpressionUUID->
  "2b11ee06-cbb6-44a8-9aa1-de7da25668cd"],
 ")\n\nrepresents an ",
 StyleBox["abstraction",
  FontWeight->"Bold"],
 " of the data.\n\nThe observed time, ",
 StyleBox["t",
  FontSlant->"Italic"],
 ", taken by the apple to move a distance ",
 StyleBox["h ",
  FontSlant->"Italic"],
 "can be approximated by the formula",
 StyleBox[" \n\nt =",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{
     FractionBox["2", "g"], " ", "h"}]], TraditionalForm]],ExpressionUUID->
  "d8fe0d90-613b-40a0-93a0-10aa6f5cdd91"]
}], "Text",
 CellChangeTimes->{{3.7750540234587927`*^9, 3.775054057683425*^9}, {
  3.775054123874927*^9, 3.775054195138919*^9}, {3.7750543892351637`*^9, 
  3.775054701348012*^9}, {3.775459773405046*^9, 3.7754598033075933`*^9}, {
  3.775466549905534*^9, 
  3.775466556177477*^9}},ExpressionUUID->"ad647df4-1364-482f-b379-\
58dc118b3268"],

Cell[TextData[{
 StyleBox["Mathematica",
  FontWeight->"Bold"],
 " can also find an approximation to this law based on the data:"
}], "Text",
 CellChangeTimes->{{3.7750545274871063`*^9, 3.77505454107484*^9}, {
  3.775054734131401*^9, 3.7750547729475317`*^9}, {3.775055512471483*^9, 
  3.775055513027668*^9}, {3.775466288306871*^9, 3.775466293516287*^9}, {
  3.775466570592867*^9, 
  3.775466576401091*^9}},ExpressionUUID->"9514d815-f9cb-4b4a-8c27-\
6ed373117afc"],

