Cell[CellGroupData[{

Cell["\<\
How many different colours are there in the image? - Lossless compression\
\>", "Section",
 CellChangeTimes->{{3.938761343751066*^9, 3.938761352689476*^9}, {
  3.9387617907065983`*^9, 
  3.9387618214406185`*^9}},ExpressionUUID->"a9e7c49b-5f10-1e43-af65-\
71b534a5c356"],

Cell[TextData[{
 "It is interesting to investigate how many different colours are there in \
the original image. If we identify the set of unique colours in the image, \
say ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["n", "TI"], 
        RowBox[{
          StyleBox["u", "TI"], 
          StyleBox["n", "TI"], 
          StyleBox["i", "TI"], 
          StyleBox["q", "TI"], 
          StyleBox["u", "TI"], 
          StyleBox["e", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "n_{unique}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "336cc5f7-c984-bb4b-a94f-77de9a86f7d0"],
 ",  we could use them for lossless compression. In essence, all we need is \
to store is each of these colours and the coordinates of pixels with each of \
the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["n", "TI"], 
        RowBox[{
          StyleBox["u", "TI"], 
          StyleBox["n", "TI"], 
          StyleBox["i", "TI"], 
          StyleBox["q", "TI"], 
          StyleBox["u", "TI"], 
          StyleBox["e", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "n_{unique}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "252c2985-4dd7-1945-9200-c8ea5b3b876d"],
 " colours (i.e. the coordinates of the cluster corresponding to each unique \
color)."
}], "Text",
 CellChangeTimes->{{3.9387614007970467`*^9, 3.9387614261041737`*^9}, {
  3.93876182785198*^9, 
  3.9387620173486233`*^9}},ExpressionUUID->"5930964d-33e1-3448-85ab-\
68fa96447963"],

Cell["\<\
The set of unique colours can be obtained by deleting the duplicated pixels \
in the flattened data:\
\>", "Text",
 CellChangeTimes->{{3.938762021457054*^9, 3.93876202197081*^9}, {
  3.9387620684521446`*^9, 
  3.938762100365364*^9}},ExpressionUUID->"7f4ff19e-2ce7-6440-96e9-\
062fe848866a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dd", "=", 
  RowBox[{"DeleteDuplicates", "[", "dataf", "]"}]}]], "Input",
 CellChangeTimes->{{3.938755341000595*^9, 3.938755359775259*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"737f208d-12cc-2740-b24a-7837766761a1"],

Cell[BoxData[
 TemplateBox[<|"shortenedBoxes" -> TagBox[
     RowBox[{"{", 
       RowBox[{
         RowBox[{"{", 
           
           RowBox[{"0.24705882352941178`", ",", "0.09411764705882353`", ",", 
             "0.06274509803921569`"}], "}"}], ",", 
         RowBox[{"{", 
           
           RowBox[{"0.23529411764705882`", ",", "0.09019607843137255`", ",", 
             "0.054901960784313725`"}], "}"}], ",", 
         TemplateBox[{"76691"}, "OutputSizeLimit`Skeleton"], ",", 
         RowBox[{"{", 
           
           RowBox[{"0.26666666666666666`", ",", "0.16470588235294117`", ",", 
             "0.13333333333333333`"}], "}"}], ",", 
         RowBox[{"{", 
           
           RowBox[{"0.42745098039215684`", ",", "0.2823529411764706`", ",", 
             "0.23921568627450981`"}], "}"}]}], "}"}], Short[#, 8]& ], "line" -> 
   3, "sessionID" -> 33858383523933517130, "byteCount" -> 1840888, "size" -> 
   8, "stored" -> False, "expr" -> Missing["NotStored"], "wrap" -> 
   OutputSizeLimit`Defer, "version" -> 1|>,
  "OutputSizeLimitTemplate"]], "Output",
 CellChangeTimes->{{3.938755348566221*^9, 3.9387553614194584`*^9}, 
   3.9387621031813965`*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"5e634a74-4795-1948-b847-acf6a2d5eba6"]
}, Open  ]],

