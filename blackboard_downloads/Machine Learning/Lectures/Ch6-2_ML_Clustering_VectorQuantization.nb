Cell[CellGroupData[{

Cell["A function to simplify image color", "Section",
 CellChangeTimes->{{3.779352358822612*^9, 3.779352401967468*^9}, {
  3.77935369455958*^9, 
  3.7793537104830637`*^9}},ExpressionUUID->"626349fa-d34b-4d68-8f0b-\
5a3a6a1f112e"],

Cell["\<\
If we wanted to apply vector quantization to images in a more systematic way, \
the following function would help (it just puts together the steps followed \
above).\
\>", "Text",
 CellChangeTimes->{{3.782100827375604*^9, 
  3.782100898298504*^9}},ExpressionUUID->"bdf825c6-6d1c-4fdb-946d-\
14d00b892100"],

Cell[BoxData[
 RowBox[{
  RowBox[{"recolor", "[", 
   RowBox[{"image_", ",", "K0_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"K", "=", "K0"}], ",", "size", ",", "dataf", ",", "class", ",", 
      "cnumber", ",", "cnumberTemp", ",", "centres"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"size", "=", 
      RowBox[{"Information", "[", 
       RowBox[{"image", ",", "\"\<ImageDimensions\>\""}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dataf", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"ImageData", "[", "image", "]"}], ",", "1"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"class", "=", 
      RowBox[{"ClusterClassify", "[", 
       RowBox[{"dataf", ",", "K", ",", 
        RowBox[{"Method", "\[Rule]", "\"\<KMeans\>\""}], ",", 
        RowBox[{"DistanceFunction", "\[Rule]", "EuclideanDistance"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"cnumber", "=", 
      RowBox[{"class", "[", "dataf", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"clusters", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"dataf", "[", 
         RowBox[{"[", 
          RowBox[{"Flatten", "[", 
           RowBox[{"Position", "[", 
            RowBox[{"cnumber", ",", "i"}], "]"}], "]"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "K"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"centres", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Mean", "[", 
         RowBox[{"clusters", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "K"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"cnumberTemp", "=", 
      RowBox[{"cnumber", " ", "/.", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"i", "\[Rule]", 
          RowBox[{"centres", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "K"}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Image", "[", 
      RowBox[{"Partition", "[", 
       RowBox[{"cnumberTemp", ",", 
        RowBox[{"size", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.938756010040537*^9, 3.9387560136875324`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"574e7504-8530-534d-bada-0efd5c927771"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"image5", "=", 
  RowBox[{"recolor", "[", 
   RowBox[{"image", ",", "5"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.779353558395645*^9, 3.779353571227217*^9}, {
  3.779353624954842*^9, 3.779353652780121*^9}, {3.7793542712135515`*^9, 
