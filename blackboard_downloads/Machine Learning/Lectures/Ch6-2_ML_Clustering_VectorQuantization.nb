Cell[CellGroupData[{

Cell["Replacing colours by the central colour in their cluster ", "Subsection",
 CellChangeTimes->{{3.782100270599796*^9, 
  3.782100304533565*^9}},ExpressionUUID->"18b33c98-da19-4948-84bd-\
e80154b8ad27"],

Cell[TextData[{
 "We now replace each pixel by the colour that represents its cluster (i.e. \
the colour in the ",
 StyleBox["centres", "CodeText"],
 " list). We do this by replacing the colour class in the cnumber list by the \
{r,g,b} coordinates corresponding to the centre of the class."
}], "Text",
 CellChangeTimes->{{3.7821003156544*^9, 3.7821003456499987`*^9}, {
  3.782100403297078*^9, 3.7821004202714853`*^9}, {3.782100512255302*^9, 
  3.7821005567387958`*^9}},ExpressionUUID->"538f7955-53e6-4076-8817-\
2918e4812ee4"],

