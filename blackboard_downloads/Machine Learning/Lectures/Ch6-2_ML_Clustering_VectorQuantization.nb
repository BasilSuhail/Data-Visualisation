Cell[TextData[{
 "At this point, we find clusters and give a class number to each of them \
(this will be a colour class). Since we want to assign a class to each \
cluster, we use the ",
 StyleBox["ClusterClassify", "CodeText"],
 " function."
}], "Text",
 CellChangeTimes->{{3.781943241807308*^9, 3.78194332079745*^9}, 
   3.782099577852644*^9},ExpressionUUID->"dfc18c7c-2c82-4c2f-af43-\
f7dbe858e3b7"],

