Cell[CellGroupData[{

Cell["\<\
Finding the colour that represents each class - Centres of clusters\
\>", "Subsection",
 CellChangeTimes->{{3.782099802374883*^9, 
  3.782099837229389*^9}},ExpressionUUID->"e51a2c0e-13a8-401b-ba6e-\
8369e1efffe2"],

Cell["\<\
At this point, we will need to find the centre for each cluster. The colour \
corresponding to the centre of each of the clusters found above are the ones \
that will be used to re-colour the image. \
\>", "Text",
 CellChangeTimes->{{3.782099638922466*^9, 3.78209969511959*^9}, {
  3.782099844700534*^9, 3.78209990153627*^9}, {3.7820999341762934`*^9, 
