Cell["Information on the image can be obtained as follows:", "Text",
 CellChangeTimes->{{3.779354585376522*^9, 3.7793546012448587`*^9}, {
  3.7793548351139035`*^9, 3.779354841965386*^9}, {3.781942044646554*^9, 
  3.781942049799868*^9}, {3.7819421692435904`*^9, 
  3.781942174632431*^9}},ExpressionUUID->"260e419b-4eb1-4574-989d-\
