Cell[TextData[{
 "The list ",
 StyleBox["cnumber", "CodeText"],
 " does not have the dimensions of the image. In order to visualize the image \
properly, we need to re-arrange the list into a nested list with ",
 StyleBox["size[[1]]", "CodeText"],
 " pixels per row. This can be achieved by applying the ",
 StyleBox["Partition", "CodeText"],
 " function to the list ",
 StyleBox["cnumber", "CodeText"],
 ". After that, we simply transform the resulting list to an image."
}], "Text",
 CellChangeTimes->{{3.782100628752761*^9, 
  3.782100762474197*^9}},ExpressionUUID->"8246579f-feec-44b3-860d-\
db7d523c1dee"],

