Cell[CellGroupData[{

Cell[TextData[{
 "Finding ",
 StyleBox["K",
  FontSlant->"Italic"],
 " colour classes automatically "
}], "Subsection",
 CellChangeTimes->{{3.7819424008835773`*^9, 3.7819424037894764`*^9}, {
  3.782099709804075*^9, 
  3.7820997463151774`*^9}},ExpressionUUID->"dea82467-22eb-4a04-9c49-\
3a4f7683538a"],

Cell[TextData[{
 "Vector quantization will be implemented by grouping pixels in the original \
image in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"K", "=", "5"}], TraditionalForm]],ExpressionUUID->
  "4e0062e0-0abf-4344-8e9f-3ea461ac2b04"],
 " clusters (everything can be done for an arbitrary ",
 StyleBox["K",
  FontSlant->"Italic"],
 ").\n\nIn order to work with Mathematica functions for clustering, we will \
need to transform the image to numerical data with the ",
 StyleBox["ImageData", "CodeText"],
 " function and flatten it to get a list with elements given by the {r,g,b} \
coordinates for each pixel. These are the points that will be used for \
clustering later."
}], "Text",
 CellChangeTimes->{{3.7819424115821176`*^9, 3.7819425044697514`*^9}, {
  3.7819428224163446`*^9, 3.7819429402515945`*^9}, {3.7819429703260965`*^9, 
  3.781942986329081*^9}, {3.781943214550774*^9, 3.78194321917225*^9}, {
  3.782099492215457*^9, 
  3.7820995225995817`*^9}},ExpressionUUID->"1fd349cc-fe88-4680-9649-\
d3ac8d98376e"],

