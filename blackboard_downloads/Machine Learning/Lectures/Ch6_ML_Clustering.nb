Cell["\<\
One can define a modular function to automatically calculate the purity for \
any dataset, classifier and true classes:\
\>", "Text",
 CellChangeTimes->{{3.7818434873296275`*^9, 
  3.781843529990944*^9}},ExpressionUUID->"9d6053b8-2b74-416d-9109-\
8d2244933e89"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Purity", "[", 
   RowBox[{"datain_", ",", "classifierin_", ",", "trueclassesin_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"data", "=", "datain"}], ",", 
      RowBox[{"classifier", "=", "classifierin"}], ",", 
      RowBox[{"trueclasses", "=", "trueclassesin"}], ",", "Ncommonest"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Ncommonest", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Count", "[", 
         RowBox[{
          RowBox[{"classifier", "[", 
           RowBox[{"trueclasses", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"Commonest", "[", 
            RowBox[{"classifier", "[", 
             RowBox[{"trueclasses", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "[", "trueclasses", "]"}]}], "}"}]}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{"Total", "[", "Ncommonest", "]"}], "/", 
       RowBox[{"Length", "[", "data", "]"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.781842875569315*^9, 3.781843255739025*^9}},
 CellLabel->"In[45]:=",ExpressionUUID->"417b0f8f-2fb7-4fda-9857-c6b5991fe0bc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Purity", "[", 
  RowBox[{"data", ",", "cc", ",", 
   RowBox[{"{", 
    RowBox[{"cluster1", ",", "cluster2"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.781843232443147*^9, 3.7818432475142117`*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"6d1cfd6f-6011-4e95-9f4f-0f20ca069030"],

