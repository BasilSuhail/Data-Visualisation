Cell[CellGroupData[{

Cell["Step 2 - Find distances of each data point to the centres", \
"Subsubsection",
 CellChangeTimes->{{3.7791087823171167`*^9, 3.7791087840934963`*^9}, {
  3.7791775214142923`*^9, 
  3.779177523897348*^9}},ExpressionUUID->"cadf0118-7b80-4b53-acaa-\
7d838ff8e711"],

Cell[TextData[{
 "Several definitions can be used for distance (several will be introduced in \
a section below). The specific choice depends on the problem at hand. \n\n\
Here, I will use the Euclidean distance. The Euclidean distance between the \
",
 StyleBox["n",
  FontSlant->"Italic"],
 "-th datum, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["x",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    RowBox[{"(", "n", ")"}]], TraditionalForm]],ExpressionUUID->
  "947611a4-b99f-4fb9-b016-00538c435678"],
 ", and the ",
 StyleBox["k",
  FontSlant->"Italic"],
 "-th centre is, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["c",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    RowBox[{"(", "k", ")"}]], TraditionalForm]],ExpressionUUID->
  "5a1cc66d-125a-4f80-b3f0-fc99799e360e"],
 ", is given by\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "("}], TraditionalForm]],ExpressionUUID->
  "4685209c-7eda-431f-b446-b7594481aa12"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["x",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    RowBox[{"(", "n", ")"}]], TraditionalForm]],ExpressionUUID->
  "743c5a11-48d6-4889-8ea7-2e679bfcf73e"],
 ",",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["c",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    RowBox[{"(", "k", ")"}]], TraditionalForm]],ExpressionUUID->
  "0a5a0213-9761-4883-844f-fee1b621e47f"],
 ")=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SqrtBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubsuperscriptBox[
          StyleBox["x",
           FontSlant->"Plain"], "1", 
          RowBox[{"(", "n", ")"}]], "-", 
         SubsuperscriptBox[
          StyleBox["c",
           FontSlant->"Plain"], "1", 
          RowBox[{"(", "k", ")"}]]}], ")"}], "2"], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubsuperscriptBox[
          StyleBox["x",
           FontSlant->"Plain"], "2", 
          RowBox[{"(", "n", ")"}]], "-", 
         SubsuperscriptBox[
          StyleBox["c",
           FontSlant->"Plain"], "2", 
          RowBox[{"(", "k", ")"}]]}], ")"}], "2"], "+", "\[CenterEllipsis]", 
      "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubsuperscriptBox[
          StyleBox["x",
           FontSlant->"Plain"], "M", 
          RowBox[{"(", "n", ")"}]], "-", 
         SubsuperscriptBox[
          StyleBox["c",
           FontSlant->"Plain"], "M", 
          RowBox[{"(", "k", ")"}]]}], ")"}], "2"]}]], "="}], 
   TraditionalForm]],ExpressionUUID->"386d9088-efa9-41a4-b4bd-910067638172"],
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"m", "=", "1"}], "M"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubsuperscriptBox[
         StyleBox["x",
          FontSlant->"Plain"], "m", 
         RowBox[{"(", "n", ")"}]], "-", 
        SubsuperscriptBox[
         StyleBox["c",
          FontSlant->"Plain"], "m", 
         RowBox[{"(", "k", ")"}]]}], ")"}], "2"]}]], TraditionalForm]],
  ExpressionUUID->"c36b27ed-e529-4686-9897-2dcfa92f8e66"],
 "\n\nThe Euclidean distance can be easily calculated in Mathematica with the \
function ",
 StyleBox["EuclideanDistance", "CodeText"]
}], "Text",
 CellChangeTimes->{{3.77910993986655*^9, 3.779109947682033*^9}, {
  3.7791100026996593`*^9, 3.779110099893598*^9}, {3.779171547296558*^9, 
  3.779171557249013*^9}, {3.779173451491989*^9, 3.7791735561587143`*^9}, {
  3.77917367433631*^9, 3.779173864443701*^9}, {3.779173949663863*^9, 
  3.779174015802685*^9}, {3.779174102154888*^9, 3.779174106315063*^9}, {
  3.8146940560935774`*^9, 
  3.8146940967534156`*^9}},ExpressionUUID->"dee410ee-927d-461c-af31-\
df389ee5dc27"],

Cell[TextData[{
 StyleBox["Example:",
  FontWeight->"Bold"],
 " For our synthetic data, the distance to the centres is"
}], "Text",
 CellChangeTimes->{{3.779174022105557*^9, 3.779174031865782*^9}, {
  3.779174062185738*^9, 
  3.779174129705188*^9}},ExpressionUUID->"a667c094-43ee-4531-8762-\
05e3a996c117"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dToCentres", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"EuclideanDistance", "[", 
        RowBox[{
         RowBox[{"data", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", 
         RowBox[{"c", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ",", 
       RowBox[{"EuclideanDistance", "[", 
        RowBox[{
         RowBox[{"data", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", 
         RowBox[{"c", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"Length", "[", "data", "]"}]}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.7791092050858507`*^9, 3.779109210262072*^9}, {
   3.779109431579446*^9, 3.7791094411954527`*^9}, {3.779109480412458*^9, 
   3.779109518389552*^9}, 3.779109596273003*^9, {3.779109677989018*^9, 
   3.779109685022262*^9}, {3.779109742585505*^9, 3.779109793995275*^9}, {
   3.779109865196293*^9, 3.779109872090578*^9}},
 CellLabel->
  "In[139]:=",ExpressionUUID->"f0d86f83-a744-4faa-b5d2-eeca52e0fd43"],

