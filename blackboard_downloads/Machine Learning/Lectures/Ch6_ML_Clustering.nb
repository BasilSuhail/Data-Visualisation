 RowBox[{"CosineDistance", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"3", ",", "3"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.7811897669760695`*^9, 3.7811897760687776`*^9}, {
  3.781189809711937*^9, 3.7811898982444706`*^9}, {3.78119062620449*^9, 
