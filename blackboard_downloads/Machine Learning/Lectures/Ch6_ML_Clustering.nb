Cell[CellGroupData[{

Cell["Manhattan distance", "Subsection",
 CellChangeTimes->{
  3.781195339647256*^9},ExpressionUUID->"b8e861fb-ea48-4d59-91d1-\
5dfa519f0859"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"ManhattanDistance", "[", 
     RowBox[{"u", ",", "v"}], "]"}], "="}], TraditionalForm]],ExpressionUUID->
  "f344ce4a-641a-4605-8f55-35f16a5bcbb2"],
 Cell[BoxData[
  RowBox[{
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"i", "=", "1"}], "M"], 
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox["u", "i"], "-", 
      SubscriptBox["v", "i"]}], "\[RightBracketingBar]"}]}], "=", 
   RowBox[{"|", 
    RowBox[{
     SubscriptBox["u", "1"], "-", 
     SubscriptBox["v", "1"]}], "|", 
    RowBox[{"+", 
     RowBox[{"|", 
      RowBox[{
       SubscriptBox["u", "2"], "-", 
       SubscriptBox["v", "2"]}], "|"}]}]}]}]],
  CellChangeTimes->{{3.7811907892728615`*^9, 3.78119080758086*^9}},
  ExpressionUUID->"6f1b1aa2-0014-491f-ade9-e3671ba25e29"]
}], "Text",
 CellChangeTimes->{{3.7811937336223*^9, 3.7811937601827993`*^9}, {
  3.8147094667711487`*^9, 
  3.814709488999117*^9}},ExpressionUUID->"5cf40b87-d1c2-42dd-a256-\
66f57411ab92"],

Cell["\<\
It is sometimes preferable to the Euclidean norm when dealing with high \
dimensional data\
\>", "Text",
 CellChangeTimes->{{3.781193770112398*^9, 
  3.7811938018088956`*^9}},ExpressionUUID->"d2fafb1f-0e5c-4de4-af02-\
592b3ca33a2c"],

Cell["Example:", "Text",
 CellChangeTimes->{{3.7811938075036345`*^9, 
  3.781193810535538*^9}},ExpressionUUID->"69c7cf0d-e72b-4c13-ac30-\
ec06ed1a7dd2"],

