Cell["Step 3 - Assign each point to the closest centre", "Subsubsection",
 CellChangeTimes->{{3.7791143777022696`*^9, 3.7791143797312546`*^9}, {
  3.7791146003152475`*^9, 3.7791146029180107`*^9}, {3.779177479430361*^9, 
