Cell[TextData[{
 "Of course, ",
 StyleBox["ClusterClassify", "CodeText"],
 " does not know which data we defined as cluster 1 or cluster 2. This \
function just finds two classes which it calls 1 and 2 but the labels we gave \
as humans do not need to agree with the labels chosen by ",
 StyleBox["ClusterClassify", "CodeText"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8149430512276025`*^9, 
  3.814943191105611*^9}},ExpressionUUID->"e246212b-c318-4fe9-a7b5-\
af0ff9aedcd7"],

Cell[TextData[{
 "Let us look at plots for the classification of what we called ",
 StyleBox["cluster1", "CodeText"],
 " and ",
 StyleBox["cluster2", "CodeText"],
 ":"
}], "Text",
 CellChangeTimes->{{3.8149432135448117`*^9, 
  3.8149432660027657`*^9}},ExpressionUUID->"de6978ca-c949-4617-bc1f-\
7979cc82b01a"],

