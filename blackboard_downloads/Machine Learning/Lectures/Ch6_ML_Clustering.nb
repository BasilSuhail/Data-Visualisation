Cell["Let us find the clusters for a given K:", "Text",
 CellChangeTimes->{{3.7791821448844767`*^9, 3.779182152529669*^9}, {
  3.779183007938439*^9, 3.779183009874762*^9}, {3.779183278930537*^9, 
  3.779183295523073*^9}},ExpressionUUID->"cfe0bf39-d44b-4c67-91cf-\
ce1bc08c0ee1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"K", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"clusters", "=", 
   RowBox[{"FindClusters", "[", 
    RowBox[{"data", ",", "K", ",", 
     RowBox[{"Method", "\[Rule]", "\"\<KMeans\>\""}], ",", 
     RowBox[{"DistanceFunction", "\[Rule]", "EuclideanDistance"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"clusters", ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"PointSize", "[", "0.01", "]"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.778511542160491*^9, 3.778511596268916*^9}, {
