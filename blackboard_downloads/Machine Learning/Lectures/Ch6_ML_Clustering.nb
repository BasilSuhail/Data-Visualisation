Cell[TextData[{
 "In this step, we obtain ",
 StyleBox["K",
  FontSlant->"Italic"],
 " clusters, one associated to each centre\n\n",
 StyleBox["Example:",
  FontWeight->"Bold"],
 " For our example, the closest centre to a given point, data[[1]] say, can \
be calculated as follows:"
}], "Text",
