Cell["\<\
As shown in the diagram, clustering problems can be broadly divided in two \
categories:\
\>", "Text",
 CellChangeTimes->{{3.7811566491732078`*^9, 3.7811566542356815`*^9}, {
  3.7811574486579423`*^9, 3.781157487792329*^9}, {3.7815902930761175`*^9, 
  3.78159030194812*^9}},ExpressionUUID->"1904ed92-222b-44ed-937e-\
a85f441a7c50"],

Cell[CellGroupData[{

Cell[TextData[{
 "Hard clustering: A data point belongs to one and only one cluster, ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "faf064c8-540b-41b8-9ca6-00f8d98db201"]
}], "Item",
 CellChangeTimes->{{3.7811574926452293`*^9, 
  3.7811575309785204`*^9}},ExpressionUUID->"0b4e25ae-7523-4d74-b5d1-\
15634081c39d"],

Cell["\<\
Partitional: Create a non-overlapping partition of the data points. \
\>", "Subitem",
 CellChangeTimes->{{3.7811574926452293`*^9, 3.7811575449373875`*^9}, {
  3.7811581924489994`*^9, 3.781158222116635*^9}, {3.781158262671356*^9, 
  3.7811582639243603`*^9}},ExpressionUUID->"9b364c08-c637-4dc0-8bb8-\
b69a0e6eef21"],

Cell[CellGroupData[{

Cell["\<\
Hierarchical: Define clusters sequentially. Impractical for large datasets.\
\>", "Subitem",
 CellChangeTimes->{{3.7811574926452293`*^9, 3.78115755126623*^9}, {
  3.781158229376541*^9, 
  3.7811582919429536`*^9}},ExpressionUUID->"e0c917b2-f8a8-436b-8990-\
ecedd1003b2c"],

Cell["\<\
Divisive: Start with a large cluster containing all the points in the data \
set and sequentially divide it into smaller clusters\
\>", "Subsubitem",
 CellChangeTimes->{{3.7811574926452293`*^9, 3.7811575571237226`*^9}, {
  3.7811580331583967`*^9, 
  3.7811580917035494`*^9}},ExpressionUUID->"796ea314-93c7-4089-a597-\
f3eb1e796f15"],

Cell["\<\
Agglomerative: Start with clusters each containing one data point and \
proceeds by merging clusters \
\>", "Subsubitem",
 CellChangeTimes->{{3.7811574926452293`*^9, 3.7811575612874002`*^9}, {
  3.781158068062827*^9, 3.781158071406488*^9}, {3.7811581062182684`*^9, 
  3.781158143445237*^9}},ExpressionUUID->"651ebbc5-b1b3-4be8-bf3f-\
6d0b37434241"]
}, Open  ]]
}, Open  ]],

Cell["\<\
Fuzzy clustering: A data point may belong to two or more clusters with some \
probabilities.\
\>", "Item",
 CellChangeTimes->{{3.7811574926452293`*^9, 3.781157611240221*^9}, {
  3.7811581482345333`*^9, 
  3.78115814883457*^9}},ExpressionUUID->"3246c0a2-7ca3-4e20-a578-\
9a8408711043"],

