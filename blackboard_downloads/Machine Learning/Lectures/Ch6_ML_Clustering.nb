Cell[CellGroupData[{

Cell["KMC using in Wolfram Language", "Subsection",
 CellChangeTimes->{{3.779175429113091*^9, 3.7791754337856073`*^9}, {
  3.7791755000096617`*^9, 3.7791755047142353`*^9}, {3.781196996478768*^9, 
  3.7811970075495663`*^9}},ExpressionUUID->"c4716fe1-d422-418b-a98e-\
66dee14199d9"],

Cell[TextData[{
 "The KMC method can be easily used in Mathematica using the ",
 StyleBox["FindClusters", "CodeText"],
 " function\n\nExample: When applied to the synthetic data, we obtain"
}], "Text",
 CellChangeTimes->{{3.7791754388892527`*^9, 3.7791754570011787`*^9}, {
  3.7791755088575897`*^9, 3.779175525481523*^9}, {3.7791761385048103`*^9, 
  3.779176173512761*^9}, {3.779176259849572*^9, 
  3.779176295368767*^9}},ExpressionUUID->"21fc3fc6-724f-46af-a20b-\
a929a4990b3d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"clustersFC", "=", 
   RowBox[{"FindClusters", "[", 
    RowBox[{"data", ",", "2", ",", 
     RowBox[{"Method", "\[Rule]", "\"\<KMeans\>\""}], ",", 
     RowBox[{"DistanceFunction", "\[Rule]", "EuclideanDistance"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.7791761302211323`*^9, 3.77917613553065*^9}, {
  3.77917618141663*^9, 3.779176181544559*^9}, {3.779176242168768*^9, 
  3.7791762548106747`*^9}, {3.7791762981046267`*^9, 3.779176319304702*^9}, {
  3.779176351772791*^9, 3.779176395917268*^9}, {3.77917686466495*^9, 
  3.779176865799492*^9}, {3.779176904826126*^9, 3.779176934407651*^9}},
 CellLabel->
  "In[153]:=",ExpressionUUID->"109174ba-4b34-4291-aa60-fcf82579557a"],

Cell[CellGroupData[{

