Cell["One would intuitively expect the following trends:", "Text",
 CellChangeTimes->{{3.814904955585514*^9, 3.8149050371679525`*^9}, {
  3.814905541636075*^9, 
  3.8149055441366243`*^9}},ExpressionUUID->"d5e5cbd4-c0df-4b3e-8b3a-\
969fa03e366b"],

Cell[TextData[{
 "The number of clusters decreases with the neighbourhood radius ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "e1fc04db-b029-418b-a26b-9debf8c1abd2"],
 ". Indeed, the larger the radius, the higher the chances for a point to be \
\[OpenCurlyDoubleQuote]invaded\[CloseCurlyDoubleQuote] by a growing cluster. \
Think about the limit with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "\[Rule]", " ", "\[Infinity]"}], TraditionalForm]],
  ExpressionUUID->"05a720d1-1ac3-4f7d-9130-0adf82f26b83"],
 "."
}], "Item",
 CellChangeTimes->{{3.814904955585514*^9, 3.8149050476624265`*^9}, {
  3.814905550331473*^9, 
  3.814905659802853*^9}},ExpressionUUID->"fa3c82ce-49e5-433a-a86b-\
daee27667dbd"],

Cell[TextData[{
 "The number of clusters increases with the minimal number of points ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "min"], TraditionalForm]],ExpressionUUID->
  "bf9b214b-36d9-46a6-85e8-12ddf93e65f8"],
 " in the ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "ee3a586f-304b-40f9-a7e6-a5ad3c16b739"],
 "-neighbourhood. Indeed, if one requires a large number of points in the ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "1b8b1e19-bede-4a73-8a57-4d4fa2789299"],
 "-neighbourhood for the cluster to grow, it is unlikely that clusters will \
grow much."
}], "Item",
 CellChangeTimes->{{3.814904955585514*^9, 3.8149050835382257`*^9}, {
  3.8149056642177415`*^9, 3.814905701430052*^9}, {3.8149057348301315`*^9, 
  3.8149057973114815`*^9}},ExpressionUUID->"e16bc008-67f9-4bfb-ba4e-\
fec1e8a0c8b8"],

Cell[TextData[{
 "For a 2-dimensional dataset, one can explore the effect of ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "ea69c73d-deef-4ab3-9aea-7e9c11fd4304"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "min"], TraditionalForm]],ExpressionUUID->
  "ec4f1b96-7b04-4c33-bf83-bda8499378ee"],
 " visually:"
}], "Text",
 CellChangeTimes->{{3.8149048713649817`*^9, 
  3.814904919921156*^9}},ExpressionUUID->"48dd4c66-4fe8-43be-874c-\
fc84fbd05051"],

