a5cb6a38fe39"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gaussian", "[", 
    RowBox[{"\[Mu]_", ",", "\[Sigma]_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"MultinormalDistribution", "[", 
      RowBox[{"\[Mu]", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Sigma]", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "\[Sigma]"}], "}"}]}], "}"}]}], "]"}], ",", "n"}],
     "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cluster1", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", "0.1", ",", "50"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cluster2", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "a"}], "}"}], ",", "0.1", ",", "50"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cluster3", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", 
       RowBox[{"-", "a"}]}], "}"}], ",", "0.1", ",", "50"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cluster4", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "a"}]}], "}"}], ",", "0.1", ",", "50"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"cluster5", "=", 
    RowBox[{"gaussian", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "a"}], ",", "a"}], "}"}], ",", "0.1", ",", "50"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Join", "[", 
    RowBox[{
    "cluster1", ",", "cluster2", ",", "cluster3", ",", "cluster4", ",", 
     "cluster5"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.778853092157978*^9, 3.77885317879671*^9}, {
