Cell[CellGroupData[{

Cell["Chessboard or Chebyshev distance", "Subsection",
 CellChangeTimes->{
  3.7811953574103107`*^9},ExpressionUUID->"445fab9a-cbfb-4d17-9575-\
e1c56d8c0525"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"ChessboardDistance", "[", 
    RowBox[{"u", ",", "v"}], "]"}], "=", 
   RowBox[{
    UnderscriptBox["max", "i"], "[", 
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox["u", "i"], "-", 
      SubscriptBox["v", "i"]}], "\[RightBracketingBar]"}], "]"}]}], 
  TraditionalForm]],ExpressionUUID->"051d7a03-2d1e-4970-8ac5-050fb83dca05"]], \
"Text",
 CellChangeTimes->{{3.781193994549862*^9, 
  3.7811940159706345`*^9}},ExpressionUUID->"58c0cb28-3bf6-4040-9f56-\
35a53c9323a3"],

Cell["\<\
This can be the preferred distance measure when data has many dimensions and \
most of them do not play an important role for classification or clustering\
\>", "Text",
 CellChangeTimes->{{3.781193888462185*^9, 
  3.7811939503720207`*^9}},ExpressionUUID->"17222afc-fa57-40bd-91d2-\
9253acce2a4d"],

Cell["Example:", "Text",
