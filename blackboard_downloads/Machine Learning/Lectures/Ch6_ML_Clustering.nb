 CellChangeTimes->{{3.7818432483674436`*^9, 3.7818432580510373`*^9}, 
   3.7818787812820435`*^9, 3.781958196537024*^9, 3.8149451341018677`*^9},
 CellLabel->"Out[46]=",ExpressionUUID->"80b1c327-5843-4373-a4be-cdffe3e5237f"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["KMC - Setting the initial centroids manually\t", "Section",
 CellChangeTimes->{{3.857752654660164*^9, 3.8577526650183697`*^9}, {
  3.8867423716294994`*^9, 
  3.8867423835113974`*^9}},ExpressionUUID->"d9b57790-3cb6-4fe1-b746-\
4b0edb99088b"],

Cell["\<\
The specific clusters obtained with the KMC method may depend on the initials \
centers used to find the clusters. To ensure that we obtain a reproducible \
clustering, it may be useful to specify the centroids manually. In this way, \
the resulting clusters should be the same every time we run the KMC algorithm.

When using FindClusters to implement the KMC method, centroids can be readily \
specified as follows:\
\>", "Text",
 CellChangeTimes->{{3.857752671554477*^9, 3.8577527781533623`*^9}, {
  3.857752851713705*^9, 3.8577529151307592`*^9}, {3.886742387633462*^9, 
  3.8867424525031743`*^9}},ExpressionUUID->"23501c77-aa45-4584-8ef8-\
8c3398808e03"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"data", "[", 
  RowBox[{"[", "1", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.886742541466858*^9, 3.8867425491276407`*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"8336eb85-fdbd-42cd-8f9c-a2163b324e3c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1.85715`", ",", "2.41134`"}], "}"}]], "Output",
 CellChangeTimes->{{3.8867425427437134`*^9, 3.886742553143732*^9}},
 CellLabel->"Out[10]=",ExpressionUUID->"9224c212-e3fd-474c-a526-edfcac389ba5"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Example", ":", " ", 
     RowBox[{
     "From", " ", "the", " ", "synthetic", " ", "data", " ", "used", " ", 
      "at", " ", "the", " ", "beginning", " ", "to", " ", "illustrate", " ", 
      "the", " ", "KMC", " ", "method"}]}], ",", " ", 
    RowBox[{
    "take", " ", "the", " ", "first", " ", "and", " ", "last", " ", "data", 
     " ", "points", " ", "as", " ", "initial", " ", "centroids", " ", "to", 
     " ", "find", " ", "two", " ", "clusters"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"centroid0", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"data", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"-", "1"}], "]"}], "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"clustersFCcentroids", "=", 
     RowBox[{"FindClusters", "[", 
      RowBox[{"data", ",", "2", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<KMeans\>\""}], ",", 
       RowBox[{"Method", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<KMeans\>\"", ",", 
          RowBox[{"\"\<InitialCentroids\>\"", "->", "centroid0"}]}], "}"}]}], 
       ",", 
       RowBox[{"DistanceFunction", "\[Rule]", "EuclideanDistance"}]}], 
      "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.886742498325582*^9, 3.8867425356391697`*^9}, {
  3.8867425817126007`*^9, 3.886742583744421*^9}, {3.8867427520790424`*^9, 
  3.886742819740038*^9}, {3.8867428756011477`*^9, 
  3.8867429120200005`*^9}},ExpressionUUID->"f0ff7c81-ec5c-4eb6-9500-\
1a08f2be859b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"clustersFCcentroids", ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Feature 1\>\"", ",", "\"\<Feature 2\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{3.886742850574391*^9},
 CellLabel->"In[13]:=",ExpressionUUID->"08a928be-1ee3-447e-8199-38c570347f5a"],

