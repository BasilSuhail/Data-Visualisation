Cell[CellGroupData[{

Cell["Bibliography for clustering", "Subsection",
 CellChangeTimes->{{3.7811584307154274`*^9, 3.7811584392633767`*^9}, {
  3.781158948261864*^9, 
  3.7811589503392677`*^9}},ExpressionUUID->"c1ac3cc0-e2b1-4eb1-9f3f-\
a0f596f68efa"],

Cell[TextData[{
 "Clustering is described in the books recommended at the beginning of the \
course and other books on machine learning.\n\nThere are also books with an \
exclusive focus on clustering. If you are interested, the following two are \
quite complete:\n\nGan, Guojun. et al. \[OpenCurlyDoubleQuote]Data \
clustering; theory, algorithms, and applications\[CloseCurlyDoubleQuote] SIAM \
(2007)\n\nC. Aggarwal, C.K. Reddy \[OpenCurlyDoubleQuote]Data clustering \
algorithms and applications\[CloseCurlyDoubleQuote] Boca Raton, Fla. : CRC \
Press (2014). ",
 ButtonBox["https://abdn.primo.exlibrisgroup.com/permalink/44ABE_INST/1jd70l9/\
alma9917747598305941",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://abdn.primo.exlibrisgroup.com/permalink/44ABE_INST/1jd70l9/\
alma9917747598305941"], None},
  ButtonNote->
   "https://abdn.primo.exlibrisgroup.com/permalink/44ABE_INST/1jd70l9/\
alma9917747598305941"]
}], "Text",
 CellChangeTimes->{{3.781158442942846*^9, 3.7811585067521296`*^9}, {
