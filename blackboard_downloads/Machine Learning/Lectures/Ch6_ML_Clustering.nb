Cell[TextData[{
 "Humans can identify three clusters. However, applying the ",
 StyleBox["FindClusters", "CodeText"],
 " blindly do not find the clustering we expect."
}], "Text",
 CellChangeTimes->{{3.7811954934352293`*^9, 3.781195563798544*^9}, {
