Cell[TextData[{
 "They can be",
 StyleBox[" implemented in Mathematica as follows",
  FontWeight->"Bold"],
 ":\n\nFindClusters[data, Method",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"\[Rule]", " "}]}], TraditionalForm]],ExpressionUUID->
  "eee11588-38d6-4795-b024-5fc768439bfb"],
 "\[CloseCurlyDoubleQuote]Method Name\[CloseCurlyDoubleQuote]]"
}], "Text",
 CellChangeTimes->{{3.7791164758491106`*^9, 3.779116533755102*^9}, 
   3.7817985978557653`*^9, {3.781798674290251*^9, 
   3.7817986884835677`*^9}},ExpressionUUID->"b50bf03f-4274-41c5-96fe-\
0d586a85ea5a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["k Means clustering (KMC)", "Section",
 CellChangeTimes->{{3.7785078199507027`*^9, 3.778507827774666*^9}, {
  3.778565631264419*^9, 3.7785656352085114`*^9}, {3.8146948825099907`*^9, 
  3.8146948970917325`*^9}},ExpressionUUID->"58c72803-8e65-49ae-a764-\
48b92d0c4910"],

Cell[CellGroupData[{

Cell["Introduction", "Subsection",
 CellChangeTimes->{{3.779107547230842*^9, 3.779107551742166*^9}, {
  3.7791165618043423`*^9, 3.7791165635392447`*^9}, {3.779169956610364*^9, 
  3.77916995819389*^9}},ExpressionUUID->"4be0c64a-96af-4afe-9362-\
c65960054e16"],

Cell[TextData[{
 "k means clustering (KMC) is the ",
 StyleBox["simplest and perhaps the most commonly used clustering method",
  FontWeight->"Bold"],
 ".\n\nIt is a partitional method.\n \nUnderstanding the KMC clustering \
algorithm sets the basis to understand other clustering algorithms that were \
proposed after KMC.\n\nSome ideas behind KMC are reminiscent of those for the \
kNN method for classification. However, ",
 StyleBox["KMC is unsupervised and KNN is supervised",
  FontWeight->"Bold"],
 "!\n\n",
 StyleBox["Central idea",
  FontWeight->"Bold"],
 " of KMC: Given a number of clusters, ",
 StyleBox["K",
  FontSlant->"Italic"],
 ", distribute a set of ",
 StyleBox["N",
  FontSlant->"Italic"],
 " points in clusters in such a way that \n\t(i) differences ",
 StyleBox["within",
  FontWeight->"Bold"],
 " each cluster are ",
 StyleBox["minimised",
  FontWeight->"Bold"],
 " and\n\t(ii) differences ",
 StyleBox["between",
  FontWeight->"Bold"],
 " the clusters are ",
 StyleBox["maximised",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.779106536578033*^9, 3.77910665625389*^9}, {
  3.779106799753846*^9, 3.779107038142418*^9}, {3.779107071134861*^9, 
  3.7791072518990517`*^9}, {3.779107343012429*^9, 3.77910734939771*^9}, {
  3.779172041393341*^9, 3.779172042402025*^9}, {3.781590609508745*^9, 
  3.7815906371330614`*^9}},ExpressionUUID->"eb333975-674f-4b96-bc2b-\
904c98c5c7db"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The algorithm", "Subsection",
 CellChangeTimes->{{3.779107783346662*^9, 
  3.779107786155587*^9}},ExpressionUUID->"0ac0486e-4e32-474e-ba4e-\
ac89e1086d50"],

Cell[CellGroupData[{

Cell["Data", "Subsubsection",
 CellChangeTimes->{{3.779171319857195*^9, 
  3.779171322784789*^9}},ExpressionUUID->"cbef25cc-29a4-4436-9b4b-\
eb90558744ae"],

Cell[TextData[{
 "The algorithm is applied to a dataset consisting of ",
 StyleBox["N",
  FontSlant->"Italic"],
 " data points consisting of ",
 StyleBox["M",
  FontSlant->"Italic"],
 " features. \n\nEach point represents a feature vector with ",
 StyleBox["M",
  FontSlant->"Italic"],
 " components:\n\nPoint 1: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Plain"], 
     RowBox[{"(", "1", ")"}]], "=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["x", "1", 
       RowBox[{"(", "1", ")"}]], ",", 
      SubsuperscriptBox["x", "2", 
       RowBox[{"(", "1", ")"}]], ",", "...", ",", 
      SubsuperscriptBox["x", "M", 
       RowBox[{"(", "1", ")"}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "9fbc1894-212e-4697-b050-da5e4f9689ea"],
 "\nPoint 2: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Plain"], 
     RowBox[{"(", "2", ")"}]], "=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["x", "1", 
       RowBox[{"(", "2", ")"}]], ",", 
      SubsuperscriptBox["x", "2", 
       RowBox[{"(", "2", ")"}]], ",", "...", ",", 
      SubsuperscriptBox["x", "M", 
       RowBox[{"(", "2", ")"}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "c31b9f26-4e04-4472-bc2d-0696e6c442df"],
 "\n...\nPoint N: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Plain"], 
     RowBox[{"(", "N", ")"}]], "=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["x", "1", 
       RowBox[{"(", "N", ")"}]], ",", 
      SubsuperscriptBox["x", "2", 
       RowBox[{"(", "N", ")"}]], ",", "...", ",", 
      SubsuperscriptBox["x", "M", 
       RowBox[{"(", "N", ")"}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "080aa2ea-be8d-48da-a3c7-bffe802836be"],
 "\n\n",
 StyleBox["Example:",
  FontWeight->"Bold"],
 " To illustrate the algorithm, we will consider a synthetic dataset with \n\n\
",
 StyleBox["N",
  FontSlant->"Italic"],
 " = 200 points\n",
 StyleBox["M",
  FontSlant->"Italic"],
 " = 2 features"
}], "Text",
 CellChangeTimes->{
  3.778512247218769*^9, {3.779107564519472*^9, 3.779107571072049*^9}, {
   3.779107789555636*^9, 3.7791078511729183`*^9}, {3.779115494612913*^9, 
   3.77911549551462*^9}, {3.779169975650296*^9, 3.779170102099209*^9}, {
   3.7791701430684767`*^9, 3.779170353618534*^9}, {3.7791703923432093`*^9, 
   3.779170399252287*^9}, {3.7791704728090267`*^9, 3.779170477523898*^9}, {
   3.7791708052499323`*^9, 3.779170806081932*^9}, {3.779170849008833*^9, 
   3.779170919473249*^9}, {3.779170967769052*^9, 3.779170986754238*^9}, {
   3.779171046482246*^9, 3.779171053858367*^9}, {3.77917121907373*^9, 
   3.77917122326612*^9}},ExpressionUUID->"ec58d304-164e-4888-931a-\
b86b62012b18"],

