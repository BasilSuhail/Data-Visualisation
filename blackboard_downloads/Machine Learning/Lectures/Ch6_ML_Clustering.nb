Cell[TextData[{
 "For ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "=", "0.12"}], TraditionalForm]],ExpressionUUID->
  "ad9fb334-4f46-49b9-80f2-2c692945495f"],
 " it looks like one gets three reasonable clusters which do not depend much \
on ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "min"], TraditionalForm]],ExpressionUUID->
  "810d676c-3eb1-4961-979f-0564db05f789"],
 " (but, of course, if ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "min"], TraditionalForm]],ExpressionUUID->
  "e19727d3-c1aa-4c0d-897f-99da9ad63cc4"],
 " is large enough (e.g. ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "min"], TraditionalForm]],ExpressionUUID->
  "737b56d7-7dda-4498-888b-f662e373f88e"],
 " larger than 20) the number of clusters is larger than three. "
}], "Text",
 CellChangeTimes->{{3.814904704925125*^9, 3.8149047159510517`*^9}, {
  3.814904761943449*^9, 3.8149048456085606`*^9}, {3.814942105694586*^9, 
