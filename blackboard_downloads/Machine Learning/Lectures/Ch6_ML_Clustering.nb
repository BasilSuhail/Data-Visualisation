Cell[TextData[{
 "The plot exhibits a ",
 StyleBox["shoulder for ",
  FontWeight->"Bold"],
 StyleBox["K",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" = 5",
  FontWeight->"Bold"],
 ": The error decreases faster for ",
 StyleBox["K",
  FontSlant->"Italic"],
 " < 5 than for ",
 StyleBox["K",
  FontSlant->"Italic"],
 " > 5. \n\nThis can be seen in the plot of the differences between \
consecutive errors:"
}], "Text",
 CellChangeTimes->{{3.779184439026157*^9, 3.779184452961652*^9}, {
  3.7791845160245247`*^9, 3.779184532322115*^9}, {3.779188136555687*^9, 
