Cell[BoxData[
 FractionBox[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"x", "-", 
           SubscriptBox["\[Mu]", "1"]}], ")"}], "2"], "\[Sigma]"]}], "-", 
      FractionBox[
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"y", "-", 
          SubscriptBox["\[Mu]", "2"]}], ")"}], "2"], "\[Sigma]"]}], ")"}]}]], 
  
  RowBox[{"2", " ", "\[Pi]", " ", 
   SqrtBox[
    SuperscriptBox["\[Sigma]", "2"]]}]]], "Output",
