Cell[TextData[{
 "The number of clusters predicted by DBSCAN normally depends on the radius \
",
 StyleBox["r",
  FontSlant->"Italic"],
 " of the neighbourhood and number of neighbors required in the \
neighbourhood, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["N", "min"], ","}], TraditionalForm]],ExpressionUUID->
  "bd4dd992-c08c-4c58-b8b5-84544d39e9a3"],
 " to decide if a point belongs to a cluster or not. We can explore the \
number of clusters predicted by the DBSCAN method as a function of            \
                             ",
 StyleBox["r",
  FontSlant->"Italic"],
 " = ",
 StyleBox["NeighborhoodRadius", "CodeText"],
 ". Three clusters (expected by humans) are found for a range of values of ",
 StyleBox["r",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.7818773077347307`*^9, 3.7818773995870075`*^9}, {
  3.7818774439083796`*^9, 3.78187764380756*^9}, {3.781877690415936*^9, 
  3.7818777622838383`*^9}, {3.814904119520162*^9, 
  3.8149041281661425`*^9}},ExpressionUUID->"0036235f-f0d6-4169-a053-\
7853728f0b2d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"NclusterVsRadius", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"clusteringDBSCAN", "=", 
         RowBox[{"FindClusters", "[", 
          RowBox[{"data", ",", 
           RowBox[{"Method", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"\"\<DBSCAN\>\"", ",", 
              RowBox[{"\"\<NeighborhoodRadius\>\"", "\[Rule]", "r"}]}], 
             "}"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Length", "[", "clusteringDBSCAN", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0.05", ",", "1", ",", "0.02"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.781863208537897*^9, 3.7818632256474934`*^9}, {
   3.7818633961190434`*^9, 3.781863449020135*^9}, {3.781863502571293*^9, 
