Cell[TextData[{
 "Consider a synthetic dataset consisting of 5 clusters of ",
 StyleBox["M",
  FontSlant->"Italic"],
 " = 2 features:"
}], "Text",
 CellChangeTimes->{{3.779181888673571*^9, 3.779181898370181*^9}, {
  3.779182091620975*^9, 3.7791821166107473`*^9}, {3.779182482842889*^9, 
