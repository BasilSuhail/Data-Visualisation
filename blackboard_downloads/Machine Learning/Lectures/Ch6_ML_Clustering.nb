Cell[CellGroupData[{

Cell["A case where cosine distance is appropriate", "Subsection",
 CellChangeTimes->{{3.7811953926963897`*^9, 3.781195411377927*^9}, {
  3.781195442273569*^9, 
  3.7811954527573724`*^9}},ExpressionUUID->"ac27b4dd-d456-44cf-bf57-\
03fda8842a0a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p1", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "10"}], "}"}], "]"}], " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"a", "=", 
          RowBox[{"RandomReal", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\[Pi]", "/", "6"}], ",", 
             RowBox[{"\[Pi]", "/", "4"}]}], "}"}], "]"}]}], "]"}], ",", 
        RowBox[{"Sin", "[", "a", "]"}]}], "}"}]}], ",", 
     RowBox[{"{", "200", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"p2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "10"}], "}"}], "]"}], " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"a", "=", 
          RowBox[{"RandomReal", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"11", " ", "\[Pi]"}], ")"}], "/", "24"}], ",", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"13", " ", "\[Pi]"}], ")"}], "/", "24"}]}], "}"}], 
           "]"}]}], "]"}], ",", 
        RowBox[{"Sin", "[", "a", "]"}]}], "}"}]}], ",", 
     RowBox[{"{", "200", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"p3", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "10"}], "}"}], "]"}], " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"a", "=", 
          RowBox[{"RandomReal", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"17", " ", "\[Pi]"}], ")"}], "/", "24"}], ",", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"19", " ", "\[Pi]"}], ")"}], "/", "24"}]}], "}"}], 
           "]"}]}], "]"}], ",", 
        RowBox[{"Sin", "[", "a", "]"}]}], "}"}]}], ",", 
     RowBox[{"{", "200", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"p1", ",", "p2", ",", "p3"}], "]"}]}], ";"}], "\n", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"data", ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"PointSize", "[", "Medium", "]"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.77781747175725*^9, 3.777817471758975*^9}},
 CellLabel->
