Cell[CellGroupData[{

Cell["Step 4 - Calculate new centres", "Subsubsection",
 CellChangeTimes->{{3.779114541369982*^9, 3.779114554178475*^9}, {
  3.7791145892542253`*^9, 3.779114610441265*^9}, {3.7791775744703283`*^9, 
  3.779177576536655*^9}},ExpressionUUID->"44adcb21-9760-4af2-b90c-\
dfa5a7ce3067"],

Cell["\<\
New centres are given by the centroids of each of the clusters found in step \
3. 

The centroid of the k-th centre is defined as the arithmetic mean of all the \
points in the cluster.\
\>", "Text",
 CellChangeTimes->{{3.7791145642750316`*^9, 3.77911466669057*^9}, {
  3.779115423367674*^9, 3.7791154414390316`*^9}, {3.77917757330264*^9, 
  3.779177626278257*^9}, {3.779177685286388*^9, 3.779177933735498*^9}, {
  3.7791779706147203`*^9, 
  3.779177972053959*^9}},ExpressionUUID->"b5c862ff-362f-4fc8-86f6-\
bca9acf99fd3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"centreNew1", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{"tempCluster1", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"Mean", "[", 
      RowBox[{"tempCluster1", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"centreNew2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mean", "[", 
      RowBox[{"tempCluster2", "[", 
