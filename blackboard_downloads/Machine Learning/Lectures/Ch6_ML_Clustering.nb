Cell[TextData[{
 "Let us compare KMC and DBSCAN\n\nClustering the data in ",
 StyleBox["2 clusters by using the KMC method",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.814892596833333*^9, 3.814892597169401*^9}, {
  3.8149037465362363`*^9, 3.8149037531930923`*^9}, {3.8149039186543303`*^9, 
