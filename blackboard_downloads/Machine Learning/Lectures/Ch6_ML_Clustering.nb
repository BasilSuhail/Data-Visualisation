Cell["However, it does not work so well for our original dataset:", "Text",
 CellChangeTimes->{{3.781955214501091*^9, 
  3.7819552271640425`*^9}},ExpressionUUID->"eeab8635-edb8-4b99-8ee7-\
5f56af255619"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gaussian", "[", 
    RowBox[{"\[Mu]_", ",", "\[Sigma]_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"MultinormalDistribution", "[", 
      RowBox[{"\[Mu]", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Sigma]", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "\[Sigma]"}], "}"}]}], "}"}]}], "]"}], ",", "n"}],
     "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cluster1", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", "0.1", ",", "50"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cluster2", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "a"}], "}"}], ",", "0.1", ",", "50"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cluster3", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", 
       RowBox[{"-", "a"}]}], "}"}], ",", "0.1", ",", "50"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cluster4", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "a"}]}], "}"}], ",", "0.1", ",", "50"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"cluster5", "=", 
    RowBox[{"gaussian", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "a"}], ",", "a"}], "}"}], ",", "0.1", ",", "50"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Join", "[", 
    RowBox[{
    "cluster1", ",", "cluster2", ",", "cluster3", ",", "cluster4", ",", 
     "cluster5"}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[200]:=",ExpressionUUID->"38a0f3dd-2218-4d67-a22a-60654ae33f0d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"K", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"clusters", "=", 
   RowBox[{"FindClusters", "[", 
    RowBox[{"data", ",", "K", ",", 
     RowBox[{"Method", "\[Rule]", "\"\<KMeans\>\""}], ",", 
     RowBox[{"DistanceFunction", "\[Rule]", "CosineDistance"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"clusters", ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"PointSize", "[", "0.01", "]"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.7819551109028797`*^9, 3.7819551271108866`*^9}, {
  3.8147102839866734`*^9, 3.8147103286793313`*^9}, {3.8147104774702377`*^9, 
  3.8147104775450315`*^9}},
 CellLabel->
  "In[211]:=",ExpressionUUID->"4a7bc60f-9a99-45b5-882e-9199f64384e9"],

