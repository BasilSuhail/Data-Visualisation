Cell["By default, DBSCAN predicts two clusters.", "Text",
 CellChangeTimes->{{3.814904072713748*^9, 
  3.814904101612745*^9}},ExpressionUUID->"52c75039-1c3f-42cf-b722-\
20ab95e17864"],

Cell[TextData[{
 "Tuning the ",
 StyleBox["neighborhood radius",
  FontWeight->"Bold"],
 " leads to a more meaningful clustering (from the human perspective...). "
}], "Text",
 CellChangeTimes->{{3.781796045249631*^9, 3.781796092490096*^9}, {
  3.781799766596816*^9, 
  3.781799813356223*^9}},ExpressionUUID->"84fc14f9-9549-4ce2-9bcc-\
3f31639863f4"],

