Cell[TextData[{
 "Specifying that we want to cluster the data in ",
 StyleBox["3 groups",
  FontWeight->"Bold"],
 " and Euclidean distance function does not work as we expect either:"
}], "Text",
 CellChangeTimes->{{3.781196078657562*^9, 
  3.781196124961045*^9}},ExpressionUUID->"06d06346-2625-4803-9e9c-\
2468fe0ad7a7"],

