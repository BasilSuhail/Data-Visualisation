Cell[CellGroupData[{

Cell["Distance functions", "Section",
 CellChangeTimes->{{3.781166159639529*^9, 3.781166172307599*^9}, 
   3.8146949199528074`*^9},ExpressionUUID->"060c270d-7725-4bd7-aed5-\
aa3db4ea66da"],

Cell[TextData[{
 "One can use several measures for the distance between two vectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["u", "1"], ",", 
      SubscriptBox["u", "2"], ",", 
      RowBox[{"...", 
       SubscriptBox["u", "M"]}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6b4fa0b4-7948-4ac2-8b8c-fc28d6522e76"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["v", "1"], ",", 
      SubscriptBox["v", "2"], ",", 
      RowBox[{"...", 
       SubscriptBox["v", "M"]}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "5dccca53-4c0a-4dca-8e50-b30ffcc3cb52"],
 "\n\nSome of the most widely used distances follow:"
}], "Text",
 CellChangeTimes->{{3.7811683470661483`*^9, 3.781168435626746*^9}, {
  3.7811684775967274`*^9, 3.7811685637693963`*^9}, {3.781176968152645*^9, 
  3.7811769995711823`*^9}, {3.781177387788127*^9, 3.781177404466007*^9}, {
  3.781195217094489*^9, 
  3.7811952692155547`*^9}},ExpressionUUID->"bff065af-851d-4769-936e-\
41ce6225f679"],

Cell[CellGroupData[{

Cell["Euclidean norm", "Subsection",
 CellChangeTimes->{{3.7811953205212092`*^9, 
  3.781195324513607*^9}},ExpressionUUID->"2673d96c-3943-40d2-a92c-\
dbe1d42a3744"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{"EuclideanDistance", "[", 
    RowBox[{"u", ",", "v"}], "]"}], "=", 
   SqrtBox[
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], "M"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["u", "i"], "-", 
        SubscriptBox["v", "i"]}], ")"}], "2"]}]]}]],
  CellChangeTimes->{{3.7811907892728615`*^9, 3.78119080758086*^9}},
  ExpressionUUID->"dc9b9f69-4db8-4784-82a3-0d43cbe50628"],
 " "
}], "Text",
 CellChangeTimes->{{3.7811934280833535`*^9, 3.7811934477603235`*^9}, {
  3.781193481974513*^9, 3.7811935299472227`*^9}, {3.781193682721316*^9, 
  3.7811936845908318`*^9}},ExpressionUUID->"df4beae0-7332-426d-926c-\
881404291410"],

Cell["\<\
It is the most widely used distance. It is used by default when dealing with \
numerical data.\
\>", "Text",
 CellChangeTimes->{
  3.7811936944619465`*^9},ExpressionUUID->"d9eb1b7a-051e-4a6b-acaf-\
87ed5f4e4f5b"],

Cell["\<\
Example: The Euclidean distance between the points (1,2) and (3,3) is\
\>", "Text",
 CellChangeTimes->{{3.7811935963784914`*^9, 3.781193639967444*^9}, {
  3.7811936970038075`*^9, 
  3.781193703334238*^9}},ExpressionUUID->"41005519-fec0-47d2-8de9-\
eb1b58c2123e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EuclideanDistance", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2"}], "}"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"3", ",", "3"}], "}"}], "}"}]}], "]"}]], "Input",
