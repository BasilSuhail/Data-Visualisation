Cell[CellGroupData[{

Cell["A function for the scree plot", "Subsubsection",
 CellChangeTimes->{{3.779183833042273*^9, 
  3.779183853602685*^9}},ExpressionUUID->"2d1d0acd-d97c-413c-bd06-\
69e84673449d"],

Cell[TextData[{
 "We can put together the instructions used above to define a function to \
calculate the error for any value of ",
 StyleBox["K",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.779184353330056*^9, 
  3.779184395730592*^9}},ExpressionUUID->"0fd0bb9f-062f-4889-80ae-\
a165d3c8db25"],

Cell[BoxData[
 RowBox[{
  RowBox[{"errorKMC", "[", 
   RowBox[{"data_", ",", "k_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"data0", "=", "data"}], ",", 
      RowBox[{"nc", "=", "k"}], ",", "clusters", ",", "centre"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"clusters", "=", 
      RowBox[{"FindClusters", "[", 
       RowBox[{"data0", ",", "nc", ",", 
        RowBox[{"Method", "->", "\"\<KMeans\>\""}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"centre", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Mean", "[", 
         RowBox[{"clusters", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "nc"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Total", "[", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"EuclideanDistance", "[", 
              RowBox[{
               RowBox[{"clusters", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
               RowBox[{"centre", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ")"}], "2"], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "1", ",", 
             RowBox[{"Length", "[", 
              RowBox[{"clusters", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "centre", "]"}]}], "}"}]}], "]"}], "]"}], 
      "]"}]}]}], "]"}]}]], "Input",
