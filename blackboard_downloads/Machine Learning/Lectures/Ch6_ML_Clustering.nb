Cell[CellGroupData[{

Cell["***Iterate 2-4 until the centres do not change!!", "Subsubsection",
 CellChangeTimes->{{3.779174565338179*^9, 3.77917456645748*^9}, {
  3.814694424674435*^9, 3.8146944530926127`*^9}, {3.814705280940222*^9, 
  3.814705281286631*^9}},ExpressionUUID->"92a325db-b76c-40af-935a-\
abf5aa027f34"],

Cell["\<\
Use the new centres obtained in 4 and repeat steps 2 to 4 until the centres \
do not change anymore. The clusters corresponding to the stable centres are \
the final result of the algorithm.\
\>", "Text",
 CellChangeTimes->{{3.779174571401292*^9, 3.7791745803618517`*^9}, {
  3.779174698505913*^9, 
  3.779174787818198*^9}},ExpressionUUID->"3829bfe5-b87f-4e04-ad27-\
98edd9a2b064"],

Cell[TextData[{
 StyleBox["Example: ",
  FontWeight->"Bold"],
 "Set c to the new centres and execute steps 2 to 4"
}], "Text",
 CellChangeTimes->{{3.779176198856649*^9, 
  3.779176218600775*^9}},ExpressionUUID->"27902ab3-5c7f-465d-95ec-\
daa3d233abee"],

Cell[BoxData[
 RowBox[{
  RowBox[{"c", "=", 
   RowBox[{"{", 
    RowBox[{"centreNew1", ",", "centreNew2"}], "}"}]}], ";"}]], "Input",
