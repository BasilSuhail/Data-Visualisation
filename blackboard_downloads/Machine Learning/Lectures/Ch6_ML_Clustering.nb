Cell[CellGroupData[{

Cell["DBSCAN (Density-based scanning of the feature space)", "Subsection",
 CellChangeTimes->{{3.781582022590665*^9, 3.781582030452395*^9}, {
  3.78179463132576*^9, 
  3.781794651014702*^9}},ExpressionUUID->"49faafdf-2fbf-415b-9524-\
327ae51bd02d"],

Cell["\<\
DBSCAN is perhaps the most popular density-based clustering method.

The main idea of the algorithm is that a point in the dataset belongs to a \
cluster if it is close to many points from that cluster.\
\>", "Text",
 CellChangeTimes->{{3.7817996634489517`*^9, 3.7817997107741404`*^9}, {
  3.814891985402922*^9, 3.8148919917353587`*^9}, {3.8148929700197554`*^9, 
  3.8148929814517193`*^9}, {3.8148930200539503`*^9, 
  3.814893044408761*^9}},ExpressionUUID->"0b55169e-1040-4136-a7c4-\
469098776b3b"],

Cell["DBSCAN uses two parameters:", "Text",
 CellChangeTimes->{{3.8148920614836855`*^9, 
  3.8148920754344378`*^9}},ExpressionUUID->"4b118bb0-975e-45e8-9ccf-\
8a4713ace724"],

Cell[TextData[{
 StyleBox["r",
  FontSlant->"Italic"],
 "  (",
 StyleBox["NeighborhoodRadius ", "CodeText"],
 StyleBox["in Mathematica", "Text"],
 StyleBox[")", "Text"],
 StyleBox[": Radius of a neighbourhood with respect to any data point.", 
  "Text"]
}], "Item",
 CellChangeTimes->{{3.814892165901039*^9, 3.814892191334753*^9}, {
  3.8148922213479433`*^9, 3.814892245566078*^9}, {3.8148923021219435`*^9, 
  3.8148923026196117`*^9}},ExpressionUUID->"365f94e4-f14a-4e06-988b-\
0d9d40620585"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "min"], TraditionalForm]],ExpressionUUID->
  "bd37e4f2-8ead-4437-a136-0cea19c94056"],
 StyleBox[" (", "Text"],
 StyleBox["NeighborsNumber", "CodeText"],
 StyleBox[" in Mathematica): Minimum number of points in the neighbourhood of \
radius ", "Text"],
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "b98a7cbc-49c2-4b55-bd6b-73cccdd146ed"],
 " for a point to be considered to belong to a cluster."
}], "Item",
 CellChangeTimes->{{3.814892165901039*^9, 3.814892191334753*^9}, {
  3.8148922213479433`*^9, 3.8148922958856773`*^9}, {3.8148923545044603`*^9, 
  3.8148923959181285`*^9}, {3.81489255480649*^9, 3.8148925668758755`*^9}, {
  3.8149406638728952`*^9, 
  3.8149406800457106`*^9}},ExpressionUUID->"d35c6112-984e-4023-be99-\
d5ef648cc6d1"],

Cell["\<\
Brief description of the algorithm (not essential for the course):\
\>", "Text",
 CellChangeTimes->{{3.814893220581668*^9, 
  3.8148932394302955`*^9}},ExpressionUUID->"297780b7-2b9f-48b4-a68f-\
90dd9838d15c"],

Cell[TextData[{
 "Starts from an arbitrary point ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "9c4d9441-66b3-4442-a0e5-ad64dfbd94f6"],
 " in the dataset that has not been visited before. "
}], "ItemNumbered",
 CellChangeTimes->{{3.814892714406004*^9, 3.814892839637653*^9}, {
  3.8148929196724896`*^9, 3.8148929644462476`*^9}, {3.8148930499784327`*^9, 
  3.814893056426425*^9}, {3.814893149776747*^9, 3.8148932155979977`*^9}, {
  3.8148932569214344`*^9, 
  3.8148932799629107`*^9}},ExpressionUUID->"595bbbcf-c1f1-414a-8a79-\
84ce8f87ea33"],

Cell[CellGroupData[{

Cell[TextData[{
 "Check the number of points ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "83b17da6-f724-4cd9-aaa6-869426116076"],
 " in the neighbourhood of radius ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "4ba553cf-2dac-4067-bd3f-c24c2c575756"],
 " of point ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "c62dde29-301c-4ac4-bead-c5b6b96ec1bd"],
 "."
}], "ItemNumbered",
 CellChangeTimes->{{3.814892714406004*^9, 3.814892839637653*^9}, {
   3.8148929196724896`*^9, 3.8148929644462476`*^9}, {3.8148930499784327`*^9, 
   3.814893056426425*^9}, {3.814893149776747*^9, 3.8148932155979977`*^9}, 
   3.8148932569214344`*^9, {3.8148942453337617`*^9, 3.8148942827252436`*^9}, {
   3.814903207429156*^9, 
   3.8149032353639054`*^9}},ExpressionUUID->"28047fd6-ec6d-4779-b93d-\
220108a8912b"],

Cell[TextData[{
 "If the neighbourhood contains a number of points ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "\[GreaterEqual]", 
    SubscriptBox["N", "min"]}], TraditionalForm]],ExpressionUUID->
  "5bfaff0a-9bc5-47b3-9c70-14b14c0afd08"],
 ", a cluster starts to grow. All the points in the neighbourhood of ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "c48c7eb3-ed58-46de-ad45-4437d14fa86c"],
 " are assigned to the growing cluster. If the newly assigned points have ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "\[GreaterEqual]", 
    SubscriptBox["N", "min"]}], TraditionalForm]],ExpressionUUID->
  "48ab2572-ed77-40ac-95ac-ded7a5f5b199"],
 " points in their ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "053f0760-f8c1-41b0-a746-a481f72552aa"],
 "-neighbourhood, they are also included in the growing cluster. Growth stops \
when all newly included points have ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "<", 
    SubscriptBox["N", "min"]}], TraditionalForm]],ExpressionUUID->
  "0825e8c7-c1db-48e2-87ba-a167188325cf"],
 " in their ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "56e93ad3-003a-4115-a132-546991ec0757"],
 "-neighbourhood."
}], "SubitemNumbered",
 CellChangeTimes->{{3.814892714406004*^9, 3.814892839637653*^9}, {
   3.8148929196724896`*^9, 3.8148929644462476`*^9}, {3.8148930499784327`*^9, 
   3.814893056426425*^9}, {3.814893149776747*^9, 3.8148932155979977`*^9}, 
   3.8148932569214344`*^9, {3.8148942453337617`*^9, 3.8148942827252436`*^9}, {
   3.814903207429156*^9, 
   3.814903483996479*^9}},ExpressionUUID->"05ca5858-2f9c-460b-ae3b-\
e2b39ca05cfc"],

Cell[TextData[{
 "If the ",
 StyleBox["r",
  FontSlant->"Italic"],
 "-neighbourhood of ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "5c87572a-bd0f-4523-b878-279f4b62b185"],
 " contains ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "<", 
    SubscriptBox["N", "min"]}], TraditionalForm]],ExpressionUUID->
  "17f03818-78d4-4429-af64-e42e92718840"],
 " points, the point ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "a28adcb9-7c00-4746-a501-e036a8c03ade"],
 " is classified as noise for the moment (it might become part of a cluster \
at later stages of the algorithm)."
}], "SubitemNumbered",
 CellChangeTimes->{{3.814892714406004*^9, 3.814892839637653*^9}, {
   3.8148929196724896`*^9, 3.8148929644462476`*^9}, {3.8148930499784327`*^9, 
   3.814893056426425*^9}, {3.814893149776747*^9, 3.8148932155979977`*^9}, 
   3.8148932569214344`*^9, {3.8148942453337617`*^9, 3.8148942827252436`*^9}, {
   3.814903207429156*^9, 
   3.814903575250347*^9}},ExpressionUUID->"3a034b37-4ce8-433c-abce-\
e7f1e768e07a"]
}, Open  ]],

Cell["\<\
Return to step 1 while there are points not visited by the algorithm.\
\>", "ItemNumbered",
 CellChangeTimes->{{3.814892714406004*^9, 3.814892839637653*^9}, {
   3.8148929196724896`*^9, 3.8148929644462476`*^9}, {3.8148930499784327`*^9, 
   3.814893056426425*^9}, {3.814893149776747*^9, 3.8148932155979977`*^9}, 
   3.8148932569214344`*^9, {3.8148942453337617`*^9, 3.814894299103506*^9}, {
