Cell[TextData[{
 "But we will pretend that ",
 StyleBox["we don\[CloseCurlyQuote]t know that the data consists of two \
clusters",
  FontWeight->"Bold"],
 ".\n\n",
 StyleBox["Aim:",
  FontWeight->"Bold"],
 " Find the clusters!"
}], "Text",
 CellChangeTimes->{{3.779171153440899*^9, 
  3.779171190705111*^9}},ExpressionUUID->"313656f0-8c90-4b55-92b6-\
82271233a77c"],

Cell[TextData[{
 "The KMC method basically consists in four steps that are iterated until it \
converges to a set of ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]],ExpressionUUID->
  "ec4f6f1e-672e-467d-bea3-fa3c1489669c"],
 " clusters (the number of clusters is set by us) ."
}], "Text",
 CellChangeTimes->{{3.814694173013173*^9, 3.8146942750536833`*^9}, {
  3.8147034374401183`*^9, 
  3.8147034495918703`*^9}},ExpressionUUID->"470070a3-9e6d-4030-8be0-\
1e3237e90f22"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Step 1 - Pick ",
 StyleBox["K",
  FontSlant->"Italic"],
 " centres "
}], "Subsubsection",
 CellChangeTimes->{{3.779108006655357*^9, 3.779108007879334*^9}, {
  3.7791081690652943`*^9, 3.7791081773547163`*^9}, {3.779177541126417*^9, 
  3.779177548022373*^9}},ExpressionUUID->"3d6a124e-b96a-406e-8ec5-\
8e893802c352"],

Cell[TextData[{
 "We first decide on the number of clusters ",
 StyleBox["K",
  FontSlant->"Italic"],
 ". \n\nWe then pick ",
 StyleBox["K",
  FontSlant->"Italic"],
 " centres, one  for each cluster. The idea is that each centre will \
represent a cluster. \n\nThe centres are given by a set of ",
 StyleBox["M",
  FontSlant->"Italic"],
 " features, as the data vectors:\n\nCentre 1: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["c",
      FontWeight->"Bold",
      FontSlant->"Plain"], 
     RowBox[{"(", "1", ")"}]], "=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["c", "1", 
       RowBox[{"(", "1", ")"}]], ",", 
      SubsuperscriptBox["c", "2", 
       RowBox[{"(", "1", ")"}]], ",", "...", ",", 
      SubsuperscriptBox["c", "M", 
       RowBox[{"(", "1", ")"}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "113d4526-087f-4dc6-8b46-08f65f6af10d"],
 "\nCentre 2: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["c",
      FontWeight->"Bold",
      FontSlant->"Plain"], 
     RowBox[{"(", "2", ")"}]], "=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["c", "1", 
       RowBox[{"(", "2", ")"}]], ",", 
      SubsuperscriptBox["c", "2", 
       RowBox[{"(", "2", ")"}]], ",", "...", ",", 
      SubsuperscriptBox["c", "M", 
       RowBox[{"(", "2", ")"}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e2873f2c-0fd7-4999-bbf4-e9e424b2f1c0"],
 "\n...\nCentre K: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["c",
      FontWeight->"Bold",
      FontSlant->"Plain"], 
     RowBox[{"(", "K", ")"}]], "=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["c", "1", 
       RowBox[{"(", "K", ")"}]], ",", 
      SubsuperscriptBox["c", "2", 
       RowBox[{"(", "K", ")"}]], ",", "...", ",", 
      SubsuperscriptBox["c", "M", 
       RowBox[{"(", "K", ")"}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "aabbcd00-677a-471d-9f56-d9e8a8d241c6"],
 "\n\nThe centres can be drawn at random or taken as ",
 StyleBox["K",
  FontSlant->"Italic"],
 " random points from the dataset ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox[
      StyleBox["x",
       FontWeight->"Bold",
       FontSlant->"Plain"], 
      RowBox[{"(", "1", ")"}]], ","}]}], TraditionalForm]],ExpressionUUID->
  "2daaea67-fe4e-4442-9681-eb6ca685b2ff"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["x",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    RowBox[{"(", "2", ")"}]], TraditionalForm]],ExpressionUUID->
  "475336f6-4c83-4bdd-8c23-77f813607388"],
 ",...,",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["x",
     FontWeight->"Bold",
     FontSlant->"Plain"], 
    RowBox[{"(", "N", ")"}]], TraditionalForm]],ExpressionUUID->
  "5269a93f-2b36-44cd-aec4-ab2eeb79b7a5"],
 "}\n\n",
 StyleBox["Example:",
  FontWeight->"Bold"],
 " Take ",
 StyleBox["K ",
  FontSlant->"Italic"],
 "= 2 of the points in the dataset at random:"
}], "Text",
 CellChangeTimes->{{3.779108181794579*^9, 3.779108264188591*^9}, {
   3.7791083736459923`*^9, 3.77910838585505*^9}, {3.779114189268655*^9, 
   3.779114343850792*^9}, 3.779115484218649*^9, {3.779171571905553*^9, 
   3.779171572481484*^9}, {3.7791716962576847`*^9, 3.779171729185239*^9}, {
   3.7791731057721148`*^9, 3.779173424476095*^9}, {3.7791737453887863`*^9, 
   3.779173746669883*^9}},ExpressionUUID->"b3df0a8f-c592-484c-9084-\
382e9a21da2c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"c", "=", 
  RowBox[{"RandomSample", "[", 
   RowBox[{"data", ",", "2"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.779108301088901*^9, 3.779108314183424*^9}, {
  3.779108350877643*^9, 3.779108359093954*^9}, {3.7791095564908333`*^9, 
  3.779109558184122*^9}},
 CellLabel->"In[77]:=",ExpressionUUID->"63e0af6b-a1d2-484e-b469-e87e1c7c45bf"],

