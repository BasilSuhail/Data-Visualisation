Cell[CellGroupData[{

Cell["Cosine distance", "Subsection",
 CellChangeTimes->{
  3.7811953732687454`*^9},ExpressionUUID->"2692edd3-0d93-4f00-b266-\
631df15bd0d7"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"CosineDistance", "[", 
     RowBox[{"u", ",", "v"}], "]"}], "=", 
    RowBox[{
     RowBox[{"1", "-", 
      RowBox[{"Cos", "[", 
       OverscriptBox["uv", "^"], "]"}]}], "=", 
     RowBox[{"1", "-", 
      FractionBox[
       RowBox[{"u", ".", "v"}], 
       RowBox[{
        RowBox[{"\[LeftBracketingBar]", "u", "\[RightBracketingBar]"}], 
        RowBox[{
        "\[LeftBracketingBar]", "v", "\[RightBracketingBar]"}]}]]}]}]}], 
   TraditionalForm]],ExpressionUUID->"a58eb957-0ff8-42ae-885d-621c60383e9e"],
 "\n\nHere, ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["uv", "^"], TraditionalForm]],ExpressionUUID->
  "8c5f5773-671d-4d4d-bad5-993a17023a58"],
 " is the angle between vector ",
 StyleBox["u",
  FontSlant->"Italic"],
 " and ",
 StyleBox["v\n\n",
  FontSlant->"Italic"],
 "The cosine distance is appropriate when two vectors are similar if they are \
pointing in the same direction even if they are of different lengths."
}], "Text",
 CellChangeTimes->{{3.781194290607066*^9, 3.7811943348524814`*^9}, {
  3.7811943733673415`*^9, 3.78119454209385*^9}, {3.7811945907136254`*^9, 
  3.7811945918707886`*^9}},ExpressionUUID->"cb103f25-d24d-4624-9584-\
1ed8a50b3073"],

Cell["Example:", "Text",
 CellChangeTimes->{{3.781194604568682*^9, 
  3.7811946064275804`*^9}},ExpressionUUID->"e3cb14f9-406c-4236-abf8-\
1331eba2a40d"],

