Cell[TextData[{
 "In order to systematically check the error for several values of ",
 StyleBox["k",
  FontSlant->"Italic"],
 ", it is useful to write a function:"
}], "Text",
 CellChangeTimes->{{3.778922827376329*^9, 
  3.778922871489072*^9}},ExpressionUUID->"0a8e5717-ddf4-48fb-8bbc-\
199d2af1d399"],

Cell[BoxData[
 RowBox[{
  RowBox[{"error", "[", 
   RowBox[{"k0_", ",", "class1in_", ",", "class2in_", ",", "testsetin_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", "=", "k0"}], ",", "ctemp", ",", 
      RowBox[{"class1", "=", "class1in"}], ",", 
      RowBox[{"class2", "=", "class2in"}], ",", "cm", ",", 
      RowBox[{"testset", "=", "testsetin"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ctemp", "=", 
      RowBox[{"Classify", "[", 
       RowBox[{
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<class 1\>\"", "->", "class1"}], ",", 
          RowBox[{"\"\<class 2\>\"", "->", "class2"}]}], "|>"}], ",", 
        RowBox[{"Method", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"\"\<NearestNeighbors\>\"", ",", 
           RowBox[{"\"\<NeighborsNumber\>\"", "\[Rule]", "k"}]}], "}"}]}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"cm", "=", 
      RowBox[{"ClassifierMeasurements", "[", 
       RowBox[{"ctemp", ",", "testset"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"cm", "[", "\"\<Error\>\"", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.778915045191306*^9, 3.7789150709190197`*^9}, {
  3.778915255021529*^9, 3.778915274762639*^9}, {3.778915360100256*^9, 
  3.778915370068089*^9}, {3.7789155980881357`*^9, 3.7789156530647917`*^9}, {
  3.7808878226187215`*^9, 3.780887835497208*^9}, {3.7808883577988625`*^9, 
  3.7808884376989627`*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"4f2476ad-0766-4d35-99f7-b126ff7051f6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"error", "[", 
  RowBox[{"1", ",", "class1", ",", "class2", ",", "testset"}], "]"}]], "Input",\

 CellChangeTimes->{{3.7808882969232593`*^9, 3.78088830041864*^9}, {
  3.7808884443267555`*^9, 3.7808884519086137`*^9}, {3.781376140630484*^9, 
  3.7813761407212467`*^9}},
