Cell[TextData[{
 "For k\[GreaterSlantEqual]50, all points are assigned to class 2. What is \
the reason?\n\nThis is because there are ",
 StyleBox["more points in the training data for class 2 than for class 1 ",
  FontWeight->"Bold"],
 "(remember, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["N", "1"], "=", "25"}], TraditionalForm]],ExpressionUUID->
  "f5b857b9-b410-480a-8c5e-4de45e9bbdc0"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["N", "2"], "=", "30"}], TraditionalForm]],ExpressionUUID->
  "47d2f9f5-1b71-4ce8-9f6b-f5492d896eab"],
 ").",
 StyleBox[" ",
  FontWeight->"Bold"],
 "As a result, when the number of nearest neighbours considered is large \
enough, class 2 will dominate simply because there are more points in the \
training data.\n\n",
 StyleBox["Conclusion:",
  FontWeight->"Bold"],
 " The exact value of ",
 StyleBox["k",
  FontSlant->"Italic"],
 " for which problems appear depends on the specific data used for training \
and testing. However, the KNN will normally be problematic for large ",
 StyleBox["k",
  FontSlant->"Italic"],
 " when using skewed training data."
}], "Text",
 CellChangeTimes->{{3.778928434745137*^9, 3.7789284407849073`*^9}, {
  3.778929105806892*^9, 3.7789292229350853`*^9}, {3.778929329601246*^9, 
  3.778929348353529*^9}, {3.778929381882559*^9, 3.778929385650378*^9}, {
  3.778929838098688*^9, 3.7789299687093687`*^9}, {3.778930075463093*^9, 
  3.7789303560599422`*^9}, {3.7812545808787804`*^9, 3.781254582024088*^9}, {
  3.81368236008807*^9, 
  3.8136823903092504`*^9}},ExpressionUUID->"49ecc6dc-3ae5-4429-a4e9-\
5eabc4dc49f2"]
}, Closed]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Data normalisation (or standardization)", "Section",
 CellChangeTimes->{{3.778413425283065*^9, 3.778413428330905*^9}, {
  3.779982559862965*^9, 3.779982575777708*^9}, {3.77998274653996*^9, 
  3.77998276752169*^9}},ExpressionUUID->"fa11e4ee-5a6d-4101-bba6-\
771c8afe1f40"],

Cell["\<\
Methods based on distances between features require some standardization of \
the data. Distances are highly dependent on how features are measured. In \
fact, if some features take values much larger than other, distances are \
dominated by the features taking the largest values. \
\>", "Text",
 CellChangeTimes->{{3.778411265979519*^9, 3.7784114698486156`*^9}, {
   3.778412001952931*^9, 3.7784120753468313`*^9}, {3.778412170211802*^9, 
   3.778412189940034*^9}, 3.7784123094704943`*^9, {3.7799826074148355`*^9, 
   3.779982608473811*^9}, {3.7812545886665134`*^9, 3.781254589278344*^9}, {
   3.7813491064268155`*^9, 3.7813491135150895`*^9}, {3.7813493176694455`*^9, 
   3.7813493438704414`*^9}, {3.781409157941945*^9, 
   3.781409168329213*^9}},ExpressionUUID->"b6439f40-f800-42ff-9ab3-\
81abba06f0bb"],

Cell["\<\
Imagine, for instance, that we characterise three people by {salary,number of \
children}\
\>", "Text",
 CellChangeTimes->{{3.781409173062792*^9, 
  3.7814092079679775`*^9}},ExpressionUUID->"70aacc15-d767-455d-a6b3-\
c4050cba1e57"],

Cell[BoxData[
 RowBox[{
  RowBox[{"people", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"12000", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"10000", ",", "8"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"12000", ",", "8"}], "}"}]}], "}"}]}], ";"}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"fe78754a-8151-4a20-ac26-b3f56be293a5"],

Cell["\<\
The Euclidean distance between pairs of individuals in this dataset is:\
\>", "Text",
 CellChangeTimes->{{3.78140922512387*^9, 
  3.7814092622374296`*^9}},ExpressionUUID->"87de7b83-233e-4764-aba9-\
82322a5501f8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"N", "[", 
   RowBox[{"DistanceMatrix", "[", "people", "]"}], "]"}], "//", 
  "MatrixForm"}]], "Input",
 CellLabel->"In[22]:=",ExpressionUUID->"134034e9-a776-496d-a651-b0272a4533b6"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0.`", "2000.0089999797501`", "6.`"},
     {"2000.0089999797501`", "0.`", "2000.`"},
     {"6.`", "2000.`", "0.`"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.781409264658236*^9},
 CellLabel->
  "Out[22]//MatrixForm=",ExpressionUUID->"e693f7be-38bf-4ee8-a679-\
345ac8cbd76e"]
}, Open  ]],

Cell["\<\
The distance is ~2000 between the first and second individuals but it is just \
6 between the first and third individuals. The huge difference in distances \
is mostly dictated by the salary difference; the number of children does not \
count much.\
\>", "Text",
 CellChangeTimes->{{3.7814092812591715`*^9, 
  3.7814093889500804`*^9}},ExpressionUUID->"0b46a38f-f6f0-4cc0-b21d-\
009be9fa721f"],

Cell["\<\
In order to make sure that features with small values significantly count \
towards distances, it is often useful to normalise each feature in a way that \
all of them have the same relative contribution to the distance.

There are several ways to normalise the data. Two popular choices are:\
\>", "Text",
 CellChangeTimes->{
  3.7814091621916866`*^9, {3.781409394697079*^9, 
   3.7814094274790354`*^9}},ExpressionUUID->"85c4d0b9-94e6-4687-b364-\
b231cdee02da"],

Cell[CellGroupData[{

Cell[TextData[{
 "Min-max normalisation: The following transformation is applied to each \
feature, ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "80b69d1f-fa7b-4533-926a-06b7f249d0db"]
}], "Item",
 CellChangeTimes->{{3.778412155923347*^9, 3.778412164963895*^9}, {
  3.778412216280241*^9, 3.778412221100759*^9}, {3.7784122963655787`*^9, 
  3.778412336502809*^9}, {3.778412509745986*^9, 
  3.778412513276039*^9}},ExpressionUUID->"6bd0cb41-90d7-48ee-8b29-\
357701431c90"],

Cell["", "ItemParagraph",
 CellChangeTimes->{{3.7784122494290953`*^9, 3.778412284359215*^9}, {
  3.7784123482571*^9, 
  3.778412353983231*^9}},ExpressionUUID->"0f581c38-5b1c-4687-93db-\
b5a69b521a08"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"x", "'"}], "=", 
   FractionBox[
    RowBox[{"x", "-", 
     RowBox[{"Min", "(", "x", ")"}]}], 
    RowBox[{
     RowBox[{"Max", "(", "x", ")"}], "-", 
     RowBox[{"Min", "(", "x", ")"}]}]]}], 
  TraditionalForm]],ExpressionUUID->"458a2f4b-5cf6-4ee3-8904-a5568012946b"]], \
"ItemParagraph",
 CellChangeTimes->{{3.7784122494290953`*^9, 3.778412284359215*^9}, {
  3.7784123482571*^9, 3.778412357992275*^9}, {3.778412543354992*^9, 
  3.778412550547422*^9}},ExpressionUUID->"699cc7fb-c3ec-418f-b8c1-\
716bb62e5b63"],

