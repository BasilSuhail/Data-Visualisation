Cell[CellGroupData[{

Cell["2-dimensional data", "Subsubsection",
 CellChangeTimes->{{3.781254654298418*^9, 
  3.7812546577256794`*^9}},ExpressionUUID->"5ee7554a-e04c-4e58-87f2-\
9e15d6a60286"],

Cell[TextData[{
 "Let us extend the data to include a 2nd feature, ",
 StyleBox["y",
  FontSlant->"Italic"],
 ". \n\nExamples of class A can take uniformly distributed random values ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    RowBox[{"[", 
     RowBox[{"0", ",", "0.7"}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "9b93212f-f9bd-449c-815c-4e69e4c2fabe"],
 "\nExamples of class B can take uniformly distributed random values ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    RowBox[{"[", 
     RowBox[{"0.3", ",", "1.0"}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "6cd770be-f154-40a8-ab90-649a7ae4bb48"],
 "\n\nNote that the data for the two classes can overlap in the 2nd dimension \
but one can still see two different clusters."
}], "Text",
 CellChangeTimes->{{3.781254665105299*^9, 3.7812546879606237`*^9}, {
  3.7812548220580473`*^9, 3.781254879696103*^9}, {3.7812552311938963`*^9, 
  3.7812552789398966`*^9}, {3.781255730027531*^9, 
  3.7812558215742116`*^9}},ExpressionUUID->"ddbcb777-18dc-46a1-9b6d-\
85d982e8a29b"],

