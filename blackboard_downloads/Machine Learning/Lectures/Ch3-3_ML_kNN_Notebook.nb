Cell[TextData[{
 "Once we have a function for the error for a given value of ",
 StyleBox["k",
  FontSlant->"Italic"],
 ", it is easy to see how the error changes with ",
 StyleBox["k",
  FontSlant->"Italic"],
 ". Here is a plot of the error as a function of ",
 StyleBox["k",
  FontSlant->"Italic"],
 ":"
}], "Text",
