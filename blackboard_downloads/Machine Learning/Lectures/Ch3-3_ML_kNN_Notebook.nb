Cell[TextData[{
 "Let us train a KNN classifier with ",
 StyleBox["k",
  FontSlant->"Italic"],
 " = 1 using ",
 StyleBox["AD1", "CodeText"],
 " and ",
 StyleBox["BD1", "CodeText"],
 " as training data:"
}], "Text",
 CellChangeTimes->{{3.781254146506929*^9, 3.781254192140087*^9}, {
  3.781255341879906*^9, 
  3.7812553447940717`*^9}},ExpressionUUID->"f3176ccc-da18-4a01-a5af-\
58b5a2dc985c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"c1D", "=", 
  RowBox[{"Classify", "[", 
   RowBox[{
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<A\>\"", "\[Rule]", "AD1"}], ",", 
      RowBox[{"\"\<B\>\"", "\[Rule]", "BD1"}]}], "|>"}], ",", 
    RowBox[{"Method", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<NearestNeighbors\>\"", ",", 
       RowBox[{"\"\<NeighborsNumber\>\"", "\[Rule]", "1"}], ",", 
       RowBox[{"\"\<NearestMethod\>\"", "\[Rule]", " ", "\"\<Scan\>\""}]}], 
      "}"}]}]}], "]"}]}]], "Input",
