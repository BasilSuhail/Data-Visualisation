Cell[TextData[{
 "Here, the unclassified point looks closer to a point in class 1. For ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "66658a77-276a-454e-96b7-298dd63fd058"],
 " we would conclude that the unclassified point belongs to class 1. \n\n",
 StyleBox["Euclidean distance:",
  FontWeight->"Bold"],
 "\nHere, the Euclidean distance between points would be a suitable metric to \
assess the distance between data points. For two points with coordinates ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "1"], ":", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["y", "1"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "bd275240-54be-4987-844d-25c425b49048"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "2"], ":", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["x", "2"], ",", 
      SubscriptBox["y", "2"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "13be8449-911c-4c23-afe8-e0e78dbcefaf"],
 ", the Euclidean distance is (remember Pythagoras theorem?):\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "("}], TraditionalForm]],ExpressionUUID->
  "a93a37c5-8b52-461b-bfb4-458294f5c3b4"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "1"], ",", 
    SubscriptBox["P", "2"]}], TraditionalForm]],ExpressionUUID->
  "a9a28314-07bc-4126-b0fe-50b090e6f098"],
 ")=",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["x", "1"], "-", 
        SubscriptBox["x", "2"]}], ")"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["y", "1"], "-", 
        SubscriptBox["y", "2"]}], ")"}], "2"]}]], TraditionalForm]],
  ExpressionUUID->"a1153aec-b72a-4ce3-9e29-3d6abc935b24"],
 "\n\nThe Euclidean distance can be easily calculated in Mathematica with the \
function ",
 StyleBox["EuclideanDistance", "CodeText"]
}], "Text",
 CellChangeTimes->{{3.813646606111241*^9, 3.813646651712325*^9}, {
  3.813646767916905*^9, 
  3.8136470882597947`*^9}},ExpressionUUID->"625bd948-459c-4de4-9235-\
499bf996b826"],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.7788705830053463`*^9, 
  3.77887058382176*^9}},ExpressionUUID->"7dfcc381-bd68-4b37-b5fb-\
cb97aebc8a9c"]
}, Open  ]],

