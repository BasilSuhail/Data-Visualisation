Cell[CellGroupData[{

Cell["The curse of dimensionality", "Section",
 CellChangeTimes->{{3.7790716304214063`*^9, 
  3.7790716363141456`*^9}},ExpressionUUID->"1682b669-42d9-4efb-97d8-\
fd09c9d3a201"],

Cell["\<\
The KNN quantifies the similarity between data point using distances. As a \
consequence, its accuracy might degrade as the number of features increases \
(unless the number of data points increases as well). This is called \
\[OpenCurlyDoubleQuote]curse of dimensionality\[CloseCurlyDoubleQuote]. The \
ultimate reason for this is that if we have few points in a high-dimensional \
space, the distance of a point to its closest neighbour is not necessarily \
much smaller than the distance to any other point in the space.\
\>", "Text",
 CellChangeTimes->{{3.779071645716638*^9, 3.7790716819226604`*^9}, {
  3.779104632747788*^9, 3.7791047019413023`*^9}, {3.780716086570183*^9, 
  3.78071613826968*^9}, {3.781253702035918*^9, 3.7812538436931887`*^9}, {
  3.781253900682071*^9, 
  3.781253901592369*^9}},ExpressionUUID->"b06bc6c9-c906-4c34-87df-\
aae8a567be91"],

Cell["\<\
Fortunately, the curse of dimensionality is not very bad in many cases and, \
in fact, KNN and other machine learning methods based on distances often \
perform very well with high dimensional data.\
\>", "Text",
 CellChangeTimes->{{3.7812538605090218`*^9, 
  3.781253998822939*^9}},ExpressionUUID->"4e73d2ad-7164-491b-bfb1-\
7754ca6141aa"],

Cell[CellGroupData[{

Cell["Example", "Subsection",
 CellChangeTimes->{{3.7812539838017406`*^9, 
  3.781253994379629*^9}},ExpressionUUID->"4edc40da-6468-4033-8b73-\
884eee9180ea"],

Cell["Let us illustrate the phenomenon in a very simple case.", "Text",
 CellChangeTimes->{{3.7812540028717422`*^9, 3.781254019195959*^9}, {
  3.781254113649723*^9, 3.7812541300659*^9}, {3.781254330848345*^9, 
  3.781254347072088*^9}, {3.7812543823787856`*^9, 
  3.7812543834316583`*^9}},ExpressionUUID->"2896b3ed-4942-4ebe-9fe6-\
f84c59bef103"],

Cell[CellGroupData[{

Cell["1-dimensional data", "Subsubsection",
 CellChangeTimes->{{3.7812543738230906`*^9, 3.7812543790734243`*^9}, {
  3.7812546446846466`*^9, 
  3.7812546450333166`*^9}},ExpressionUUID->"b93d5d1b-d87a-47ce-8679-\
6749331e8896"],

Cell[TextData[{
 "Consider two disjoint 1-dimensional datasets for class A and B.\n\nExamples \
of class A take uniformly distributed random values ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", " "}], TraditionalForm]],ExpressionUUID->
  "050873e5-ae03-4f3d-b62a-8e7921e34412"],
 "[-0.5,-0.01]\nExamples of class B take uniformly distributed random values \
in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]"}], TraditionalForm]],ExpressionUUID->
  "800cec01-19d8-4517-a737-6d849dff301a"],
 " [0.01,0.5]"
}], "Text",
 CellChangeTimes->{
  3.7812543876715927`*^9, {3.7812554147621775`*^9, 3.7812554872244835`*^9}, {
   3.7812555965034404`*^9, 3.7812556071726217`*^9}, {3.781255642876506*^9, 
   3.7812556524093103`*^9}},ExpressionUUID->"a33040e8-ef87-48a3-ad0f-\
4669cb34648d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ndata", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AD1", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"UniformDistribution", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "0.50"}], ",", 
        RowBox[{"-", "0.01"}]}], "}"}], "]"}], ",", "ndata"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BD1", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"UniformDistribution", "[", 
      RowBox[{"{", 
       RowBox[{"0.01", ",", "0.5"}], "}"}], "]"}], ",", "ndata"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.781105952215121*^9, 3.781105954296999*^9}, {
