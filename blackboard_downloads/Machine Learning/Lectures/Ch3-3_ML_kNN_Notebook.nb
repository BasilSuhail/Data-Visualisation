Cell[CellGroupData[{

Cell["Problems for skewed data", "Subsubsection",
 CellChangeTimes->{{3.778929118092832*^9, 
  3.778929124629046*^9}},ExpressionUUID->"b19ddf25-8a77-4667-82a8-\
536c354c3be5"],

Cell[TextData[{
 "What happens for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[GreaterSlantEqual]", "50"}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"3eaf6b63-4fef-40d8-9bbe-8bbedb8e072f"],
 StyleBox["? \n\n",
  FontWeight->"Bold"],
 "This can be investigated in terms of the confusion matrix. We just write a \
function for this analogous to the ",
 StyleBox["error[k]", "CodeText"],
 " function written above:"
}], "Text",
 CellChangeTimes->{{3.778918763657221*^9, 3.778918789433804*^9}, 
   3.778918850331052*^9, {3.7789229254981213`*^9, 3.778922947490334*^9}, {
   3.778922983162488*^9, 3.778923016875596*^9}, 
   3.77892319321451*^9},ExpressionUUID->"3b7acf28-049c-411c-8b1d-\
e5f182255e51"],

Cell[BoxData[
 RowBox[{
  RowBox[{"confusion", "[", 
   RowBox[{"k0_", ",", "class1in_", ",", "class2in_", ",", "testsetin_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", "=", "k0"}], ",", "ctemp", ",", 
      RowBox[{"class1", "=", "class1in"}], ",", 
