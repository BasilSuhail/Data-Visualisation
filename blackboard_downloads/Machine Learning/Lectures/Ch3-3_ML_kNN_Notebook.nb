Cell[CellGroupData[{

Cell["\<\
Checking standardization with synthetic data (check it yourself)\
\>", "Subsection",
 CellChangeTimes->{{3.778996978713813*^9, 3.778996996425665*^9}, {
  3.779982848464994*^9, 3.7799828523479347`*^9}, {3.78024196727765*^9, 
  3.780241981018714*^9}, {3.780715712390428*^9, 3.7807157153185854`*^9}, {
  3.780716202889994*^9, 3.780716207406887*^9}, {3.780888615785674*^9, 
  3.7808886251363087`*^9}, {3.813685190060646*^9, 
  3.8136851960142884`*^9}},ExpressionUUID->"17682bdf-e6d1-4270-ae14-\
566373a151b5"],

Cell[TextData[{
 "One can check that standardizing the data manually does not lead to a \
significant improvement when using ",
 StyleBox["Classify", "CodeText"],
 ".\n\nLet us consider a data consisting of two classes. \nIn order to avoid \
skewness, we consider both data "
}], "Text",
 CellChangeTimes->{{3.77899701082806*^9, 3.7789970335776*^9}, {
  3.778997162269413*^9, 3.778997198713925*^9}, {3.7802418176600356`*^9, 
  3.7802418528125787`*^9}, {3.7802420882039366`*^9, 
  3.7802420936666203`*^9}},ExpressionUUID->"11b737d8-d2f0-4e55-9c7e-\
8382acfa70fe"],

Cell[TextData[{
 "Class 1: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "1"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"fe775851-ed99-4433-a5ef-65b959584594"],
 StyleBox[" = 30",
  FontWeight->"Bold"],
 " data points from a multivariate normal x~ ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "(", 
    RowBox[{
     SubscriptBox["\[Mu]", "1"], ",", 
     SubscriptBox["\[CapitalSigma]", "1"]}]}], TraditionalForm]],
  ExpressionUUID->"ba7fbfd4-198a-4749-9768-15b2274a7003"],
 ") with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "1"], TraditionalForm]],ExpressionUUID->
  "12c6c9c7-939f-4946-afda-156188a0e1a1"],
 " = {35,2} and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalSigma]", "1"], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Sigma]", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "\[Sigma]"}], "}"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"ab7cc3d2-2444-4d21-a9ae-82d089ed53f0"],
 " where \[Sigma]=0.3\nClass 2: ",
