Notebook[{

Cell[CellGroupData[{
Cell[TextData[{
 "Classification with ",
 StyleBox["K ",
  FontSlant->"Italic"],
 "Nearest Neighbours (KNN)"
}], "Chapter",
 CellChangeTimes->{{3.7779606895409307`*^9, 3.7779607136402693`*^9}, {
  3.7779653433855047`*^9, 3.777965348137472*^9}, {3.7779653880098057`*^9, 
  3.777965389593543*^9}, {3.778412672964738*^9, 3.7784127212537527`*^9}, {
  3.778865016031845*^9, 3.778865017172569*^9}, {3.778865296296229*^9, 
  3.7788653011405063`*^9}, {3.7788654792565317`*^9, 3.77886547961635*^9}, {
  3.781254617098314*^9, 
  3.781254617514882*^9}},ExpressionUUID->"394b073e-1162-4053-839d-\
48c3cddc5022"],

Cell[CellGroupData[{

Cell["The method", "Section",
 CellChangeTimes->{{3.778867043290506*^9, 
  3.778867045166044*^9}},ExpressionUUID->"7a13045b-67c5-4b3a-99be-\
3949756f3527"],

Cell[TextData[{
 "The K nearest neighbour (",
 StyleBox["KNN",
  FontWeight->"Bold"],
 ") is probably the ",
 StyleBox["simplest classifier",
  FontWeight->"Bold"],
 " one can imagine. \nThe method assumes that points that are ",
 StyleBox["close",
  FontWeight->"Bold"],
 " to one another are ",
 StyleBox["similar",
  FontWeight->"Bold"],
 ".\nIn order to measure the similarity between data points, the method \
requires some ",
 StyleBox["notion of distance, ",
  FontWeight->"Bold"],
 StyleBox["d",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ".\nThe method can be applied to data characterised by ",
 StyleBox["any number ",
  FontWeight->"Bold"],
 StyleBox["M",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" of features",
  FontWeight->"Bold"],
 "\n"
}], "Text",
 CellChangeTimes->{{3.778865461395697*^9, 3.7788655594368734`*^9}, {
   3.7788661554365225`*^9, 3.7788661913449078`*^9}, {3.778866624912817*^9, 
   3.7788667818157196`*^9}, 3.7788668930663424`*^9, {3.7788669708276463`*^9, 
   3.778867036086915*^9}, {3.7788674006416793`*^9, 3.7788674043918743`*^9}, {
   3.7788674773843813`*^9, 3.7788675695818872`*^9}, {3.7788676719154625`*^9, 
   3.7788676943397403`*^9}, {3.7788677671743913`*^9, 
   3.7788679060786533`*^9}, {3.7788679533962097`*^9, 
   3.7788679787113953`*^9}, {3.7788680342947454`*^9, 
   3.778868222438743*^9}},ExpressionUUID->"52f81c6d-a115-41a4-93fd-\
5aac762522c1"],

Cell[TextData[StyleBox["Algorithm:",
 FontVariations->{"Underline"->True}]], "Text",
 CellChangeTimes->{{3.778868232767912*^9, 
  3.7788682564890575`*^9}},ExpressionUUID->"bfa7bfe4-299c-4647-9a5f-\
7ff7d1dd5886"],

Cell[CellGroupData[{

Cell[TextData[{
 "The method starts with a set of ",
 StyleBox["N",
  FontSlant->"Italic"],
 " already-classified data. "
}], "Item",
 CellChangeTimes->{{3.778868232767912*^9, 
  3.7788682676308117`*^9}},ExpressionUUID->"ffc7284d-3742-489b-8140-\
8a50ff2ff791"],

Cell["Given a new, unclassified data point,", "Item",
 CellChangeTimes->{{3.778868232767912*^9, 3.778868268927825*^9}, {
  3.778868310807304*^9, 3.778868314760857*^9}, {3.7788683536242476`*^9, 
  3.7788683536242476`*^9}},ExpressionUUID->"f80de7cb-5081-40ea-94ab-\
0a4c82d90ae1"],

Cell[CellGroupData[{

Cell["Measure the distance to all the classified data points", "Subitem",
 CellChangeTimes->{{3.778868232767912*^9, 3.778868268927825*^9}, {
  3.778868310807304*^9, 3.778868314760857*^9}, {3.7788684435545936`*^9, 
  3.7788684480238223`*^9}, {3.7788685785563784`*^9, 
  3.7788685785563784`*^9}},ExpressionUUID->"47ac6109-abbf-4281-9720-\
a413c5b41b33"],

Cell["Look at the K points with the smallest distance", "Subitem",
 CellChangeTimes->{{3.778868232767912*^9, 3.778868268927825*^9}, {
  3.778868310807304*^9, 3.778868314760857*^9}, {3.7788684435545936`*^9, 
  3.7788684480238223`*^9}, {3.778868588354302*^9, 
  3.778868603277874*^9}},ExpressionUUID->"b9d4aff3-234e-47c6-b662-\
4f4157b6c364"],

Cell["\<\
Assign the unclassified point to the class having the largest number of \
points nearby.\
\>", "Subitem",
 CellChangeTimes->{{3.778868232767912*^9, 3.778868268927825*^9}, {
  3.778868310807304*^9, 3.778868314760857*^9}, {3.7788684435545936`*^9, 
  3.7788684480238223`*^9}, {3.778868588354302*^9, 
  3.778868675301628*^9}},ExpressionUUID->"06538f62-1648-4179-894b-\
dce92e4f9884"]
}, Open  ]]
}, Open  ]],

