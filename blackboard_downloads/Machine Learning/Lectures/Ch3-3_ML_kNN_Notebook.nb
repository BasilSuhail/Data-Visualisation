Cell[TextData[{
 StyleBox["Aside:",
  FontWeight->"Bold"],
 " This is just a particular realisation of multinormal random variables.\n\n\
Class 1: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "1"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"d0f61e13-a176-48d6-9543-24bc59e7647e"],
 StyleBox[" = 25",
  FontWeight->"Bold"],
 " data points from a multivariate normal x~ ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "(", 
    RowBox[{
     SubscriptBox["\[Mu]", "1"], ",", 
     SubscriptBox["\[CapitalSigma]", "1"]}]}], TraditionalForm]],
  ExpressionUUID->"c4c48f10-4769-4a6e-b80e-8279c3aef43f"],
 ") with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "1"], TraditionalForm]],ExpressionUUID->
  "b04cb2e6-b15f-4a99-a095-3e4272f2c9c5"],
 " = {3.5,2} and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalSigma]", "1"], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Sigma]", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "\[Sigma]"}], "}"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"a6bd67df-b6ff-4e37-8b42-f8c80d055032"],
 " where \[Sigma]=0.3\nClass 2: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "2"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"0163f9db-d78e-43c6-a677-85defd340819"],
 StyleBox[" = 30",
  FontWeight->"Bold"],
 " data points from a multivariate normal x~ ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "(", 
    RowBox[{
     SubscriptBox["\[Mu]", "2"], ",", 
     SubscriptBox["\[CapitalSigma]", "2"]}]}], TraditionalForm]],
  ExpressionUUID->"46c44381-81f5-421c-8709-497a3cf78cd7"],
 ") with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "2"], TraditionalForm]],ExpressionUUID->
  "112c2a92-ef46-42c6-88fd-b047bed43e22"],
 " = {2,3} and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalSigma]", "2"], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Sigma]", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "\[Sigma]"}], "}"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"6b4c8898-3161-412b-8541-cf416b96d993"],
 " where \[Sigma]=0.5"
}], "Text",
 CellChangeTimes->{{3.7811047350624914`*^9, 3.781104776512678*^9}, {
  3.8136526204142747`*^9, 
  3.8136526277985215`*^9}},ExpressionUUID->"bbff56e9-bed6-46d2-bde2-\
715444a9534a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"gaussian", "[", 
    RowBox[{"\[Mu]_", ",", "\[Sigma]_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"MultinormalDistribution", "[", 
      RowBox[{"\[Mu]", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Sigma]", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "\[Sigma]"}], "}"}]}], "}"}]}], "]"}], ",", "n"}],
     "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cluster1", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"3.5", ",", "2"}], "}"}], ",", "0.3", ",", "25"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cluster2", "=", 
   RowBox[{"gaussian", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", "3"}], "}"}], ",", "0.5", ",", "30"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.778853092157978*^9, 3.77885317879671*^9}, {
   3.7788649694643407`*^9, 3.778864976074418*^9}, {3.7788651723607206`*^9, 
