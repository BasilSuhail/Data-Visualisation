Cell[CellGroupData[{

Cell["Using a ClassifierMeasurements object", "Subsubsection",
 CellChangeTimes->{{3.7789190208535337`*^9, 3.7789190259494343`*^9}, {
  3.778922696814227*^9, 
  3.778922710222496*^9}},ExpressionUUID->"ccd33dba-9051-4511-9ca0-\
340a94f9ff8d"],

Cell[TextData[{
 "In order to look at the effect of ",
 StyleBox["k",
  FontSlant->"Italic"],
 " in a more systematic way, we obtain a ",
 StyleBox["ClassifierMeasurements", "CodeText"],
 " object and study performance measures."
}], "Text",
 CellChangeTimes->{{3.778916996368957*^9, 3.7789169989047337`*^9}, {
  3.778918595814415*^9, 3.778918652911399*^9}, {3.7789190332695932`*^9, 
  3.778919050766281*^9}, {3.779105739686862*^9, 3.7791057808631144`*^9}, {
  3.813681885160903*^9, 
  3.8136818869401445`*^9}},ExpressionUUID->"fb67faed-786a-42f2-9887-\
317343d23bd8"],

Cell[TextData[{
 "We first train a classifier for a certain value of ",
 StyleBox["k",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.813681889842428*^9, 
  3.8136819080137873`*^9}},ExpressionUUID->"be240ec4-26b4-4d54-84d7-\
a9166ab67173"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"k", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"c", "=", 
  RowBox[{"Classify", "[", 
   RowBox[{
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<class 1\>\"", "->", "class1"}], ",", 
      RowBox[{"\"\<class 2\>\"", "->", "class2"}]}], "|>"}], ",", 
    RowBox[{"Method", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<NearestNeighbors\>\"", ",", 
       RowBox[{"\"\<NeighborsNumber\>\"", "\[Rule]", "k"}]}], "}"}]}]}], 
   "]"}]}]}], "Input",
