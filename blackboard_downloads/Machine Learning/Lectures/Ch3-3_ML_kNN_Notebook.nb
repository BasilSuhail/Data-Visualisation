  3.778916695555174*^9}},ExpressionUUID->"788a5f3f-ed94-4c3f-a972-\
1ae9650cb52b"],

Cell["\<\
Train a classifier using the data for the two classes with KNN:\
\>", "Text",
 CellChangeTimes->{{3.778907184747175*^9, 
  3.7789072264200583`*^9}},ExpressionUUID->"4e5d3c8a-9aad-49e4-8649-\
8ba7b1812d0e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"k", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"c", "=", 
  RowBox[{"Classify", "[", 
   RowBox[{
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<class 1\>\"", "->", "class1"}], ",", 
      RowBox[{"\"\<class 2\>\"", "->", "class2"}]}], "|>"}], ",", 
    RowBox[{"Method", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<NearestNeighbors\>\"", ",", 
       RowBox[{"\"\<NeighborsNumber\>\"", "\[Rule]", "k"}]}], "}"}]}]}], 
   "]"}]}]}], "Input",
