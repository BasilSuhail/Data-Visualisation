Cell["\<\
The distance between first-second and first-third are more similar which \
might make sense, for instance, when calculating an insurance premium for \
different individuals.\
\>", "Text",
 CellChangeTimes->{{3.781409596730176*^9, 3.7814096582542596`*^9}, {
  3.8139308479745483`*^9, 
  3.813930849766755*^9}},ExpressionUUID->"33d39166-e7ee-4fc5-aff3-\
6b1e17d4ded9"],

Cell[TextData[StyleBox["Min-Max normalization", "Subsubsection"]], "Text",
 CellChangeTimes->{{3.779983024782633*^9, 3.7799830296009035`*^9}, {
  3.779984237251752*^9, 
  3.779984242834875*^9}},ExpressionUUID->"e05ad04d-8603-45a3-82a2-\
622b764e1c7e"],

Cell["\<\
The Standardize function can be implemented in a more general way as follows:\
\
\>", "Text",
 CellChangeTimes->{{3.779984247996572*^9, 3.779984262370411*^9}, {
  3.779984454765525*^9, 
  3.7799844650054183`*^9}},ExpressionUUID->"a0638ac9-c396-405a-b096-\
e0994d8ecc25"],

Cell[TextData[{
 "Standardize[list,",
 Cell[BoxData[
  FormBox[
   SubscriptBox["f", "1"], TraditionalForm]],ExpressionUUID->
  "2b0b0981-3bb7-4854-a072-22238b86d449"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["f", "2"], TraditionalForm]],ExpressionUUID->
  "2719faae-eb94-451b-9fe1-1c41f8c5cb30"],
 "] = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"list", "-", 
     RowBox[{
      SubscriptBox["f", "1"], "[", "list", "]"}]}], 
    RowBox[{
     SubscriptBox["f", "2"], "[", "list", "]"}]], TraditionalForm]],
  ExpressionUUID->"d85fd2d5-494d-475f-9813-f9afe4f55e8a"]
}], "Text",
 CellChangeTimes->{{3.7799842726410418`*^9, 
  3.779984445264476*^9}},ExpressionUUID->"3b82ae01-bbec-4e37-97dc-\
a7f6d2ca53fd"],

Cell["For Min-Max normalization, ", "Text",
 CellChangeTimes->{{3.7799844706442003`*^9, 
  3.7799844890683603`*^9}},ExpressionUUID->"49d97022-1819-4601-8a0c-\
3dd435474785"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"f2", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Max", "[", "x", "]"}], "-", 
    RowBox[{"Min", "[", "x", "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7799851245447474`*^9, 3.7799851441348076`*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"7c4748a1-5c5a-4392-af95-8918d6a837f9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"f1", "[", "x_", "]"}], ":=", 
   RowBox[{"Min", "[", "x", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.781349726000003*^9, 3.781349738128333*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"817c9b38-64f7-4d48-9e66-aa07b8a7caaf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Standardize", "[", 
  RowBox[{"x", ",", "f1", ",", "f2"}], "]"}]], "Input",
 CellChangeTimes->{{3.779985094666583*^9, 3.7799851505983725`*^9}, {
  3.8139328267757*^9, 3.8139328282856607`*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"3fc8faf8-4bcf-4026-8143-cc623bb6aed7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "1", ",", 
   FractionBox["1", "3"], ",", 
   FractionBox["1", "6"], ",", 
   FractionBox["5", "6"], ",", "1"}], "}"}]], "Output",
 CellChangeTimes->{{3.779985111877228*^9, 3.7799851205782886`*^9}, 
   3.779985151200698*^9, 3.7813497454053636`*^9, {3.7814096803265076`*^9, 
   3.781409703686448*^9}, 3.7814104494459*^9, {3.813932815286775*^9, 
   3.8139328303172264`*^9}},
 CellLabel->"Out[28]=",ExpressionUUID->"05321988-34da-47ce-adff-94d563660885"]
}, Open  ]],

