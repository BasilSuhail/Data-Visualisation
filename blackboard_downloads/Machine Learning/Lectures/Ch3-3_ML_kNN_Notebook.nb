 RowBox[{
  RowBox[{"AD2", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"AD1", ",", 
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"UniformDistribution", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0.7"}], "}"}], "]"}], ",", "ndata"}], "]"}]}], 
