Cell["We then define the test dataset as follows:", "Text",
 CellChangeTimes->{{3.8136814748939886`*^9, 
  3.813681494679076*^9}},ExpressionUUID->"7357070b-7ee9-4a08-9914-\
c0ba385f8cc3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"testset", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<class 1\>\"", "\[Rule]", " ", "test1"}], ",", 
     RowBox[{"\"\<class 2\>\"", "\[Rule]", " ", "test2"}]}], "|>"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.7789150017817698`*^9, 3.778915016341832*^9}, {
  3.778916846608098*^9, 3.778916847609858*^9}, {3.813681330872151*^9, 
  3.8136813321427507`*^9}, {3.813681470217497*^9, 
  3.8136814710113773`*^9}},ExpressionUUID->"b89a33ac-52b6-4a37-97ec-\
b9aafbaa6097"],

Cell[TextData[{
 "We create a module to plot the predicted class and test class for any value \
of ",
 StyleBox["k",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.778918193855054*^9, 3.778918236019175*^9}, {
  3.7789184704443808`*^9, 
  3.778918471636047*^9}},ExpressionUUID->"9f8aeddf-7252-4932-b061-\
f51afaf0bb1e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"plotTest", "[", "k0_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", "=", "k0"}], ",", "line", ",", "points", ",", "ctemp", ",",
       "pred", ",", "temp"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"line", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"0", ",", "5", ",", "0.05"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"points", "=", 
      RowBox[{"Tuples", "[", 
       RowBox[{"line", ",", "2"}], "]"}]}], ";", 
     RowBox[{"ctemp", "=", 
      RowBox[{"Classify", "[", 
       RowBox[{
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<class 1\>\"", "->", "class1"}], ",", 
          RowBox[{"\"\<class 2\>\"", "->", "class2"}]}], "|>"}], ",", 
        RowBox[{"Method", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"\"\<NearestNeighbors\>\"", ",", 
           RowBox[{"\"\<NeighborsNumber\>\"", "\[Rule]", "k"}]}], "}"}]}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pred", "=", 
      RowBox[{"ctemp", "[", "points", "]"}]}], ";", "\n", 
     RowBox[{"temp", "=", 
      RowBox[{"Tally", "[", 
       RowBox[{"Sort", "[", "pred", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"points", "[", 
             RowBox[{"[", 
              RowBox[{"Ordering", "[", "pred", "]"}], "]"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", 
              RowBox[{"temp", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"points", "[", 
             RowBox[{"[", 
              RowBox[{"Ordering", "[", "pred", "]"}], "]"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{
               RowBox[{"temp", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "2"}], "]"}], "]"}], "+", "1"}], ";;", 
              RowBox[{"Length", "[", "pred", "]"}]}], "]"}], "]"}]}], "}"}], 
         ",", 
         RowBox[{"PlotStyle", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"RGBColor", "[", 
               RowBox[{"0.97", ",", "1.", ",", "0.55"}], "]"}], ",", 
              RowBox[{"PointSize", "[", "0.015", "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"RGBColor", "[", 
               RowBox[{"0.5", ",", "1", ",", "0.5"}], "]"}], ",", 
              RowBox[{"PointSize", "[", "0.015", "]"}]}], "}"}]}], "}"}]}], 
         ",", 
         RowBox[{"PlotLabel", "\[Rule]", 
          RowBox[{"\"\<k=\>\"", "<>", 
           RowBox[{"ToString", "[", "k", "]"}]}]}]}], "]"}], ",", 
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"test1", ",", "test2"}], "}"}], ",", 
         RowBox[{"PlotStyle", "\[Rule]", 
          RowBox[{"PointSize", "[", "Medium", "]"}]}], ",", " ", 
         RowBox[{"PlotLegends", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"\"\<Test 1\>\"", ",", "\"\<Test 2\>\""}], "}"}]}]}], 
        "]"}]}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.778917182749977*^9, 3.778917216365032*^9}, {
  3.7789172940422707`*^9, 3.77891739177871*^9}, {3.778917565735497*^9, 
  3.7789175852379827`*^9}, {3.778917686170979*^9, 3.7789177217525673`*^9}, {
  3.778917972029518*^9, 3.778917974573197*^9}, {3.778918244052709*^9, 
  3.778918250529849*^9}, {3.778922637355382*^9, 3.778922652459654*^9}, {
  3.7808877723186216`*^9, 3.78088779487566*^9}, {3.7813473151116934`*^9, 
  3.781347317782584*^9}, {3.7813473565862474`*^9, 3.7813473872402725`*^9}, {
  3.7813475575483494`*^9, 3.7813475805521927`*^9}, {3.781367881958894*^9, 
  3.7813678911065693`*^9}, {3.7813679221827226`*^9, 3.7813679240093193`*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"5de9ef31-ba14-442f-9b18-404cb407f360"],

