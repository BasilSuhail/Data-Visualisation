Cell[TextData[{
 "Note that ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "0e1c2112-9faa-491a-865d-b62fa50638ce"],
 " is a list with two elements, i.e. is the mean value of the bi-variate \
random variable."
}], "Text",
 CellChangeTimes->{{3.8139995014549065`*^9, 
  3.8139995543945694`*^9}},ExpressionUUID->"a8ccca49-aae4-4450-b370-\
f2d25840a050"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tasks for your", "Subsubsection",
 CellChangeTimes->{{3.813997899233886*^9, 3.813997901491378*^9}, 
   3.8139993541802626`*^9},ExpressionUUID->"bebf7a6a-bb35-4c55-b420-\
47bb71caa9a4"],

Cell[TextData[{
 "1. Consider a random variable ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", "=", 
    RowBox[{
     SubscriptBox["X", "1"], "+", 
     SubscriptBox["X", "2"], "+", 
     SubscriptBox["X", "3"]}]}], TraditionalForm]],ExpressionUUID->
  "d7e6f6c5-c31b-4ba7-93a5-c2704bce9775"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "1"], "\[Distributed]", 
    RowBox[{"N", "(", 
     RowBox[{"1", ",", "4"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "8e7876c1-650d-4996-9a4b-b1abbdc817e1"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["X", "2"], "\[Distributed]", 
     RowBox[{"N", "(", 
      RowBox[{
       RowBox[{"-", "1"}], ",", "2"}], ")"}]}], ",", " ", 
    RowBox[{
     SubscriptBox["X", "3"], "\[Distributed]", 
     RowBox[{"N", "(", 
      RowBox[{"0", ",", "1"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "6099efd4-75ac-42fb-914d-aeff403d9440"],
 ". "
}], "Text",
 CellChangeTimes->{{3.813997929473069*^9, 3.813997971546563*^9}, {
  3.8139980059665785`*^9, 3.8139982126531043`*^9}, {3.813999132596434*^9, 
  3.81399918007755*^9}, {3.8139993566107397`*^9, 
  3.8139993575213313`*^9}},ExpressionUUID->"52da4fec-f2eb-4f86-be4a-\
6fc9fbbe73c4"],

Cell[TextData[{
 "Obtain 1000 random variates for ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "6086c263-0cf8-4a96-96e4-b6e1ec0c1c6b"],
 ". "
}], "Item",
 CellChangeTimes->{{3.813999188612725*^9, 3.8139991936492543`*^9}, {
   3.8140002393907146`*^9, 3.8140002648894815`*^9}, 
   3.8140132385154657`*^9},ExpressionUUID->"a3eaff22-d740-4153-861b-\
3b6ef842ffaf"],

Cell[TextData[{
 "Plot the values of  the random variates for ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "08403b22-98ac-4466-9405-a39bcd02f18c"],
 " in the axis of real numbers."
}], "Item",
 CellChangeTimes->{{3.813999188612725*^9, 
  3.8139992472628746`*^9}},ExpressionUUID->"92590032-e827-4cfc-a55a-\
170426279e15"],

Cell[TextData[{
 "Calculate the mean and variance of the random variates. Can you explain the \
obtained values for the mean and variance in terms of the mean and variance \
of the random variables ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "1"], ",", " ", 
    RowBox[{
     SubscriptBox["X", "2"], " ", "and", " ", Cell[TextData[Cell[BoxData[
      FormBox[
       RowBox[{
        SubscriptBox["X", "3"], "."}], TraditionalForm]],ExpressionUUID->
      "ec5fef10-ccee-45fb-a8db-286418d61423"]],ExpressionUUID->
      "2fe0985e-3aea-4dde-8d55-6ab02cb072fa"]}]}], TraditionalForm]],
  ExpressionUUID->"0d01716a-7239-4d50-b794-fd4cb745c15d"]
}], "Item",
 CellChangeTimes->{{3.813999188612725*^9, 3.813999251686099*^9}, {
  3.8139992916068907`*^9, 
  3.813999350208898*^9}},ExpressionUUID->"35520fd0-e591-45fa-8bdd-\
201cad3bc240"],

Cell[TextData[{
 "2. Consider a bi-variate random variable ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["X", "1"], ",", 
      SubscriptBox["X", "2"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "04477b02-6a66-450a-bae6-2d8e3a485fe5"],
 ". "
}], "Text",
 CellChangeTimes->{{3.813999188612725*^9, 3.813999251686099*^9}, {
  3.8139992916068907`*^9, 
  3.8139994088400607`*^9}},ExpressionUUID->"2cac491d-fb3d-40f2-acfb-\
a8e5570bfe86"],

Cell[TextData[{
 "Obtain 100 random variates for ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "906638d2-037e-4d24-b1c5-b8ecc6c5f912"],
 "."
}], "Item",
 CellChangeTimes->{{3.8139994168526306`*^9, 
  3.813999424501177*^9}},ExpressionUUID->"723c7469-4bcf-4325-9a05-\
934534daa437"],

Cell[TextData[{
 "Do a scatterplot of the random variates of ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "3e6e56b1-0157-4105-8265-88317b7e01dd"],
 " on the 2D plane."
}], "Item",
 CellChangeTimes->{{3.8139994168526306`*^9, 
  3.8139994664599657`*^9}},ExpressionUUID->"24a6416d-b1f6-45f5-aadd-\
46a6d166e39d"],

Cell[TextData[{
 "Try to obtain 100 random variates for ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "0f1e69c5-afa0-43d2-8a03-617562847c3b"],
 " using the ",
 StyleBox["MultinormalDistribution", "CodeText"],
 StyleBox[". Plot these random variates together with those obtained in the \
previous item. Did you get a similar cloud of points with both procedures?", 
  "Text"]
}], "Item",
 CellChangeTimes->{{3.8139994168526306`*^9, 3.8139994727042665`*^9}, {
  3.813999587738433*^9, 3.8139996918699975`*^9}, {3.814000870330662*^9, 
  3.8140009001239862`*^9}, {3.814000989108013*^9, 3.814000989587762*^9}, {
  3.814001083656211*^9, 
  3.8140010841648345`*^9}},ExpressionUUID->"1439c500-cdd0-4458-a4b0-\
7527dc6853d4"]
}, Closed]]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Other distributions", "Section",
 CellChangeTimes->{{3.780061433387186*^9, 
  3.780061436748763*^9}},ExpressionUUID->"b4a69eec-ca6d-45b9-8ecb-\
0646c6603863"],

Cell[TextData[{
 "In addition to Bernoulli, binomial and normal distributions there are many \
other distributions that are useful to describe certain random variables. The \
Wolfram Mathematica guide on ",
 Cell[BoxData[
  FormBox[
   ButtonBox[
    RowBox[{"Parametric", " ", "Statistical", " ", "Distributions"}],
    BaseStyle->"Link",
    ButtonData->"paclet:guide/ParametricStatisticalDistributions"], 
   TraditionalForm]],ExpressionUUID->"2f3db9b7-ea5d-4e81-b63f-e82d7473b089"],
 " provide many examples for distributions of random variables.\n\nPX5010 - \
Statistics and Times Series Analysis will cover more on random variables and \
distributions."
}], "Text",
 CellChangeTimes->{{3.780061477574692*^9, 3.780061517411831*^9}, {
  3.7800616331895027`*^9, 3.7800616483380327`*^9}, {3.7800617355263233`*^9, 
  3.7800617372199287`*^9}, {3.7800617672519197`*^9, 3.7800618048208137`*^9}, {
  3.780061865615221*^9, 3.780061950390806*^9}, {3.8139588789105783`*^9, 
  3.8139589021681037`*^9}, {3.8139941903976974`*^9, 3.813994303689316*^9}, {
  3.814013596766963*^9, 3.8140136685764446`*^9}, {3.814013700628032*^9, 
  3.8140137914191227`*^9}},ExpressionUUID->"b9097adc-99c1-49ba-a1a2-\
46746bb5b6c3"]
}, Closed]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Finding and learning distributions from data", "Chapter",
 CellChangeTimes->{{3.882852373120623*^9, 
  3.882852381280738*^9}},ExpressionUUID->"7795a0d2-7ed6-45e7-8ff0-\
974db5b41164"],

Cell["\<\
The next two sections are the core of this chapter. They are not optional and \
must be covered.\
\>", "Text",
 CellChangeTimes->{{3.882852389825296*^9, 3.882852401144161*^9}, {
  3.882852906988328*^9, 
  3.882852942441723*^9}},ExpressionUUID->"6d899ae1-372f-4af8-92f7-\
3e4528e1aa5a"],

Cell[CellGroupData[{

Cell["\<\
Finding distribution of data - Classifying data into distributions\
\>", "Section",
 CellChangeTimes->{{3.7800612430296803`*^9, 3.7800612540824537`*^9}, {
  3.780129584577571*^9, 
  3.780129636545993*^9}},ExpressionUUID->"961d1ec3-79a6-4820-adc0-\
c13ceb89562c"],

Cell[TextData[{
 "Given a set of random values, one can use the Wolfram Language function ",
 StyleBox["FindDistribution", "CodeText"],
 " to find the distribution that best describes the data.\n\nThis can be \
viewed as a ",
 StyleBox["classification machine learning",
  FontWeight->"Bold"],
 " task: We input data to Mathematica and it is ",
 StyleBox["classified",
  FontWeight->"Bold"],
 " into a set of possible distributions (these are the ",
 StyleBox["categories",
  FontWeight->"Bold"],
 "). "
}], "Text",
 CellChangeTimes->{{3.780061297722501*^9, 3.780061412880522*^9}, 
   3.780120013009439*^9, {3.780129421344468*^9, 3.780129466129171*^9}, {
   3.7801295446901417`*^9, 3.780129598642261*^9}, {3.7801296458586473`*^9, 
   3.780129651651355*^9}},ExpressionUUID->"fc9f7e45-feed-4abe-bc20-\
fa125c8012b9"],

Cell[CellGroupData[{

Cell["Example", "Subsection",
 CellChangeTimes->{{3.780125606769672*^9, 
  3.78012560870555*^9}},ExpressionUUID->"536bec01-5d1d-4233-a39d-\
3a3f127a665a"],

Cell[TextData[{
 "For instance, the probability of 1000 values for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "~", 
    RowBox[{"Ber", "(", "0.2", ")"}]}], TraditionalForm]],ExpressionUUID->
  "f1dfa524-cd78-4cb8-8694-af56fe3f68bd"],
 " can be found as follows:"
}], "Text",
 CellChangeTimes->{{3.7801200224676523`*^9, 3.780120092624432*^9}, {
  3.8140011907637243`*^9, 
  3.814001193738799*^9}},ExpressionUUID->"1c641470-9ea2-430c-979a-\
f5fb45fcacc6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"BernoulliDistribution", "[", "0.2", "]"}], ",", "1000"}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.780062058264038*^9, 3.78006206106511*^9}, {
   3.7800621764106045`*^9, 3.7800622070143166`*^9}, {3.780062237024974*^9, 
   3.780062303297202*^9}, {3.8140011796225553`*^9, 3.8140011969920645`*^9}, 
   3.8140156479983473`*^9, 3.814015679868246*^9},
 CellLabel->
  "In[158]:=",ExpressionUUID->"05ac2734-14f5-4dfa-a437-f417f8edb119"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"estimated\[ScriptCapitalD]", "=", 
  RowBox[{"FindDistribution", "[", "data", "]"}], "   ", 
  RowBox[{"(*", " ", 
   RowBox[{"here", ",", " ", 
    RowBox[{
     RowBox[{
     "symbol", " ", "\[ScriptCapitalD]", " ", "can", " ", "be", " ", "typed", 
      " ", "as", " ", "esc"}], "+", "scD", "+", "esc"}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.780061359021269*^9, 3.7800613651763725`*^9}, {
  3.7800622642503104`*^9, 3.7800622659711437`*^9}, {3.78012018442243*^9, 
  3.7801202622424994`*^9}},
 CellLabel->
  "In[159]:=",ExpressionUUID->"5bcc0ce7-e67a-4685-88f2-0c847b1bb8a3"],

Cell[BoxData[
 RowBox[{"BinomialDistribution", "[", 
  RowBox[{"1", ",", "0.22185430463576158`"}], "]"}]], "Output",
 CellChangeTimes->{{3.780062268718325*^9, 3.780062307616177*^9}, 
   3.780119998540649*^9, 3.780120144133052*^9, 3.780120267076825*^9, 
   3.7815204476156225`*^9, 3.7815205362978563`*^9, 3.81400120889826*^9, 
   3.8140155022240467`*^9, {3.814015660043541*^9, 3.814015683920767*^9}},
 CellLabel->
  "Out[159]=",ExpressionUUID->"d7efdb02-8a58-442e-9b67-8b376a409fa1"]
}, Open  ]],

Cell["\<\
In fact, the binomial distribution for one attempt corresponds to Bernoulli \
distribution.\
\>", "Text",
 CellChangeTimes->{{3.814001336094061*^9, 3.8140013482884493`*^9}, {
  3.814015702271397*^9, 
  3.8140157137620163`*^9}},ExpressionUUID->"fbc61e64-1bbe-4a41-a524-\
c4a64a877019"],

Cell["\<\
The estimated distribution is indeed close to the original distribution\
\>", "Text",
 CellChangeTimes->{{3.7801206573153973`*^9, 3.7801206736352377`*^9}, {
  3.780120728226822*^9, 
  3.780120749155725*^9}},ExpressionUUID->"0cba39df-46c3-4014-8f84-\
8861168cc3a7"],

