Cell[CellGroupData[{

Cell["The Bernoulli distribution in Wolfram Language", "Subsection",
 CellChangeTimes->{{3.779691458390561*^9, 3.779691467238727*^9}, {
  3.7796922680223827`*^9, 
  3.779692276886104*^9}},ExpressionUUID->"d2db810c-48d8-44b8-93b9-\
00aa45ad7af0"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BernoulliDistribution"]], "paclet:ref/BernoulliDistribution"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   StyleBox["p", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0cab23dd-3e33-45e9-992f-14f2be4a7ed9"],
 "  represents a Bernoulli distribution with probability parameter ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9f627c8c-58b5-402b-acfb-51db69e1dc14"],
 "."
}], "Text",
 CellChangeTimes->{{3.7796915710251017`*^9, 
  3.779691580998464*^9}},ExpressionUUID->"c056dc99-7632-4fff-890c-\
c0c835513bd8"],

Cell[TextData[{
 "The probability distribution can be displayed for any ",
 StyleBox["p ",
  FontSlant->"Italic"],
 "using the function ",
 StyleBox["PDF", "CodeText"],
 ". Success and failure correspond to 0 and 1, respectively."
}], "Text",
 CellChangeTimes->{{3.779692032725999*^9, 
  3.779692116518173*^9}},ExpressionUUID->"d66030fd-5bc0-4bc0-96a5-\
5b2538db4f9c"],

