Cell["\<\
This probability distribution plays an important role in the logistic \
regression method for classification.\
\>", "Text",
 CellChangeTimes->{{3.813958206251519*^9, 
  3.8139582452578564`*^9}},ExpressionUUID->"f94d8950-fe75-46df-9614-\
7853d21e4d09"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Example - A raffle", "Subsection"]], "Subsection",
 CellChangeTimes->{
  3.779687618852497*^9},ExpressionUUID->"76c91208-c460-49e4-b1b5-\
33e0c96ccfee"],

Cell[TextData[{
 "A bag contains ",
 StyleBox["100 tickets",
  FontWeight->"Bold"],
 " of which only ",
 StyleBox["10",
  FontWeight->"Bold"],
 " contain a ",
 StyleBox["prize",
  FontWeight->"Bold"],
 ". \n\nSuppose 1000 people play the game. \nWhat is the probability ",
 StyleBox["p",
  FontSlant->"Italic"],
 " that someone will get a prize?\nWhat is the probability ",
 StyleBox["q",
  FontSlant->"Italic"],
 " of getting no prize?"
}], "Text",
 CellChangeTimes->{{3.779686475583824*^9, 3.779686478687955*^9}, {
  3.7796865112352448`*^9, 3.779686681097794*^9}, {3.779686847464964*^9, 
  3.779686849302724*^9}, {3.779686895477957*^9, 3.779686896452626*^9}, {
  3.779687246964406*^9, 
  3.779687264082631*^9}},ExpressionUUID->"97bc730f-9f59-43e1-add0-\
11a00c3f5531"],

Cell[CellGroupData[{

Cell["Answer", "Subsubsection",
 CellChangeTimes->{{3.779687630497809*^9, 
  3.77968764109007*^9}},ExpressionUUID->"b3407409-af10-4c93-9c2c-\
9beb5e1d5042"],

Cell[TextData[{
 "In this case, ",
 StyleBox["the answer is easy:",
  FontWeight->"Bold"],
 " "
}], "Text",
 CellChangeTimes->{{3.779686700824744*^9, 3.779686717481536*^9}, {
   3.779686833062776*^9, 3.779686841606784*^9}, {3.779686898981717*^9, 
   3.779686904950444*^9}, 3.779687275330659*^9, {3.779687334786354*^9, 
   3.7796873447862053`*^9}, 
   3.779687645330291*^9},ExpressionUUID->"4bfe35ec-2994-4007-84e0-\
1c4fb39f38a6"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{
     FractionBox[
      RowBox[{"Number", " ", "of", " ", "prizes"}], 
      RowBox[{"Number", " ", "of", " ", "tickets"}]], "=", 
     RowBox[{
      FractionBox["10", "100"], "=", "0.1"}]}]}], TraditionalForm]],
  ExpressionUUID->"145d6f71-dc54-4182-a509-0c4d6ebee729"]
}], "Item",
 CellChangeTimes->{{3.779687285720707*^9, 
  3.779687329347004*^9}},ExpressionUUID->"ca3666fb-e998-49f3-9a4e-\
a14633162101"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "=", 
    RowBox[{
     FractionBox[
      RowBox[{"Number", " ", "of", " ", "no", " ", "prizes"}], 
      RowBox[{"Number", " ", "of", " ", "tickets"}]], "=", 
     FractionBox["90", "100"]}]}], TraditionalForm]],ExpressionUUID->
  "d2ef0a4d-6f2a-4baf-8313-a09c9c623aa8"],
 "= 0.9"
}], "Item",
 CellChangeTimes->{{3.779687285720707*^9, 3.779687304163344*^9}, {
  3.779687354978825*^9, 3.77968736846731*^9}, {3.781509758932789*^9, 
  3.7815097626990285`*^9}},ExpressionUUID->"462c44d1-4fde-4c69-afce-\
7c2c6246c9d2"],

Cell[TextData[{
 "In general, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "=", 
    RowBox[{"1", "-", "p"}]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"6d5828b2-a984-4fdb-b881-d297b1d7004c"],
 ".  Therefore, the Bernoulli distribution is fully characterised by ",
 StyleBox["p",
  FontSlant->"Italic"],
 ", the probability of success.\n\nA r.v. X obeying the Bernoulli \
distribution is denoted as\n\n\t\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "\[Distributed]", 
    RowBox[{"Ber", "(", "p", ")"}]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"8453cb6a-0a2d-437c-b0ee-f06cd45b4b31"]
}], "Text",
 CellChangeTimes->{{3.7796873965140533`*^9, 3.779687490947494*^9}, {
  3.781503051822121*^9, 3.7815030524933243`*^9}, {3.8139965462092304`*^9, 
  3.813996549090746*^9}},ExpressionUUID->"8bc7253a-7ed5-489b-a51a-\
e43aa173fac2"],

Cell["\<\
The symbol \[OpenCurlyDoubleQuote]\[Distributed]\[CloseCurlyDoubleQuote] can \
be read as \[OpenCurlyDoubleQuote]distributed as\[CloseCurlyDoubleQuote]. In \
Mathematica, it can be typed with the combination esc + dist + esc.\
\>", "Text",
 CellChangeTimes->{{3.813996552639241*^9, 
  3.81399662914737*^9}},ExpressionUUID->"fbe8b020-2f18-4f94-9ae7-\
9e3acea82711"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Simulation", "Subsubsection",
 CellChangeTimes->{{3.77968767107373*^9, 
  3.779687672593647*^9}},ExpressionUUID->"eedc31ee-a696-4372-bdcf-\
4f70376048e2"],

Cell[TextData[{
 "One can also ",
 StyleBox["simulate",
  FontWeight->"Bold"],
 " this..."
}], "Text",
 CellChangeTimes->{{3.779686724288052*^9, 3.779686739672264*^9}, {
   3.7796868434145412`*^9, 3.779686871221859*^9}, 
   3.779687675346137*^9},ExpressionUUID->"608beaae-7145-4916-b7d8-\
55092e301080"],

Cell["Define the bag:", "Text",
 CellChangeTimes->{{3.779686861893724*^9, 
  3.779686873653851*^9}},ExpressionUUID->"bfbd5a57-2622-420c-b4a1-\
d6df3fdb4b92"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bag", "=", 
  RowBox[{"Flatten", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"ConstantArray", "[", 
      RowBox[{"\"\<prize\>\"", ",", "10"}], "]"}], ",", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"\"\<no prize\>\"", ",", 
       RowBox[{"100", "-", "10"}]}], "]"}]}], "}"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.779686747209537*^9, 3.779686799367661*^9}, {
  3.779686908312689*^9, 3.779686911733712*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"5570c5a3-dd58-4132-9898-498ffbeec3e1"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"prize\"\>", ",", "\<\"prize\"\>", ",", "\<\"prize\"\>", 
   ",", "\<\"prize\"\>", ",", "\<\"prize\"\>", ",", "\<\"prize\"\>", 
   ",", "\<\"prize\"\>", ",", "\<\"prize\"\>", ",", "\<\"prize\"\>", 
   ",", "\<\"prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
