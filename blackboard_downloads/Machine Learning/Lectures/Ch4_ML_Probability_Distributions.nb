Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{"Variance", "[", "trials1000", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.779700880403018*^9, 3.779700883460903*^9}, 
   3.8139575545977106`*^9, {3.813957964322152*^9, 3.8139579651920285`*^9}, {
   3.8139954782123785`*^9, 3.8139954786924124`*^9}},
