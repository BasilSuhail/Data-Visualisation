Cell[TextData[{
 "It is indeed close to the expected probability, ",
 StyleBox["p",
  FontSlant->"Italic"],
 " = 0.1\n\nAn even closer value to 0.1 would be obtained if more people \
would play... Try for, e.g. 10000 people playing."
}], "Text",
 CellChangeTimes->{{3.779687070627667*^9, 3.779687096258823*^9}, {
  3.779687127010734*^9, 
  3.779687171139244*^9}},ExpressionUUID->"8e6a6c0e-2ea8-41fb-b80c-\
f9e194bfd057"],

