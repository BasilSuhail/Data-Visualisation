 CellChangeTimes->{{3.780125698113469*^9, 
  3.780125740304579*^9}},ExpressionUUID->"6471a81e-7302-4251-bf83-\
c5dc5db8ab9d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ExampleData", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<Statistics\>\"", ",", "\"\<BuffaloSnow\>\""}], "}"}], ",", 
   "\"\<LongDescription\>\""}], "]"}]], "Input",
 CellLabel->
  "In[161]:=",ExpressionUUID->"298b8db3-2079-4d80-8d8a-30329862c9b5"],

Cell[BoxData["\<\"Snow accumulations in inches for Buffalo, New York from \
1910 to 1972.\"\>"], "Output",
 CellChangeTimes->{3.780125750520268*^9, 3.7815206824261003`*^9, 
  3.81401584632138*^9},
 CellLabel->
  "Out[161]=",ExpressionUUID->"97e9de20-7d6b-4afe-8538-5fb9fd4ea66f"]
}, Open  ]],

