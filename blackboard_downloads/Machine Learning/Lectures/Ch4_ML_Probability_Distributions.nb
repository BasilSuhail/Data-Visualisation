Cell[CellGroupData[{

Cell["Normally distributed random numbers - Artificial data ", "Subsubsection",
 CellChangeTimes->{
  3.8139974165857954`*^9},ExpressionUUID->"ddcd008b-8a58-4308-9ee5-\
297d9087935b"],

Cell[TextData[{
 "One can use the ",
 StyleBox["RandomVariate", "CodeText"],
 " function to generate normally distributed random numbers. \n\nIn Section \
3.2 on classification, we generated artificial data using random variates for \
the normal distribution. Specifically, we constructed training data set for \
two classes A and B simulated as two random variables  considered two random \
variables, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "A"], "\[Distributed]", 
    RowBox[{
     RowBox[{
      StyleBox["N",
       FontSlant->"Plain"], "(", 
      RowBox[{
       RowBox[{"-", "2"}], ",", 
       SuperscriptBox["2", "2"]}], ")"}], " ", "and", " ", 
     SubscriptBox["X", "B"]}], "\[Distributed]", 
    RowBox[{
     StyleBox["N",
      FontSlant->"Plain"], "(", 
     RowBox[{"2", ",", 
      SuperscriptBox["2", "2"]}], ")"}], " "}], TraditionalForm]],
  ExpressionUUID->"95aace40-67f7-4399-b3e7-120e60d776a6"],
 ":"
}], "Text",
 CellChangeTimes->{{3.8139587638828697`*^9, 3.813958768587949*^9}, {
  3.8139974809729047`*^9, 3.8139976975114946`*^9}, {3.813997832452863*^9, 
  3.8139978352675524`*^9}},ExpressionUUID->"03c12022-21a5-4ca0-a8da-\
42da9e908b0f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"n", "=", "50"}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
   "Number", " ", "of", " ", "random", " ", "variates", " ", "for", " ", 
    "each", " ", "random", " ", "variable"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Mu]", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Sigma]", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"XA", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"NormalDistribution", "[", 
      RowBox[{
       RowBox[{"-", "\[Mu]"}], ",", "\[Sigma]"}], "]"}], ",", "n"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"XB", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"NormalDistribution", "[", 
      RowBox[{"\[Mu]", ",", "\[Sigma]"}], "]"}], ",", "n"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.813481124510393*^9, 3.813481161392758*^9}, {
  3.8139587964845123`*^9, 3.8139588024260025`*^9}, {3.81399757835121*^9, 
  3.8139975835884275`*^9}, {3.813997617891638*^9, 3.813997619988866*^9}, {
  3.8139977014996743`*^9, 3.8139977245406733`*^9}},
 CellLabel->
  "In[132]:=",ExpressionUUID->"d4e79fa4-959c-4d95-b95d-f5efbc06bea9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"XA", ",", 
        RowBox[{"Table", "[", 
         RowBox[{"0", ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], "}"}], "]"}], 
     ",", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"XB", ",", 
        RowBox[{"Table", "[", 
         RowBox[{"0", ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], "}"}], 
      "]"}]}], "}"}], ",", 
   RowBox[{"PlotMarkers", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<OpenMarkers\>\"", ",", " ", "Medium"}], "}"}]}], ",", 
   RowBox[{"PlotLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<A\>\"", ",", "\"\<B\>\""}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.813958808262969*^9, 3.813958821184922*^9}, {
  3.8139976226181836`*^9, 3.8139976272451577`*^9}},
 CellLabel->
  "In[136]:=",ExpressionUUID->"40984dee-a4a8-4f1b-877b-4b48fafc1c0d"],

