Cell["Probability of success in the raffle game is", "Text",
 CellChangeTimes->{{3.7796918687608147`*^9, 3.779691876581997*^9}, {
  3.7796921381182756`*^9, 
  3.779692154661865*^9}},ExpressionUUID->"c337b838-e35c-444d-a662-\
b6230c68d3fe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PDF", "[", 
  RowBox[{
   RowBox[{"BernoulliDistribution", "[", "0.10", "]"}], ",", "0"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.7796918245857897`*^9, 3.779691850262766*^9}, {
   3.779692157513125*^9, 3.779692157605962*^9}, 3.8140048170704107`*^9},
 CellLabel->
  "In[110]:=",ExpressionUUID->"27db58f2-0586-4510-b523-a43a79ece68c"],

Cell[BoxData["0.9`"], "Output",
 CellChangeTimes->{
  3.77969185092581*^9, 3.7796921585530977`*^9, 3.7815099773480015`*^9, 
   3.8140047708095837`*^9, {3.814004813975688*^9, 3.8140048175750265`*^9}},
 CellLabel->
  "Out[110]=",ExpressionUUID->"e5ba24a1-bd0f-4df4-b326-1ea496df68c8"]
}, Open  ]],

Cell["and that of failure ", "Text",
 CellChangeTimes->{{3.779692161558016*^9, 
  3.779692166902231*^9}},ExpressionUUID->"5e6b0ae2-a491-49ea-97de-\
d6f1628f5b83"],

