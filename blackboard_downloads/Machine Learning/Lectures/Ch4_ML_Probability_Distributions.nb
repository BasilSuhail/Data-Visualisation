Cell[TextData[{
 "Random variables are ",
 StyleBox["numerical descriptions",
  FontWeight->"Bold"],
 " of each outcome. We need to represent the results in the bag by numbers.\n\
\nI replace ",
 StyleBox["\[OpenCurlyDoubleQuote]prize\[CloseCurlyDoubleQuote] by 1",
  FontWeight->"Bold"],
 " and ",
 StyleBox["\[OpenCurlyDoubleQuote]no prize\[CloseCurlyDoubleQuote] by 0",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.813994755661376*^9, 3.8139948389275217`*^9}, {
  3.8139959921492915`*^9, 
  3.8139960086790824`*^9}},ExpressionUUID->"3997cab3-e1b2-4464-8dbc-\
d5b9fcd11217"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bagrv", "=", 
  RowBox[{
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<prize\>\"", "\[Rule]", "1"}], ",", 
      RowBox[{"\"\<no prize\>\"", "\[Rule]", " ", "0"}]}], "}"}], "]"}], "[", 
   "bag", "]"}]}]], "Input",
 CellChangeTimes->{{3.8139949236032295`*^9, 3.8139949585790567`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"01134c37-fb06-4835-98ef-f5fceec543c9"],

