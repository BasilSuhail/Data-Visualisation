Cell[CellGroupData[{

Cell["Binomial distribution", "Subsection",
 CellChangeTimes->{{3.8139972471610994`*^9, 
  3.8139972510186224`*^9}},ExpressionUUID->"1278c8cb-5815-4616-9e48-\
6430f0deb0ab"],

Cell[TextData[{
 "The binomial distribution gives the probability that we get ",
 StyleBox["k",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" successes in ",
  FontWeight->"Bold"],
 StyleBox["n",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" Bernoulli trials.\n\n",
  FontWeight->"Bold"],
 "This is an important distribution related to the Bernoulli distribution.",
 StyleBox["\n\n",
  FontWeight->"Bold"],
 "A r.v. X obeying the Binomial distribution with ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "6c59f2e5-316f-4862-87a7-8c6addb1ee75"],
 " attempts and probability of success ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "dd615d72-0345-4bc9-b466-75731cb876b2"],
 " in each attempt is denoted as \n\n\t\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "\[Distributed]", 
    RowBox[{"Bin", "(", 
     RowBox[{"n", ",", "p"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "65cd4072-eeb0-4d10-aac9-b74141cb5935"],
 StyleBox["\n\n",
  FontWeight->"Bold"],
 "Remark: If we do a single attempt, i.e ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "dda669c0-b1f6-426c-97ed-d3f6031e29d7"],
 ", the binomial distribution reduces to the Bernoulli distribution.\n",
 StyleBox["\nMore on the binomial distribution ",
  FontWeight->"Bold"],
 "will be covered in more detail in PX5010 - Statistics and Times Series \
Analysis."
}], "Text",
 CellChangeTimes->{{3.779687724146029*^9, 3.779687794578589*^9}, {
  3.7796880543393383`*^9, 3.779688055379695*^9}, {3.779694148411433*^9, 
  3.779694158635378*^9}, {3.77969439038116*^9, 3.779694457966909*^9}, {
  3.813958097495331*^9, 3.813958124255351*^9}, {3.8139582979398413`*^9, 
  3.8139583282251835`*^9}, {3.8139955282353373`*^9, 3.8139955310907793`*^9}, {
  3.814001362146389*^9, 3.814001365171298*^9}, {3.814001406726167*^9, 
  3.8140015774925404`*^9}},ExpressionUUID->"cf908634-2894-455d-9498-\
8b5fab8df37f"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Continuous r.v.", "Section",
 CellChangeTimes->{{3.7796933807138987`*^9, 3.779693394505706*^9}, {
  3.813958156897606*^9, 3.8139581634175673`*^9}, {3.8139972217283587`*^9, 
  3.813997226476098*^9}, {3.8139973557677183`*^9, 
  3.81399735609273*^9}},ExpressionUUID->"72f422c1-bfb7-4612-8201-\
dbf75d231619"],

Cell[TextData[{
 "If X is a continuous r.v., we need the probability density function (",
 StyleBox["p.d.f.",
  FontWeight->"Bold"],
 ") concept.\n\nExample of continuous r.v.: Height of people, speed of \
molecules in a gas, etc\n\nThe problem with continuous random variables is \
that the values they take cannot be enumerated (they can take any value in an \
interval of the real numbers)"
}], "Text",
 CellChangeTimes->{{3.779695204708823*^9, 3.7796953931725492`*^9}, {
  3.779695583347528*^9, 3.7796956536355343`*^9}, {3.77969604568193*^9, 
  3.779696047266346*^9}, {3.779701110903305*^9, 
  3.779701114247595*^9}},ExpressionUUID->"5a02c6d1-6a75-4653-b4d2-\
751b527450c6"],

Cell[CellGroupData[{

Cell["Mission impossible - Hitting a real number", "Subsection",
 CellChangeTimes->{
  3.779696403779524*^9},ExpressionUUID->"4996126c-099c-4079-8730-\
f3df58b5e0e8"],

