   ",", "0", ",", "0"}], "}"}]], "Output",
 CellChangeTimes->{3.813994968970584*^9},
 CellLabel->"Out[4]=",ExpressionUUID->"04f64721-e7d3-47eb-9cd8-e1d7cc2d8d10"]
}, Open  ]],

Cell["\<\
1000 people playing corresponds to 1000 random choices from the bag:\
\>", "Text",
 CellChangeTimes->{{3.779686939908923*^9, 
  3.779686997875869*^9}},ExpressionUUID->"5a95598d-1876-4ea0-a6e5-\
e94e252446a4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RandomChoice", "[", "bagrv", "]"}]], "Input",
 CellChangeTimes->{3.8140042885525746`*^9},
 CellLabel->
  "In[102]:=",ExpressionUUID->"f6c2110a-4712-49a3-9f00-94fea425013c"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{{3.814004288931559*^9, 3.8140043034292755`*^9}, 
   3.814004426526792*^9},
 CellLabel->
  "Out[102]=",ExpressionUUID->"ff023e93-8a08-4377-8d58-4bef008b9301"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"trials1000", "=", 
   RowBox[{"RandomChoice", "[", 
    RowBox[{"bagrv", ",", "1000"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.779686815480633*^9, 3.7796868191270447`*^9}, {
   3.7796869164853077`*^9, 3.779686933765006*^9}, {3.779686987241452*^9, 
