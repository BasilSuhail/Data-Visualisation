Cell[CellGroupData[{

Cell["\<\
Plotting histograms for the probability to fall in each bin (i.e. probability \
instead of frequency). This gives a better comparison between the two \
histograms.\
\>", "Item",
 CellChangeTimes->{{3.814017185787423*^9, 
  3.814017245105217*^9}},ExpressionUUID->"100904ff-52cc-4675-b084-\
