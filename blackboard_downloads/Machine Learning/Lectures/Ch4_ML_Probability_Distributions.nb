Cell[TextData[StyleBox["Normalization", "Subsubsection"]], "Text",
 CellChangeTimes->{{3.780126886942504*^9, 
  3.780126889566535*^9}},ExpressionUUID->"23305f6a-5c61-48cd-9cae-\
02d3ddbc517b"],

Cell[TextData[{
 "Since the probability that the random variable takes any value in [-\
\[Infinity],+\[Infinity]] must be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "\[CapitalOmega]", ")"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"f8522956-c08c-453a-bcb4-b2cae9a4cb0a"],
 " (i.e. the probability of the whole sample space),\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", 
     RowBox[{
      RowBox[{"-", "\[Infinity]"}], "<", "X", "<", "\[Infinity]"}], ")"}], 
    " ", "=", " ", 
    RowBox[{"Area", " ", "under", " ", 
     RowBox[{"f", "(", "x", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "58f47482-ca0d-4848-a747-d2e639900c4a"],
 " = 1"
}], "Text",
 CellChangeTimes->{{3.78012690046281*^9, 
  3.7801270083676987`*^9}},ExpressionUUID->"a5a19c5f-c534-46be-aef1-\
6942714e1251"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Normal distribution", "Subsection",
 CellChangeTimes->{
  3.813997373008939*^9},ExpressionUUID->"611bb28d-2a44-47eb-be0f-\
c6cd861d0575"],

Cell["\<\
The normal distribution is the most ubiquitous of all distributions.

Any variation which is the sum of many small independent contributions, leads \
to normal r.v.\[CloseCurlyQuote]s

Examples: \
\>", "Text",
 CellChangeTimes->{{3.77969675672075*^9, 3.779696826832509*^9}, {
  3.7796979288174*^9, 3.779697997713142*^9}, {3.780061039787871*^9, 
  3.7800610411766667`*^9}},ExpressionUUID->"f81dcc09-42ff-494f-b631-\
b98081063721"],

Cell["\<\
Height of people (\[OpenCurlyDoubleQuote]height\[CloseCurlyDoubleQuote] \
depends on several factors - diet, genes, history of illness, etc)\
\>", "Item",
 CellChangeTimes->{{3.779698004360264*^9, 
  3.779698005621961*^9}},ExpressionUUID->"dd440489-ecbd-4a0c-bd9a-\
6b211b02050f"],

Cell["\<\
Annual rainfall (several factors will affect the variations in annual \
rainfall)\
\>", "Item",
 CellChangeTimes->{{3.779698004360264*^9, 
  3.779698029425049*^9}},ExpressionUUID->"275de73b-ee74-4d4a-bd3c-\
3930d07a4cd0"],

Cell["The p.d.f. for the normal distribution is", "Text",
 CellChangeTimes->{{3.779701102086033*^9, 
  3.7797011450472507`*^9}},ExpressionUUID->"e81f717f-6a2f-47b3-bbda-\
ef2528e64d54"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PDF", "[", 
  RowBox[{
   RowBox[{"NormalDistribution", "[", 
    RowBox[{"\[Mu]", ",", "\[Sigma]"}], "]"}], ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.7797010808080482`*^9, 3.7797010955647078`*^9}},
 CellLabel->
  "In[131]:=",ExpressionUUID->"d559d7fb-047a-4a90-86cc-c3cd959e9f16"],

Cell[BoxData[
 FractionBox[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"x", "-", "\[Mu]"}], ")"}], "2"], 
     RowBox[{"2", " ", 
      SuperscriptBox["\[Sigma]", "2"]}]]}]], 
  RowBox[{
   SqrtBox[
    RowBox[{"2", " ", "\[Pi]"}]], " ", "\[Sigma]"}]]], "Output",
 CellChangeTimes->{3.779701097358595*^9, 3.814012329568779*^9},
 CellLabel->
  "Out[131]=",ExpressionUUID->"f9df016f-d986-4c5e-ab35-7d745ba277e9"]
}, Open  ]],

Cell["Here, ", "Text",
 CellChangeTimes->{{3.7797011504267883`*^9, 3.7797011548872213`*^9}, {
  3.779701269720582*^9, 
  3.7797012726971827`*^9}},ExpressionUUID->"68ec65b8-63d5-446c-96d0-\
ea2710040c31"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "=", 
    RowBox[{"E", "(", "X", ")"}]}], TraditionalForm]],ExpressionUUID->
  "4d46c0f4-8b7a-4ac3-947e-829b79389344"],
 "  - Expectation "
}], "Item",
 CellChangeTimes->{{3.779701280429571*^9, 3.779701296132389*^9}, {
  3.779701335849176*^9, 
  3.779701344825161*^9}},ExpressionUUID->"bb2cebcd-7098-445f-9ed9-\
3d12df6ebbbf"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Sigma]", "2"], "=", 
    RowBox[{"Var", "(", "X", ")"}]}], TraditionalForm]],ExpressionUUID->
  "b8e5b9a6-b9f9-4808-ab43-7bc77915dae7"],
 "  - Variance"
}], "Item",
 CellChangeTimes->{{3.779701280429571*^9, 
  3.7797013518176403`*^9}},ExpressionUUID->"5aa9e022-9d3b-480e-a239-\
5e6ba9884e90"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", "=", 
    RowBox[{"SD", "(", "X", ")"}]}], TraditionalForm]],ExpressionUUID->
  "c5bca10e-b02a-40b0-9eec-7468df430884"],
 " - Standard deviation"
}], "Item",
 CellChangeTimes->{{3.779701280429571*^9, 
  3.779701365369547*^9}},ExpressionUUID->"fc2b84d9-d227-4077-8211-\
f852a91b0515"],

Cell[TextData[{
 "A random variable X obeying a normal distribution with mean \[Mu] and \
variance ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Sigma]", "2"], TraditionalForm]],ExpressionUUID->
  "c02669ee-07f2-4782-90aa-8fd9add1e63a"],
 " is denoted as\n\n\t\t\t\t\t\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "\[Distributed]", 
    RowBox[{"N", "(", 
     RowBox[{"\[Mu]", ",", 
      SuperscriptBox["\[Sigma]", "2"]}]}]}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "46654b4a-4257-4cc0-99dc-ebb8336fa138"],
 ")"
}], "Text",
 CellChangeTimes->{{3.7800610517528615`*^9, 3.7800611457587566`*^9}, {
  3.813999822733795*^9, 
  3.813999824704516*^9}},ExpressionUUID->"297a01f8-6fa6-4836-9d8d-\
8bb359941099"],

Cell[CellGroupData[{

Cell["Effect of varying \[Mu]", "Subsubsection",
 CellChangeTimes->{
  3.8139973904753246`*^9},ExpressionUUID->"6d41e037-7e93-45fc-8416-\
290d1baedd6b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"PDF", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", 
         RowBox[{"\[Mu]", ",", "1.5"}], "]"}], ",", "x"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Mu]", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1", ",", "2"}], "}"}]}], "}"}]}], "]"}], "//",
     "Evaluate"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "6"}], ",", "6"}], "}"}], ",", 
   RowBox[{"Filling", "\[Rule]", "Axis"}]}], "]"}]], "Input",
 CellLabel->
  "In[181]:=",ExpressionUUID->"30be75c4-c516-47cd-ba4d-61a17bc38df9"],

