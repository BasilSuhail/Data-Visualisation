   3.781509859637217*^9, {3.813994992983509*^9, 3.813995027965864*^9}, {
   3.8139951252359495`*^9, 3.813995130903998*^9}, {3.8140044101211863`*^9, 
   3.8140044266454678`*^9}},
 CellLabel->
  "Out[104]=",ExpressionUUID->"2203eb97-93d6-48b8-bec7-ab111341eb0e"]
}, Open  ]],

