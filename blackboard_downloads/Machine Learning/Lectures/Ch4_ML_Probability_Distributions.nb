Cell["Example", "Subsection",
 CellChangeTimes->{{3.780125620641815*^9, 
  3.7801256245936813`*^9}},ExpressionUUID->"0a73d265-09b2-4784-a156-\
9e90412622c7"],

Cell["\<\
The BuffaloSnow dataset from the Wolfram Data Repository gives the snow \
accumulations in inches for Buffalo, New York from 1910 to 1972. We want to \
find the distribution of the snow accumulations.\
\>", "Text",
 CellChangeTimes->{{3.7801256318896637`*^9, 
  3.780125695172379*^9}},ExpressionUUID->"56656e2f-ed80-4d63-84b6-\
d9a0707bad36"],

