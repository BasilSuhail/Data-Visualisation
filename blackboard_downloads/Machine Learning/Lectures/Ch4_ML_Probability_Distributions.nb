 CellLabel->"In[79]:=",ExpressionUUID->"522d92f9-237d-40ef-927f-bd4e05ba7929"],

Cell[BoxData["0.9`"], "Output",
 CellChangeTimes->{3.779692184498893*^9, 3.7815099958133698`*^9},
 CellLabel->"Out[79]=",ExpressionUUID->"631b7ff9-6d2a-4262-b012-4f207849efd1"]
