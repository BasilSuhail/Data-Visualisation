   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", ",", "\<\"no prize\"\>", 
   ",", "\<\"no prize\"\>"}], "}"}]], "Output",
 CellChangeTimes->{{3.7796867909232197`*^9, 3.779686801328211*^9}, 
