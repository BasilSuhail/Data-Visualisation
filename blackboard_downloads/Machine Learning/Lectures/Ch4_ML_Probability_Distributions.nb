Cell[CellGroupData[{

Cell["Task for you", "Subsection",
 CellChangeTimes->{{3.780121888898185*^9, 3.780121889457011*^9}, {
  3.7815035548462086`*^9, 
  3.78150355640594*^9}},ExpressionUUID->"074f606a-31dd-402c-9884-\
c75de43153ee"],

Cell[TextData[{
 "Repeat the steps in the previous example but now for the ",
 StyleBox["\[OpenCurlyDoubleQuote]ChickenWeight\[CloseCurlyDoubleQuote]", 
  "CodeText"],
 " dataset from the Wolfram Repository. Do you expect a normal distribution \
for the weight of chickens? Do you find enough evidence in favour of a normal \
distribution?"
}], "Text",
 CellChangeTimes->{{3.7801254091217213`*^9, 3.780125453044787*^9}, {
  3.780125494770049*^9, 3.7801255473623943`*^9}, {3.780127723669486*^9, 
  3.780127729237238*^9}, {3.780127773509447*^9, 3.7801278026290503`*^9}, {
  3.7801286016537867`*^9, 3.78012861509435*^9}, {3.814016510546417*^9, 
  3.8140165337993217`*^9}},ExpressionUUID->"cc8c3497-c0ab-4c53-996c-\
65ac061de493"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Learning distributions", "Section",
 CellChangeTimes->{{3.780129736082056*^9, 
  3.78012975560255*^9}},ExpressionUUID->"f4b18924-fafe-4e4e-a220-\
2b31559a1874"],

Cell[TextData[{
 "In the previous section, we have seen how to classify data into known, \
important distributions.\n\nIn some cases, it might not be possible to find a \
known distribution that fits well the data. In this case, it is possible to \
use a ",
 StyleBox["machine learning procedure",
  FontWeight->"Bold"],
 " that uses data to train an object that attempts to represent an underlying \
distribution for the examples given.\n\nIn Wolfram Language, this is achieved \
with the ",
 StyleBox["LearnDistribution", "CodeText"],
 " function."
}], "Text",
 CellChangeTimes->{{3.780129775890126*^9, 3.780129952003037*^9}, {
  3.780130031987706*^9, 3.7801300731244583`*^9}, {3.814002161098036*^9, 
  3.8140021621292815`*^9}},ExpressionUUID->"cb20caea-340d-48e4-ad59-\
5e922ed4baa5"],

Cell[CellGroupData[{

Cell["Discrete random variables", "Subsection",
 CellChangeTimes->{{3.780132369458721*^9, 
  3.780132379379018*^9}},ExpressionUUID->"14994084-a0da-4ac7-afa1-\
d9d5f26c9c2b"],

