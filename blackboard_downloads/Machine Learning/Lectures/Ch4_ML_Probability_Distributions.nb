 CellLabel->
  "In[103]:=",ExpressionUUID->"83636c3a-21fb-4af9-bbec-0f3fbb68bb2e"],

Cell["\<\
The probability of success is then estimated by the fraction of people \
obtaining a prize:\
\>", "Text",
 CellChangeTimes->{{3.7796871021314697`*^9, 
  3.779687122595402*^9}},ExpressionUUID->"d8f75e48-1b12-4f92-9fc6-\
5940d4dc27c8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"p", "=", 
  FractionBox[
   RowBox[{"Count", "[", 
    RowBox[{"trials1000", ",", "1"}], "]"}], "1000"]}]], "Input",
 CellChangeTimes->{{3.7796870153351793`*^9, 3.779687049380246*^9}, 
   3.8139949924170246`*^9},
 CellLabel->
  "In[104]:=",ExpressionUUID->"75afa6c1-440c-47e4-a4d8-0264f82de079"],

