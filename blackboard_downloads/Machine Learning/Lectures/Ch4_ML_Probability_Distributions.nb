Cell["Probability density function", "Subsection",
 CellChangeTimes->{{3.779696610369874*^9, 
  3.779696617458212*^9}},ExpressionUUID->"259931eb-1a11-48c7-975b-\
75a12fca04c6"],

Cell[TextData[{
 "The probability density function (pdf) of a continuous r.v. X is a \
non-negative function, f, such that \n\t\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", 
     RowBox[{"x", "\[LessEqual]", "X", "\[LessEqual]", 
      RowBox[{"x", "+", "\[CapitalDelta]x"}]}], ")"}], "=", 
    RowBox[{
     RowBox[{"f", "(", "x", ")"}], "\[CapitalDelta]x"}]}], TraditionalForm]],
  ExpressionUUID->"d3c54a5e-8a04-4751-85fe-472123e947d7"]
}], "Text",
 CellChangeTimes->{{3.77969663797217*^9, 
  3.779696740100361*^9}},ExpressionUUID->"b8771d48-ecf8-43aa-a257-\
761525007082"],

