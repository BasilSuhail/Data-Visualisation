Cell["Why do we need probability?", "Section",
 CellChangeTimes->{{3.778764702960601*^9, 3.7787647069126377`*^9}, {
  3.778767149381019*^9, 
  3.778767151140176*^9}},ExpressionUUID->"647f62de-7893-41cb-97b8-\
873a9214ad66"],

Cell["\<\
Consider a game in which you win a prize if you get an object from the \
\[OpenCurlyDoubleQuote]Win\[CloseCurlyDoubleQuote] class or lose if you get \
an object from the \[OpenCurlyDoubleQuote]Lose\[CloseCurlyDoubleQuote] class. \
All you know is some of the objects in each class. You don\[CloseCurlyQuote]t \
know all objects in each class! \
\>", "Text",
 CellChangeTimes->{{3.777970072208363*^9, 3.777970082270461*^9}, {
  3.777970196942951*^9, 3.7779702644950743`*^9}, {3.77798738220392*^9, 
