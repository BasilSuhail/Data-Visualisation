Cell[CellGroupData[{

Cell["Simulating many experiments", "Subsubsection",
 CellChangeTimes->{{3.7805804836817102`*^9, 3.7805804882910585`*^9}, {
  3.7805810491708727`*^9, 3.7805810809790745`*^9}, {3.780581323557086*^9, 
  3.7805813380881586`*^9}},ExpressionUUID->"a56e86e0-4360-4ff5-a0f7-\
ee278dc30871"],

Cell[TextData[{
 "Let us define a function that gives the relative frequency of heads in a \
series of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " trials:"
}], "Text",
 CellChangeTimes->{{3.7788414465377617`*^9, 3.778841470078703*^9}, {
  3.778843147828518*^9, 
  3.7788431863332148`*^9}},ExpressionUUID->"0380214a-66d5-4d44-8508-\
8c3ed3c61958"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"relfreq", "[", "n_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"n0", "=", "n"}], ",", "count1", ",", "freq1"}], "}"}], ",", 
     RowBox[{
      RowBox[{"count1", "=", 
       RowBox[{"KeySort", "[", 
        RowBox[{"Counts", "[", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}], ",", "n0"}], "]"}], "]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"freq1", "=", 
       RowBox[{
        RowBox[{"count1", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "/", "n0"}]}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.778841871884355*^9, 3.778842000098353*^9}, {
  3.780580909753753*^9, 3.7805809099464664`*^9}, {3.7807386950445604`*^9, 
  3.7807386997999425`*^9}, {3.7807391102539845`*^9, 3.7807391157701473`*^9}, {
  3.780739521561057*^9, 3.7807395235627823`*^9}, {3.7807396020335093`*^9, 
  3.780739604728899*^9}, {3.78073972437142*^9, 3.7807397277983866`*^9}, {
  3.780886614887148*^9, 3.7808866194368725`*^9}, {3.7808873360537367`*^9, 
  3.7808873416752815`*^9}, {3.812872131006797*^9, 3.812872150841827*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"30931805-7264-42d8-b7bf-a76f02e73d74"],

