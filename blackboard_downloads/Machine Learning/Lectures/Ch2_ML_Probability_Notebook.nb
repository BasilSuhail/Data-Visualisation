Cell[TextData[{
 "The value ",
 StyleBox["P",
  FontSlant->"Italic"],
 "(",
 StyleBox["H",
  FontSlant->"Italic"],
 ")=1/2 is only obtained with certainty for infinitely many trials.\n\nIf we \
repeat experiments with ",
 StyleBox["n",
  FontSlant->"Italic"],
 " trials many times, the dispersion of the results for ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["n", "H"], 
    SubscriptBox["n", "T"]], TraditionalForm]],ExpressionUUID->
  "b2fef982-ae9f-4997-b6db-1e160746d868"],
 " decreases with increasing ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "T"], TraditionalForm]],ExpressionUUID->
  "109ff258-d712-4bc2-a08f-8fa5abf2c45d"]
}], "Text",
 CellChangeTimes->{
  3.778844403318091*^9, {3.778844808435645*^9, 3.778844865555482*^9}, {
   3.778845533430414*^9, 3.7788455750871887`*^9}, {3.7788456424645653`*^9, 
   3.778845728242866*^9}},ExpressionUUID->"1ce0f5eb-91f4-40ee-9e9b-\
53a7a6f66982"],

