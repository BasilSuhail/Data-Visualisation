 StyleBox["Aside",
  FontSlant->"Italic"],
 ": Here, we use 0/1 for H/T but one could also use \[OpenCurlyDoubleQuote]H\
\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]T\[CloseCurlyDoubleQuote]:"
}], "Text",
