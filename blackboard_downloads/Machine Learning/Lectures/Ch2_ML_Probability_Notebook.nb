  3.778765754372154*^9}},ExpressionUUID->"28566884-a708-4fbe-a0a7-\
0a81d4de5269"],

Cell[TextData[{
 "Can you certainly tell if you win or lose? One could use a classifier to \
decide but the decision is not easy in all cases...\n\nThe ",
 StyleBox["heart",
  FontWeight->"Bold"],
 " does not appear in any of the examples but most blue objects are in the \
Win class. You might reasonably conclude that you win if you get a blue \
heart.\n\nThe yellow circle and blue cloud are more difficult to classify...\n\
\nThe most reasonable is to talk about the ",
 StyleBox["chances",
  FontWeight->"Bold"],
 " that a previously unseen object is in each class. \n\n",
 StyleBox["Probability",
  FontWeight->"Bold"],
 " allows us to formalise and quantify the concept of chance."
}], "Text",
 CellChangeTimes->{{3.778765541332357*^9, 3.778765639684759*^9}, {
  3.7787657613642273`*^9, 3.778765863332555*^9}, {3.778765916724662*^9, 
  3.778766062055292*^9}, {3.778767191002467*^9, 
  3.7787672003095293`*^9}},ExpressionUUID->"7096a360-8828-4216-a041-\
1a1048b029b7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Basics: Experiments and events", "Section",
 CellChangeTimes->{{3.778767586213025*^9, 
  3.778767593683588*^9}},ExpressionUUID->"6d8c91ab-fee6-430e-9462-\
36295f339989"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Experiment (or trial):",
  FontWeight->"Bold"],
 " Action which results in one of several possible outcomes."
}], "Item",
 CellChangeTimes->{{3.778767679739868*^9, 
  3.7787676901890287`*^9}},ExpressionUUID->"1c8e3176-0e93-45c3-b61c-\
5e68bdedf762"],

Cell["Examples: Toss a coin, Toss a six-sided dice...", "ItemParagraph",
 CellChangeTimes->{{3.778767721652175*^9, 3.7787677321407824`*^9}, {
   3.7787678716629877`*^9, 3.778767872235744*^9}, 
   3.8128712350267305`*^9},ExpressionUUID->"1cad9836-cd21-40e1-978e-\
242782c63793"],

Cell[TextData[{
 StyleBox["Sample space:",
  FontWeight->"Bold"],
 " Set of all possible outcomes of the experiment."
}], "Item",
 CellChangeTimes->{{3.778767895284073*^9, 
  3.77876792787702*^9}},ExpressionUUID->"b124dd88-d787-46b5-b4b3-\
ec72fd455077"],

Cell["Often denoted by \[CapitalOmega] (Greek capital \
\[OpenCurlyDoubleQuote]omega\[CloseCurlyDoubleQuote])", "ItemParagraph",
 CellChangeTimes->{{3.778767947332238*^9, 
  3.778767976093202*^9}},ExpressionUUID->"c1eb288e-3fec-4881-a75f-\
bb1c425a8e57"],

Cell[TextData[{
 "Example: For a coin, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalOmega]", "=", 
    RowBox[{"{", 
     RowBox[{"Heads", ",", " ", "Tails"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"e6d844b4-611c-4996-8680-3705e3c83f87"]
}], "ItemParagraph",
 CellChangeTimes->{{3.778767947332238*^9, 
  3.778768023251788*^9}},ExpressionUUID->"c3dbdc05-81c5-440f-9db5-\
7b9bd008fd24"],

Cell[TextData[{
 StyleBox["Event:",
  FontWeight->"Bold"],
 " Collection of outcomes of an experiment (elements from \[CapitalOmega])"
}], "Item",
 CellChangeTimes->{{3.7787680619881268`*^9, 
  3.778768096436059*^9}},ExpressionUUID->"cc007325-74b5-4056-8779-\
30a157303d6c"],

Cell["Denoted by capital letters: A, B, C ...", "ItemParagraph",
 CellChangeTimes->{{3.778768110132524*^9, 
  3.778768136987183*^9}},ExpressionUUID->"e1803e36-120e-4851-8e3d-\
de24d93f2a4d"],

Cell["Empty event: Contains no outcomes (denoted as \[EmptySet])", \
"ItemParagraph",
 CellChangeTimes->{{3.778768110132524*^9, 
  3.778768211501443*^9}},ExpressionUUID->"dd580c9c-ce63-44ce-ad17-\
c713100c72e7"],

Cell["\<\
Example: Toss a six-sided die and obtain an odd number. The event is \
A={1,3,5}.\
\>", "ItemParagraph",
 CellChangeTimes->{{3.778768110132524*^9, 
  3.778768275843244*^9}},ExpressionUUID->"546a5a7e-da8c-4ddc-822b-\
79031b50d2bc"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Probability", "Section",
 CellChangeTimes->{{3.778767459958042*^9, 3.778767467348455*^9}, 
   3.778768681812398*^9},ExpressionUUID->"07364ffb-5191-4541-aad5-\
9e629352179f"],

Cell[TextData[{
 StyleBox["Rough definition:",
  FontWeight->"Bold"],
 " The probability of an event of a random experiment is a number ",
 StyleBox["between 0 and 1",
  FontWeight->"Bold"],
 " which measures the likelihood of the event occurring when the experiment \
is performed.\n\nThe probability of an event ",
 StyleBox["A",
  FontSlant->"Italic"],
 " is denoted by ",
 StyleBox["P",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox["(",
  FontWeight->"Bold"],
 StyleBox["A",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[")",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.778767479139967*^9, 3.778767499463382*^9}, {
  3.7787685782448483`*^9, 3.778768605424234*^9}, {3.778768650884197*^9, 
  3.7787686900847187`*^9}},ExpressionUUID->"510de30f-4228-4f25-9a1d-\
fef0b394b6ad"],

Cell[CellGroupData[{

Cell["Probability as a relative frequency", "Subsection",
 CellChangeTimes->{{3.778768720084383*^9, 
  3.778768729948588*^9}},ExpressionUUID->"9450eed0-3878-4c64-a459-\
0398eb3ec9f3"],

Cell["\<\
Assume that experiments can be repeated in identical conditions:\
\>", "Text",
 CellChangeTimes->{
  3.778768760044462*^9},ExpressionUUID->"99e69f0e-a405-4a68-94c6-\
a4cc5795b713"],

Cell[CellGroupData[{

Cell["Some regularity between different experiments.", "Item",
 CellChangeTimes->{{3.778768784524432*^9, 
  3.7787687859469833`*^9}},ExpressionUUID->"a5f39e21-ed22-4381-a559-\
7e50d195d0a0"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "T"], ":", " "}], TraditionalForm]],ExpressionUUID->
  "beb52c33-93cb-445a-87ac-32fb1d88b85e"],
 "Number of trials"
}], "Item",
 CellChangeTimes->{{3.778768784524432*^9, 
  3.7787688091463823`*^9}},ExpressionUUID->"cc46cee4-d0eb-464f-b11f-\
315312e58828"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "A"], ":"}], TraditionalForm]],ExpressionUUID->
  "9289ebf8-2970-4f21-98a9-35fbac8f439a"],
 " Number of times the event ",
 StyleBox["A",
  FontSlant->"Italic"],
 " is observed."
}], "Item",
 CellChangeTimes->{{3.778768784524432*^9, 
  3.778768847323188*^9}},ExpressionUUID->"a3826000-429f-44cb-ac18-\
406873cf49c8"],

Cell[TextData[{
 "The relative frequency of event ",
 StyleBox["A",
  FontSlant->"Italic"],
 ": ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["n", "A"], 
    SubscriptBox["n", "T"]], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"b9ae0b73-dd6a-4c77-9659-e5f4368bb948"]
}], "Item",
 CellChangeTimes->{{3.778768784524432*^9, 
  3.7787688975725117`*^9}},ExpressionUUID->"788d1927-0ad0-4c84-a996-\
fd2c4240675c"]
}, Open  ]],

Cell[TextData[{
 "\n",
 StyleBox["Frequentist interpretation",
  FontWeight->"Bold"],
 " of probability:"
}], "Text",
 CellChangeTimes->{{3.778768930404418*^9, 
  3.778768976404747*^9}},ExpressionUUID->"5f516ffb-a22c-4014-a01d-\
80fdb6ea5f12"],

Cell[TextData[{
 "The probability of ",
 StyleBox["A",
  FontSlant->"Italic"],
 " is the relative frequency of ",
 StyleBox["A",
  FontSlant->"Italic"],
 " in the limit of ",
 StyleBox["infinite number of trials",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.7787689663639727`*^9, 3.778769006452942*^9}, {
  3.778769138148912*^9, 
  3.778769164772443*^9}},ExpressionUUID->"aaab971d-d9d0-4e5b-9ede-\
aa8678392de0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox["P",
    FontSlant->"Italic"], 
   RowBox[{"(", 
    StyleBox["A",
     FontSlant->"Italic"], ")"}]}], "=", 
  FormBox[
   RowBox[{
    UnderscriptBox["lim", 
     RowBox[{
      SubscriptBox["n", "T"], "\[Rule]", " ", "\[Infinity]"}]], " ", 
    FractionBox[
     SubscriptBox["n", "A"], 
     SubscriptBox["n", "T"]]}],
   TraditionalForm]}]], "DisplayFormula",
 CellChangeTimes->{
  3.778769300782057*^9},ExpressionUUID->"2bc382e8-e524-4c0b-bb54-\
6b954faf735c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Example: Tossing a ",
 StyleBox["fair",
  FontSlant->"Italic"],
 " coin"
}], "Subsection",
 CellChangeTimes->{{3.778769348980648*^9, 
  3.7787693669324903`*^9}},ExpressionUUID->"ca637dca-60ba-4c05-b612-\
6f019a9fc56b"],

Cell[TextData[{
 "Two events: ",
 StyleBox["H",
  FontSlant->"Italic"],
 " (``heads\[CloseCurlyQuote]\[CloseCurlyQuote]) and ",
 StyleBox["T",
  FontSlant->"Italic"],
 " (``tails\[CloseCurlyQuote]\[CloseCurlyQuote])\n\nAbstraction:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "H", ")"}], "=", 
    FractionBox["1", "2"]}], TraditionalForm]],ExpressionUUID->
  "90dda5d3-d449-422a-8176-7ed19ddfa6c7"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "T", ")"}], "=", 
    FractionBox["1", "2"]}], TraditionalForm]],ExpressionUUID->
  "dad0d49e-1b4d-4688-b3c1-eaef9349d91c"],
 "\n\nHow good is the abstraction?"
}], "Text",
 CellChangeTimes->{{3.7787697366684732`*^9, 3.778769786823072*^9}, {
  3.7787698301320972`*^9, 
  3.778769838004909*^9}},ExpressionUUID->"17e03a27-f957-4b17-95a1-\
6166f079d318"],

Cell[CellGroupData[{

Cell["Simulate experiments with a large number of trials.", "Item",
 CellChangeTimes->{{3.778769855100272*^9, 
  3.7787698671796*^9}},ExpressionUUID->"b9010ef5-693b-4b8c-b36b-5810fa565ee7"],

Cell[TextData[{
 "The relative frequency of ",
 StyleBox["H",
  FontSlant->"Italic"],
 " tends to 1/2 but one needs many trials."
}], "Item",
 CellChangeTimes->{{3.778769855100272*^9, 
  3.778769886980371*^9}},ExpressionUUID->"9bdd7ac8-b02a-48f7-8111-\
d2fea38a3722"]
}, Open  ]],

