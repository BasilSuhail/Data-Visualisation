   RowBox[{"{", 
    RowBox[{"\"\<Class\>\"", ",", 
     RowBox[{"{", 
      RowBox[{"\"\<male\>\"", ",", "\"\<female\>\""}], "}"}]}], "}"}], 
   "]"}]}]], "Input",
