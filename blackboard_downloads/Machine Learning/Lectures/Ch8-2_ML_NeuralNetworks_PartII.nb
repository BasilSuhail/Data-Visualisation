Cell[CellGroupData[{

Cell["Decoding data", "Subsection",
 CellChangeTimes->{{3.782186919934187*^9, 
  3.782186922318857*^9}},ExpressionUUID->"c908c55c-812b-44fe-a68c-\
e84af638c771"],

Cell["\<\
In some cases, the outputs of neural nets are numerical predictions that do \
not require decoding. 

In many cases, however, we would like to convert numerical arrays to human \
readable classes, images, audio, etc.\
\>", "Text",
 CellChangeTimes->{{3.782187394815261*^9, 3.7821874883318596`*^9}, {
  3.782187638119508*^9, 
  3.7821876394180474`*^9}},ExpressionUUID->"27945a55-59b2-4662-943b-\
84063aa34bdb"],

Cell[CellGroupData[{

Cell["Decoding to classes", "Subsubsection",
 CellChangeTimes->{{3.7821878843577933`*^9, 
  3.782187888793313*^9}},ExpressionUUID->"9478ad86-194e-4e13-bdcf-\
7b9f2df0b706"],

Cell["\<\
For example, the output of an ANN could give the probability that the gender \
of a face corresponds to male or female \
\>", "Text",
 CellChangeTimes->{{3.78218813050609*^9, 
  3.7821882192766056`*^9}},ExpressionUUID->"0f9e1689-f034-4017-a90f-\
35e578d46d52"],

