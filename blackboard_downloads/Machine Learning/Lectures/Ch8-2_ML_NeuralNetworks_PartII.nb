Cell[CellGroupData[{

Cell["Pre-trained Neural Networks", "Section",
 CellChangeTimes->{
  3.780037452737472*^9, {3.815064896540778*^9, 
   3.815064910729108*^9}},ExpressionUUID->"a0bacd8c-81a2-4857-aa90-\
ef6142b320d7"],

Cell[TextData[{
 "The ",
 ButtonBox["Wolfram Neural Net Repository",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://resources.wolframcloud.com/NeuralNetRepository"], None},
  ButtonNote->"http://resources.wolframcloud.com/NeuralNetRepository"],
 " is a public resource that hosts an expanding collection of trained and \
untrained neural network models suitable for immediate evaluation, training, \
visualization, transfer learning and more. \n\nIn this section, we will"
}], "Text",
 CellChangeTimes->{{3.7800374691067247`*^9, 3.780037494075345*^9}, {
  3.780037575900375*^9, 3.7800375760679197`*^9}, {3.782188541950675*^9, 
  3.782188560889058*^9}},ExpressionUUID->"6938908c-4357-4877-a0f5-\
831dfe08aec1"],

Cell["\<\
Focus a bit on a classic: An ANN to identify images of handwritten images.\
\>", "Item",
 CellChangeTimes->{{3.782188573249674*^9, 3.7821886283909874`*^9}, 
   3.782188743348117*^9},ExpressionUUID->"36e27d8d-52aa-4b43-a5f8-\
fef171932338"],

Cell["\<\
Give two more examples: Facial features and a machine trained to paint as \
Cezanne (really?).\
\>", "Item",
 CellChangeTimes->{{3.782188573249674*^9, 3.782188700077159*^9}, 
   3.7821887454580865`*^9},ExpressionUUID->"59181637-ff1b-4990-88ee-\
52db70507286"],

Cell[TextData[{
 "Feel free to explore the ",
 ButtonBox["Wolfram Neural Net Repository",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://resources.wolframcloud.com/NeuralNetRepository"], None},
  ButtonNote->"http://resources.wolframcloud.com/NeuralNetRepository"],
 " to find many interesting ANNs."
}], "Item",
 CellChangeTimes->{{3.782188573249674*^9, 
  3.7821887401048946`*^9}},ExpressionUUID->"20bdb9a4-26ff-445a-8f60-\
afa1b52bd077"],

Cell[CellGroupData[{

Cell["\<\
LeNet Trained on MNIST Data - Identify the handwritten digit in an image\
\>", "Subsection",
 CellChangeTimes->{{3.782108143310902*^9, 3.7821081537627563`*^9}, {
   3.7821082271815186`*^9, 3.7821082307630887`*^9}, 
   3.782108267845735*^9},ExpressionUUID->"202ce063-31ef-4ad5-81e9-\
93e6d7f14f19"],

Cell[TextData[{
 "This pioneer work for image classification with convolutional neural nets \
was released in 1998. It was developed by Yann LeCun and his collaborators at \
AT&T Labs while they experimented with a large range of machine learning \
solutions for classification on the MNIST dataset.\n\nIt is a classic in \
machine learning.\n\n",
 StyleBox["Training data:",
  FontWeight->"Bold"],
 " MNIST Database of Handwritten Digits, consisting of 60,000 training and \
10,000 test grayscale images of size 28x28."
}], "Text",
 CellChangeTimes->{{3.7821082927899165`*^9, 3.782108333513197*^9}, {
  3.7821083895151563`*^9, 
  3.782108412474682*^9}},ExpressionUUID->"177270c5-8cf7-4a58-ac6d-\
9a7de2feff57"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"28", " ", "28"}]], "Input",
 CellChangeTimes->{{3.782200316386331*^9, 3.7822003181966934`*^9}},
 CellLabel->"In[57]:=",ExpressionUUID->"ea82d445-37ad-4f66-8022-171a8359ab26"],

Cell[BoxData["784"], "Output",
 CellChangeTimes->{3.782200320048145*^9},
 CellLabel->"Out[57]=",ExpressionUUID->"70df942c-3d83-4a42-ae5f-bf0c53922760"]
}, Open  ]],

