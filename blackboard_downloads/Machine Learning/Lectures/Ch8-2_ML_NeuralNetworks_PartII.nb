Cell[TextData[{
 "The net is composed of a variety of layers, such as a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ConvolutionLayer"]], "paclet:ref/ConvolutionLayer"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e77e6476-64d7-4c7f-a3f1-63447c9d568c"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PoolingLayer"]], "paclet:ref/PoolingLayer"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ea99d4ac-f324-499f-b807-2471e66f7089"],
 ", etc. Each of these layers accomplishes different tasks, in this case, \
tasks related to computer vision."
}], "Text",
 CellID->2023251369,ExpressionUUID->"e6a6ec82-bc33-4d60-af64-56cc65ae2a1f"],

Cell["Take a look at the last layer of the net.", "Text",
 CellID->1812378861,ExpressionUUID->"3abf8b7e-c0a4-469c-9fe7-94c683757906"],

Cell[TextData[{
 "Extract the last layer of the net using ",
 Cell[BoxData[
  TemplateBox[{Cell[
     TextData["NetExtract"]],"paclet:ref/NetExtract"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c911e82b-3baf-45c8-91d8-4c6db5ce49fc"],
 ":"
}], "Text",
