Cell[TextData[{
 "\n\nWe can also use ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["NetMeasurements"]], "paclet:ref/NetMeasurements"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5f6b7b07-8ff0-472e-975d-824e210cf40a"],
 " to measure various properties of the net. It shares many properties with ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ClassifierMeasurements"]], "paclet:ref/ClassifierMeasurements"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "62b3ab9e-6a9d-46d4-857c-6ecc61a7578e"],
 " but each has properties of its own. \n\n",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["NetMeasurements"]], "paclet:ref/NetMeasurements"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "44b90f6d-6a7c-448a-9028-e5f9b068fdfd"],
 " has the advantage that it is efficiently implemented for networks and can \
be run on GPU.\n\nThe syntax for NetMeasurements is:"
}], "Text",
 CellChangeTimes->{{3.7821372750127916`*^9, 3.782137383897857*^9}, {
  3.782137513338411*^9, 3.782137572375327*^9}, {3.78215661673438*^9, 
