63fdb777a49c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", "CC"], "=", 
    RowBox[{
     RowBox[{"P", "(", 
      RowBox[{
       SubscriptBox["X", 
        RowBox[{"t", "+", "1"}]], "=", 
       RowBox[{
        RowBox[{"\"\<C\>\"", "|", 
         SubscriptBox["X", "t"]}], "=", "\"\<C\>\""}]}], ")"}], "=", 
     FractionBox[
      RowBox[{
       RowBox[{
       "Number", " ", "of", " ", "times", " ", "we", " ", "observe", " ", 
        "the", " ", "subsequence", " ", "C"}], "-", "C", " "}], 
      RowBox[{
       RowBox[{
       "Number", " ", "of", " ", "times", " ", "we", " ", "observe", " ", 
        "C"}], "-", "*"}]]}]}], TraditionalForm]],ExpressionUUID->
  "0910ecf3-6c86-406b-abb7-e92cf80c220d"],
 " ,"
}], "Text",
