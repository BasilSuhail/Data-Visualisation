Cell[TextData[{
 StyleBox["Task 1.",
  FontWeight->"Bold"],
 " For the example presented above, one could estimate the elements of the \
transition matrix by just counting. For instance, "
}], "Text",
 CellChangeTimes->{{3.814626064378278*^9, 3.814626079114262*^9}, {
  3.8146265021235533`*^9, 3.81462652516474*^9}, {3.814628418389371*^9, 
