 RowBox[{"Take", "[", 
  RowBox[{
   RowBox[{"Reverse", "[", 
    RowBox[{"Sort", "[", 
     RowBox[{"spRaven", "[", 
      RowBox[{
       RowBox[{"{", "\"\<is\>\"", "}"}], ",", "\"\<Probabilities\>\""}], 
      "]"}], "]"}], "]"}], ",", "10"}], "]"}]], "Input",
