Cell[CellGroupData[{

Cell["Application: Predicting text - The Raven", "Subsection",
 CellChangeTimes->{
  3.780147210482779*^9, {3.813413011894291*^9, 
   3.8134130149301724`*^9}},ExpressionUUID->"401939c1-3459-4488-9b0d-\
b63cb7d8737d"],

Cell["\<\
Language modelling is an important application of machine learning sequence \
prediction. SequencePredict can be used to make a statistical language model \
which are probability distributions over sequences of words.

In particular, here we look at an application for sentence completion using \
the text from The Raven by Edgar Allan Poe.\
\>", "Text",
 CellChangeTimes->{{3.780148322157728*^9, 3.78014832367829*^9}, {
  3.7801502395098057`*^9, 3.780150313861092*^9}, {3.780150390739985*^9, 
  3.780150518930955*^9}, {3.780150571411047*^9, 
  3.78015058992307*^9}},ExpressionUUID->"be8bba2a-b216-4bfd-8c0a-\
4bf4b67331e2"],

Cell["\<\
Let us first build a word cloud to get an idea of the words appearing in the \
test:\
\>", "Text",
 CellChangeTimes->{{3.7801506877141542`*^9, 
  3.780150724801312*^9}},ExpressionUUID->"9cf57b54-3e56-470c-9054-\
d2e086c17c0f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"WordCloud", "[", 
  RowBox[{"TextWords", "[", 
   RowBox[{"ExampleData", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<Text\>\"", ",", "\"\<TheRaven\>\""}], "}"}], "]"}], "]"}], 
  "]"}]], "Input",
