Cell[CellGroupData[{

Cell["Higher order predictor", "Subsection",
 CellChangeTimes->{
  3.814450640267421*^9},ExpressionUUID->"9b86f159-932a-44ca-83e7-\
2db968379935"],

Cell[TextData[{
 "The predictor used above corresponds to a Markov process of order 1. This \
means that the next outcome in a sequence only depends on the current \
outcome. This might be unrealistic in some situations since an outcome might \
have longer memory, i.e. it might depend on ",
 StyleBox["n",
  FontSlant->"Italic"],
 " previous outcomes for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", ">", "1"}], TraditionalForm]],ExpressionUUID->
  "0e96a823-3b79-40ee-bd00-d37e049e8674"],
 ". For a given set of training sequences, ",
 StyleBox["trainseq", "CodeText",
  FontSlant->"Italic"],
 ", one can use the ",
 StyleBox["SequencePredict", "CodeText"],
 " function to train Markov process with memory ",
 StyleBox["n",
  FontSlant->"Italic"],
 " as follows:\n\n",
 StyleBox["SequencePredict[trainseq,Method\[Rule]{\[OpenCurlyDoubleQuote]\
Markov\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]Order\
\[CloseCurlyDoubleQuote]\[Rule] ", "CodeText"],
 StyleBox["n", "CodeText",
  FontSlant->"Italic"],
 StyleBox["}]", "CodeText"]
}], "Text",
 CellChangeTimes->{{3.780195290799159*^9, 3.78019530285221*^9}, {
  3.78019534992458*^9, 3.7801956353966804`*^9}, {3.7801957469876738`*^9, 
  3.780195752339261*^9}, {3.780195829915267*^9, 
  3.780195872640915*^9}},ExpressionUUID->"eff9e01a-1ce4-443d-9787-\
198bd3882bf2"],

Cell["\<\
Let us train an order 2 predictor for the colour sequence used above:\
\>", "Text",
