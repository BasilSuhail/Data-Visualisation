Cell[TextData[{
 "The ",
 StyleBox["comparison plot",
  FontWeight->"Bold"],
 " shows the actual value of instances (value in $ of houses in the test \
data) vs. the predicted value. Predictions predictions are those that fall \
along the diagonal line corresponding to \[OpenCurlyDoubleQuote]actual value \
= predicted value\[CloseCurlyDoubleQuote] "
}], "Text",
 CellChangeTimes->{{3.7805480887440434`*^9, 
  3.7805482063749022`*^9}},ExpressionUUID->"ad712ac5-d994-4b8f-9ded-\
008b383aabd1"],

