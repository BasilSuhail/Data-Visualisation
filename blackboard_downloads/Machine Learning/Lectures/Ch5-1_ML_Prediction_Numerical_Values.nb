Cell[TextData[{
 "For instance, the prediction for a point with x = 1.2 is given by the mean \
of the value of y of the neighbours.\n\nFor ",
 StyleBox["k",
  FontSlant->"Italic"],
 " = 2, the neighbours are"
}], "Text",
 CellChangeTimes->{{3.7814547119344783`*^9, 
  3.781454802309079*^9}},ExpressionUUID->"b67c02a2-542c-47d0-ba87-\
