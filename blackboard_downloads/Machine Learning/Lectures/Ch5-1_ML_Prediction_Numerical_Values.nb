Cell[CellGroupData[{

Cell["Methods for prediction", "Subsection",
 CellChangeTimes->{{3.7812744893303947`*^9, 
  3.7812744944624186`*^9}},ExpressionUUID->"23112dd5-93a3-46a7-a361-\
85840730ff7d"],

Cell["\<\
Several methods can be used for prediction of numerical values. Some of the \
most widely used are:\
\>", "Text",
 CellChangeTimes->{{3.7812755480637865`*^9, 3.7812755730794206`*^9}, {
  3.7812761214466796`*^9, 
  3.781276130164795*^9}},ExpressionUUID->"0f81a4b2-ecc6-423d-a800-\
8062c57acb4b"],

