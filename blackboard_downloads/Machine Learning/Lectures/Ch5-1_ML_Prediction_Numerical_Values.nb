Cell["\<\
One can plot the dispersion of predictions together with the straight line \
giving the mean value of the prediction. It can be convenient to define a \
function to do this:\
\>", "Text",
 CellChangeTimes->{{3.7802365965360737`*^9, 
  3.7802366833262053`*^9}},ExpressionUUID->"bd3f5d71-fb81-4b17-a0aa-\
b0869943f579"],

Cell[BoxData[
 RowBox[{
  RowBox[{"plotSDRegion", "[", 
   RowBox[{"predictor_", ",", "data_", ",", "xmin_", ",", "xmax_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"p", "=", "predictor"}], ",", 
      RowBox[{"data0", "=", "data"}], ",", 
      RowBox[{"xmin0", "=", "xmin"}], ",", 
      RowBox[{"xmax0", "=", "xmax"}], ",", "x"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"p", "[", "x", "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"p", "[", "x", "]"}], "+", 
           RowBox[{"StandardDeviation", "[", 
            RowBox[{"p", "[", 
             RowBox[{"x", ",", "\"\<Distribution\>\""}], "]"}], "]"}]}], ",", 
          
          RowBox[{
           RowBox[{"p", "[", "x", "]"}], "-", 
           RowBox[{"StandardDeviation", "[", 
            RowBox[{"p", "[", 
             RowBox[{"x", ",", "\"\<Distribution\>\""}], "]"}], "]"}]}]}], 
         "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"x", ",", "xmin0", ",", "xmax0"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"Blue", ",", "Gray", ",", "Gray"}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Filling", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"2", "\[Rule]", 
           RowBox[{"{", "3", "}"}]}], "}"}]}], ",", 
        RowBox[{"PlotLegends", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"\"\<Prediction\>\"", ",", "\"\<Confidence Interval\>\""}], 
          "}"}]}]}], "]"}], ",", 
      RowBox[{"ListPlot", "[", 
       RowBox[{"data0", ",", 
        RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
        RowBox[{"PlotLegends", "\[Rule]", 
         RowBox[{"{", "\"\<Data\>\"", "}"}]}]}], "]"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.780236117063687*^9, 3.7802362015367045`*^9}, {
   3.7802362573146563`*^9, 3.780236324643689*^9}, {3.781274822532689*^9, 
   3.78127486178449*^9}, 3.7814276446989784`*^9, {3.814115565612536*^9, 
   3.8141155687160683`*^9}, {3.814115623386387*^9, 3.814115625658637*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"3385c6e2-57d0-45d8-817e-71aaa2ff9fed"],

