Cell[TextData[{
 "Some details (not crucial for the course): In the \
\[OpenCurlyDoubleQuote]learning curves for all algorithms\
\[CloseCurlyDoubleQuote] panel, we see that Mathematica tried several models \
for prediction despite the fact that we set it to use \
\[OpenCurlyDoubleQuote]LinearRegression\[CloseCurlyDoubleQuote] method. In \
fact, all the models are linear regression but the loss function used to \
obtain each of them is slightly different. Costs functions differ in the \
regularization term that is added to the normal loss function, ",
 Cell[BoxData[
  FormBox["J", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "aa484a74-476a-48da-a4c3-86dd4bfd7113"],
 ". For 1-dimensional data (i.e. one feature per example), the regularized \
loss function is:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["J", "r"], "(", 
     RowBox[{
      SubscriptBox["w", "0"], ",", 
      SubscriptBox["w", "1"]}], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"J", "(", 
       RowBox[{
        SubscriptBox["w", "0"], ",", 
        SubscriptBox["w", "1"]}], ")"}], "+", 
      SubscriptBox["\[Lambda]", "1"]}], "|", 
     SubscriptBox["w", "1"], "|", "+"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "9c0c56aa-644e-4c95-a4cc-0be6a33f41c3"],
 Cell[BoxData[
  RowBox[{
   FractionBox[
    SubscriptBox["\[Lambda]", "2"], "2"], 
   SubsuperscriptBox[
    StyleBox["w",
     FontSlant->"Italic"], "1", "2"]}]],
  CellChangeTimes->{3.814432996468219*^9},ExpressionUUID->
  "10d5e543-4fad-4214-a6f3-dbee132e7abc"],
 "\nIn Mathematica, the regularization parameter ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "1"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "aa80408e-b379-48ee-abb1-39ab8705d887"],
 " is indicated as \[OpenCurlyDoubleQuote]L1Regularization\
\[CloseCurlyDoubleQuote] (set as 0 by default) and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "2"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "12dd9e2c-c0fc-4257-a461-b3d2c167b0c4"],
 " as \[OpenCurlyDoubleQuote]L2Regularization\[CloseCurlyDoubleQuote]."
}], "Text",
 CellChangeTimes->{{3.8144325461046324`*^9, 3.814432696901354*^9}, {
  3.8144327381590204`*^9, 3.814432945794737*^9}, {3.8144329878163557`*^9, 
  3.8144331447207794`*^9}},ExpressionUUID->"2d8614af-3618-436d-9e6c-\
3185702b0931"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Nearest neighbours method", "Subsection",
 CellChangeTimes->{
  3.781423693237735*^9, {3.7814541536627417`*^9, 
   3.7814541544846897`*^9}},ExpressionUUID->"cf324408-aacc-41b1-8142-\
5cddec5ca192"],

Cell[CellGroupData[{

Cell["How does it work?", "Subsubsection",
 CellChangeTimes->{{3.7814546651694937`*^9, 
  3.7814546713058767`*^9}},ExpressionUUID->"7da2a19d-efa6-47b8-9233-\
dae7aaedd255"],

Cell[TextData[{
 "Suppose that we want to predict the value of ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "af020060-91ca-4808-90bf-c0e69086cf39"],
 " for a point with feature vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["x",
     FontWeight->"Bold"], "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"], ",", "...", ",", 
      SubscriptBox["x", "M"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "51e7b586-b3ba-45f7-a7bb-9118354f8286"],
 " (i.e. in general each example is characterised by ",
 StyleBox["M",
  FontSlant->"Italic"],
 " features)."
}], "Text",
 CellChangeTimes->{{3.781454161194561*^9, 3.781454262447698*^9}, {
   3.78145429582804*^9, 3.7814543510569983`*^9}, {3.7814543915210066`*^9, 
   3.7814545887015057`*^9}, 3.7814546522806053`*^9, {3.8143656930695887`*^9, 
   3.814365700873776*^9}, {3.814365784762375*^9, 
   3.8143658216756907`*^9}},ExpressionUUID->"e546f93c-51b3-4b4e-8396-\
f9d3edd90a77"],

Cell[CellGroupData[{

Cell[TextData[{
 "Fix a number of neighbours ",
 StyleBox["k",
  FontSlant->"Italic"]
}], "Item",
 CellChangeTimes->{{3.78145458492074*^9, 
  3.7814545858389215`*^9}},ExpressionUUID->"56ec1c8d-fe6f-43bf-ae84-\
782afd96d383"],

Cell[TextData[{
 "Select ",
 StyleBox["k",
  FontSlant->"Italic"],
 " nearest points to ",
 Cell[BoxData[
  FormBox[
   StyleBox["x",
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "4a971e6a-a552-4ca2-8a06-cc9fe3bdd72c"],
 " in the training data set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox[
      StyleBox["x",
       FontWeight->"Bold"], 
      RowBox[{"(", "1", ")"}]], ",", 
     SuperscriptBox[
      StyleBox["x",
       FontWeight->"Bold"], 
      RowBox[{"(", "2", ")"}]], ",", "...", ",", 
     SuperscriptBox[
      StyleBox["x",
       FontWeight->"Bold"], 
      RowBox[{"(", "N", ")"}]]}], "}"}], TraditionalForm]],ExpressionUUID->
  "557340e2-3930-41ec-9d4b-d2a9a2ade50b"],
 ". Suppose that the nearest neighbours are ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["z", "1"], ",", 
     SubscriptBox["z", "2"], ",", "...", ",", 
     SubscriptBox["z", "k"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "0d5f747d-685c-41f8-919d-99ceec13e6d6"]
}], "Item",
 CellChangeTimes->{{3.78145458492074*^9, 
  3.7814546213323145`*^9}},ExpressionUUID->"ef559a4f-b1d4-4143-a3e7-\
c24fa5a31025"],

Cell[TextData[{
 "The prediction for ",
 StyleBox["y",
  FontSlant->"Italic"],
 " is the mean value of the features of the nearest ",
 StyleBox["k",
  FontSlant->"Italic"],
 " neighbours: \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"Mean", "[", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["z", "1"], ",", 
       SubscriptBox["z", "2"], ",", "...", ",", 
       SubscriptBox["z", "k"]}], "}"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"d7509bca-7698-47af-9afc-fc6b985139c4"]
}], "Item",
 CellChangeTimes->{{3.78145458492074*^9, 
  3.781454627507431*^9}},ExpressionUUID->"cacb6f22-b151-415c-8823-\
e4f05969f7db"]
}, Open  ]]
}, Open  ]],

