Cell[CellGroupData[{

Cell["Decision tree", "Subsection",
 CellChangeTimes->{{3.7814548798457685`*^9, 
  3.781454882190709*^9}},ExpressionUUID->"f9e8f5d5-8702-427c-87a9-\
856986bee3ec"],

Cell[TextData[{
 "Decision trees can be used for ",
 StyleBox["both classification and prediction",
  FontWeight->"Bold"],
 ".\n\nA decision tree is a flow chart\[Dash]like structure in which each \
internal node represents a \
\[OpenCurlyDoubleQuote]test\[CloseCurlyDoubleQuote] on a feature, each branch \
represents the outcome of the test, and each leaf represents a class \
distribution, value distribution or probability density."
}], "Text",
 CellChangeTimes->{{3.7814548856321473`*^9, 3.78145490110146*^9}, {
  3.814099463565837*^9, 3.814099510030611*^9}, {3.8143661892987576`*^9, 
  3.8143662000420265`*^9}},ExpressionUUID->"eebedc51-b260-41c2-9c59-\
0600b8ea016e"],

Cell[CellGroupData[{

Cell["Decision tree for classification", "Subsubsection",
 CellChangeTimes->{{3.8143730947569256`*^9, 
  3.8143731092122684`*^9}},ExpressionUUID->"4ad6f4d7-91c0-4862-9864-\
e62d22d2cc8c"],

Cell[TextData[{
 "Decision trees are easy to understand intuitively. A ",
 StyleBox["classification example",
  FontWeight->"Bold"],
 " to get the idea: Have you played \[OpenCurlyDoubleQuote]Guess Who\
\[CloseCurlyDoubleQuote] or the 20 questions game?"
}], "Text",
 CellChangeTimes->{{3.7803077536754155`*^9, 3.780307775216985*^9}, {
  3.814099854122362*^9, 3.8140998771589537`*^9}, {3.814366203084925*^9, 
  3.814366216248684*^9}},ExpressionUUID->"ad0ea271-c8a5-417e-8dd0-\
bc5a1d14aaac"],

