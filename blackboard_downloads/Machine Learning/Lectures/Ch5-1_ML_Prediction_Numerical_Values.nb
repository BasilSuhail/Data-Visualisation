Cell[CellGroupData[{

Cell["Loss function (or cost function)", "Subsubsection",
 CellChangeTimes->{{3.7814289566880274`*^9, 3.7814289665385723`*^9}, {
  3.8140893583554864`*^9, 
  3.8140893662603455`*^9}},ExpressionUUID->"50bedb88-0f2b-4ab8-bed2-\
2a736bfb36df"],

Cell[TextData[{
 "A cost function measures how far away a mathematical model is from the \
data.\n\nIn linear regression, one adjusts the parameters ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["w", "0"]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "330fd381-a55d-45df-93e4-bdf275c0ca35"],
 ",",
 StyleBox["w",
  FontWeight->"Bold"],
 "} to minimise the cost function."
}], "Text",
 CellChangeTimes->{{3.7814290125976467`*^9, 3.7814291368809786`*^9}, {
  3.781446377337017*^9, 3.781446395784563*^9}, {3.781448819412541*^9, 
  3.7814488452238255`*^9}},ExpressionUUID->"5fd2845a-3f2a-413f-8bb2-\
6e4d3b3955bb"],

Cell["\<\
The Predict function uses the mean cross entropy for the linear regression \
model:\
\>", "Text",
 CellChangeTimes->{{3.7814488496865754`*^9, 3.7814488743409996`*^9}, {
  3.8141092846607976`*^9, 
  3.8141093025854654`*^9}},ExpressionUUID->"420dc311-1e0a-42e1-8f90-\
5bf9c05eb5cc"],

