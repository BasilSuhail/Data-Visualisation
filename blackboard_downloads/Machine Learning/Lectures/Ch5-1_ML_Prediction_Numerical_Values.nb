Cell["Use Apply and List functions.", "Item",
 CellChangeTimes->{{3.814087069848817*^9, 3.814087082057473*^9}, {
  3.8140874766268687`*^9, 3.8140875461325893`*^9}, {3.814087728594808*^9, 
  3.814087734600789*^9}},ExpressionUUID->"d25929b5-eeaa-4cd2-823e-\
8315e225c10d"],

Cell[TextData[{
 "You probably saw how to use ",
 StyleBox["Apply", "CodeText"],
 " in other courses of the programme but let us remind ourselves how it \
works. Consider the following example:"
}], "Text",
 CellChangeTimes->{{3.8140876140000944`*^9, 
  3.8140876658673835`*^9}},ExpressionUUID->"54913461-6607-4013-ae8a-\
cd0e29b742ac"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Apply", "[", 
  RowBox[{"f", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"1", "->", "a"}], ",", 
     RowBox[{"2", "->", "b"}], ",", 
     RowBox[{"3", "->", "c"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{3.814087672794855*^9},
 CellLabel->"In[56]:=",ExpressionUUID->"b340c59b-4ac0-498b-ae7e-4528c471dc62"],

Cell[BoxData[
 RowBox[{"f", "[", 
  RowBox[{
   RowBox[{"1", "\[Rule]", "a"}], ",", 
   RowBox[{"2", "\[Rule]", "b"}], ",", 
   RowBox[{"3", "\[Rule]", "c"}]}], "]"}]], "Output",
 CellChangeTimes->{3.8140876732825527`*^9, 3.8141044323484564`*^9},
 CellLabel->"Out[56]=",ExpressionUUID->"8cf57d17-7e42-465d-a783-fc26141af51b"]
}, Open  ]],

Cell["Alternatively, one can use @@:", "Text",
 CellChangeTimes->{{3.814087902940039*^9, 3.814087913300333*^9}, {
  3.814096186097872*^9, 
  3.8140961891696544`*^9}},ExpressionUUID->"7252ba9a-75d8-4991-9d8f-\
8f8561d5d25e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"f", "@@", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"1", "->", "a"}], ",", 
    RowBox[{"2", "->", "b"}], ",", 
    RowBox[{"3", "->", "c"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.8140879165556936`*^9, 3.8140879227252817`*^9}},
 CellLabel->"In[57]:=",ExpressionUUID->"7161da4b-4cab-4696-a21e-dca038d51058"],

Cell[BoxData[
 RowBox[{"f", "[", 
  RowBox[{
   RowBox[{"1", "\[Rule]", "a"}], ",", 
   RowBox[{"2", "\[Rule]", "b"}], ",", 
   RowBox[{"3", "\[Rule]", "c"}]}], "]"}]], "Output",
 CellChangeTimes->{3.8140879244247003`*^9, 3.8141044445717316`*^9},
 CellLabel->"Out[57]=",ExpressionUUID->"6cdb5f53-a834-44c4-a469-5ac6465d0d27"]
}, Open  ]],

Cell[TextData[{
 "In this way, the function ",
 StyleBox["f", "CodeText"],
 " is applied to the whole list. However, we want to apply it to each element \
of the list. This can be done by specifying that we want to apply it al level \
{1} of the list as follows:"
}], "Text",
 CellChangeTimes->{{3.8140876781924715`*^9, 3.8140877240189548`*^9}, {
  3.814087888078795*^9, 3.814087890928163*^9}, {3.8140961938880386`*^9, 
  3.814096196799252*^9}, {3.8140962657707987`*^9, 
  3.8140963096444674`*^9}},ExpressionUUID->"3d275e63-7249-4a58-8e63-\
7f5b8dc6bec5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Apply", "[", 
  RowBox[{"f", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"1", "->", "a"}], ",", 
     RowBox[{"2", "->", "b"}], ",", 
     RowBox[{"3", "->", "c"}]}], "}"}], ",", 
   RowBox[{"{", "1", "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.814087883959801*^9, 3.8140878852144423`*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"3f84d8fe-3c02-44e1-b6e7-51a1bc05f3f3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"1", ",", "a"}], "]"}], ",", 
   RowBox[{"f", "[", 
    RowBox[{"2", ",", "b"}], "]"}], ",", 
   RowBox[{"f", "[", 
    RowBox[{"3", ",", "c"}], "]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.814087893849352*^9, 3.8141044820250406`*^9},
 CellLabel->"Out[58]=",ExpressionUUID->"de8dc289-715f-431d-8377-d26f09f189fa"]
}, Open  ]],

