Cell["", "Text",
 CellChangeTimes->{{3.780135311551491*^9, 3.7801353708389072`*^9}, 
   3.7801354102237988`*^9},ExpressionUUID->"c79525d2-1f34-4abb-b9fe-\
d3f862cc7dcb"],

Cell["Use a trained model to ", "Text",
 CellChangeTimes->{
  3.7774546164672337`*^9, {3.777562421568159*^9, 3.7775624487199793`*^9}, {
   3.777562497792286*^9, 3.777562565152143*^9}, {3.77756260724864*^9, 
   3.777562626192449*^9}},ExpressionUUID->"5bf9c28f-0c47-4c8a-9395-\
813fbf8759f5"],

Cell[CellGroupData[{

Cell["\<\
Predict numerical values based on numerical or categorical data \
\>", "Item",
 CellChangeTimes->{{3.777455028641049*^9, 3.777455047207428*^9}, {
  3.777562579504201*^9, 3.777562591254078*^9}, {3.780135411807473*^9, 
  3.780135413172998*^9}},ExpressionUUID->"d8b14a70-0cbf-4c2f-8c78-\
d2f36cd13a79"],

Cell[TextData[{
 "Each example is a vector ",
 Cell[BoxData[
  FormBox[
   StyleBox["x",
    FontWeight->"Bold"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "68ce819f-0636-47b5-b978-e6537be371c3"],
 " of ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "67bb7b31-73a2-45ff-8525-e6b9a661956f"],
 " numerical features, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"], ",", "...", ",", 
     SubscriptBox["x", "M"]}], "}"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "250cb259-a4b7-4ea0-8221-4249264f3a72"]
}], "ItemParagraph",
 CellChangeTimes->{{3.780135424578845*^9, 
  3.780135445506177*^9}},ExpressionUUID->"fcefa2d3-200a-41e4-8c95-\
053612a38676"],

Cell[TextData[{
 "Implemented in Wolfram Language with the function ",
 Cell[BoxData[
  ButtonBox[Cell[
   "Predict",ExpressionUUID->"b7742f1a-fbbb-471f-a6e8-51f2f1456698"],
   BaseStyle->Dynamic[
     If[
      CurrentValue["MouseOver"], {
      "Link", FontColor -> 
       RGBColor[0.9686274509803922, 0.4666666666666667, 0.]}, {"Link"}]],
   ButtonData->"paclet:ref/Predict"]],ExpressionUUID->
  "c083b165-bcb7-47e1-b468-03370d2b53c0"]
}], "ItemParagraph",
 CellChangeTimes->{{3.780135424578845*^9, 
  3.7801354789425163`*^9}},ExpressionUUID->"1de94f0f-02d6-44ce-9b83-\
612d0df781dd"],

Cell["Predict the next value in a sequence", "Item",
 CellChangeTimes->{{3.777455028641049*^9, 3.777455054592502*^9}, {
  3.777562574032029*^9, 3.777562577301722*^9}, {3.780151225871109*^9, 
  3.7801512284795227`*^9}},ExpressionUUID->"6ef267ec-c78d-4c3e-99d3-\
c9aedc4b2958"],

Cell[TextData[{
 "Function ",
 Cell[BoxData[
  ButtonBox[Cell[
   "SequencePredict",ExpressionUUID->"29af25b5-634c-4c0f-b0ad-9adc0f8d6cba"],
   BaseStyle->Dynamic[
     If[
      CurrentValue["MouseOver"], {
      "Link", FontColor -> 
       RGBColor[0.9686274509803922, 0.4666666666666667, 0.]}, {"Link"}]],
   ButtonData->"paclet:ref/SequencePredict"]],ExpressionUUID->
  "1cb9384e-1b3c-4d87-8d09-2195573382f3"]
}], "ItemParagraph",
 CellChangeTimes->{
  3.780151247111002*^9},ExpressionUUID->"113febdd-4b4d-4db1-a3a9-\
f9ff202127d1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.1 Predicting numerical values", "Section",
 CellChangeTimes->{{3.780135487647196*^9, 3.780135490350729*^9}, {
  3.780137135564385*^9, 3.780137141548617*^9}, {3.8144504449483113`*^9, 
  3.814450445829954*^9}, {3.814451040101495*^9, 
  3.814451040232189*^9}},ExpressionUUID->"9f49bc10-96be-4380-acfd-\
d03396b35d92"],

Cell[TextData[{
 "This section explains the basic usage of the ",
 StyleBox["Predict", "CodeText"],
 " function. Basic concepts will be illustrated by means of a simple example. \
An example using real data will be given at the end of this chapter and \
another example will be covered (by you) in practicals."
}], "Text",
 CellChangeTimes->{{3.7801355077429028`*^9, 3.7801355233267403`*^9}, {
  3.780135682607607*^9, 
  3.780135800383275*^9}},ExpressionUUID->"aef54106-508d-44e1-ba1e-\
887af9be2020"],

Cell[CellGroupData[{

Cell["A simple example", "Subsection",
 CellChangeTimes->{{3.780135497487105*^9, 
  3.78013550036687*^9}},ExpressionUUID->"73f04ece-2010-4326-b8de-\
2927235d4a6f"],

Cell[CellGroupData[{

Cell["The data", "Subsubsection",
 CellChangeTimes->{{3.780136382334711*^9, 
  3.7801363832621403`*^9}},ExpressionUUID->"d3e8e709-0b98-4f66-b1a4-\
8d13faf9af8b"],

Cell[TextData[{
 "Consider a small training dataset in which a variable ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "da6fbfcc-1a82-449e-a68d-a848ffc4aad8"],
 " (to be predicted) depends on a numerical variable ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "51ea212e-f68b-4f56-9b0f-e870e875c483"],
 "."
}], "Text",
 CellChangeTimes->{{3.780135813535356*^9, 3.780135885415251*^9}, {
  3.81408614558827*^9, 
  3.8140861459941854`*^9}},ExpressionUUID->"548f2b44-fe29-4508-b0bf-\
53f43ae9187b"],

Cell[TextData[{
 "We consider the following small training set with format giving the value \
of ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "f99441ac-780e-4bb7-9f91-ddf796e0f554"],
 " for several values of ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "49770baa-8c0b-4ffa-8cf0-a72cb71510a2"],
 " (format ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Rule]", " ", "y"}], TraditionalForm]],ExpressionUUID->
  "f695848d-9649-4258-b133-d5a445c539da"],
 ")"
}], "Text",
 CellChangeTimes->{{3.7801358919988003`*^9, 
  3.780135952359185*^9}},ExpressionUUID->"7a67c43e-e0c3-4d12-889d-\
64d5b97543ab"],

Cell[BoxData[
 RowBox[{
  RowBox[{"trainingset", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"1", "\[Rule]", " ", "12.9"}], ",", 
     RowBox[{"2", "\[Rule]", " ", "8.2"}], ",", 
     RowBox[{"3", "\[Rule]", " ", "6.9"}], ",", 
     RowBox[{"4", "\[Rule]", " ", "3.1"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.777438143380382*^9, 3.7774381827184563`*^9}, {
  3.777438223070286*^9, 3.777438247486546*^9}, {3.7774383233928337`*^9, 
  3.777438342030225*^9}, {3.777439564451293*^9, 3.777439575180964*^9}, {
  3.7814264126432123`*^9, 3.7814264402361684`*^9}, {3.7814265414962215`*^9, 
  3.7814265420742536`*^9}, {3.7814266106360188`*^9, 3.781426612089099*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"2456220a-d5c0-4dde-bcad-00279ffcccdb"],

Cell["The data can be easily visualised in a scatterplot. ", "Text",
 CellChangeTimes->{{3.7801359864628468`*^9, 3.780136003870948*^9}, {
   3.780136174110752*^9, 3.7801361780147552`*^9}, {3.780136263471031*^9, 
   3.7801363076792793`*^9}, {3.81408644517669*^9, 3.8140864920938535`*^9}, {
   3.8140867989101725`*^9, 3.814086799212366*^9}, 
   3.814086846903824*^9},ExpressionUUID->"acbfe4ac-1be2-4567-83cd-\
4582784e98f5"],

Cell[TextData[{
 "Before doing the scatterplot, we need to convert the ",
 StyleBox["trainingset", "CodeText"],
 " into a list to be plotted with ",
 StyleBox["ListPlot.", "CodeText"],
 " "
}], "Text",
 CellChangeTimes->{{3.8140867896060953`*^9, 3.814086795769576*^9}, {
  3.8140868282995763`*^9, 3.814086883414182*^9}, {3.8140882155463514`*^9, 
  3.8140882321878123`*^9}},ExpressionUUID->"23c35252-9495-4316-8641-\
2ccff75f3457"],

Cell[TextData[{
 StyleBox["Aside:",
  FontWeight->"Bold",
  FontVariations->{"Underline"->True}],
 "\nOne can transform ",
 StyleBox["trainingset", "CodeText"],
 " into the list we need in several ways:"
}], "Text",
 CellChangeTimes->{{3.8140882357223606`*^9, 3.814088277663231*^9}, 
   3.8140962351596975`*^9},ExpressionUUID->"3171c14c-b287-42e7-861f-\
4db49ec080e6"],

Cell[TextData[{
 "Extracting elements from ",
 StyleBox["trainingset", "CodeText"],
 " and creating a list with {x,y} for each data point."
}], "Item",
 CellChangeTimes->{{3.814087018829263*^9, 3.8140870350528755`*^9}, {
   3.8140874449036865`*^9, 3.814087470655838*^9}, 
   3.8140962363774405`*^9},ExpressionUUID->"38c2296e-9237-4d30-a178-\
90a743439fd8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Transpose", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"trainingset", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
    RowBox[{"trainingset", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.814087039529869*^9, 3.814087058404389*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"3f11303b-74a4-4c0b-9f5f-177cbbaf7100"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "12.9`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2", ",", "8.2`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"3", ",", "6.9`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"4", ",", "3.1`"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.8140870592102346`*^9},
 CellLabel->"Out[14]=",ExpressionUUID->"8936cc35-c1a9-436e-b275-45ce69a75ec4"]
}, Open  ]],

Cell[TextData[{
 "Transform ",
 StyleBox["trainingset", "CodeText"],
 " into a list would use ",
 StyleBox["Keys", "CodeText"],
 ", ",
 StyleBox["Values", "CodeText"],
 " and ",
 StyleBox["Transpose", "CodeText"],
 ". Feel free to use the way you find more intuitive. This might include ways \
that I didn\[CloseCurlyQuote]t explain."
}], "Item",
 CellChangeTimes->{
  3.814088164836932*^9},ExpressionUUID->"fcfbd858-bd72-4bd5-9787-\
299f0cf480f2"],

Cell[CellGroupData[{

Cell[BoxData["trainingset"], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"bbf748a5-f5ed-4310-a1d7-43129d08e6e4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"1", "\[Rule]", "12.9`"}], ",", 
