Cell["\<\
In this way, you can easily plot the PDF for any normally distributed random \
variable, irrespective of they mean and standard deviation.\
\>", "Text",
 CellChangeTimes->{{3.8140958344865494`*^9, 
  3.8140959211074495`*^9}},ExpressionUUID->"8e215b2f-29ba-4cbb-a2f4-\
96754be039a2"],

Cell[TextData[{
 "The value found above for the ",
 StyleBox["prediction", "CodeText"],
 " variable is just the expected value of the predicted distribution:"
}], "Text",
 CellChangeTimes->{{3.780136933676546*^9, 
  3.780136992508698*^9}},ExpressionUUID->"e7b92f3f-f83d-46a2-9184-\
