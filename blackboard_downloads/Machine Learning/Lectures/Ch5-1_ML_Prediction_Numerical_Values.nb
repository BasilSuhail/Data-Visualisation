Cell[TextData[{
 "One can try for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"s", " ", "=", " ", "1"}], ",", "2", ",", "3", ",", "4"}], 
   TraditionalForm]],ExpressionUUID->"062e73d1-cb22-4f1f-a6c8-4563bf45c85b"],
 " and check that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"s", " ", "=", " ", "2"}], TraditionalForm]],ExpressionUUID->
  "8c20ce72-5523-4ba0-89b3-1bb53e364bc5"],
 " gives the smallest loss."
}], "Text",
 CellChangeTimes->{{3.8143754097693996`*^9, 
  3.8143754537378454`*^9}},ExpressionUUID->"e581a462-7ca9-47b8-916b-\
23e4e8345766"]
