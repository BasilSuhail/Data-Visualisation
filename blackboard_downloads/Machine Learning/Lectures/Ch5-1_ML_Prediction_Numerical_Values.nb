Cell[TextData[StyleBox["A perfect fit would give a zero cost.",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.78144965597651*^9, 
  3.781449671352854*^9}},ExpressionUUID->"5111d852-5cd2-497e-8c6f-\
d1a513f4f870"],

Cell[TextData[{
 StyleBox["In ",
  FontWeight->"Bold"],
 StyleBox["M",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" dimensions: ",
  FontWeight->"Bold"],
 "Suppose that you have a training dataset with ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "0d580998-f3e5-4798-aa82-063aeb3aa2a2"],
 " data points ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox[
      StyleBox["x",
       FontWeight->"Bold"], 
      RowBox[{"(", "1", ")"}]], ",", 
     SuperscriptBox[
      StyleBox["x",
       FontWeight->"Bold"], 
      RowBox[{"(", "2", ")"}]], ",", "...", ",", 
     SuperscriptBox[
      StyleBox["x",
       FontWeight->"Bold"], 
      RowBox[{"(", "N", ")"}]]}], "}"}], TraditionalForm]],ExpressionUUID->
  "c8f3bf40-6866-499e-8f4d-367686eecc59"],
 " with ",
 StyleBox["M",
  FontSlant->"Italic"],
 " features each. Each example carries a numerical value,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox["y", 
      RowBox[{"(", "1", ")"}]], ",", 
     SuperscriptBox["y", 
      RowBox[{"(", "2", ")"}]], ",", "...", ",", 
     SuperscriptBox["y", 
      RowBox[{"(", "N", ")"}]]}], "}"}], TraditionalForm]],ExpressionUUID->
  "dd8bb9d1-867b-4231-a672-4de25c547ccf"],
 ". More explicitly, the data set can be viewed as follows:"
}], "Text",
 CellChangeTimes->{{3.7814287683841934`*^9, 3.7814287827589293`*^9}, {
  3.781428941559663*^9, 3.7814289457733183`*^9}, {3.781429192370515*^9, 
  3.7814292580320034`*^9}, {3.781429432193118*^9, 3.7814294327007046`*^9}, {
  3.781429703343114*^9, 3.78142975294916*^9}, {3.7814446643747683`*^9, 
  3.781444693084997*^9}, {3.7814448738284874`*^9, 3.7814449057544594`*^9}, {
  3.7814450207861376`*^9, 
  3.7814451610886183`*^9}},ExpressionUUID->"8b2fc9d8-ab7a-4cae-882f-\
d59383960e3b"],

Cell[BoxData[GridBox[{
   {
    SubsuperscriptBox["x", "1", 
     RowBox[{"(", "1", ")"}]], 
    SubsuperscriptBox["x", "2", 
     RowBox[{"(", "1", ")"}]], "...", 
    SubsuperscriptBox["x", "M", 
     RowBox[{"(", "1", ")"}]], 
    SuperscriptBox["y", 
     RowBox[{"(", "1", ")"}]]},
   {
    SubsuperscriptBox["x", "1", 
     RowBox[{"(", "2", ")"}]], 
    SubsuperscriptBox["x", "2", 
     RowBox[{"(", "2", ")"}]], "...", 
    SubsuperscriptBox["x", "M", 
     RowBox[{"(", "2", ")"}]], 
    SuperscriptBox["y", 
     RowBox[{"(", "2", ")"}]]},
   {"...", "...", "...", "...", "..."},
   {
    SubsuperscriptBox["x", "1", 
     RowBox[{"(", "N", ")"}]], 
    SubsuperscriptBox["x", "2", 
     RowBox[{"(", "N", ")"}]], "...", 
    SubsuperscriptBox["x", "M", 
     RowBox[{"(", "N", ")"}]], 
    SuperscriptBox["y", 
     RowBox[{"(", "N", ")"}]]}
  }]], "Text",
 CellChangeTimes->{{3.78142954178489*^9, 
  3.7814296970589914`*^9}},ExpressionUUID->"e8ed27b2-2a6b-461b-bf6a-\
21b4a8a3c9f7"],

Cell[TextData[{
 "We fit a linear model ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", 
    StyleBox["x",
     FontWeight->"Bold"], ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "aaa4f0a8-9512-4846-8eb1-96815cb631e0"],
 " to the data. The general expression for the quadratic distance cost \
function is"
}], "Text",
 CellChangeTimes->{{3.781429763380011*^9, 
  3.781429826988178*^9}},ExpressionUUID->"e1795211-1626-45ed-a6a2-\
af8057fef847"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"J", "(", 
     RowBox[{
      SubscriptBox["w", "0"], ",", 
      StyleBox["w",
       FontWeight->"Bold"]}], ")"}], "=", 
    FractionBox["1", 
     RowBox[{"2", "N"}]]}], TraditionalForm]],ExpressionUUID->
  "5ca25a4a-657b-43d3-91ab-532a5cb6c2ca"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"n", "=", "1"}], "N"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"f", "(", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           StyleBox["x",
            FontWeight->"Bold"], 
           RowBox[{"(", "n", ")"}]], ";", 
          SubscriptBox["w", "0"]}], ",", 
         StyleBox["w",
          FontWeight->"Bold"]}], ")"}], "-", 
       SuperscriptBox["y", 
        RowBox[{"(", "n", ")"}]]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"4c936058-d2c8-45b3-958d-63857a08e11b"]
}], "Text",
 CellChangeTimes->{{3.781428795912368*^9, 3.7814288682057166`*^9}, {
  3.78142983772917*^9, 3.7814299431932898`*^9}, {3.7814454867863584`*^9, 
  3.7814454910690947`*^9}},ExpressionUUID->"989294ab-ef94-4103-826a-\
b9d9e005f922"]
}, Open  ]]
}, Open  ]],

