Cell[CellGroupData[{

Cell["Decision tree for prediction - Regression tree", "Subsubsection",
 CellChangeTimes->{{3.814373115446596*^9, 
  3.814373130164235*^9}},ExpressionUUID->"3d2014d8-7f12-45d3-ba47-\
bdeae21713cc"],

Cell[TextData[{
 StyleBox["For prediction",
  FontWeight->"Bold"],
 ", a decision tree is built to partition the data in such a way that \
predictions are made in a piecewise manner.\n\nLet us see what Mathematica \
gives for our simple example when setting the method to decision tree."
}], "Text",
 CellChangeTimes->{{3.7814549111713023`*^9, 3.781454961122964*^9}, 
