Cell["\<\
In order to set the horizontal axis range without having to guess the values \
for x, one can use the mean and standard deviation of the distribution as \
follows:\
\>", "Text",
 CellChangeTimes->{{3.814095763426654*^9, 
  3.8140958282781525`*^9}},ExpressionUUID->"15928192-1feb-48c3-93b7-\
6d0a8348f266"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"PDF", "[", 
    RowBox[{"dist", ",", "x"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{"Mean", "[", "dist", "]"}], "-", 
      RowBox[{"4", " ", 
       RowBox[{"StandardDeviation", "[", "dist", "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"Mean", "[", "dist", "]"}], "+", 
      RowBox[{"4", " ", 
       RowBox[{"StandardDeviation", "[", "dist", "]"}]}]}]}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.777441359102838*^9, 3.777441437403174*^9}, {
  3.777441476123282*^9, 3.777441527178789*^9}, {3.781593080881312*^9, 
