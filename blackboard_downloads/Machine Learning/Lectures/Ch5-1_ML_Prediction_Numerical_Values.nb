 CellChangeTimes->{{3.777465797019559*^9, 3.777465838443962*^9}},
 CellLabel->
  "In[162]:=",ExpressionUUID->"48ca8eaf-f4a2-4754-81fe-53d0c54ce5d5"],

Cell[BoxData["\<\"\\tHome values for 506 Boston suburbs with potential \
influential factors (such as the crime rate, number of rooms, distance to \
employment centers, etc.).\\n\\n\\tThe test and training sets were obtained \
by creating a random sample of 30% of the data for the test set, using the \
rest for training.\"\>"], "Output",
 CellChangeTimes->{3.777465839542625*^9},
 CellLabel->
  "Out[162]=",ExpressionUUID->"56bedccc-83cd-45af-90ea-58a136aea01c"]
}, Open  ]],

