Cell[CellGroupData[{

Cell["Cost function for LinearModelFit", "Subsubsection",
 CellChangeTimes->{{3.78144925481546*^9, 
  3.7814492760855293`*^9}},ExpressionUUID->"e62d958b-a076-4b8c-a902-\
9db722c9f501"],

Cell[TextData[{
 "The cost function used by the LinearModelFit function is a classical. It is \
the ",
 StyleBox["sum of the residuals measuring the distance between the points and \
the linear function.",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{
  3.781448838016523*^9, {3.781449300556569*^9, 3.781449366532226*^9}, {
