    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSize->Automatic,
   ImageSizeRaw->{241.5, 189.},
   PlotRange->{{0, 241.5}, {0, 189.}}]], "Input",ExpressionUUID->
  "90cf87b8-94aa-46c9-8126-d6a136492b0f"],
 "\n\n",
 StyleBox["Vertices",
  FontWeight->"Bold"],
 " in the tree are questions to the data (i.e. whether an example has a \
feature below or above a partition point ",
 StyleBox["s",
  FontSlant->"Italic"],
 ").\n\nThe ",
 StyleBox["leaf",
  FontWeight->"Bold"],
 " parameters are values of the response variable corresponding to the data \
in each vertex.\n\n",
 StyleBox["**Warning**: The following description is given for students \
interested in deeper understanding of algorithms. It is not considered to be \
a core part of the course\n",
  FontColor->RGBColor[0, 0, 1]],
 "\n",
 StyleBox["More formally",
  FontWeight->"Bold"],
 ", the algorithm to partition the data into two subsets works as follows. \
Let us consider a dataset with ",
 StyleBox["N",
  FontSlant->"Italic"],
 " examples ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["y", "1"]}], ")"}], ",", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["y", "2"]}], ")"}], ",", "...", ","}]}], 
   TraditionalForm]],ExpressionUUID->"52487e9c-a95e-4aaf-8d62-631bc35f5108"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["x", "N"], ",", 
      SubscriptBox["y", "N"]}], ")"}], "}"}], TraditionalForm]],
  ExpressionUUID->"22c34a2f-b007-4a15-b7a8-2a951680cd67"],
 ".\n\n",
 StyleBox["1.",
  FontWeight->"Bold"],
 " Split the data into two sets depending on the value of ",
 StyleBox["x\n\n",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "L"], "(", "s", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{"l", "|", 
      RowBox[{
       SubscriptBox["x", "l"], "\[LessEqual]", "s"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"f0dfbbf1-6e01-4e83-96c0-4815ca9d12bf"],
 " : Examples in the dataset with a features ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "l"], "\[LessEqual]", "s"}], TraditionalForm]],
  ExpressionUUID->"39a58f09-e7aa-482b-b6b2-d1788f82e7c9"],
 ".\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "R"], "(", "s", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{"r", "|", 
      RowBox[{
       SubscriptBox["x", "r"], ">", "s"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"143c5e81-0aff-45d8-bcbe-b0787cbfddd9"],
 " : Examples in the dataset with a features ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "r"], ">", "s"}], TraditionalForm]],ExpressionUUID->
  "f40685d8-8410-4944-ab83-75cc49503215"],
 ".\n\nThese define two branches in the tree.\n\n",
 StyleBox["2.",
  FontWeight->"Bold"],
 " Approximate the response variable ",
 StyleBox["y",
  FontSlant->"Italic"],
 " in each branch by the mean value of the response variables in each branch, \
i.e. by the leaf variables \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"|", 
       SubscriptBox["\[CapitalOmega]", "L"], "|"}]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"l", "\[Element]", 
        SubscriptBox["\[CapitalOmega]", "L"]}]], 
      SubscriptBox["y", "l"]}]}]}], TraditionalForm]],ExpressionUUID->
  "eb52542e-7ba0-4b4a-8ee7-e5eae521104b"],
 "\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "2"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"|", 
       SubscriptBox["\[CapitalOmega]", "R"], "|"}]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"r", "\[Element]", 
        SubscriptBox["\[CapitalOmega]", "R"]}]], 
      SubscriptBox["y", "r"]}]}]}], TraditionalForm]],ExpressionUUID->
  "c1d106f5-e0fa-44e1-a7ae-80f81ec5427a"],
 "\n\n",
 StyleBox["3.",
  FontWeight->"Bold"],
 " Consider a loss function giving the quadratic distance from the data in \
each branch to the leaf variable in the branch, i.e.\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"J", "(", "s", ")"}], "="}], TraditionalForm]],ExpressionUUID->
  "9865ae3b-2c07-46d0-9cd1-691fd9b19ee8"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"l", "\[Element]", 
       SubscriptBox["\[CapitalOmega]", "L"]}]], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["y", "l"], "-", 
        SubscriptBox["v", "1"]}], ")"}], "2"]}], "+", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"r", "\[Element]", 
       SubscriptBox["\[CapitalOmega]", "R"]}]], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["y", "r"], "-", 
        SubscriptBox["v", "2"]}], ")"}], "2"]}]}], TraditionalForm]],
  ExpressionUUID->"aab65537-3583-482e-b1df-d1371fed876d"],
 "\n\n",
 StyleBox["4.",
  FontWeight->"Bold"],
 " Find the optimal value ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["s", "*"], TraditionalForm]],ExpressionUUID->
  "ef869893-b5cb-4cd9-861f-21cf8b5112dd"],
 " of the partition parameter ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "0bdba62e-01f8-414c-8bc1-3aed9d1844cc"],
 " by minimising the cost function, i.e.\n\n",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["s", "*"], TraditionalForm]],ExpressionUUID->
  "31e2092a-efbd-476b-84c1-f879f76d5d23"],
 "=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["argmin", "s"], 
    RowBox[{"{", 
     RowBox[{"J", "(", "s", ")"}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "533c9a7f-beb2-4d95-ac73-04bb46906cc9"],
 "\n\n",
 StyleBox["5.",
  FontWeight->"Bold"],
 " One could do more partitions of the data by defining a tree with more \
branches. \n\n",
