Cell[CellGroupData[{

Cell["Neurons layout - Network topology or architecture", "Subsection",
 CellChangeTimes->{{3.782027117305171*^9, 3.7820271572716494`*^9}, {
  3.7820312158860893`*^9, 
  3.782031220037863*^9}},ExpressionUUID->"7b21c99c-a8c2-4fc5-b2c2-\
a90cb5ade618"],

Cell[TextData[{
 "Suppose that data consists of ",
 StyleBox["M",
  FontSlant->"Italic"],
 " features ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"], ",", "...", ",", 
     SubscriptBox["x", "M"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "d4f9b59f-4d01-40f1-aeef-4f1f8c616a02"],
 " and the goal of an ANN is to transform it into ",
 StyleBox["O",
  FontSlant->"Italic"],
 " outputs  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["y", "1"], ",", 
     SubscriptBox["y", "2"], ",", "...", ",", 
     SubscriptBox["y", "O"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "f1fef828-2c0e-48cc-bc3f-9b776fed8eb6"],
 ". \n\nFor instance, the outputs can be classes or numerical values. \
Therefore, ANNs can be used for both classification and prediction.\n\nThe \
most common layout of ANNs consists of a layer structure:"
}], "Text",
 CellChangeTimes->{{3.7820312260599885`*^9, 3.7820312545919247`*^9}, {
  3.782031285517191*^9, 
  3.782031440241581*^9}},ExpressionUUID->"3b2c230f-8331-40c8-8260-\
d368991e5faf"],

Cell[CellGroupData[{

Cell["Input layer: A neuron for each feature in the input data.", "Item",
 CellChangeTimes->{{3.782031263906116*^9, 3.782031282931368*^9}, {
  3.7820314449724026`*^9, 
  3.7820314606815104`*^9}},ExpressionUUID->"ebd4b862-ace6-48d5-bf4b-\
50b225b5c6c0"],

Cell["\<\
Hidden layers: These layers take the outputs from the input layer, operate \
with them and outputs the results to the output layer.\
\>", "Item",
 CellChangeTimes->{{3.782031263906116*^9, 3.782031282931368*^9}, {
  3.7820314449724026`*^9, 
  3.782031527269467*^9}},ExpressionUUID->"c58f6351-97ae-4e33-ac22-\
83a3072c94e1"],

Cell["\<\
Output layer: Transforms the output of the hidden layers to give the output \
we are interested in.\
\>", "Item",
 CellChangeTimes->{{3.782031263906116*^9, 3.782031282931368*^9}, {
  3.7820314449724026`*^9, 3.7820315595968294`*^9}, {3.7820320442500753`*^9, 
  3.7820320699729424`*^9}},ExpressionUUID->"68719491-d41f-461a-a6c5-\
fc8c269dc835"]
}, Open  ]],

