  3.782046127944778*^9, 3.7820461280949297`*^9}},
 CellLabel->
  "In[142]:=",ExpressionUUID->"ac6a1a5d-c64f-4900-bffd-de1e764e84f5"],

Cell[BoxData[
 TagBox[
  PanelBox["\<\"An neural networks is composed of layers of artificial neuron \
units. Each unit computes its value as a \\nfunction of the unit values in \
the previous layer. Information is processed layer by layer from the feature \
layer to the \\noutput unit which gives the predicted value. It is also \
called a feed-forward neural network or a multi-layer perceptron.\"\>",
   BaseStyle->{LineIndent -> 0}],
  Deploy,
  DefaultBaseStyle->"Deploy"]], "Output",
 CellChangeTimes->{3.7816210344386034`*^9, 3.782046160519874*^9, 
  3.782130739033583*^9},
 CellLabel->
  "Out[142]=",ExpressionUUID->"4e559f18-7e9e-455c-9197-270414903b0d"]
}, Open  ]],

