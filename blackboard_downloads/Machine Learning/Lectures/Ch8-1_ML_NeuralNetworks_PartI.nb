Cell[BoxData[
 RowBox[{"fNet4", ":=", 
  RowBox[{"NetChain", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"LinearLayer", "[", "4", "]"}], ",", 
      RowBox[{"ElementwiseLayer", "[", "LogisticSigmoid", "]"}], ",", 
      RowBox[{"LinearLayer", "[", "1", "]"}]}], "}"}], ",", 
    RowBox[{"\"\<Input\>\"", "\[Rule]", "\"\<Real\>\""}], ",", 
    RowBox[{"\"\<Output\>\"", "\[Rule]", 
     RowBox[{"NetDecoder", "[", "\"\<Scalar\>\"", "]"}]}]}], "]"}]}]], "Input",
