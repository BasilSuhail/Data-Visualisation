Cell[CellGroupData[{

Cell["ANN Layers in Mathematica", "Section",
 CellChangeTimes->{{3.779072097889924*^9, 3.7790721062977695`*^9}, {
  3.7790724327838497`*^9, 3.7790724345712624`*^9}, {3.7817755924026637`*^9, 
