Cell[TextData[{
 "The syntax is  ",
 StyleBox["LinearLayer[", "CodeText"],
 Cell[BoxData[
  FormBox["O", TraditionalForm]],ExpressionUUID->
  "29cd1221-ce5c-40a1-bdb9-90a87275128d"],
 StyleBox[",\[CloseCurlyDoubleQuote]Input\[CloseCurlyDoubleQuote]\[Rule]", 
  "CodeText"],
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "015901d2-c1c0-425e-9f0c-23b03c3e471e"],
 StyleBox["]", "CodeText"],
 ", where ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "fb44c1a4-17b1-4a25-a766-5c875973f993"],
 " is the number of input variables and ",
 Cell[BoxData[
  FormBox["O", TraditionalForm]],ExpressionUUID->
  "cb731caf-2570-4222-93c3-1749a039f4de"],
 " is the number of output variables (both equal to 1 in our simple example)"
}], "Text",
 CellChangeTimes->{{3.782034138921975*^9, 
  3.7820342748789597`*^9}},ExpressionUUID->"079dc746-d4c3-4f8a-adf6-\
5af12e3ffd15"]
}, Open  ]],

