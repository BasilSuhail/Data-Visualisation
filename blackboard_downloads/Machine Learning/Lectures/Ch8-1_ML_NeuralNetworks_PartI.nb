Cell["Visualizing the fitted model", "Subsubsection",
 CellChangeTimes->{{3.7820473085935435`*^9, 
  3.7820473199309483`*^9}},ExpressionUUID->"6432d7d0-84c9-4f2f-aac8-\
2d6354b33e76"],

Cell[BoxData[
 RowBox[{
  RowBox[{"plotSDRegion", "[", 
   RowBox[{"predictor_", ",", "data_", ",", "xmin_", ",", "xmax_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"p", "=", "predictor"}], ",", 
      RowBox[{"data0", "=", "data"}], ",", 
      RowBox[{"xmin0", "=", "xmin"}], ",", 
      RowBox[{"xmax0", "=", "xmax"}], ",", "x"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"p", "[", "x", "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"p", "[", "x", "]"}], "+", 
           RowBox[{"StandardDeviation", "[", 
            RowBox[{"p", "[", 
             RowBox[{"x", ",", "\"\<Distribution\>\""}], "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"p", "[", "x", "]"}], "-", 
           RowBox[{"StandardDeviation", "[", 
            RowBox[{"p", "[", 
             RowBox[{"x", ",", "\"\<Distribution\>\""}], "]"}], "]"}]}]}], 
         "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"x", ",", "xmin0", ",", "xmax0"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"Blue", ",", "Gray", ",", "Gray"}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Filling", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"2", "\[Rule]", 
           RowBox[{"{", "3", "}"}]}], "}"}]}], ",", 
        RowBox[{"PlotLegends", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"\"\<Prediction\>\"", ",", "\"\<Confidence Interval\>\""}], 
          "}"}]}]}], "]"}], ",", 
      RowBox[{"ListPlot", "[", 
       RowBox[{"data0", ",", 
        RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
        RowBox[{"PlotLegends", "\[Rule]", 
         RowBox[{"{", "\"\<Data\>\"", "}"}]}]}], "]"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"e7b2ee21-d650-49a7-83b5-bb6f7098a9c9"],

