Cell[CellGroupData[{

Cell["Number of neurons and layers", "Subsubsection",
 CellChangeTimes->{{3.782038116352751*^9, 
  3.7820381242056694`*^9}},ExpressionUUID->"fa952f43-4433-442b-834f-\
12c64b213da5"],

Cell[TextData[{
 "Large neural networks may consist of the order of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", "7"], TraditionalForm]],ExpressionUUID->
  "b97fd7c6-df5c-4eba-97e9-f3ab6e854ae8"],
 " neurons. This is still far from the human brain which contains of the \
order of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", "11"], TraditionalForm]],ExpressionUUID->
  "f01816b0-e835-416e-8839-bf6bb26296c7"],
 " neurons. It was predicted that the number of neurons in ANNs will get to \
the size of the human brain in 2056 (see the freely available book ",
 ButtonBox["http://www.deeplearningbook.org/",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://www.deeplearningbook.org/"], None},
  ButtonNote->"http://www.deeplearningbook.org/"],
 ").\n\nThe ",
 StyleBox["depth",
  FontWeight->"Bold"],
 " of an ANN is the number of layers. Current ANNs can have tens of layers.\n\
\n",
 StyleBox["Deep neural network (DNN):",
  FontWeight->"Bold"],
 " It is an ANN with multiple hidden layers.\n\n",
 StyleBox["Deep learning",
  FontWeight->"Bold"],
 " refers to training DNNs."
}], "Text",
 CellChangeTimes->{{3.782026785705351*^9, 3.7820268001447763`*^9}, {
   3.782030178980733*^9, 3.7820302453061795`*^9}, {3.782030277529623*^9, 
   3.782030311971589*^9}, {3.7820304326153145`*^9, 3.782030505537941*^9}, {
   3.7820320775644546`*^9, 3.782032106292353*^9}, 3.782032158486351*^9, {
   3.7820381273120813`*^9, 3.782038217274661*^9}, {3.7820383636077566`*^9, 
   3.782038427170805*^9}, {3.78203854306343*^9, 3.7820385489058104`*^9}, {
   3.8149622479274817`*^9, 3.814962247928479*^9}, {3.8149623412047215`*^9, 
   3.8149623444600105`*^9}},ExpressionUUID->"3d9b2d5a-600e-453b-bce2-\
a395b61ec5f8"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["How can ANNs be used?", "Subsection",
 CellChangeTimes->{{3.782033456275232*^9, 
  3.782033464732093*^9}},ExpressionUUID->"fe3acd81-726a-4150-9f8f-\
bdf35bcad63a"],

Cell[CellGroupData[{

Cell["Building networks from scratch", "Item",
 CellChangeTimes->{{3.7820335138696423`*^9, 
  3.7820335233045936`*^9}},ExpressionUUID->"e53b50b5-4eb8-4d58-b78c-\
91c806f94bcb"],

Cell[CellGroupData[{

Cell["Build the network architecture. Decide what layers you need.", "Subitem",
 CellChangeTimes->{{3.7820335138696423`*^9, 3.782033535907542*^9}, {
  3.7820335685058155`*^9, 
  3.782033581256049*^9}},ExpressionUUID->"c302ce5c-6dac-4167-82f8-\
a69a6b470778"],

Cell["\<\
Use data to train the network. This defines what each neuron will do to the \
input data or inputs from other neurons.\
\>", "Subitem",
 CellChangeTimes->{{3.7820335138696423`*^9, 
  3.782033607914609*^9}},ExpressionUUID->"72d61361-15af-412f-b7bb-\
18572899d7dc"],

Cell["\<\
Apply the trained network to other data with the same format as the data used \
to train.\
\>", "Subitem",
 CellChangeTimes->{{3.7820335138696423`*^9, 
  3.7820336388462257`*^9}},ExpressionUUID->"48cd3173-a02b-4366-a4ba-\
b3deecddc4c6"]
}, Open  ]],

Cell[TextData[{
 "In Mathematica: Use ",
 StyleBox["Predict", "CodeText"],
 " and ",
 StyleBox["Classify", "CodeText"],
 " superfunctions to automatically train networks for prediction and \
classification."
}], "Item",
 CellChangeTimes->{{3.7820335138696423`*^9, 3.782033664923831*^9}, {
  3.7820337154893064`*^9, 
  3.782033715889186*^9}},ExpressionUUID->"ce19ee4c-5e58-4c13-82e3-\
c8088a699de8"],

Cell["Use pre-built networks. ", "Item",
 CellChangeTimes->{{3.7820335138696423`*^9, 3.782033729699837*^9}, {
  3.782033784628932*^9, 
  3.782033801575879*^9}},ExpressionUUID->"ea631653-a61d-4bd8-8eb2-\
20f8c036631a"],

Cell[CellGroupData[{

Cell[TextData[{
 "For instance, the ",
 ButtonBox["Wolfram Neural Net Repository",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://resources.wolframcloud.com/NeuralNetRepository"], None},
  ButtonNote->"http://resources.wolframcloud.com/NeuralNetRepository"],
 " is a public resource that hosts an expanding collection of trained and \
untrained neural network models suitable for immediate evaluation, training, \
visualization, transfer learning and more. "
}], "Subitem",
 CellChangeTimes->{{3.7820335138696423`*^9, 3.782033729699837*^9}, {
  3.7820338046524305`*^9, 
  3.7820338240562606`*^9}},ExpressionUUID->"7d7a3e6d-b1e5-449b-92c5-\
4886d9c392be"],

Cell[TextData[{
 "Do ",
 StyleBox["net surgery",
  FontWeight->"Bold"],
 " on pre-built networks."
}], "Subitem",
 CellChangeTimes->{{3.7820335138696423`*^9, 3.782033729699837*^9}, {
  3.7820338046524305`*^9, 
  3.7820338553312383`*^9}},ExpressionUUID->"0927c836-d20c-496d-bfe6-\
d053086109b2"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Strengths and weaknesses of ANNs", "Subsection",
 CellChangeTimes->{{3.782024296047351*^9, 3.782024298911811*^9}, {
  3.7820334108318853`*^9, 3.782033413305339*^9}, {3.7820385639934254`*^9, 
  3.7820385693793077`*^9}},ExpressionUUID->"3213b147-bcf9-4623-96e2-\
c1569a13913e"],

Cell[CellGroupData[{

Cell["Strengths", "Subsubsection",
 CellChangeTimes->{{3.7820385766672816`*^9, 
  3.7820385787659945`*^9}},ExpressionUUID->"dbccecb8-181f-4f9b-8620-\
61605b489053"],

Cell[CellGroupData[{

Cell["\<\
Can model more complex situations than most other methods in machine learning.\
\>", "Item",
 CellChangeTimes->{{3.7820243288151326`*^9, 3.7820243569701147`*^9}, 
   3.8149628121750917`*^9},ExpressionUUID->"819aeb7c-13a8-4bb8-bf51-\
932439aa458f"],

Cell["Can be used for both classification and prediction problems.", "Item",
 CellChangeTimes->{{3.7820243288151326`*^9, 3.782024374882459*^9}, 
   3.8149628140829883`*^9},ExpressionUUID->"37d2a36c-6f0e-4f67-a743-\
5c376ff34b05"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Weaknesses", "Subsubsection",
 CellChangeTimes->{{3.7820243053349967`*^9, 3.7820243072975492`*^9}, 
   3.7820334179996386`*^9, 
   3.782038590666312*^9},ExpressionUUID->"44993ce2-333e-4f5e-9125-\
958a25770581"],

Cell[CellGroupData[{

Cell["Computationally intensive.", "Item",
 CellChangeTimes->{{3.782024393600809*^9, 
  3.7820244134087315`*^9}},ExpressionUUID->"ec532e3c-708a-441b-b39c-\
15cd1cd2d374"],

Cell["\<\
Slow to train, mainly if the network topology is reasonably complex. GPU can \
be used to accelerate the process.\
\>", "Item",
 CellChangeTimes->{{3.782024393600809*^9, 3.782024451433591*^9}, {
  3.7820297673808784`*^9, 
  3.7820297673808784`*^9}},ExpressionUUID->"2391d32f-7572-42da-a022-\
2974a78bbe47"],

Cell["Can easily lead to overfitting.", "Item",
 CellChangeTimes->{{3.782024393600809*^9, 3.782024451433591*^9}, {
  3.7820297705067234`*^9, 
  3.7820297899028215`*^9}},ExpressionUUID->"1151ef45-de9f-4228-9740-\
158d447ca8c8"],

Cell["\<\
The model behind trained networks is often difficult (or impossible) to \
interpret by humans.\
\>", "Item",
 CellChangeTimes->{{3.782024393600809*^9, 
  3.7820244921124754`*^9}},ExpressionUUID->"237ed34e-4939-4635-b566-\
938550c3574b"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Additional Bibliography for ANNs", "Subsection",
 CellChangeTimes->{
  3.814962788962628*^9},ExpressionUUID->"e30b1baf-7f0d-4947-a69f-\
d6c147b60069"],

Cell[TextData[{
 "Neural networks are covered in all books recommended on machine learning. \
There are many other books and articles on the topic. \n\nFreely available \
book online: Ian Goodfellow and Yoshua Bengio and Aaron Courville \
http://www.deeplearningbook.org/\n\nCharu C. Aggarwal \
\[OpenCurlyDoubleQuote]Neural Networks and Deep Learning\
\[CloseCurlyDoubleQuote], Springer (2018)\n\nYann LeCun, Yoshua Bengio & \
Geoffrey Hinton \[OpenCurlyDoubleQuote]Deep Learning\[CloseCurlyDoubleQuote], \
Nature ",
 StyleBox["521",
  FontWeight->"Bold"],
 ", 436 (2015).\n\nA. Zhang, Z.C. Lipton, M. Li and A. J. Smola, \
\[OpenCurlyDoubleQuote]Dive into deep learning\[CloseCurlyDoubleQuote], \
(2020) ",
 ButtonBox["https://d2l.ai/",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://d2l.ai/"], None},
  ButtonNote->"https://d2l.ai/"],
 "\n\nThe Mathematica tutorial on Neural Networks is also very instructive: ",
 Cell[BoxData[
  ButtonBox[Cell[
   "Neural Networks in the Wolfram Language",ExpressionUUID->
    "b9c92a01-2635-4144-abb1-69db16c1849b"],
   BaseStyle->Dynamic[
     If[
      CurrentValue["MouseOver"], {
      "Link", FontColor -> 
       RGBColor[0.9686274509803922, 0.4666666666666667, 0.]}, {"Link"}]],
   ButtonData->"paclet:tutorial/NeuralNetworksOverview"]],ExpressionUUID->
  "1e9892c8-42d7-4d03-9f29-011fee677200"]
}], "Text",
 CellChangeTimes->{{3.7820307469550114`*^9, 3.7820308009434376`*^9}, {
   3.7820308359055595`*^9, 3.7820308586769123`*^9}, {3.782030918935911*^9, 
   3.7820310581655607`*^9}, {3.782042336918908*^9, 3.782042374255783*^9}, 
   3.814962511905175*^9, {3.8149626564253693`*^9, 3.8149627043869467`*^9}, {
   3.8149627600413094`*^9, 
   3.814962778186234*^9}},ExpressionUUID->"9aefdb5a-4662-43c6-be9e-\
fd45919c26cd"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Understanding ANNs through simple examples", "Section",
 CellChangeTimes->{{3.782032252188916*^9, 3.7820322629604692`*^9}, {
  3.782032344949068*^9, 3.782032350024344*^9}, {3.8149657698245955`*^9, 
  3.814965798083989*^9}},ExpressionUUID->"c316caaa-e8b0-41f6-ab14-\
0f1dbf0de07e"],

Cell["Linear and logistic regression can be seen as simple ANNs.", "Text",
 CellChangeTimes->{{3.7820324725540934`*^9, 3.7820324864922514`*^9}, {
  3.782033895030424*^9, 
  3.782033900228075*^9}},ExpressionUUID->"5b8b89c9-2e98-4cdc-9fd7-\
8585683b72a8"],

Cell[CellGroupData[{

Cell["ANN for linear regression", "Subsection",
 CellChangeTimes->{{3.781762707531267*^9, 3.7817627296982327`*^9}, {
  3.7820324949669957`*^9, 
  3.782032496039727*^9}},ExpressionUUID->"51ad7362-2ca3-4b82-a1b4-\
db91385734dd"],

Cell[TextData[{
 "Let us consider data with just one feature, ",
 StyleBox["x",
  FontSlant->"Italic"],
 ". Linear regression can predict the value of a dependent variable ",
 StyleBox["y",
  FontSlant->"Italic"],
 " by assuming that it is a linear combination of ",
 StyleBox["x",
  FontSlant->"Italic"],
 ". \n\nThis can be viewed as an ANN with a single layer. This is called a \
linear layer:"
}], "Text",
 CellChangeTimes->{{3.78203295692352*^9, 
  3.7820330935880847`*^9}},ExpressionUUID->"c5cbd600-4618-4dfe-adcd-\
25d37a90120a"],

