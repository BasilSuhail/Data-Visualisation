Cell[CellGroupData[{

Cell["Universal Approximation Theorem", "Section",
 CellChangeTimes->{{3.78214670955473*^9, 
  3.782146725787231*^9}},ExpressionUUID->"680481bc-5451-47cc-a175-\
60c0845ba9ed"],

Cell["\<\
The Universal Approximation Theorem that, under quite general conditions, a \
feedforward ANN with a single layer can approximate any continuous function \
with any degree of accuracy if the layer contains enough neurons.\
\>", "Text",
 CellChangeTimes->{{3.782146844454783*^9, 3.7821469227431703`*^9}, {
  3.782152046906746*^9, 3.7821520651301413`*^9}, {3.782152103041193*^9, 
  3.782152148064218*^9}},ExpressionUUID->"011d08c8-9e21-487c-a75f-\
2e8be128fc40"],

Cell[CellGroupData[{

Cell["Using neural networks to approximate functions", "Subsection",
 CellChangeTimes->{{3.7821938266496296`*^9, 
  3.7821938357075543`*^9}},ExpressionUUID->"2d168b1c-2ca0-4b2f-8a0d-\
b3e73d1829a2"],

Cell[TextData[{
 "In numerical analysis of data, it is often useful to fit a function to the \
data. \n\nA typical way to do this is to fit polynomials ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"a", "+", 
      RowBox[{"b", " ", "x"}], "+", 
      RowBox[{"c", " ", 
       SuperscriptBox["x", "2"]}], "+"}], "..."}], ")"}], TraditionalForm]],
  ExpressionUUID->"e43c7e43-cc9e-4130-a189-d8da8e6fdef4"],
 ". However, this might not be very efficient if the data has a complicated \
structure.\n\nFollowing from the universal approximation theorem, neural \
networks can be trained to fit any function to an arbitrary degree of \
accuracy. We just need to use enough nodes in our network."
}], "Text",
 CellChangeTimes->{{3.782193857962497*^9, 3.7821938933876*^9}, {
  3.7821939289173036`*^9, 3.782194075277761*^9}, {3.782194166907738*^9, 
  3.7821941672676992`*^9}, {3.782194690922083*^9, 3.7821947416923623`*^9}, {
  3.7821978115218387`*^9, 3.782197828388569*^9}, {3.8149640629061995`*^9, 
  3.8149640642276573`*^9}},ExpressionUUID->"325b6f13-d296-4e51-8ea6-\
bd54591c92a5"],

Cell["\<\
Consider, for instance data that obeys the following function:\
\>", "Text",
 CellChangeTimes->{{3.782194173240861*^9, 3.782194191078044*^9}, 
   3.782194747872241*^9},ExpressionUUID->"e930e41b-e490-45ad-9b22-\
7db18d38d7ca"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"2", " ", "x"}], "]"}], "+", 
     RowBox[{"Cos", "[", 
      RowBox[{"3", " ", "x"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", 
