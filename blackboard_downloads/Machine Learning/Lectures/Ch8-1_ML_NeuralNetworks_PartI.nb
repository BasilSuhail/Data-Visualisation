Cell[BoxData[
 RowBox[{
  RowBox[{"plotFitData", "[", 
   RowBox[{"predictor_", ",", "data_", ",", "xmin_", ",", "xmax_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"p", "=", "predictor"}], ",", 
      RowBox[{"data0", "=", "data"}], ",", 
      RowBox[{"xmin0", "=", "xmin"}], ",", 
      RowBox[{"xmax0", "=", "xmax"}], ",", "x"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"p", "[", "x", "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"x", ",", "xmin0", ",", "xmax0"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"{", "Blue", "}"}]}], ",", 
        RowBox[{"PlotLegends", "\[Rule]", 
         RowBox[{"{", "\"\<Prediction\>\"", "}"}]}]}], "]"}], ",", 
      RowBox[{"ListPlot", "[", 
       RowBox[{"data0", ",", 
        RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
        RowBox[{"PlotLegends", "\[Rule]", 
         RowBox[{"{", "\"\<Data\>\"", "}"}]}]}], "]"}]}], "]"}]}], 
   "]"}]}]], "Input",
