Cell["\<\
Our data might be random (in some way). Here, I consider 5000 data points:\
\>", "Text",
 CellChangeTimes->{{3.7821942056079245`*^9, 
  3.782194296207847*^9}},ExpressionUUID->"61cea352-8b79-4fd8-bd48-\
ec6f3216b73c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"#", "\[Rule]", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"2", " ", "#"}], "]"}], "+", 
        RowBox[{"Cos", "[", 
         RowBox[{"3", " ", "#"}], "]"}]}]}], ")"}], "&"}], "@", 
    RowBox[{"RandomReal", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", 
        RowBox[{"2", " ", "Pi"}]}], "}"}], ",", "5000"}], "]"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.7821534077246*^9, 3.7821534077289143`*^9}, {
  3.782153547664338*^9, 3.782153548040476*^9}, {3.7821535786722417`*^9, 
