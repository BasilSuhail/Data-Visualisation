Cell[CellGroupData[{

Cell["Basic layers", "Subsection",
 CellChangeTimes->{{3.7821453296420884`*^9, 
  3.7821453563209395`*^9}},ExpressionUUID->"e5126ffc-33e1-4912-91df-\
3983bb6a5fa4"],

Cell[TextData[{
 "The basic layers are LinearLayer and ElementwiseLayer[]\n\nThe functioning \
of LinearLayer has been illustrated above.\n\nElementwiseLayer[",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "99c37109-b565-4ae2-9e75-05273fdc9801"],
 "] can be used to apply any function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "fd343314-395c-4a85-8c6b-822d03c9feca"],
 " to every element of the input of the layer.\n\nThe function ",
 StyleBox["f ",
  FontFamily->"Arial",
  FontSlant->"Italic"],
 "is referred to as the ",
 StyleBox["activation function",
  FontWeight->"Bold"],
 " in the literature; commonly used activation functions are ",
 Cell[BoxData[
  FormBox[
   ButtonBox["LogisticSigmoid",
    BaseStyle->"Link",
    ButtonData->"paclet:ref/LogisticSigmoid"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"38b809cb-ca5d-4068-b945-37a808863c55"],
 StyleBox[", ",
  FontWeight->"Bold"],
 StyleBox[ButtonBox["Tanh",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Tanh"],
  FontWeight->"Bold"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "and",
 StyleBox[" ",
  FontWeight->"Bold"],
 StyleBox[ButtonBox["Ramp",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Ramp"],
  FontWeight->"Bold"],
 " (Rectified Linear Unit, ReLU): "
}], "Text",
 CellChangeTimes->{{3.782145358390458*^9, 3.7821455372265973`*^9}, {
  3.7821455877074175`*^9, 
  3.782145590340186*^9}},ExpressionUUID->"a40bb5d2-1471-49a9-9e1f-\
cdbfc3dddfe9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"LogisticSigmoid", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"PlotLabel", "\[Rule]", "\"\<Logistic\>\""}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Tanh", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"PlotLabel", "\[Rule]", "\"\<Tanh\>\""}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Ramp", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"PlotLabel", "\[Rule]", "\"\<Ramp, ReLU\>\""}]}], "]"}]}], 
  "}"}]], "Input",
 CellChangeTimes->{{3.782145655536383*^9, 3.782145716081376*^9}, {
  3.782145746262764*^9, 3.7821458696592026`*^9}},
