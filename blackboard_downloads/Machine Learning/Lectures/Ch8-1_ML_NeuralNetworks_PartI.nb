Cell[CellGroupData[{

Cell["Initializing the network - NetInitialize", "Subsubsection",
 CellChangeTimes->{{3.7820347662720404`*^9, 3.7820347718415747`*^9}, {
  3.7820387816994486`*^9, 
  3.782038783020772*^9}},ExpressionUUID->"e1448ac1-2dec-4b59-8048-\
08c164698216"],

Cell[TextData[{
 "Notice that in the summary box above, there is an \
\[OpenCurlyDoubleQuote]uninitialized\[CloseCurlyDoubleQuote] caption \
indicating that the net contains learnable parameters that have not yet been \
provided. In this case, these are the parameters ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "0"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "defabd2d-090e-46df-b1f3-86ec1afcb62d"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "1"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "092a9744-bf0b-4e09-8d5a-99c137270a9e"]
}], "Text",
 CellChangeTimes->{{3.7820339527526803`*^9, 
  3.782033990255074*^9}},ExpressionUUID->"61fac646-215a-455b-a2d2-\
dba679c4fc7a"],

Cell["\<\
Using NetInitialize, we can give random values to the parameters:\
\>", "Text",
 CellChangeTimes->{{3.7820340658755984`*^9, 3.7820340994682817`*^9}, {
  3.7820348471091585`*^9, 3.782034849017644*^9}},
