Cell["\<\
In fact, this model resembles what a biological neuron is believed to do: \
Gather information (input), transform it (integrate) and give a signal out \
(fire) or not, depending on the strength of the integrated signal.\
\>", "Text",
 CellChangeTimes->{{3.7820441269500065`*^9, 3.7820442016539755`*^9}, {
  3.7820443029000206`*^9, 
  3.7820443105997887`*^9}},ExpressionUUID->"06c7eede-ab2f-4e5d-b609-\
69a5b9d25bdd"],

Cell[TextData[{
 "In Mathematica, a sigmoid neuron can be implemented as an ",
 StyleBox["ElementwiseLayer", "CodeText"],
 " with ",
 StyleBox["LogisticSigmoid", "CodeText"],
 " shape.\n\nHere, I use the ",
 StyleBox["NetGraph", "CodeText"],
 " command to concatenate the two layers ({1,2} means that the input of the \
second element,  ",
 StyleBox["ElementwiseLayer[LogisticSigmoid]", "CodeText"],
 ", is the output of the first, ",
 StyleBox["LinearLayer[]", "CodeText"],
 "):"
}], "Text",
 CellChangeTimes->{{3.7820440918692365`*^9, 3.78204410913947*^9}, {
  3.7820443150640836`*^9, 3.782044351168973*^9}, {3.7820445426870966`*^9, 
  3.7820446464158287`*^9}},ExpressionUUID->"5e9217fb-9ef2-4396-b7a9-\
52427b9f1969"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"logistic", "=", 
  RowBox[{"NetGraph", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"LinearLayer", "[", "]"}], ",", 
      RowBox[{"ElementwiseLayer", "[", "LogisticSigmoid", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"1", "\[Rule]", "2"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.781762986928998*^9, 3.7817629972582197`*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"26139daf-0b33-4822-afa0-b822620d7d30"],

