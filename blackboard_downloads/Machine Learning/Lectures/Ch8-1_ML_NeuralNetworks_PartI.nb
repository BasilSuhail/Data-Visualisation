  3.8149637481546974`*^9}},ExpressionUUID->"2efbd37f-ba96-4ba5-8507-\
1bb56cf3d001"],

Cell[TextData[{
 "So far, we have just used two types of layers: ",
 StyleBox["LinearLayer", "CodeText"],
 " and ",
 StyleBox["ElementwiseLayer[LogisticSigmoid]", "CodeText"],
 " \n\nHowever, Mathematica offers many layers to build neural networks"
}], "Text",
 CellChangeTimes->{{3.7800512830019903`*^9, 3.780051294873809*^9}, {
  3.7817756014348154`*^9, 3.7817756164983935`*^9}, {3.7820452449637766`*^9, 
  3.7820452850465364`*^9}, {3.7820453167542887`*^9, 
  3.7820453264342585`*^9}},ExpressionUUID->"b2f99019-1905-4b3d-8aa4-\
364668c74db4"],

