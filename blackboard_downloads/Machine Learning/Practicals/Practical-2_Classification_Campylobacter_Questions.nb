Cell[CellGroupData[{

Cell["Task 2", "Section",
 CellChangeTimes->{{3.779636226562393*^9, 3.7796362283546057`*^9}, {
  3.779899023707754*^9, 3.779899024936124*^9}, {3.7799688454588614`*^9, 
  3.7799688460772753`*^9}},ExpressionUUID->"7b2d7ea2-9e56-4cc3-a912-\
044df4ea0577"],

Cell[TextData[{
 "Examine the format of the dataset. For instance, use the function ",
 StyleBox["Take", "CodeText"],
 " to see the 10 first instances and look at the dimensions of the dataset. \
As you will see, ",
 StyleBox["data", "CodeText"],
 " is a list of lists. It can be thought as a table consisting of 8 columns \
and 1173 rows. The first column gives the category of each isolate and each \
row corresponds to a different isolate."
}], "Text",
 CellChangeTimes->{{3.7798016653237147`*^9, 3.7798016731764383`*^9}, {
  3.7798989262317142`*^9, 3.7798989629746633`*^9}, {3.779898997890277*^9, 
  3.7798990096430287`*^9}, {3.779899987962044*^9, 3.7799000089470606`*^9}, {
  3.7799000439191113`*^9, 3.779900149292407*^9}, {3.7799441111317587`*^9, 
  3.779944190689382*^9}},ExpressionUUID->"a5dc5bc1-cb99-4623-bd9a-\
587c8614cd0c"]
}, Closed]],

Cell[CellGroupData[{

Cell["Task 3", "Section",
 CellChangeTimes->{{3.7798995126241236`*^9, 3.7798995147358494`*^9}, {
  3.779968848317216*^9, 
  3.779968848934904*^9}},ExpressionUUID->"32f112a7-2289-49e4-a4aa-\
0683367be81a"],

Cell[TextData[{
 "Look at the name of different categories in the dataset which are given in \
the first column for each instance (isolate). This can be done by ",
 StyleBox["DeleteDuplicates", "CodeText"],
 ".",
 " "
}], "Text",
 CellChangeTimes->{{3.7798995187452555`*^9, 3.7798996124624557`*^9}, {
  3.7798996650757265`*^9, 3.7798996969800615`*^9}, {3.7799442111834235`*^9, 
  3.7799442404040422`*^9}},ExpressionUUID->"36bb9402-38ea-4e59-afc8-\
abbca9b59e13"]
}, Closed]],

Cell[CellGroupData[{

Cell["Task 4", "Section",
 CellChangeTimes->{{3.779899034545989*^9, 3.779899036813922*^9}, {
  3.7799688508091154`*^9, 
  3.7799688518750124`*^9}},ExpressionUUID->"b5c1b465-04dd-4996-9d93-\
793e13eb3dfc"],

Cell[TextData[{
 "Since the isolates from food reservoirs are assumed to be the sources of \
human isolates, it makes sense to split the list data into two lists, one \
corresponding to human isolates and another for isolates from food \
reservoirs.  The resulting lists should have the same format (e.g. same \
number of columns) as ",
 StyleBox["data", "CodeText"],
 ". More explicitly:"
}], "Text",
 CellChangeTimes->{{3.7798990406267743`*^9, 3.7798992299602504`*^9}, {
  3.7799443844212193`*^9, 3.7799443988584003`*^9}, {3.779944472909704*^9, 
  3.7799445142789774`*^9}, {3.7799445780631757`*^9, 
  3.7799446171026993`*^9}},ExpressionUUID->"f195ddb3-8bcd-415b-a6f2-\
28dc91cdf59e"],

Cell[CellGroupData[{

Cell[TextData[{
 "Create a sublist from ",
 StyleBox["data", "CodeText"],
 " for human isolates. Refer to it as ",
 StyleBox["dataHuman", "CodeText"],
 ". "
}], "Item",
 CellChangeTimes->{{3.778672975312646*^9, 3.778673000529127*^9}, 
   3.779899252670478*^9, {3.779899454065422*^9, 3.7798994799339056`*^9}, {
   3.779899961230956*^9, 3.7798999653998985`*^9}, {3.779900304777667*^9, 
   3.779900473139451*^9}, 3.779944532818875*^9, 
   3.8141009773170705`*^9},ExpressionUUID->"e634d825-a8bc-4e4b-a5ae-\
c3ab401f403a"],

Cell[TextData[{
 "Create a list containing the data for food reservoirs only. Refer to the \
new list as ",
 StyleBox["dataSources", "CodeText"],
 ". "
}], "Item",
 CellChangeTimes->{{3.778674338688918*^9, 3.7786743620808277`*^9}, {
   3.7799004805361667`*^9, 3.7799004968945427`*^9}, {3.77990069490193*^9, 
   3.7799007288193407`*^9}, {3.779944551222447*^9, 3.7799445729913387`*^9}, 
   3.8141009808396316`*^9},ExpressionUUID->"20f5e0f1-9ada-49e3-afd8-\
70b9ebd04412"]
}, Open  ]],

Cell["\<\
As usual when defining new lists or variables, check that they look like you \
expect them to look.\
\>", "Text",
 CellChangeTimes->{{3.779945476537468*^9, 
  3.779945502491917*^9}},ExpressionUUID->"9c57d3a8-d456-4688-8903-\
50d57535461f"]
}, Closed]],

Cell[CellGroupData[{

Cell["Task 5", "Section",
 CellChangeTimes->{{3.7799008813406773`*^9, 3.7799008833473835`*^9}, {
  3.7799688549902873`*^9, 
  3.7799688560393157`*^9}},ExpressionUUID->"20163eb0-4612-4012-a836-\
86441e89dd46"],

Cell[TextData[{
 "Use ",
 StyleBox["dataSources", "CodeText"],
 " to define a list named ",
 StyleBox["sourcenames", "CodeText"],
 " containing the name of the sources. This will be useful to explore the \
data below. Note that isolates from wild birds are labeled as WB."
}], "Text",
 CellChangeTimes->{{3.779900890715333*^9, 3.7799009420350857`*^9}, {
  3.7799449727039175`*^9, 3.779944993937152*^9}, {3.7799467576305895`*^9, 
  3.7799467790948076`*^9}},ExpressionUUID->"552b4c3a-9836-483a-b4c1-\
