Cell[CellGroupData[{

Cell["Task 7", "Section",
 CellChangeTimes->{{3.77989889326932*^9, 3.7798988979287596`*^9}, {
  3.779968860955378*^9, 
  3.779968862074503*^9}},ExpressionUUID->"641acbe5-a81c-4481-a7af-\
31ac854cfbe7"],

Cell["\<\
Separate the instances in dataSources by source. In order to achieve this \
task, you may want to go back to the Iris flowers classification example \
where a similar task was done.\
\>", "Text",
 CellChangeTimes->{{3.7798025559630165`*^9, 3.779802623536672*^9}, {
  3.779898901891939*^9, 3.779898903634409*^9}, {3.77994555730057*^9, 
  3.779945645525818*^9}, {3.8141860653264637`*^9, 
  3.8141860671215973`*^9}},ExpressionUUID->"8cf631f5-c8f4-4f1c-8353-\
0a68ee3b11b1"],

Cell[CellGroupData[{

Cell["Answer", "Subsection",
 CellChangeTimes->{{3.7798026268516707`*^9, 
  3.77980262808584*^9}},ExpressionUUID->"43696ff8-179b-4363-9446-\
33906c39e1d5"],

Cell["\<\
As explained in the Iris flowers classification problem, there are at least \
two ways to achieve this: by using Cases or Position. Both should give the \
same result.\
\>", "Text",
 CellChangeTimes->{
  3.779802639380831*^9, {3.7798027804952335`*^9, 3.7798028165250187`*^9}, {
   3.7799456563184834`*^9, 
   3.7799456865197954`*^9}},ExpressionUUID->"466a0a05-2e95-4a01-9045-\
fc03bdf50a9b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"bySources", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Cases", "[", 
      RowBox[{"dataSources", ",", 
       RowBox[{"{", 
        RowBox[{"#", ",", "___"}], "}"}]}], "]"}], "&"}], "/@", 
    "sourcenames"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7798019900522137`*^9, 3.7798020229103436`*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"679e2c0f-1c20-4f37-9dc9-a0145c7f744c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"bySources", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"dataSources", "[", 
      RowBox[{"[", 
       RowBox[{"Flatten", "[", 
        RowBox[{"Position", "[", 
         RowBox[{"dataSources", ",", 
          RowBox[{"sourcenames", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "]"}], "]"}], "]"}], ",", 
     
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"Length", "[", "sourcenames", "]"}]}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.7798023580520124`*^9, 3.7798024800769153`*^9}, 
   3.779802607867442*^9},
 CellLabel->"In[27]:=",ExpressionUUID->"c307ce3a-317b-4145-841c-d50116e9f89b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Task 8", "Section",
 CellChangeTimes->{{3.77989700630942*^9, 3.7798970085487976`*^9}, {
  3.7799688668383017`*^9, 
  3.7799688675558653`*^9}},ExpressionUUID->"0127efff-5414-4fca-92de-\
b97174ba91be"],

Cell["\<\
The goal of the classifier to be trained in this practical will be to \
classify unseen isolates into food reservoirs. In order for classification to \
be accurate, we need a reasonable separation between different reservoirs in \
the feature space. The feature space in this case consists of 7 dimensions \
(each isolate is represented by a point in this space and its coordinates are \
the values taken by its 7 genes). 

Since the dimension of the feature space is larger than 3, it is difficult to \
visualise at once on a 2D screen. 

One possible way to do a preliminary exploration is to plot the alleles for \
pairs of genes (pairs of features) and pairs of sources. This can be done \
using the following scatterplot:\
\>", "Text",
 CellChangeTimes->{
  3.779898777312253*^9, {3.779898834342233*^9, 3.77989887692052*^9}, {
   3.779901112579751*^9, 3.779901253616436*^9}, {3.7799015460615935`*^9, 
   3.779901632627884*^9}, {3.779901663219002*^9, 3.779901709291774*^9}, {
   3.7799450264127316`*^9, 3.7799452035250535`*^9}, {3.7799452872280827`*^9, 
   3.779945350044128*^9}, {3.7799456995798607`*^9, 3.77994579943478*^9}, {
   3.7799461331942244`*^9, 
   3.779946144253993*^9}},ExpressionUUID->"b49167cd-99cd-4ff2-ae5d-\
97dd50fc6b64"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"bySources", "[", 
   RowBox[{"[", "1", "]"}], "]"}], "[", 
  RowBox[{"[", "1", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.781353169898099*^9, 3.7813532479146085`*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"a442debd-b382-4a10-9966-091bb16c9300"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"Cattle\"\>", ",", "2", ",", "1", ",", "5", ",", "3", ",", 
   "725", ",", "1", ",", "5"}], "}"}]], "Output",
 CellChangeTimes->{{3.7813532171001577`*^9, 3.781353248365407*^9}, 
   3.8147239119771113`*^9, 3.8147241172794824`*^9, 3.814769940840397*^9},
 CellLabel->"Out[28]=",ExpressionUUID->"2f56bf68-958c-4523-840b-9b4a38c5ec77"]
}, Open  ]],

