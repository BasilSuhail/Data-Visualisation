Cell[TextData[{
 "Most of human isolates are attributed to chicken, followed by sheep. This \
suggests that chicken is the main ",
 StyleBox["Campylobacter",
  FontSlant->"Italic"],
 " reservoir affecting humans."
}], "Text",
 CellChangeTimes->{{3.7799760189074*^9, 
  3.7799761287221327`*^9}},ExpressionUUID->"25d772a6-bf83-47bb-a2bf-\
528d1c15127a"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

