Cell[TextData[{
 "Here, ",
 StyleBox["f1", "CodeText"],
 " and ",
 StyleBox["f2", "CodeText"],
 " correspond to features (genes). ",
 StyleBox["source1", "CodeText"],
 " and ",
 StyleBox["source2", "CodeText"],
 " correspond to two reservoirs. "
}], "Text",
