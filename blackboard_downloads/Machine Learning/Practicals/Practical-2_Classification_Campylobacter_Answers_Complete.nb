  3.779968862074503*^9}},ExpressionUUID->"e7d80966-bd3e-47ea-a7b6-\
641e17c22e72"],

Cell[TextData[{
 "Separate the instances in dataSources by source. I will refer to the new \
list as ",
 StyleBox["bySources", "CodeText"],
 ". In order to achieve this task, you may want to go back to the Iris \
flowers classification example where a similar task was done. "
}], "Text",
 CellChangeTimes->{{3.7798025559630165`*^9, 3.779802623536672*^9}, {
  3.779898901891939*^9, 3.779898903634409*^9}, {3.77994555730057*^9, 
  3.779945645525818*^9}},ExpressionUUID->"2c010641-e992-4625-ae4e-\
010ad4ad33ec"],

Cell[CellGroupData[{

Cell["Answer", "Subsection",
 CellChangeTimes->{{3.7798026268516707`*^9, 
  3.77980262808584*^9}},ExpressionUUID->"d73d4687-9cac-4d5e-a25f-\
c438357ea788"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SortData", "[", "list_List", "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"test", ",", "datalength", ",", "sorteddata"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"test", "=", 
       RowBox[{"GroupBy", "[", 
        RowBox[{
         RowBox[{"list", "[", 
          RowBox[{"[", 
           RowBox[{";;", ",", ";;"}], "]"}], "]"}], ",", "First"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"datalength", "=", 
       RowBox[{"Min", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Length", "[", 
           RowBox[{"test", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Length", "[", "test", "]"}]}], "}"}]}], "]"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"sorteddata", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Take", "[", 
             RowBox[{
              RowBox[{"test", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", "datalength"}], "]"}], 
            "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"Length", "[", 
              RowBox[{"Keys", "[", "test", "]"}], "]"}]}], "}"}]}], "]"}], 
         ",", "2"}], "]"}]}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bySources", "=", 
   RowBox[{"Reverse", "[", 
    RowBox[{"GroupBy", "[", 
     RowBox[{
      RowBox[{"SortData", "[", 
       RowBox[{
        RowBox[{"Values", "@", "dataSources"}], "//", "Normal"}], "]"}], ",", 
      "First"}], "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.8146067749414873`*^9, 3.814606843637495*^9}, {
  3.814715793479895*^9, 3.814715793680781*^9}, {3.814715893202468*^9, 
  3.8147159094583263`*^9}},
 CellLabel->
  "In[204]:=",ExpressionUUID->"9481762d-fe4d-4056-9cbb-9a54e0ae1047"],

