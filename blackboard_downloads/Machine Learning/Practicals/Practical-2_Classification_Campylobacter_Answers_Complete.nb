  3.779900874888792*^9}},ExpressionUUID->"2e223424-7ffd-4a0f-863e-\
d529fe12abdf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"dataHuman", "=", 
   RowBox[{"data", "[", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"#classification", "\[Equal]", "\"\<Human\>\""}], "&"}], "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dataSources", "=", 
   RowBox[{"data", "[", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"#classification", "!=", "\"\<Human\>\""}], "&"}], "]"}], 
    "]"}]}], ";"}]}], "Input",
