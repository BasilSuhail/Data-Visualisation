Cell[CellGroupData[{

Cell["Task 9", "Section",
 CellChangeTimes->{{3.779802962449816*^9, 3.779802964633836*^9}, {
  3.779968871535158*^9, 
  3.779968873171789*^9}},ExpressionUUID->"10ac078c-1b99-4c78-8fc5-\
9c1db67aadd5"],

Cell["\<\
In order to further analyse the data and try to confirm some of your \
conclusions in the previous task, you can use a a scatter plot matrix using \
the function ScatterPlotMatrix defined in lectures for the Iris flower \
classification problem. In order to reduce the complexity of the scatter plot \
matrix, you may want to plot a reduced number of features (genes) at once.\
\>", "Text",
 CellChangeTimes->{{3.779802974179901*^9, 3.779803067589616*^9}, 
   3.7798987651026793`*^9, {3.7799474117375174`*^9, 3.779947507811039*^9}, {
   3.77994812469623*^9, 
   3.7799482042470427`*^9}},ExpressionUUID->"3ce58208-5e92-4983-99fd-\
809452e5ed70"],

Cell[CellGroupData[{

Cell["Answer", "Subsection",
 CellChangeTimes->{{3.779947516593438*^9, 
  3.7799475177590933`*^9}},ExpressionUUID->"aa844669-f47e-4d41-8968-\
761aff2a3dda"],

Cell["\<\
One can define a function to do scatter plot matrix plots automatically. The \
inputs for the function are as follows:

values: matrix with values for all features
names: names of the features
vfeatures: vector with the feature number to be plotted 
vclass: vector with class of each instance\
\>", "Text",
 CellChangeTimes->{{3.779034479245809*^9, 3.779034492621681*^9}, {
  3.779039341103677*^9, 3.779039367945136*^9}, {3.779620556010962*^9, 
  3.77962059191473*^9}},ExpressionUUID->"abcabdcf-2871-4292-a6f7-\
0abbe4fd4ef1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ScatterPlotMatrix", "[", 
   RowBox[{"values0_", ",", "names0_", ",", "vfeatures0_", ",", "vclass0_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"values", "=", "values0"}], ",", 
      RowBox[{"names", "=", "names0"}], ",", 
      RowBox[{"vf", "=", "vfeatures0"}], ",", 
      RowBox[{"vc", "=", "vclass0"}], ",", "classes", ",", "pos"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"classes", "=", 
      RowBox[{"DeleteDuplicates", "[", "vc", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pos", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"Position", "[", 
          RowBox[{"vc", ",", 
           RowBox[{"classes", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "[", "classes", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"i", "\[Equal]", "j"}], ",", 
          RowBox[{"names", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ",", 
          RowBox[{"ListPlot", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Transpose", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"values", "[", 
                  RowBox[{"[", 
                   RowBox[{
                    RowBox[{"pos", "[", 
                    RowBox[{"[", "ic", "]"}], "]"}], ",", "i"}], "]"}], "]"}],
                  ",", 
                 RowBox[{"values", "[", 
                  RowBox[{"[", 
                   RowBox[{
                    RowBox[{"pos", "[", 
                    RowBox[{"[", "ic", "]"}], "]"}], ",", "j"}], "]"}], 
                  "]"}]}], "}"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"ic", ",", "1", ",", 
                RowBox[{"Length", "[", "classes", "]"}]}], "}"}]}], "]"}], 
            ",", 
            RowBox[{"PlotMarkers", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"\"\<OpenMarkers\>\"", ",", " ", "Small"}], "}"}]}], 
            ",", 
            RowBox[{"PlotLegends", "\[Rule]", 
             RowBox[{"DeleteDuplicates", "[", "vclass0", "]"}]}], ",", 
            RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "vf"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "vf"}], "}"}]}], "]"}], "//", "Grid"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.7790270779874153`*^9, 3.77902713904109*^9}, {
   3.779029676439308*^9, 3.779029721408546*^9}, {3.779029840401621*^9, 
   3.779029858513554*^9}, {3.779029890084231*^9, 3.779029892481703*^9}, {
   3.779031212402829*^9, 3.779031223810766*^9}, {3.7790312557946587`*^9, 
   3.779031326562895*^9}, {3.7790313792667437`*^9, 3.779031436674402*^9}, {
   3.7790314731231337`*^9, 3.779031475330873*^9}, {3.7790315931382637`*^9, 
   3.779031690723193*^9}, {3.779031751202943*^9, 3.7790318695075703`*^9}, 
   3.779031927958046*^9, {3.779031969173843*^9, 3.7790319697799788`*^9}, {
   3.779032085368704*^9, 3.779032107477495*^9}, {3.7790322110611877`*^9, 
   3.779032211640546*^9}, {3.7790322674929323`*^9, 3.779032427141987*^9}, {
   3.779032483093739*^9, 3.779032518917679*^9}, {3.779032552726225*^9, 
   3.7790325697169333`*^9}, {3.779039144380267*^9, 3.7790391499623623`*^9}, {
   3.779894857723609*^9, 3.7798949208918905`*^9}, {3.7798955868769293`*^9, 
   3.779895589400037*^9}, {3.7798956200819955`*^9, 3.779895703965274*^9}, {
   3.7798957479231577`*^9, 3.7798957673792276`*^9}, {3.77994765833498*^9, 
   3.7799476588205748`*^9}, {3.7799476940128136`*^9, 3.779947735990864*^9}, {
   3.779948274990099*^9, 3.779948280024517*^9}, {3.7808889643490305`*^9, 
   3.7808889840460634`*^9}},
 CellLabel->
