Cell[CellGroupData[{

Cell["Task 4", "Section",
 CellChangeTimes->{{3.779899034545989*^9, 3.779899036813922*^9}, {
  3.7799688508091154`*^9, 
  3.7799688518750124`*^9}},ExpressionUUID->"b5c1b465-04dd-4996-9d93-\
793e13eb3dfc"],

Cell[TextData[{
 "Since the isolates from food reservoirs are assumed to be the sources of \
human isolates, it makes sense to split the list data into two lists, one \
corresponding to human isolates and another for isolates from food \
reservoirs.  The resulting lists should have the same format (e.g. same \
number of columns) as ",
 StyleBox["data", "CodeText"],
 ". More explicitly:"
}], "Text",
 CellChangeTimes->{{3.7798990406267743`*^9, 3.7798992299602504`*^9}, {
  3.7799443844212193`*^9, 3.7799443988584003`*^9}, {3.779944472909704*^9, 
  3.7799445142789774`*^9}, {3.7799445780631757`*^9, 
  3.7799446171026993`*^9}},ExpressionUUID->"f195ddb3-8bcd-415b-a6f2-\
28dc91cdf59e"],

Cell[CellGroupData[{

Cell[TextData[{
 "Create a sublist from ",
 StyleBox["data", "CodeText"],
 " for human isolates. Refer to it as ",
 StyleBox["dataHuman", "CodeText"],
 ". (Hint: use the function Position of \[OpenCurlyDoubleQuote]Human\
\[CloseCurlyDoubleQuote] in the first column of data to select the rows of \
data corresponding to humans)."
}], "Item",
 CellChangeTimes->{{3.778672975312646*^9, 3.778673000529127*^9}, 
   3.779899252670478*^9, {3.779899454065422*^9, 3.7798994799339056`*^9}, {
   3.779899961230956*^9, 3.7798999653998985`*^9}, {3.779900304777667*^9, 
   3.779900473139451*^9}, 
   3.779944532818875*^9},ExpressionUUID->"e634d825-a8bc-4e4b-a5ae-\
c3ab401f403a"],

Cell[TextData[{
 "Create a list containing the data for food reservoirs only. Refer to the \
new list as ",
 StyleBox["dataSources", "CodeText"],
 ". Hint: Use the complement of the rows corresponding to humans. "
}], "Item",
 CellChangeTimes->{{3.778674338688918*^9, 3.7786743620808277`*^9}, {
  3.7799004805361667`*^9, 3.7799004968945427`*^9}, {3.77990069490193*^9, 
  3.7799007288193407`*^9}, {3.779944551222447*^9, 
  3.7799445729913387`*^9}},ExpressionUUID->"20f5e0f1-9ada-49e3-afd8-\
70b9ebd04412"]
}, Open  ]],

Cell["\<\
As usual when defining new lists or variables, check that they look like you \
expect them to look.\
\>", "Text",
