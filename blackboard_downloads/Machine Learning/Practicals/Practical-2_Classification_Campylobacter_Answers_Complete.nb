 RowBox[{"cAllSourcesTwo", "=", 
  RowBox[{"Classify", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"dataSources", "[", 
       RowBox[{"[", 
        RowBox[{"i", ",", 
         RowBox[{"2", ";;", "8"}]}], "]"}], "]"}], "\[Rule]", " ", 
      RowBox[{"dataSources", "[", 
       RowBox[{"[", 
        RowBox[{"i", ",", "1"}], "]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"Length", "[", "dataSources", "]"}]}], "}"}]}], "]"}], 
   "]"}]}]], "Input",
