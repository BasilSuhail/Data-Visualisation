            RowBox[{
             RowBox[{"RandomSample", "@", 
              RowBox[{"bySources", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], ",", "trainN"}], "]"}], ",", 
           
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", 
              RowBox[{"Keys", "@", "bySources"}], "]"}]}], "}"}]}], "]"}], 
         "[", 
         RowBox[{"[", "j", "]"}], "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", 
         RowBox[{"Length", "[", 
          RowBox[{"Keys", "@", "bySources"}], "]"}]}], "}"}]}], "]"}], ",", 
     "1"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.8146080537252398`*^9, 3.8146081106353636`*^9}, {
