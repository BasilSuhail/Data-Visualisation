Cell[CellGroupData[{

Cell["Sort Function", "Subsubsection",
 CellChangeTimes->{{3.8146090864595313`*^9, 
  3.8146091100496683`*^9}},ExpressionUUID->"932efc33-9356-4a98-adf2-\
a72c3f524090"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SortData", "[", "list_List", "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"test", ",", "datalength", ",", "sorteddata"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"test", "=", 
       RowBox[{"GroupBy", "[", 
        RowBox[{
         RowBox[{"list", "[", 
          RowBox[{"[", 
           RowBox[{";;", ",", ";;"}], "]"}], "]"}], ",", "First"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"datalength", "=", 
       RowBox[{"Min", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Length", "[", 
           RowBox[{"test", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Length", "[", "test", "]"}]}], "}"}]}], "]"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"sorteddata", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Take", "[", 
             RowBox[{
              RowBox[{"test", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", "datalength"}], "]"}], 
            "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"Length", "[", 
              RowBox[{"Keys", "[", "test", "]"}], "]"}]}], "}"}]}], "]"}], 
         ",", "2"}], "]"}]}]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7905658759780393`*^9, 3.7905658944042077`*^9}, {
   3.790587693543725*^9, 3.7905876946220713`*^9}, {3.790946105586237*^9, 
