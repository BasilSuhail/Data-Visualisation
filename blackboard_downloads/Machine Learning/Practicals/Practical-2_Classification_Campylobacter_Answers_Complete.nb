 CellChangeTimes->{{3.779972728744031*^9, 
  3.7799727304017906`*^9}},ExpressionUUID->"17db339c-aebb-4040-ae48-\
5fbfa854d970"],

Cell["\<\
The specific value of the accuracy and any other measures of performance for \
the classifier will depend a bit on the particular training and test datasets \
you have chosen at random.\
\>", "Text",
 CellChangeTimes->{{3.7799727715270033`*^9, 3.7799728668404083`*^9}, {
  3.779973478771522*^9, 
  3.7799735320752435`*^9}},ExpressionUUID->"4f38f38b-d5f1-441c-b7ea-\
76e55d880754"],

Cell["\<\
Accuracy is typically not very high for this classification problem: \
\>", "Text",
 CellChangeTimes->{{3.779973536603409*^9, 3.7799735429064856`*^9}, {
  3.7799735826808805`*^9, 
