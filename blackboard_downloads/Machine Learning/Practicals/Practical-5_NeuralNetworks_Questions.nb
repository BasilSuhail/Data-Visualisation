Cell["\<\
Consider the following synthetic data for two classes A and B:\
\>", "Text",
 CellChangeTimes->{{3.821370618960548*^9, 
  3.821370706416642*^9}},ExpressionUUID->"00fc2fc0-9419-44e6-9958-\
dd12c1118a6f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"classA", "=", 
   RowBox[{"RandomPoint", "[", 
    RowBox[{
     RowBox[{"Annulus", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0.5", ",", "1"}], "}"}]}], "]"}], ",", "100"}], "]"}]}], ";", 
  RowBox[{"classB", "=", 
   RowBox[{"RandomPoint", "[", 
    RowBox[{
     RowBox[{"Annulus", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"1.5", ",", "2"}], "}"}]}], "]"}], ",", "100"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"classA", ",", "classB"}], "}"}], ",", 
   RowBox[{"PlotLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<A\>\"", ",", "\"\<B\>\""}], "}"}]}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.820074527997723*^9, 3.8200745462249775`*^9}, {
  3.8200745816843414`*^9, 3.8200746551806755`*^9}, {3.8200759427867413`*^9, 
