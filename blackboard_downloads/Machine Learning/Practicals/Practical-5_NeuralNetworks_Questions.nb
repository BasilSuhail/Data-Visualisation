Cell[TextData[{
 "Use the following data to train ",
 StyleBox["logisticClass", "CodeText"],
 ":\n\ntDLogClass={1.2\[Rule]\[CloseCurlyDoubleQuote]A\[CloseCurlyDoubleQuote]\
,2.1\[Rule]\[CloseCurlyDoubleQuote]A\[CloseCurlyDoubleQuote],3.4\[Rule]\
\[CloseCurlyDoubleQuote]A\[CloseCurlyDoubleQuote],5.1\[Rule]\
\[CloseCurlyDoubleQuote]B\[CloseCurlyDoubleQuote],7.3\[Rule] \
\[OpenCurlyDoubleQuote]B\[CloseCurlyDoubleQuote],9.7\[Rule] \
\[OpenCurlyDoubleQuote]B\[CloseCurlyDoubleQuote]};"
}], "Text",
