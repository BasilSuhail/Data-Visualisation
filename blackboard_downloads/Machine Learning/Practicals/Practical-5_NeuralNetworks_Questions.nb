Cell["\<\
Remember that plots of this type were used, for instance, when explaining the \
\>", "Text",
 CellChangeTimes->{{3.8258795782875066`*^9, 3.8258796012310705`*^9}, {
  3.8258796498616176`*^9, 
  3.825879654879944*^9}},ExpressionUUID->"a4142584-cbc9-42c9-b25a-\
cbb4cfdee28b"],

Cell[TextData[{
 "Predictions in this plot are obtained by applying the trained ANN to \
predict the class of points ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]],ExpressionUUID->
  "a84df6f2-6e33-412e-b2e7-a814e19b29e1"],
 " in a rectangular domain ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "2"}], "]"}], "\[Times]", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"-", "0.5"}], ",", "2"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"a906fa03-e349-42bf-93b8-dd4c80393b39"],
 ". The points in this region are separated by increments ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]x", " ", "=", " ", 
    RowBox[{"\[CapitalDelta]y", "=", "0.05"}]}], TraditionalForm]],
  ExpressionUUID->"b9dbf90c-a25c-4acf-a195-e5c06a85433d"],
 " in the horizontal and vertical directions."
}], "Text",
 CellChangeTimes->{{3.821365780420781*^9, 3.821365982754554*^9}, {
  3.8213660445455847`*^9, 3.821366141664946*^9}, {3.821370009346656*^9, 
  3.821370039346017*^9}, {3.821370154066268*^9, 3.8213701939059258`*^9}, {
  3.821370229201684*^9, 
  3.821370230497882*^9}},ExpressionUUID->"6b52a496-2d03-4859-a5a8-\
fe49c1c3a046"],

Cell[TextData[{
 StyleBox["Hint",
  FontSlant->"Italic"],
 ": Inspiration on how to generate this plot can be obtained from section \
5.1.1 in chapter 5. You could also use the function below:"
}], "Text",
 CellChangeTimes->{{3.8213026335909567`*^9, 3.821302714949029*^9}, 
   3.8213650736209517`*^9, {3.955695820309987*^9, 
   3.95569585146949*^9}},ExpressionUUID->"e27c776f-e989-40e6-9cb3-\
0b8cf42bb905"],

Cell[BoxData[
 RowBox[{
  RowBox[{"plotClassification", "[", 
   RowBox[{
   "xmin0_", ",", "xmax0_", ",", "ymin0_", ",", "ymax0_", ",", "Dx0_", ",", 
    "Dy0_", ",", "net0_", ",", "classA0_", ",", "classB0_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"xmin", "=", "xmin0"}], ",", 
      RowBox[{"xmax", "=", "xmax0"}], ",", 
      RowBox[{"ymin", "=", "ymin0"}], ",", 
      RowBox[{"ymax", "=", "ymax0"}], ",", 
      RowBox[{"Dx", "=", "Dx0"}], ",", 
      RowBox[{"Dy", "=", "Dy0"}], ",", 
      RowBox[{"net", "=", "net0"}], ",", 
      RowBox[{"classA", "=", "classA0"}], ",", 
      RowBox[{"classB", "=", "classB0"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"linex", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"xmin", ",", "xmax", ",", "Dx"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"liney", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"ymin", ",", "ymax", ",", "Dy"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"points", "=", 
      RowBox[{"Tuples", "[", 
       RowBox[{"{", 
        RowBox[{"linex", ",", "liney"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pred", "=", 
      RowBox[{"net", "[", "points", "]"}]}], ";", "\n", 
     RowBox[{"temp", "=", 
      RowBox[{"Tally", "[", 
       RowBox[{"Sort", "[", "pred", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"points", "[", 
             RowBox[{"[", 
              RowBox[{"Ordering", "[", "pred", "]"}], "]"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", 
              RowBox[{"temp", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"points", "[", 
             RowBox[{"[", 
              RowBox[{"Ordering", "[", "pred", "]"}], "]"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{
               RowBox[{"temp", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "2"}], "]"}], "]"}], "+", "1"}], ";;", 
              RowBox[{"Length", "[", "pred", "]"}]}], "]"}], "]"}]}], "}"}], 
         ",", " ", 
         RowBox[{"PlotStyle", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"RGBColor", "[", 
               RowBox[{"0.97", ",", "1.", ",", "0.55"}], "]"}], ",", 
              RowBox[{"PointSize", "[", "0.015", "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"RGBColor", "[", 
               RowBox[{"0.5", ",", "1", ",", "0.5"}], "]"}], ",", 
              RowBox[{"PointSize", "[", "0.015", "]"}]}], "}"}]}], "}"}]}], 
         ",", 
         RowBox[{"PlotLegends", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"\"\<Predicted A\>\"", ",", "\"\<Predicted B\>\""}], 
           "}"}]}]}], "]"}], ",", 
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"classA", ",", "classB"}], "}"}], ",", 
         RowBox[{"PlotStyle", "\[Rule]", "Large"}], ",", " ", 
         RowBox[{"PlotLegends", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"\"\<A\>\"", ",", "\"\<B\>\""}], "}"}]}]}], "]"}]}], 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",ExpressionUUID->\
"a516c87b-c962-4f15-a4b1-2f63f27a2a75"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Task 4", "Subsection",
 CellChangeTimes->{{3.825947273200405*^9, 
