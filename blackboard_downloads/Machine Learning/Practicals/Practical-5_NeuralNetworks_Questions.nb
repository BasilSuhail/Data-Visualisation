Cell["Use the following function, ", "Text",
 CellChangeTimes->{
  3.8212936916226187`*^9, {3.821293735628646*^9, 3.8212937571436796`*^9}, 
   3.8212988351432157`*^9, {3.821298899887165*^9, 
   3.821298912019293*^9}},ExpressionUUID->"c6eec62c-131a-4116-ad75-\
5584e46ae408"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"gaussian", "[", 
    RowBox[{"\[Mu]_", ",", "\[Sigma]_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"MultinormalDistribution", "[", 
      RowBox[{"\[Mu]", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
