Notebook[{

Cell[CellGroupData[{
Cell["\<\
Exercises on built-in classification functions in Wolfram Language\
\>", "Chapter",
 CellChangeTimes->{{3.7795481851645145`*^9, 
  3.779548224831187*^9}},ExpressionUUID->"d1dee269-4a10-4668-909e-\
8b7634995b47"],

Cell[CellGroupData[{

Cell["Task 1", "Section",
 CellChangeTimes->{{3.779548249927658*^9, 
  3.779548258178501*^9}},ExpressionUUID->"7f36a3c6-2103-4788-89ee-\
f82effe92732"],

Cell[TextData[{
 "Use the entity query command (Ctrl + = , ",
 Cell[BoxData[
  NamespaceBox["LinguisticAssistant",
   DynamicModuleBox[{Typeset`query$$ = "", Typeset`boxes$$ = "None", 
    Typeset`allassumptions$$ = {}, Typeset`assumptions$$ = {}, 
    Typeset`open$$ = {1}, Typeset`querystate$$ = {}}, 
    DynamicBox[ToBoxes[
      AlphaIntegration`LinguisticAssistantBoxes["", 4, Automatic, 
       Dynamic[Typeset`query$$], 
       Dynamic[Typeset`boxes$$], 
       Dynamic[Typeset`allassumptions$$], 
       Dynamic[Typeset`assumptions$$], 
       Dynamic[Typeset`open$$], 
       Dynamic[Typeset`querystate$$]], StandardForm],
     ImageSizeCache->{49., {10., 26.}},
     TrackedSymbols:>{
      Typeset`query$$, Typeset`boxes$$, Typeset`allassumptions$$, 
       Typeset`assumptions$$, Typeset`open$$, Typeset`querystate$$}],
    DynamicModuleValues:>{},
    UndoTrackedVariables:>{Typeset`open$$}],
   BaseStyle->{"Deploy"},
   DeleteWithContents->True,
   Editable->False,
   SelectWithContents->True]], "Input",
  CellChangeTimes->{3.779612612501409*^9},ExpressionUUID->
  "7a73eb04-e901-4b8d-92b8-841b0ccf5952"],
 ") to get an image of a German Shepherd dog and test the performance of \
ImageIdentify on a series of blurred images. Discuss the result."
}], "Text",
 CellChangeTimes->{{3.777719853152915*^9, 3.777719905841052*^9}, {
  3.777736695580298*^9, 3.777736703468357*^9}, {3.777736816076474*^9, 
  3.777736831740346*^9}, {3.779605748084916*^9, 3.77960575720408*^9}, {
  3.7796125943515863`*^9, 
  3.7796126244638653`*^9}},ExpressionUUID->"0be81751-4ddf-403c-997b-\
9424d42f3343"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Task 2", "Section",
 CellChangeTimes->{{3.7796053436673*^9, 3.779605347283667*^9}, {
  3.779610360991927*^9, 
  3.779610362063737*^9}},ExpressionUUID->"f5f418ba-bbcf-4b72-b992-\
38004d633b33"],

Cell["\<\
Take a photo of an object and see if Mathematica tells that the image \
contains the object (it might be better if you use a sheet of paper as the \
background so that the object is clearly visible)\
\>", "Text",
 CellChangeTimes->{{3.779605351459402*^9, 3.779605424420182*^9}, {
  3.779605635668542*^9, 
  3.779605649940423*^9}},ExpressionUUID->"7c12119f-98aa-4580-98cb-\
8279c0151d45"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Task 3", "Section",
 CellChangeTimes->{{3.7796104439193993`*^9, 
  3.779610445855516*^9}},ExpressionUUID->"9003757d-299f-48c5-b337-\
7abbf19c4291"],

Cell[TextData[{
 "Classify[\[OpenCurlyDoubleQuote]CountryFlag\[CloseCurlyDoubleQuote], ",
 StyleBox["flag image",
  FontSlant->"Italic"],
 "] allows the flag of countries to be recognized. \n\nUse Ctrl+= (",
 Cell[BoxData[
  NamespaceBox["LinguisticAssistant",
   DynamicModuleBox[{Typeset`query$$ = "", Typeset`boxes$$ = "None", 
    Typeset`allassumptions$$ = {}, Typeset`assumptions$$ = {}, 
    Typeset`open$$ = {1}, Typeset`querystate$$ = {}}, 
    DynamicBox[ToBoxes[
      AlphaIntegration`LinguisticAssistantBoxes["", 4, Automatic, 
       Dynamic[Typeset`query$$], 
       Dynamic[Typeset`boxes$$], 
       Dynamic[Typeset`allassumptions$$], 
       Dynamic[Typeset`assumptions$$], 
       Dynamic[Typeset`open$$], 
       Dynamic[Typeset`querystate$$]], StandardForm],
     ImageSizeCache->{49., {10., 26.}},
     TrackedSymbols:>{
      Typeset`query$$, Typeset`boxes$$, Typeset`allassumptions$$, 
       Typeset`assumptions$$, Typeset`open$$, Typeset`querystate$$}],
    DynamicModuleValues:>{},
    UndoTrackedVariables:>{Typeset`open$$}],
   BaseStyle->{"Deploy"},
   DeleteWithContents->True,
   Editable->False,
   SelectWithContents->True]], "Input",
  CellChangeTimes->{3.779610894824395*^9},ExpressionUUID->
  "04655a50-38c4-4470-a514-9093dc219015"],
 ") to obtain the flag of France and use Classify with the syntax given above \
to recognize the country of the flag"
}], "Text",
 CellChangeTimes->{{3.77961048535935*^9, 3.7796105283189793`*^9}, {
  3.779610734527855*^9, 3.779610735407501*^9}, {3.779610778495182*^9, 
