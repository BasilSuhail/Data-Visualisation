Cell[CellGroupData[{

Cell["\<\
Analyse its structure, i.e. find the constituent tree. The limerick consists \
of two sentences. How does Wolfram Language deal with this?\
\>", "Item",
 CellChangeTimes->{{3.779560250233198*^9, 3.779560278161654*^9}, {
  3.7795603937650633`*^9, 
  3.7795604364534187`*^9}},ExpressionUUID->"c7beb7fc-c009-48f6-a06b-\
52f924773e46"],

Cell["\<\
Consider the first sentence of the limerick. Represent the grammar \
dependencies as a graph. \
\>", "Item",
 CellChangeTimes->{{3.779560250233198*^9, 3.7795602524871984`*^9}, {
   3.7795603789695606`*^9, 3.7795603910046573`*^9}, {3.7795604411559606`*^9, 
