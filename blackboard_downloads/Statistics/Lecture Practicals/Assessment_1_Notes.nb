Cell[CellGroupData[{

Cell["The binomial distribution in Wolfram Language", "Subsubsection",
 CellChangeTimes->{
  3.9804537117646275`*^9},ExpressionUUID->"7a1eaac1-61c7-b441-8f92-\
4ffacfb2e54d"],

Cell[TextData[{
 "> ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BinomialDistribution"]], "paclet:ref/BinomialDistribution"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    StyleBox["n", "TI"], ",", 
    StyleBox["p", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",
  FontWeight->"Bold",ExpressionUUID->"46d25e9f-df64-774f-87b0-d145220d2c4b"],
 "  -> represents a binomial distribution with ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7b1a77be-edb3-bc45-bc4b-7f95dcaf0a4b"],
 " trials and success probability ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "18faaa37-fc04-e64f-9ed1-551157db0133"],
 ".\n\n> ",
 StyleBox["ntrials=20;\npsuccess=N[1/6];",
  FontWeight->"Bold"],
 "\[LineSeparator]",
 StyleBox["ProbSuccess=Table[{k,PDF[BinomialDistribution[ntrials,psuccess],k]}\
,{k,0,9}] ",
  FontWeight->"Bold"],
 "-> Calculates the binomial distribution. \n"
}], "Text",
 CellChangeTimes->{{3.9804537206478786`*^9, 3.9804537353027954`*^9}, {
  3.980453864329876*^9, 3.9804539193569145`*^9}, {3.980455640543455*^9, 
  3.98045564209194*^9}},ExpressionUUID->"305d3ae4-6f01-7040-8fef-\
b04409539800"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Expected value and variance", "Subsubsection",
 CellChangeTimes->{{3.980455645813921*^9, 
  3.9804556538216743`*^9}},ExpressionUUID->"7d58d9e6-11bd-594b-b10c-\
99e32f822f23"],

Cell[TextData[{
 "> ",
 StyleBox["N[Mean[nsuccess1000]] ",
  FontWeight->"Bold"],
 "-> The empirical expected value is the arithmetic mean\n\n> ",
 StyleBox["N[Variance[nsuccess1000]] ",
  FontWeight->"Bold"],
 "-> Calculates the variance\n\n> ",
 StyleBox["Expectation[x,x\[Distributed]BinomialDistribution[20,1./6.]]",
  FontWeight->"Bold"],
 ": \[LineSeparator]-> Expected value of a binomial distribution: ",
 StyleBox["E[X] = n \[Times] p",
  FontWeight->"Bold"],
 ".\n-> ",
 StyleBox["BinomialDistribution[20, 1./6.] ",
  FontWeight->"Bold"],
 "defines a binomial distribution with:\[LineSeparator]\t\t-> ",
 StyleBox["n = 20 ",
  FontWeight->"Bold"],
 "\[LongDash] the number of trials\[LineSeparator] \t\t-> ",
 StyleBox["p = 1/6",
  FontWeight->"Bold"],
 " \[LongDash] the probability of success on each trial (like rolling \t\t    \
 a specific number on a die)\n-> ",
 StyleBox["Expectation[x, x \[Distributed] BinomialDistribution[20, 1./6.]] ",
  FontWeight->"Bold"],
 "calculates the expected value of the random variable ",
 StyleBox["x",
  FontWeight->"Bold"],
 ", where ",
 StyleBox["x",
  FontWeight->"Bold"],
 " follows that binomial distribution. The",
 StyleBox[" \[Distributed] ",
  FontWeight->"Bold"],
 "symbol essentially means \[OpenCurlyDoubleQuote]where ",
 StyleBox["x",
  FontWeight->"Bold"],
 " is distributed as.\n\n> ",
 StyleBox["Variance[BinomialDistribution[20, 1./6.]]",
  FontWeight->"Bold"],
 ": \[LineSeparator]",
 StyleBox["BinomialDistribution[20, 1./6.] ",
  FontWeight->"Bold"],
 "defines the same binomial distribution as before \[LongDash] 20 trials with \
a probability of success of 1/6.\n",
 StyleBox["Variance[]",
  FontWeight->"Bold"],
 " computes the theoretical variance of that distribution."
}], "Text",
 CellChangeTimes->{{3.980455666910488*^9, 3.980455913175892*^9}, {
  3.980455966049036*^9, 
  3.9804560124254*^9}},ExpressionUUID->"7f84efcc-8a47-8c4b-a7c0-c207a6de26d4"],

Cell[TextData[StyleBox["Distributions in Wolfram Mathematica", \
"Subsubsection"]], "Text",
 CellChangeTimes->{
  3.980456019418358*^9},ExpressionUUID->"6c101ec3-6650-2c40-82a8-\
117bf06d831a"],

Cell[TextData[{
 "> ",
 StyleBox["RandomVariate[BernoulliDistribution[1./6.],10]",
  FontWeight->"Bold"],
 " -> Use this when you have a single trial with only two possible outcomes \
\[LongDash] success or failure. The parameter is the probability of success. \
Example: flipping a coin once, or rolling a die once and asking if you got a \
1.\n> ",
 StyleBox["RandomVariate[BinomialDistribution[20,1./6.],10] ",
  FontWeight->"Bold"],
 "-> Use this when you have a fixed number of repeated independent Bernoulli \
trials and you want to count the total number of successes. Example: rolling \
a die 20 times and counting how many times you get a 1. It\[CloseCurlyQuote]s \
essentially the Bernoulli distribution extended to n trials.",
 "\n> ",
 StyleBox["RandomVariate[PoissonDistribution[1.2],10] ",
  FontWeight->"Bold"],
 "-> Use this when you\[CloseCurlyQuote]re counting how many times an event \
occurs within a fixed interval (of time, space, etc.) where events occur \
randomly but at a known average rate. Example: the number of cars passing a \
checkpoint per minute, or the number of emails received per hour.\n> ",
 StyleBox["RandomVariate[NormalDistribution[0,1],10] ",
  FontWeight->"Bold"],
 "-> Use this for continuous data that is symmetric and bell-shaped around a \
mean. It appears naturally in many real-world phenomena due to the central \
limit theorem. Example: heights, exam scores, measurement errors. The \
parameters are the mean and standard deviation.",
 StyleBox["\n",
  FontWeight->"Bold"],
 "> ",
 StyleBox["RandomVariate[ExponentialDistribution[1.2],10] ",
  FontWeight->"Bold"],
 "-> Use this to model the waiting time between events in a Poisson process \
\[LongDash] so it naturally pairs with the Poisson distribution. Example: how \
long until the next customer arrives, or how long a machine runs before \
failing. It always starts at zero and skews right.\n> ",
 StyleBox["RandomVariate[LogNormalDistribution[0,1],10]",
  FontWeight->"Bold"],
 " -> Use this when your data is always positive and right-skewed, where the \
logarithm of the variable is normally distributed. Example: income \
distributions, stock prices, or biological measurements like enzyme \
concentrations \[LongDash] which is why it\[CloseCurlyQuote]s relevant in \
your context.\n> ",
 StyleBox["PDF[NormalDistribution[0,1],0]",
  FontWeight->"Bold"],
 " -> This isn\[CloseCurlyQuote]t a sampling command like the others \
\[LongDash] instead it evaluates the probability density function of the \
standard normal distribution at x=0, giving you the height of the bell curve \
at its peak. This is useful when you want to calculate exact density values \
rather than generate random samples.\n\n> ",
 StyleBox["poissondata=RandomVariate[PoissonDistribution[4.8],10000];\n\
Show[Histogram[poissondata,100,\[CloseCurlyDoubleQuote]PDF\
\[CloseCurlyDoubleQuote]],DiscretePlot[PDF[PoissonDistribution[4.8],x],{x,0,\
15},PlotStyle->Thick,Filling->Axis,PlotRange->Full]] ",
  FontWeight->"Bold"],
 "-> compare the histogram of 10,000 data points obtained with RandomVariate \
with the theoretical PDF(PMF): \n\n> ",
 StyleBox["normaldata=RandomVariate[NormalDistribution[0,1],10000];\n\
Show[Histogram[normaldata,100,\[CloseCurlyDoubleQuote]PDF\
\[CloseCurlyDoubleQuote]],Plot[PDF[NormalDistribution[0,1],x],{x,-10,10},\
PlotStyle->Thick,Filling->Axis,PlotRange->Full]] ",
  FontWeight->"Bold"],
 "-> Plotting of continuous random variable. \n\n>  ",
 StyleBox["empdist = EmpiricalDistribution[data];\n\
{DiscretePlot[PDF[empdist,x],{x,data}],DiscretePlot[CDF[empdist,x],{x,-4,4,0.\
01}]} ",
  FontWeight->"Bold"],
 ": Plotting the empirical cumulative distribution function obtained from \
data and compare it with the theoretical cumulative distribution function. \n\
\n> ",
 StyleBox["empCDFPlot=DiscretePlot[CDF[empdist,x],{x,-4,4,0.01},\n\
PlotLegends->{\[OpenCurlyDoubleQuote]Empirical CDF\[CloseCurlyDoubleQuote]}] ",
  FontWeight->"Bold"],
 "-> An empirical CDF plot. \n\n> ",
 StyleBox["theoCDFPlot=Plot[CDF[NormalDistribution[0,1],x],{x,-4,4},PlotStyle-\
>{Red,Thick},PlotLegends->{\[OpenCurlyDoubleQuote]Theoretical CDF\
\[CloseCurlyDoubleQuote]}] ",
  FontWeight->"Bold"],
 "-> the probability that a random variable X takes a value less than or \
equal to x \[LongDash] so for any point on the curve, the y-value represents \
P(X \[LessEqual] x)\n\n> ",
 StyleBox["Show[empCDFPlot,theoCDFPlot,AxesLabel->{\[OpenCurlyDoubleQuote]x\
\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]CDF\[CloseCurlyDoubleQuote]},\
PlotRange->All,GridLines->Automatic,PlotLabel->\[CloseCurlyDoubleQuote]\
Empirical vs. Theoretical CDF\[CloseCurlyDoubleQuote]] ",
  FontWeight->"Bold"],
 "-> Plotting and comparison of ",
 StyleBox["empCDFPlot",
  FontWeight->"Bold"],
 " and ",
 StyleBox["theoCDFPlot",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.9804560441018333`*^9, 3.980456181938532*^9}, {
  3.980456250108597*^9, 3.980456316358467*^9}, {3.9804563674460793`*^9, 
  3.980456557662512*^9}, {3.9804565924576473`*^9, 3.980456634324255*^9}, {
  3.980456730844946*^9, 
  3.980456766919388*^9}},ExpressionUUID->"27114325-b1e9-4b42-8138-\
555fc90ecafe"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["#6_Central_Limit_Theorem.nb", "Title",
 CellChangeTimes->{{3.980456807872078*^9, 
  3.9804568207612705`*^9}},ExpressionUUID->"b3da8aa4-3aa5-2b47-b9bb-\
ad8a81647fe0"],

Cell[CellGroupData[{

Cell["Discrete Distribution", "Subsubsection",
 CellChangeTimes->{{3.980456827674366*^9, 
  3.9804568430929203`*^9}},ExpressionUUID->"df44e0b2-7878-644a-9885-\
7f18ba96603b"],

Cell[TextData[{
 "> ",
 StyleBox["RandomVariate[BernoulliDistribution[0.3],1] ",
  FontWeight->"Bold"],
 "-> A single random number taken drawn from the Bernoulli distribution with \
probability of success equal to 0.3. \n\n> ",
 StyleBox["rndseq=RandomVariate[BernoulliDistribution[0.3],4]",
  FontWeight->"Bold"],
 " -> Sample 4 numbers according to the Bernoulli distribution. \n\n> ",
 StyleBox["Histogram[rndseq,{-0.1,1.1,0.1},\[CloseCurlyDoubleQuote]\
Probability\[CloseCurlyDoubleQuote]]",
  FontWeight->"Bold"],
 " -> Displays it in graph form. \n\n>",
 StyleBox[" p = 0.3;(*probability of success*)\nnsample1 = 4;(*size of the \
sample*)\nnrepeat = 1000;(*we repeat the experiment 1000 times*)\n\
meansamp[p_, nsample_] := \n N[Mean[RandomVariate[BernoulliDistribution[p], \
nsample]]]\nreslist = Table[meansamp[p, nsample1],  nrepeat]; ",
  FontWeight->"Bold"],
 ": \n-> ",
 StyleBox["p = 0.3",
  FontWeight->"Bold"],
 " sets the probability of success at 30%.\n-> ",
 StyleBox["nsample1 = 4",
  FontWeight->"Bold"],
 " means each sample will contain only 4 observations.\n-> ",
 StyleBox["nrepeat = 1000",
  FontWeight->"Bold"],
 " means the experiment will be repeated 1000 times.\n-> ",
 StyleBox["meansamp[p_, nsample_]",
  FontWeight->"Bold"],
 " defines a function that:\n\tGenerates nsample random Bernoulli trials with \
probability p using \t",
 StyleBox["RandomVariate[]",
  FontWeight->"Bold"],
 "\n\tCalculates and returns the mean of that sample using ",
 StyleBox["N[Mean[...]]",
  FontWeight->"Bold"],
 "\n-> ",
 StyleBox["reslist",
  FontWeight->"Bold"],
 " ",
 StyleBox["=",
  FontWeight->"Bold"],
 " ",
 StyleBox["Table[meansamp[p, nsample1], nrepeat]",
  FontWeight->"Bold"],
 " then calls this function 1000 times, storing all 1000 sample means into a \
list called reslist."
}], "Text",
 CellChangeTimes->{{3.9804568469146233`*^9, 3.980456847034281*^9}, {
  3.98045693658428*^9, 3.9804570525481377`*^9}, {3.9804577201599655`*^9, 
  3.9804577925482025`*^9}, {3.98045782536022*^9, 3.9804578593035183`*^9}, {
  3.980457934291479*^9, 
  3.980457939576271*^9}},ExpressionUUID->"7b036d50-bb46-af4d-8ba1-\
7682b8485f91"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Practical 2: ", "Title",
 CellChangeTimes->{{3.980424116687052*^9, 3.9804241192682724`*^9}, 
   3.980424197081936*^9, {3.9804292779086857`*^9, 
   3.98042929074489*^9}},ExpressionUUID->"d75cc0b9-fc6e-fd4c-8fbf-\
351d7f007005"],

Cell[TextData[{
 "> \[OpenCurlyDoubleQuote]Do the chances\[CloseCurlyDoubleQuote] -> Odds \
Ratio \n\n> ",
 StyleBox["SpearmanRho[pizza[[2;;,7]],pizza[[2;;,8]]] ",
  FontWeight->"Bold"],
 "-> Calculates the Spearman Correlation Coefficient"
}], "Text",
 CellChangeTimes->{{3.9804242407184925`*^9, 3.9804242642242584`*^9}, {
  3.980429220249687*^9, 
  3.980429319960684*^9}},ExpressionUUID->"e7067ce5-80b7-b94c-8f2c-\
4912fb38a187"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Practical 3:", "Title"]], "Title",
 CellChangeTimes->{{3.980429309048916*^9, 3.9804293118927803`*^9}, {
  3.9804466785971794`*^9, 
  3.980446680601303*^9}},ExpressionUUID->"1fa263dd-0ba1-6b44-80dc-\
b96cef409a8e"],

Cell[TextData[{
 "1. ",
 StyleBox["Union of Events formula: P(PE \:222a T E) =P(PE) + P(TE) \[Minus] \
P(TE \:2229 PE) ",
  FontWeight->"Bold"],
 "\n\n> Used to calculate the probability that at least one of two or more \
events occurs\n\n2.",
 StyleBox[" P(PE \:222a TE) \[Minus] P(PE \:2229 TE) ",
  FontWeight->"Bold"],
 "\n\n> The probability that exactly one of them happens.\n\n3. ",
 StyleBox["P(M) = P(M|A)P(A) + P(M|",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       OverscriptBox[
        StyleBox["A", "TI"], "_"], TraditionalForm], "errors" -> {}, "input" -> 
     "\\overline{A}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"90915a72-bf4e-324c-8cfa-3c2fbea9d68a"],
 StyleBox[")P(",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       OverscriptBox[
        StyleBox["A", "TI"], "_"], TraditionalForm], "errors" -> {}, "input" -> 
     "\\overline{A}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"a7b0ba28-6d35-2642-a94b-1bac439559af"],
 StyleBox[")",
  FontWeight->"Bold"],
 "\n\n> If an event can happen in several different ways, then its total \
probability is the sum of the probabilities of each way it can happen.\n\n4. ",
 StyleBox["P(A|M) = ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     RowBox[{"P", "(", "A", ")"}], 
     RowBox[{"P", "(", 
      RowBox[{"M", "|", "A"}], ")"}]}], 
    RowBox[{"P", "(", "M", ")"}]], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"16c26af6-4250-7640-8910-e217f032cfdf"],
 "\n\n> How to update the probability of something being true after seeing \
new evidence.\n\n5. ",
 StyleBox["P(B \:2229 A)\n\n",
  FontWeight->"Bold"],
 "> \[OpenCurlyDoubleQuote]and\[CloseCurlyDoubleQuote] operator refers to the \
joint distribution of two variables. "
}], "Text",
 CellChangeTimes->{{3.9803395267584248`*^9, 3.980339592801731*^9}, {
  3.980340089993799*^9, 3.9803401438789883`*^9}, {3.980340193812708*^9, 
  3.9803401979061184`*^9}, {3.9803402446315727`*^9, 3.9803402450631256`*^9}, {
  3.98034029508239*^9, 3.9803403059679947`*^9}, {3.9803403784266434`*^9, 
  3.980340391203682*^9}, {3.980340605606325*^9, 3.980340635662199*^9}, {
  3.9803406702614536`*^9, 3.98034067794985*^9}, {3.9803408352611313`*^9, 
  3.980340838820265*^9}, {3.980340915566944*^9, 3.9803409825470276`*^9}, {
  3.9803412400671806`*^9, 3.980341243864624*^9}, {3.9804241081516647`*^9, 
  3.9804241093149624`*^9}, {3.9804292698998737`*^9, 3.9804292705453987`*^9}, {
  3.9804293025453987`*^9, 
  3.9804293053409634`*^9}},ExpressionUUID->"b0463300-a069-d74f-b63a-\
22f207b0061b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Practical 4", "Title",
 CellChangeTimes->{{3.98042932710791*^9, 
  3.9804293296442986`*^9}},ExpressionUUID->"38425989-1187-6f46-bf51-\
bb27297da5ae"],

Cell[TextData[{
 "> Calculate the Expected Variance: ",
 StyleBox["E(X)=",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], " ", "1"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], "2"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], "3"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"2", "/", "9"}], ")"}], "4"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], "5"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"3", "/", "9"}], ")"}], "6"}]}], "=", 
    RowBox[{"37", "/", "9", "  "}]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"f7a97ec0-9838-5f40-afda-a773ef2dc235"],
 "\n",
 StyleBox["E(",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["X", "2"], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "9"}], ")"}], " ", "1"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "9"}], ")"}], "4"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "9"}], ")"}], "9"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "/", "9"}], ")"}], "16"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "9"}], ")"}], "25"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"3", "/", "9"}], ")"}], "36"}]}], "=", 
     RowBox[{"179", "/", "9"}]}]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"f4ede945-c9cd-e14a-8b83-c823cb9a1c42"],
 "\n\n",
 "> Calculate the variance:  ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Var", "(", "X", ")"}], "=", 
   RowBox[{
    RowBox[{"E", "(", 
     SuperscriptBox["X", "2"], ")"}], "-", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"E", "(", "X", ")"}], ")"}], "2"]}]}]],
  FontWeight->"Bold",ExpressionUUID->"d972dc54-ab50-6d45-92fc-66596c792205"],
 " "
}], "Text",
 CellChangeTimes->{{3.980429672198225*^9, 3.980429678377901*^9}, {
