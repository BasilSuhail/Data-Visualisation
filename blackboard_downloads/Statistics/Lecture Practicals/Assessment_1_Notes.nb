Cell[CellGroupData[{

Cell["Practical 5", "Title",
 CellChangeTimes->{{3.980438836202324*^9, 
  3.9804388418959255`*^9}},ExpressionUUID->"2b9c53b8-841e-834a-93d4-\
537c4fdb851e"],

Cell[TextData[{
 "> ",
 StyleBox["1.-CDF[NormalDistribution[42.1,20.8],50]",
  FontWeight->"Bold"],
 ": \n ",
 StyleBox["CDF[] ",
  FontWeight->"Bold"],
 "-> gives the cumulative distribution function for the distribution dist \
evaluated at x.\[LineSeparator]",
 StyleBox["NormalDistribution[] ",
  FontWeight->"Bold"],
 "-> represents a normal (Gaussian) distribution with mean ",
 StyleBox["\[Mu]",
  FontWeight->"Bold"],
 " and standard deviation ",
 StyleBox["\[Sigma]",
  FontWeight->"Bold"],
 ". \n \n > ",
 StyleBox["N[CDF[NormalDistribution[42.1,20.8],40]-CDF[NormalDistribution[42.\
1,20.8],30]]",
  FontWeight->"Bold"],
 ": \n Helps find something between a range (in this case 30 and 40)\n \n > ",
 StyleBox["1.-CDF[BinomialDistribution[10,0.5],7]",
  FontWeight->"Bold"],
 ": \n ",
 StyleBox["BinomialDistribution[]",
  FontWeight->"Bold"],
 " -> represents a binomial distribution with ",
 StyleBox["n",
  FontWeight->"Bold"],
 " trials and success probability ",
 StyleBox["p",
  FontWeight->"Bold"],
 ".\n \n >  ",
 StyleBox["mean=Total[nbrokenbulbs*relfreq]",
  FontWeight->"Bold"],
 ": \n ",
 StyleBox["relfreq=N[counts/Total[counts]]",
  FontWeight->"Bold"],
 " -> counts the relative frequencies\n",
 StyleBox[" nbrokenbulbs=Range[0,5] ",
  FontWeight->"Bold"],
 "-> range for days\n \n > ",
 StyleBox["expectedx2=Total[nbrokenbulbs^2*relfreq] ",
  FontWeight->"Bold"],
 "-> Calculates the expected frequencies. \n\n> ",
 StyleBox["variance=expectedx2-mean^2 ",
  FontWeight->"Bold"],
 "-> calculates the variance\n\nIf we see that the mean and the variance are \
very close -> Poisson distribution is appropriate, because E(X)=\[Lambda] and \
Var(X)=\[Lambda].\n\n>",
 StyleBox["poissonpmf=Table[PDF[PoissonDistribution[1.73],x],{x,0,5}]\n\n",
  FontWeight->"Bold"],
 "> ",
 StyleBox["PairedBarChart[{relfreq},{poissonpmf},ChartLabels->nbrokenbulbs,\
ChartLegends->{{\[OpenCurlyDoubleQuote]real freq\[CloseCurlyDoubleQuote], \
\[OpenCurlyDoubleQuote]PMF\[CloseCurlyDoubleQuote]},None,None},ChartStyle->{\
\[OpenCurlyDoubleQuote]Pastel\[CloseCurlyDoubleQuote],None,None}] ",
  FontWeight->"Bold"],
 "-> Plotting a Paired Bar Chart. \n\n> The expectation of an exponential \
distributed variable is ",
 StyleBox["E(Y)=1/\[Lambda]=1/1.73",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.9804403246302032`*^9, 3.980440433220667*^9}, {
  3.9804404665593624`*^9, 3.9804404672105103`*^9}, {3.9804405023523808`*^9, 
  3.9804405581334534`*^9}, {3.980440618896961*^9, 3.980440632736845*^9}, {
  3.9804407826963997`*^9, 3.980440798178255*^9}, {3.980441607025978*^9, 
  3.980441788667549*^9}, {3.980441824735157*^9, 3.9804418959164085`*^9}, {
  3.9804422911017456`*^9, 3.980442312346979*^9}, {3.980444457891321*^9, 
  3.9804444824811325`*^9}, {3.980444631097225*^9, 3.980444668405575*^9}, {
  3.980444729780754*^9, 3.9804447573948956`*^9}, {3.980444791669945*^9, 
  3.9804447992944183`*^9}, {3.980445026546356*^9, 
  3.9804450278876762`*^9}},ExpressionUUID->"edbeec15-f836-8a43-a10d-\
61a81391cfdb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Practical 10", "Title",
 CellChangeTimes->{{3.9803412547376747`*^9, 3.980341268474325*^9}, {
  3.9804208070638504`*^9, 
  3.9804208073851757`*^9}},ExpressionUUID->"c4ed12f6-b7a4-e949-8ed6-\
6718cf18a26b"],

Cell[TextData[{
 "> ",
 StyleBox["LinearModelFit[]",
  FontWeight->"Bold"],
 " -> Constructs a linear model of the form that fits the ",
 StyleBox["yi",
  FontSlant->"Italic"],
 " for successive xi values. \n\n> ",
 StyleBox["N[Correlation[data2[[;;,1]],data2[[;;,2]]]] ",
  FontWeight->"Bold"],
 "-> Calculates the correlation coefficient. \n\n> ",
 StyleBox["r*Sqrt[Variance[data2[[;;,2]]]/Variance[data2[[;;,1]]]] ",
  FontWeight->"Bold"],
 "-> Calculates the beta slope of linear regression. \n\n> ",
 StyleBox["ListPlot[dataset,AxesLabel->{\[OpenCurlyDoubleQuote]height\
\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]weight\
\[CloseCurlyDoubleQuote]},PlotMarkers->{Automatic,12},LabelStyle->{FontSize->\
14}] ",
  FontWeight->"Bold"],
 "-> Produces a scatter plot\n\n> ",
 StyleBox["pred1=lmpizza[Sequence@@#]&/@data3[[;;,{1,2,3,4}]]",
  FontWeight->"Bold"],
 " -> This calculates the predicted data by both models, by applying them to \
the corresponding input data.  \n\n> ",
 StyleBox["combinedPlot1=Show[scatterPlot1,identityLine1,ImageSize->Large,\
PlotLabel->Style[\[OpenCurlyDoubleQuote]Model 1, R2adj=0.29\
\[CloseCurlyDoubleQuote],FontSize->16,Bold]] ",
  FontWeight->"Bold"],
 "-> Combines two plots together. \n\n"
}], "Text",
 CellChangeTimes->{{3.980420814495411*^9, 3.98042081724502*^9}, {
  3.980420867130516*^9, 3.9804209231712036`*^9}, {3.98042098997505*^9, 
  3.9804210551378574`*^9}, {3.980422952872156*^9, 3.980422989314192*^9}, {
  3.980423655010441*^9, 3.98042370196624*^9}, {3.9804237839071255`*^9, 
  3.980423808952055*^9}},ExpressionUUID->"e7617ca7-8770-9047-ae4d-\
49de0517db3d"],

