  "a4adc509-5d77-43c7-8e4e-9afd20280e92"],
 "\nThe expectation is equal to:\nE(X)=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], " ", "1"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], "2"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], "3"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"2", "/", "9"}], ")"}], "4"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], "5"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"3", "/", "9"}], ")"}], "6"}]}], "=", 
    RowBox[{"37", "/", "9", "  "}]}], TraditionalForm]],ExpressionUUID->
  "048602f0-5a2f-4d8f-b0bc-d0791d8046cf"],
 "which is approximately equal to 4.1.\n\nTo calculate the variance, we first \
need:\nE(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["X", "2"], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "9"}], ")"}], " ", "1"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "9"}], ")"}], "4"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "9"}], ")"}], "9"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "/", "9"}], ")"}], "16"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "9"}], ")"}], "25"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"3", "/", "9"}], ")"}], "36"}]}], "=", 
     RowBox[{"179", "/", 
      RowBox[{"9", "  ", "."}]}]}]}], TraditionalForm]],ExpressionUUID->
  "abe222e7-2bfd-4886-a010-d0ada7eab92f"],
 "\nUsing ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Var", "(", "X", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"E", "(", 
       SuperscriptBox["X", "2"], ")"}], "-", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"E", "(", "X", ")"}], ")"}], "2"]}], "="}]}], 
   TraditionalForm]],ExpressionUUID->"005f5ff1-7ca1-438b-b626-e0ec6b81a7d4"],
 "(179/9)-",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"37", "/", "9"}], ")"}], "2"], TraditionalForm]],ExpressionUUID->
  "9122da4e-35eb-4b2d-a66e-68f9dfc35cb4"],
 "=242/81 which is approximately equal to 2.98.\n\nThe manipulated die yields \
on average higher values than a fair die because its expectation is 4.1 > \
3.5. The variability of is, however, similar because 2.98 \[TildeTilde]2.92.\n\
\n(b) The probability mass function of Y = 1/X is:\n",
