  "b572dc50-c121-4f4b-b421-aec876bc51c8"],
 "\n(a) Plot the cumulative distribution function with Mathematica.\n(b) \
Determine the probability density function f (x).\n(c) What is the \
probability of selling at least one-third of his wine, but not more than two \
thirds? (try to calculate this with pen and paper).\n(d) Calculate the \
probability of (c) again using Mathematica.\n(e) What is the variance of X?\n\
"
}], "Subsubsection",
 CellChangeTimes->{{3.947901601093861*^9, 3.947901709265603*^9}, {
  3.94790444649314*^9, 3.947904451874319*^9}, {3.9479045090124063`*^9, 
  3.947904535123672*^9}},ExpressionUUID->"6938d001-ee9a-4a14-9a2e-\
ebb5024704b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", "x_", "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"x", "<", "0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"3", "*", 
         RowBox[{"x", "^", "2"}]}], "-", 
        RowBox[{"2", "*", 
         RowBox[{"x", "^", "3"}]}]}], ",", 
       RowBox[{"0", "<=", "x", "<=", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", 
       RowBox[{"x", ">", "1"}]}], "}"}]}], "}"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.947904180718051*^9, 3.947904272680567*^9}},
 CellLabel->
  "In[474]:=",ExpressionUUID->"b4fbc53b-d873-4d01-a64b-8ac2bd3bb815"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"F", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "0.5"}], ",", "1.5"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.947904279561522*^9, 3.947904318055581*^9}, {
  3.947904354485251*^9, 3.947904357312965*^9}},
