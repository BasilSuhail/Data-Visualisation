 "\nThe expectation value is then calculated as:\nE(1/X)=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], " ", "1"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "/", "3"}], ")"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"2", "/", "9"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "/", "4"}], ")"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "9"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "/", "5"}], ")"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"3", "/", "9"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "/", "6"}], ")"}]}]}], "=", 
    RowBox[{"91", "/", "270", "  "}]}], TraditionalForm]],ExpressionUUID->
  "09f2f620-de39-4cfa-bfe9-8bace15489a6"]
}], "Text",
