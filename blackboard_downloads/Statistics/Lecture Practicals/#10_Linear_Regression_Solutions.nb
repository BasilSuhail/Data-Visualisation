 CellLabel->"Out[5]=",ExpressionUUID->"3de33514-9637-9944-b596-ae46fa3026d0"]
}, Open  ]],

Cell["\<\
Thus 66%of the data\[CloseCurlyQuote]s variability can be explained by the \
model. The goodness of fit is good, but not perfect.\
\>", "Text",
 CellChangeTimes->{{3.948238846679295*^9, 
  3.9482388496502028`*^9}},ExpressionUUID->"0eeac822-4efa-4dce-820a-\
3080a5359364"]
}, Open  ]],

