Cell["We now determine the range for the plot:", "Text",
 CellChangeTimes->{{3.948251130535166*^9, 
  3.948251144574223*^9}},ExpressionUUID->"1e863a41-96cd-4ceb-ae88-\
c7e1b3b38a4a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"allValues1", "=", 
   RowBox[{"Flatten", "[", "dataPairs1", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"minValue1", "=", 
   RowBox[{"Min", "[", "allValues1", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"maxValue1", "=", 
   RowBox[{"Max", "[", "allValues1", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.948251062684874*^9, 3.948251069221689*^9}, {
  3.9482511174041643`*^9, 3.948251119489087*^9}},
 CellLabel->
  "In[2239]:=",ExpressionUUID->"afd16fae-6b21-44f8-ad95-f684298dc08e"],

Cell["We now plot the identity line:", "Text",
 CellChangeTimes->{{3.948251157804956*^9, 
  3.948251172944516*^9}},ExpressionUUID->"e838728a-00be-4488-b0fc-\
ef0309339775"],

Cell[BoxData[
 RowBox[{
  RowBox[{"identityLine1", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{"x", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "minValue1", ",", "maxValue1"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Dashed"}], "}"}]}], ",", 
     RowBox[{"AspectRatio", "->", "Automatic"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.948251174825213*^9, 3.948251185310666*^9}, 
   3.9482512285413723`*^9, {3.948251308116481*^9, 3.948251308655998*^9}, 
   3.9482517143127527`*^9},
 CellLabel->
  "In[2242]:=",ExpressionUUID->"49bfd5b7-8509-4beb-8b18-4eb680b8063d"],

Cell["Now we combine the plots:", "Text",
 CellChangeTimes->{{3.9482512005814743`*^9, 
  3.9482512048891087`*^9}},ExpressionUUID->"9b67156f-6cc2-4ef3-b6b0-\
448520d55ef5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"combinedPlot1", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"scatterPlot1", ",", "identityLine1", ",", 
    RowBox[{"ImageSize", "->", "Large"}], ",", 
