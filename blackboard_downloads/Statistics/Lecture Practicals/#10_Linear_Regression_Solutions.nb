  "ce8aca6e-1c68-4229-b92d-e4e7f79a8633"],
 "\n(a) Calculate the correlation coefficient of Bravais\[Dash]Pearson. What \
does this imply with respect to a linear regression of height on weight?\n(b) \
Now estimate and interpret the linear regression model where \
\[OpenCurlyDoubleQuote]weight\[CloseCurlyDoubleQuote] is the\noutcome. \
Calculate ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["R", "2"], TraditionalForm]],ExpressionUUID->
  "0f131b21-f970-424f-9dd9-112f2c61fcfe"],
 ".\n(c) Predict the weight of a student with a height 175 cm.\n(d) Now \
produce a scatter plot of the data and interpret it.\n(e) Add the following \
two points to the scatter plot ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["x", "18"]}], TraditionalForm]],ExpressionUUID->
  "fb46355f-e9d4-4e2f-9436-195f1d3ba645"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "18"], TraditionalForm]],ExpressionUUID->
  "cdfc6840-894c-4537-823e-27f358e47d6b"],
 ") = (175, 55) and\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["x", "19"]}], TraditionalForm]],ExpressionUUID->
  "67d4a200-dae9-4057-8ada-3fb9679d9ddf"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "19"], TraditionalForm]],ExpressionUUID->
  "8f03483e-66f0-4783-8f1b-6da45d19c3a3"],
 ") = (150, 75). Speculate how the linear regression estimate will change\n\
after adding these points.\n(f) Re-estimate the model using all 19 \
observations and calculate ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["R", "2"], TraditionalForm]],ExpressionUUID->
  "878728cc-cba0-4e0a-8bec-3d6f208ff65b"],
 " again.\n(g) Given the results of the two regression models: What are the \
general implications\nwith respect to the least squares estimator of \[Beta]?\
\n"
}], "Subsubsection",
 CellChangeTimes->{{3.948162856922332*^9, 3.9481628818493958`*^9}, {
  3.9481632608806562`*^9, 
  3.948163279304658*^9}},ExpressionUUID->"530dc966-edbe-4c1d-a23a-\
7a35c64e38ed"],

Cell["\<\
Solution to (a):
(a) Calculate the correlation coefficient of Bravais\[Dash]Pearson. What does \
this imply with respect to a linear regression of height on weight?\
\>", "Text",
 CellChangeTimes->{{3.948238893369637*^9, 3.948238896258808*^9}, {
  3.948239574644637*^9, 
  3.948239576499736*^9}},ExpressionUUID->"6aa5fe45-05d6-40d6-8132-\
7d0b5c33f10b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"68", ",", "174"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"58", ",", "164"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"53", ",", "164"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"60", ",", "165"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"59", ",", "170"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"60", ",", "168"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"55", ",", "167"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"62", ",", "166"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"58", ",", "160"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"53", ",", "160"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"53", ",", "163"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"50", ",", "157"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"64", ",", "168"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"77", ",", "179"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"60", ",", "170"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"63", ",", "168"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"69", ",", "170"}], "}"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.948238898822475*^9, 3.948239087456503*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"d46ad814-e1a0-4a84-8c94-e24eb193be26"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"r", "=", 
  RowBox[{"N", "[", 
   RowBox[{"Correlation", "[", 
    RowBox[{
     RowBox[{"data2", "[", 
      RowBox[{"[", 
       RowBox[{";;", ",", "1"}], "]"}], "]"}], ",", 
     RowBox[{"data2", "[", 
      RowBox[{"[", 
       RowBox[{";;", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.948239098524691*^9, 3.9482391504999866`*^9}, {
  3.948239527836199*^9, 3.948239528100593*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"f2cb2857-49cf-4c12-9bfd-9a0a9d2cd08d"],

Cell[BoxData["0.8699964077360831`"], "Output",
 CellChangeTimes->{{3.948239145656425*^9, 3.948239150808877*^9}, 
   3.94823952954034*^9, 3.953166554254084*^9, 3.953167181517046*^9, 
   3.9804209743451214`*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"111cbe63-38d1-7749-9f9b-f9914d08c754"]
}, Open  ]],

Cell["\<\
From the correlation coefficient, we know that beta (slope of linear \
regression) must be equal to:\
\>", "Text",
 CellChangeTimes->{{3.9482394990988607`*^9, 
  3.948239519116948*^9}},ExpressionUUID->"8b3f05ac-4558-45d6-8715-\
ebd0486d2934"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"beta", "=", 
  RowBox[{"r", "*", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{"Variance", "[", 
      RowBox[{"data2", "[", 
       RowBox[{"[", 
        RowBox[{";;", ",", "2"}], "]"}], "]"}], "]"}], "/", 
     RowBox[{"Variance", "[", 
      RowBox[{"data2", "[", 
       RowBox[{"[", 
        RowBox[{";;", ",", "1"}], "]"}], "]"}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.948239522063442*^9, 3.948239557361277*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"c648839c-a127-4a04-b345-92c256a84bed"],

Cell[BoxData["0.6826162606770009`"], "Output",
 CellChangeTimes->{3.948239559328167*^9, 3.953166554256672*^9, 
  3.953167181558576*^9, 3.9804211374384727`*^9},
 CellLabel->"Out[10]=",ExpressionUUID->"0ded8e1c-cd58-874b-8b1a-35836605c4ba"]
}, Open  ]],

Cell["\<\
Hence, for an increase of 1 kg in weight, we expect an increase of 0.68cm in \
height. Also, we know that:\
\>", "Text",
 CellChangeTimes->{{3.948239587291397*^9, 3.9482396264511833`*^9}, {
  3.948239806653152*^9, 
  3.9482398105265923`*^9}},ExpressionUUID->"45585be0-6d6d-4775-be3f-\
6a322aac9db9"],

