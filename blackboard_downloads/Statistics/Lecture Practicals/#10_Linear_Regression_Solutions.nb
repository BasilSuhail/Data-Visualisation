  3.953166694004434*^9, 3.953167181888566*^9, 3.9804233933052616`*^9},
 CellLabel->"Out[32]=",ExpressionUUID->"3df314d8-e0e0-5544-b92e-90af1d4897e7"]
}, Open  ]],

Cell["\<\
These results indicate that including the squared temperature as a covariate \
slightly  improves the fit, even though both models can only explain \
approximately 30% of the variability of the data.

We now calculate the predicted data by both models, by applying them to the \
corresponding input data:\
\>", "Text",
 CellChangeTimes->{{3.9482491850815153`*^9, 3.948249250533936*^9}, {
  3.9482507295453157`*^9, 3.948250740890201*^9}, {3.948252301787383*^9, 
  3.9482523203875103`*^9}},ExpressionUUID->"0d10506e-bdf8-4df4-aca6-\
d6cbd64206c2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pred1", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"lmpizza", "[", 
      RowBox[{"Sequence", "@@", "#"}], "]"}], "&"}], "/@", 
    RowBox[{"data3", "[", 
     RowBox[{"[", 
      RowBox[{";;", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}], "]"}], 
     "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.948249577500511*^9, 3.948249618919059*^9}, {
  3.9482505352730827`*^9, 3.948250539853372*^9}},
 CellLabel->
  "In[2234]:=",ExpressionUUID->"f6c15aa0-df7e-4a20-81bf-80e8c251f1b4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pred2", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"lmpizza2", "[", 
      RowBox[{"Sequence", "@@", "#"}], "]"}], "&"}], "/@", 
    RowBox[{"data3b", "[", 
     RowBox[{"[", 
      RowBox[{";;", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}]}], "]"}],
      "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.948249261099436*^9, 3.948249264961788*^9}, 
   3.948249637851768*^9, {3.948250319089457*^9, 3.948250355464807*^9}},
 CellLabel->
  "In[2235]:=",ExpressionUUID->"b8a3228e-2416-40f9-9bec-7dde954b7da5"],

Cell["\<\
Now we create data pairs containing the observed data and the predicted ones:\
\
\>", "Text",
 CellChangeTimes->{{3.948250746020111*^9, 
  3.948250763662866*^9}},ExpressionUUID->"01b9dcfe-0732-43c8-bfce-\
d2cc7ea9431c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dataPairs1", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"data3", "[", 
       RowBox[{"[", 
        RowBox[{";;", ",", "5"}], "]"}], "]"}], ",", "pred1"}], "}"}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.948250653185629*^9, 3.9482506957114973`*^9}},
 CellLabel->
  "In[2236]:=",ExpressionUUID->"3d7976c2-61d7-46a7-b395-214c8e3c6f87"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dataPairs2", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"data3b", "[", 
       RowBox[{"[", 
        RowBox[{";;", ",", "6"}], "]"}], "]"}], ",", "pred2"}], "}"}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.948250705397354*^9, 3.948250716152141*^9}},
 CellLabel->
  "In[2237]:=",ExpressionUUID->"b83bd1a2-f216-4010-a12c-21cffdfc5f1c"],

Cell["\<\
Now we create the scatter plots and add the identity line for reference:\
\>", "Text",
 CellChangeTimes->{{3.948250865248722*^9, 
  3.948250876729692*^9}},ExpressionUUID->"ca01cf92-31e6-464a-81b6-\
9374f5775ada"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"scatterPlot1", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{"dataPairs1", ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<Actual Delivery Time\>\"", 
       ",", "\"\<Predicted Delivery Time\>\""}], "}"}]}], ",", 
    RowBox[{"PlotStyle", "->", "Red"}], ",", 
    RowBox[{"LabelStyle", "->", 
     RowBox[{"{", 
      RowBox[{"FontSize", "->", "14"}], "}"}]}], ",", 
    RowBox[{"AspectRatio", "->", "Automatic"}], ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"10", ",", "50"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "50"}], "}"}]}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.94825087917177*^9, 3.948250899824048*^9}, {
