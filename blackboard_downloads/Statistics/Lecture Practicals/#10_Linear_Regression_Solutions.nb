Cell[BoxData[
 RowBox[{"40.79115720704288`", "\[VeryThinSpace]", "+", 
  RowBox[{"0.16305225604064635`", " ", "bill"}], "-", 
  RowBox[{"0.3835871595187346`", " ", "disc"}], "+", 
  RowBox[{"0.6433925409798429`", " ", "np"}], "-", 
