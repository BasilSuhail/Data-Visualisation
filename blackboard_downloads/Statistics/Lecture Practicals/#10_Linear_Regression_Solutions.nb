Cell["We now determine the range for the plot:", "Text",
 CellChangeTimes->{{3.948251130535166*^9, 
  3.948251144574223*^9}},ExpressionUUID->"85054220-3250-430d-858f-\
4997c06843a1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"allValues2", "=", 
   RowBox[{"Flatten", "[", "dataPairs2", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"minValue2", "=", 
   RowBox[{"Min", "[", "allValues2", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"maxValue2", "=", 
   RowBox[{"Max", "[", "allValues2", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.948251062684874*^9, 3.948251069221689*^9}, {
  3.9482511174041643`*^9, 3.948251119489087*^9}, {3.948251476142612*^9, 
  3.948251488028935*^9}},
 CellLabel->
  "In[2245]:=",ExpressionUUID->"22ee5d04-5199-44c5-904d-6afabb966d8e"],

Cell["We now plot the identity line:", "Text",
 CellChangeTimes->{{3.948251157804956*^9, 
  3.948251172944516*^9}},ExpressionUUID->"9dd1a705-ba93-4172-b220-\
6db5f4322968"],

Cell[BoxData[
 RowBox[{
  RowBox[{"identityLine2", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{"x", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "minValue2", ",", "maxValue2"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Dashed"}], "}"}]}], ",", 
     RowBox[{"AspectRatio", "->", "Automatic"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.948251174825213*^9, 3.948251185310666*^9}, 
   3.9482512285413723`*^9, {3.948251308116481*^9, 3.948251308655998*^9}, {
   3.9482514924209948`*^9, 3.9482514965775623`*^9}, 3.9482519378970613`*^9},
 CellLabel->
  "In[2248]:=",ExpressionUUID->"dec940f0-1e06-44c9-a96d-2f4facf7e352"],

Cell["Now we combine the plots:", "Text",
 CellChangeTimes->{{3.9482512005814743`*^9, 
  3.9482512048891087`*^9}},ExpressionUUID->"6707c876-9b2f-4eb3-81d9-\
894fd30c2ee9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"combinedPlot2", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"scatterPlot2", ",", "identityLine2", ",", 
    RowBox[{"ImageSize", "->", "Large"}], ",", 
    RowBox[{"PlotLabel", "->", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Model 2, R2adj=0.32\>\"", ",", 
       RowBox[{"FontSize", "->", "16"}], ",", "Bold"}], "]"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.948251221323204*^9, 3.948251235575698*^9}, {
