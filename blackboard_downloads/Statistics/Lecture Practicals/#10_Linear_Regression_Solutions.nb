Cell[BoxData[
 RowBox[{"data3", "[", 
  RowBox[{"[", 
   RowBox[{
    RowBox[{"1", ";;", "2"}], ",", ";;"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.953166587928417*^9, 3.953166601668181*^9}},
 CellLabel->
  "In[2227]:=",ExpressionUUID->"4846a101-4384-4b54-af59-88a79290be79"],

