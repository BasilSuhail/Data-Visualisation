Cell["\<\
Dominico seems to deliver pizzas with the highest temperature on average, and \
Bruno has the lowest median temperature. However, the temperatures of Bruno \
have several outliers, and the maximum temperature in the entire dataset was \
delivered by Bruno. \
\>", "Text",
 CellChangeTimes->{{3.947143055901379*^9, 3.947143167575899*^9}, {
  3.980429199674362*^9, 
  3.9804292016445503`*^9}},ExpressionUUID->"d668c294-b1be-4c12-97a9-\
fec10210625d"],

Cell["Association between temperature and operator:", "Text",
 CellChangeTimes->{{3.9471423563592987`*^9, 
  3.94714237890655*^9}},ExpressionUUID->"d45f59f6-dc65-485f-bf8b-\
7c5439f20afe"],

