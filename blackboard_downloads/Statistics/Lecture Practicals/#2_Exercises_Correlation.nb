Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "a", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"cafe", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"3", ",", "6"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"8", ",", "7"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"7", ",", "10"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"9", ",", "8"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"5", ",", "4"}], "}"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{"SpearmanRho", " ", "=", " ", 
    RowBox[{"N", "[", 
     RowBox[{"SpearmanRho", "[", 
      RowBox[{
       RowBox[{"cafe", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
       RowBox[{"cafe", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}], 
     "]"}]}]}]}]], "Code",
