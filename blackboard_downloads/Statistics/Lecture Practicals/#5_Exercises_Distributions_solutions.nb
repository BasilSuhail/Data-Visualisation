    RowBox[{"PoissonDistribution", "[", "1.73", "]"}], ",", "5"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.947906970067114*^9, 3.947906975049637*^9}, {
   3.947907023419639*^9, 3.947907080015037*^9}, 3.9479071970068197`*^9, {
