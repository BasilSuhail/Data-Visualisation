Cell["(d) Using \[Lambda]=1.73, we calculate P(X>5)=1-P(X\[LessEqual]5):", \
"Text",
 CellChangeTimes->{{3.947907326677744*^9, 3.947907346165827*^9}, {
  3.947907496196055*^9, 
  3.947907511117744*^9}},ExpressionUUID->"ad57d858-b2e1-4f45-8d51-\
b71d82e6cee1"],

