     ColorFunction->RGBColor,
     ImageResolution->{72., 72.},
     RasterInterpolation->"High"],
    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSize->Automatic,
   ImageSizeRaw->{551., 104.},
   PlotRange->{{0, 551.}, {0, 104.}}]], "Input",ExpressionUUID->
  "83962e9f-1905-43e2-b998-1dddcdf6e955"],
 "\n(a) Suggest an appropriate distribution for X : \"number of broken bulbs \
per day .\n(b) What is the average number of broken bulbs per day? What is \
the variance?\n(c) Determine the probabilities P(X = x) using the \
distribution you chose in (a)\nand using the average number of broken bulbs \
you calculated in (b) . Compare\nthe probabilities with the proportions \
obtained from the data . \n(d) Calculate the probability that at least 6 \
bulbs are fused, which means they need\nto be replaced. \n(e) Consider the \
random variable Y : \"time until next bulb breaks\". What is the distribution \
of Y?\n(f) Calculate and interpret E (Y) .\n"
}], "Subsubsection",
 CellChangeTimes->{{3.947905616728078*^9, 3.9479056545046377`*^9}, {
   3.947905733372034*^9, 3.9479057705731087`*^9}, 
   3.947906932657886*^9},ExpressionUUID->"6aef08ea-bbad-441a-bb03-\
66995a991505"],

Cell["\<\
(a) It seems appropriate to model the number of fused bulbs with a Poisson \
distribution. We assume, however, that the probabilities of fused bulbs on \
two consecutive days are independent of each other; i.e. they only depend on \
\[Lambda] but not on the time t.
(b) The absolute frequencies for the number of days we had a certain number \
of fused bulbs between 0 and 5, are as follows:\
\>", "Text",
 CellChangeTimes->{{3.947906914985005*^9, 3.9479069658029127`*^9}, {
  3.9479071996576138`*^9, 3.9479072166020117`*^9}, {3.947907941877234*^9, 
  3.9479080034850273`*^9}, {3.9479123464168987`*^9, 3.947912352493231*^9}, {
  3.9479124162798767`*^9, 
  3.947912439061942*^9}},ExpressionUUID->"d23799b6-e754-400f-8e81-\
84c3eab0270e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"counts", "=", 
  RowBox[{"{", 
   RowBox[{"6", ",", "8", ",", "8", ",", "5", ",", "2", ",", "1"}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.947908051193139*^9, 3.9479080788093357`*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"3faa7551-3ffb-4d79-838a-01c3bbaa2527"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"6", ",", "8", ",", "8", ",", "5", ",", "2", ",", "1"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.947908079797063*^9, 3.980441566864462*^9},
 CellLabel->"Out[36]=",ExpressionUUID->"76a39cf9-a641-2d49-8322-890af16f3ca7"]
}, Open  ]],

Cell["The relative frequencies are then:", "Text",
 CellChangeTimes->{{3.947908087954566*^9, 
  3.947908094443788*^9}},ExpressionUUID->"a29cfbbc-0c4f-4c5b-871f-\
fae84e3e1d5d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"relfreq", "=", 
  RowBox[{"N", "[", 
   RowBox[{"counts", "/", 
    RowBox[{"Total", "[", "counts", "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.947908098369667*^9, 3.947908107693264*^9}, {
  3.9804415692423344`*^9, 3.980441573338276*^9}},
 CellLabel->"In[37]:=",ExpressionUUID->"e0aa7306-e0f3-4ae4-8fa2-06e45323cfd3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0.2`", ",", "0.26666666666666666`", ",", "0.26666666666666666`", ",", 
   "0.16666666666666666`", ",", "0.06666666666666667`", ",", 
   "0.03333333333333333`"}], "}"}]], "Output",
 CellChangeTimes->{3.9479081084773197`*^9, 3.980441573658123*^9},
 CellLabel->"Out[37]=",ExpressionUUID->"fbf86764-99a1-eb43-a34c-2a4283024948"]
}, Open  ]],

Cell["\<\
Hence, we calculate the arithmetic mean for the number of broken bulbs as \
follows:\
\>", "Text",
 CellChangeTimes->{{3.947908119687704*^9, 
  3.947908136177721*^9}},ExpressionUUID->"abceeec5-83e0-46e4-ab73-\
b98282a395f0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"nbrokenbulbs", "=", 
  RowBox[{"Range", "[", 
   RowBox[{"0", ",", "5"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.947908885981338*^9, 3.94790892969424*^9}},
 CellLabel->"In[38]:=",ExpressionUUID->"9581cb88-3324-4a6b-842b-bc6bf4802eef"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "1", ",", "2", ",", "3", ",", "4", ",", "5"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.947908932316704*^9, 3.9804415792935276`*^9},
 CellLabel->"Out[38]=",ExpressionUUID->"dc954130-c8fe-7f40-86af-f4e9ecfd14b1"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"mean", "=", 
  RowBox[{"Total", "[", 
   RowBox[{"nbrokenbulbs", "*", "relfreq"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9479081392460403`*^9, 3.947908160561221*^9}, {
  3.947908785122568*^9, 3.947908791433639*^9}, {3.9479088672943*^9, 
  3.947908881605729*^9}, {3.947908935931878*^9, 3.947908939093058*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"0ec0e79f-fec6-4d54-9730-67633b096bd2"],

Cell[BoxData["1.7333333333333334`"], "Output",
 CellChangeTimes->{3.9479081578631077`*^9, 3.947908792454401*^9, 
  3.947908940420806*^9, 3.9804415823161736`*^9},
 CellLabel->"Out[39]=",ExpressionUUID->"b063b5a3-40ca-fc47-82a6-203acccf92dc"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", "%", "]"}]], "Input",
 CellChangeTimes->{{3.947908802057888*^9, 3.9479088042902193`*^9}},
 CellLabel->
  "In[500]:=",ExpressionUUID->"2970b8f5-2090-4f23-9fbe-a029043c7ed1"],

Cell[BoxData["1.7333333333333334`"], "Output",
 CellChangeTimes->{3.947908805663343*^9, 3.9479089418862047`*^9},
 CellLabel->
  "Out[500]=",ExpressionUUID->"7716d351-346b-4915-9907-202a81c9ef4f"]
}, Open  ]],

Cell["\<\
Hence, on average, 1.73 bulbs are fused per day.
We can calculate the variance as follows:\
\>", "Text",
 CellChangeTimes->{{3.9479090184117413`*^9, 3.947909028107614*^9}, {
  3.94791219455538*^9, 
  3.9479122009034567`*^9}},ExpressionUUID->"957120a1-47fa-45ed-b1dc-\
b9bfd43bac7c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"expectedx2", "=", 
  RowBox[{"Total", "[", 
   RowBox[{
    RowBox[{"nbrokenbulbs", "^", "2"}], "*", "relfreq"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9479122084872723`*^9, 3.947912242062866*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"f299b83c-16b4-47e0-8bc2-4db14a54e8a5"],

Cell[BoxData["4.7333333333333325`"], "Output",
 CellChangeTimes->{3.947912244954571*^9, 3.980441793505373*^9},
 CellLabel->"Out[40]=",ExpressionUUID->"0f91f738-12f8-9646-bca7-0329d2903b29"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"variance", "=", 
  RowBox[{"expectedx2", "-", 
   RowBox[{"mean", "^", "2"}]}]}]], "Input",
 CellChangeTimes->{{3.947912247401415*^9, 3.947912254494993*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"4f298a2c-86e2-4f45-a114-14e36f7f0576"],

Cell[BoxData["1.7288888888888878`"], "Output",
 CellChangeTimes->{3.947912255680739*^9, 3.9804417946097527`*^9},
 CellLabel->"Out[41]=",ExpressionUUID->"71cfdfa1-b34c-1148-a7f0-7c2f12b11fe4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", "%", "]"}]], "Input",
 CellChangeTimes->{{3.947912257438508*^9, 3.947912258572817*^9}},
 CellLabel->
  "In[503]:=",ExpressionUUID->"b7402787-551e-4ba9-bb74-9b67f1d994b5"],

Cell[BoxData["1.728888888888889`"], "Output",
 CellChangeTimes->{3.947912260048312*^9},
 CellLabel->
  "Out[503]=",ExpressionUUID->"bc21a1ae-3d81-4441-bc48-82bb54911995"]
}, Open  ]],

Cell["\<\
We see that the mean and the variance are very close, indicating that the \
choice of Poisson distribution is appropriate, because E(X)=\[Lambda] and \
Var(X)=\[Lambda].\
\>", "Text",
 CellChangeTimes->{{3.9479122765532017`*^9, 3.947912343469317*^9}, {
  3.980441798267769*^9, 
  3.9804418021867924`*^9}},ExpressionUUID->"338fcd8f-6604-48e1-b006-\
a25e93dfdf37"],

Cell["\<\
(c) We can compare the probabilities according to the Poisson distribution \
with \[Lambda]=1.73 with the relative frequencies that we got as follows:\
\>", "Text",
 CellChangeTimes->{{3.947912467036244*^9, 
  3.9479125216115913`*^9}},ExpressionUUID->"97482386-ada5-42c1-8d86-\
56a0cdc60102"],

