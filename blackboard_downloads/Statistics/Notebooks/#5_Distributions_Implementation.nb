Cell["The Bernoulli distribution in Wolfram Language", "Subsubsection",
 CellChangeTimes->{{3.779691458390561*^9, 3.779691467238727*^9}, {
  3.7796922680223827`*^9, 
  3.779692276886104*^9}},ExpressionUUID->"286b6eae-0fa7-48d3-b5bb-\
9162704e5648"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BernoulliDistribution"]], "paclet:ref/BernoulliDistribution"},
    
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   StyleBox["p", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bfad18dc-8353-4070-9a08-ac44bf33c26b"],
 "  represents a Bernoulli distribution with probability parameter ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "95509f50-4386-4a2a-8756-4d5c2cf962c7"],
 "."
}], "Text",
 CellChangeTimes->{{3.7796915710251017`*^9, 
  3.779691580998464*^9}},ExpressionUUID->"55f9cc0c-0637-44a9-bb1a-\
72c9e44fed26"],

Cell[TextData[{
 "We can use the function ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BernoulliDistribution"]], "paclet:ref/BernoulliDistribution"},
    
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   StyleBox["p", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "caac055a-238e-413c-83a2-383e6a3e3dd4"],
 "  and the function ",
 StyleBox["PDF", "CodeText"],
 " to calculate the probability of failure (k=0) or success (k=1) of the \
experiment."
}], "Text",
 CellChangeTimes->{{3.947815244582513*^9, 3.9478152453551197`*^9}, {
  3.947815295627469*^9, 3.947815385066367*^9}, {3.9478154273307734`*^9, 
