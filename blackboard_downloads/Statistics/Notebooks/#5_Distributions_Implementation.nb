Cell[TextData[{
 "The function",
 ButtonBox[" PDF",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/PDF.html?q=PDF"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/PDF.html?q=PDF"],
 "[",
 StyleBox["dist,x",
  FontSlant->"Italic"],
 "]",
 " gives the probability density function(probability mass function) of a \
certain distribution ",
 StyleBox["dist",
  FontSlant->"Italic"],
 ", evaluated at ",
 StyleBox["x",
  FontSlant->"Italic"],
 ":"
}], "Text",
 CellChangeTimes->{{3.947894510990348*^9, 3.947894544641396*^9}, {
  3.9478945780310497`*^9, 3.947894578031386*^9}, {3.947894643808667*^9, 
