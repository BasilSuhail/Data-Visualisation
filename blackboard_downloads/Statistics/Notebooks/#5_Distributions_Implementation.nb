}, Open  ]],

Cell["\<\
Now let\[CloseCurlyQuote]s compare the histogram of 10,000 data points \
obtained with RandomVariate with the theoretical PDF(PMF):\
\>", "Text",
 CellChangeTimes->{{3.9478947467645197`*^9, 3.947894795668954*^9}, 
   3.947894885933659*^9, {3.947896000472484*^9, 
   3.947896002738435*^9}},ExpressionUUID->"4a5e7933-d0cc-4934-b300-\
69784175c891"],

Cell["First we do that for a discrete random variable:", "Text",
 CellChangeTimes->{{3.947896008110919*^9, 
  3.947896015973351*^9}},ExpressionUUID->"99f0ee62-7ac1-4860-9013-\
cc8eb5202d94"],

Cell[BoxData[
 RowBox[{
  RowBox[{"poissondata", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"PoissonDistribution", "[", "4.8", "]"}], ",", "10000"}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.94789559310502*^9, 3.94789567826893*^9}},
 CellLabel->
  "In[418]:=",ExpressionUUID->"c27b8561-5337-4dbe-bdb7-a66b267d83c7"],

