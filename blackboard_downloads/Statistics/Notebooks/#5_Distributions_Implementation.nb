   RowBox[{"Histogram", "[", 
    RowBox[{"poissondata", ",", "100", ",", "\"\<PDF\>\""}], "]"}], ",", 
   RowBox[{"DiscretePlot", "[", 
    RowBox[{
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"PoissonDistribution", "[", "4.8", "]"}], ",", "x"}], "]"}], ",", 
