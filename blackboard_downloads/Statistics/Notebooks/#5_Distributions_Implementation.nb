Cell[TextData[{
 "We can also plot the empirical cumulative distribution function obtained \
from data, and compare it with the theoretical cumulative distribution \
function. For that, we first create the empirical distribution using the \
function ",
 ButtonBox["EmpiricalDistribution",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/EmpiricalDistribution.\
html"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/EmpiricalDistribution.html"],
 ", and then we apply the function ",
 ButtonBox["CDF",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/CDF.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/CDF.html"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9478960985943527`*^9, 3.947896111999148*^9}, {
  3.947896371898679*^9, 3.947896448672782*^9}, {3.947896988589574*^9, 
  3.9478970248782682`*^9}},ExpressionUUID->"0bec170e-1262-44ac-ab84-\
0f2b2a5fcc8a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"NormalDistribution", "[", 
      RowBox[{"0", ",", "1"}], "]"}], ",", "50"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9478964622065763`*^9, 3.947896468026012*^9}},
 CellLabel->
  "In[428]:=",ExpressionUUID->"4a64b840-f811-425e-902c-b557e8cbd91b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"empdist", "=", 
   RowBox[{"EmpiricalDistribution", "[", "data", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.94789647551178*^9, 3.947896497762948*^9}},
 CellLabel->
  "In[431]:=",ExpressionUUID->"50357f2f-7c54-4f37-bcd1-ac335ed141a3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"DiscretePlot", "[", 
    RowBox[{
     RowBox[{"PDF", "[", 
      RowBox[{"empdist", ",", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "data"}], "}"}]}], "]"}], ",", 
   RowBox[{"DiscretePlot", "[", 
    RowBox[{
     RowBox[{"CDF", "[", 
      RowBox[{"empdist", ",", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "4"}], ",", "4", ",", "0.01"}], "}"}]}], "]"}]}], 
  "}"}]], "Input",
 CellChangeTimes->{{3.947896513880931*^9, 3.947896529515514*^9}, {
  3.947896796661879*^9, 3.9478968241807117`*^9}},
 CellLabel->
  "In[439]:=",ExpressionUUID->"98861b3c-be62-4cd0-862b-42668c9dfeba"],

