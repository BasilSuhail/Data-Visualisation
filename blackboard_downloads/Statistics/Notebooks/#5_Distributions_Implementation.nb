Notebook[{

Cell[CellGroupData[{
Cell["Simulation of Bernoulli process", "Subsection",
 CellChangeTimes->{{3.77968767107373*^9, 3.779687672593647*^9}, {
  3.947741556428071*^9, 
  3.947741563280702*^9}},ExpressionUUID->"cdccd000-a5d2-46e6-be68-\
dd55e7addeed"],

Cell["We roll a die. If we get a 6 we win, otherwise we lose. ", "Text",
 CellChangeTimes->{{3.779686724288052*^9, 3.779686739672264*^9}, {
   3.7796868434145412`*^9, 3.779686871221859*^9}, 3.779687675346137*^9, {
   3.947741565860939*^9, 3.947741592177538*^9}, {3.9477522277111177`*^9, 
   3.947752235194666*^9}},ExpressionUUID->"4ae00b43-71f8-4362-8cb5-\
746a39f52863"],

Cell["Here is how we can simulate rolling the die 100 times. ", "Text",
 CellChangeTimes->{{3.779686861893724*^9, 3.779686873653851*^9}, {
  3.94774160143686*^9, 3.947741604093745*^9}, {3.947751464530532*^9, 
  3.9477514890940447`*^9}},ExpressionUUID->"d9bdba99-1315-40ce-8a04-\
b26c2c2c3e24"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"trials100", "=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"RandomInteger", "[", 
     RowBox[{"{", 
      RowBox[{"1", ",", "6"}], "}"}], "]"}], ",", 
    RowBox[{"{", "100", "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.947751509024437*^9, 3.947751518060446*^9}, {
  3.9477515495541143`*^9, 3.947751563064824*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"677a620a-92ff-4cd0-90ef-cd22387af2cb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "3", ",", "4", ",", "1", ",", "2", ",", "4", ",", "6", ",", "5", ",", "3", ",",
    "5", ",", "4", ",", "5", ",", "2", ",", "5", ",", "1", ",", "1", ",", "1",
    ",", "1", ",", "3", ",", "1", ",", "1", ",", "5", ",", "1", ",", "3", ",",
    "1", ",", "5", ",", "5", ",", "6", ",", "2", ",", "6", ",", "6", ",", "6",
    ",", "6", ",", "1", ",", "1", ",", "1", ",", "3", ",", "6", ",", "4", ",",
    "3", ",", "5", ",", "5", ",", "3", ",", "3", ",", "6", ",", "3", ",", "1",
    ",", "4", ",", "6", ",", "3", ",", "1", ",", "6", ",", "6", ",", "5", ",",
    "2", ",", "2", ",", "3", ",", "6", ",", "6", ",", "3", ",", "6", ",", "1",
    ",", "4", ",", "4", ",", "5", ",", "3", ",", "5", ",", "3", ",", "4", ",",
    "4", ",", "4", ",", "4", ",", "5", ",", "5", ",", "5", ",", "1", ",", "4",
    ",", "3", ",", "5", ",", "5", ",", "5", ",", "6", ",", "5", ",", "1", ",",
    "3", ",", "6", ",", "6", ",", "1", ",", "4", ",", "3", ",", "3", ",", "2",
    ",", "3", ",", "5", ",", "2", ",", "5", ",", "2", ",", "2", ",", "5", ",",
    "6", ",", "2"}], "}"}]], "Output",
 CellChangeTimes->{3.947751563857431*^9, 3.9804533509911327`*^9},
 CellLabel->"Out[65]=",ExpressionUUID->"7d6eeee7-d0e5-684e-a118-823db93f2e5f"]
}, Open  ]],

Cell["\<\
The probability of success is then estimated by the fraction of people \
obtaining a prize:\
\>", "Text",
 CellChangeTimes->{{3.7796871021314697`*^9, 
  3.779687122595402*^9}},ExpressionUUID->"f72ce3ba-1bd8-4f5d-b9ba-\
d6d5d831672b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"p", "=", 
  FractionBox[
   RowBox[{"Count", "[", 
    RowBox[{"trials100", ",", "6"}], "]"}], "100"]}]], "Input",
 CellChangeTimes->{{3.7796870153351793`*^9, 3.779687049380246*^9}, {
   3.947751605621523*^9, 3.9477516106971292`*^9}, 3.9804533574681206`*^9},
 CellLabel->"In[67]:=",ExpressionUUID->"bb69ed03-2e22-40ba-b565-7c6071822600"],

Cell[BoxData[
 FractionBox["9", "50"]], "Output",
 CellChangeTimes->{
  3.947741121425747*^9, 3.947751612018244*^9, {3.9804533481452866`*^9, 
   3.980453366013233*^9}},
 CellLabel->"Out[67]=",ExpressionUUID->"8f3ee797-c355-c147-9eb5-65da8bdba6c7"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", "%", "]"}]], "Input",
 CellChangeTimes->{{3.7796870564560957`*^9, 3.779687058003283*^9}},
 CellLabel->"In[68]:=",ExpressionUUID->"4d96b436-91e3-4d02-ac24-8b28293685c7"],

Cell[BoxData["0.18`"], "Output",
 CellChangeTimes->{3.947741129279396*^9, 3.9477516144912167`*^9, 
  3.980453422583887*^9},
 CellLabel->"Out[68]=",ExpressionUUID->"32130a5c-eb30-ff46-888e-88b4a34a65fe"]
}, Open  ]],

Cell["\<\
The theoretical probability to obtain a 6 is equal to p=1/6=0.166667. \
\[LineSeparator]We expect to obtain a better estimate by rolling the die more \
times, e.g., 1,000 times. \
\>", "Text",
 CellChangeTimes->{{3.779687070627667*^9, 3.779687096258823*^9}, {
   3.779687127010734*^9, 3.779687171139244*^9}, 3.947741131556355*^9, {
   3.947751634304225*^9, 
   3.9477517601213083`*^9}},ExpressionUUID->"c48d74f9-29e5-438e-bf5e-\
d699a9065d41"],

Cell[BoxData[
 RowBox[{
  RowBox[{"trials1000", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"RandomInteger", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "6"}], "}"}], "]"}], ",", 
     RowBox[{"{", "1000", "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.947751509024437*^9, 3.947751518060446*^9}, {
  3.9477515495541143`*^9, 3.947751563064824*^9}, {3.947751768076429*^9, 
  3.947751774335554*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"92ab3d87-bf9d-43fe-874a-15fc8b6c55bc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"p", "=", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{"Count", "[", 
     RowBox[{"trials1000", ",", "6"}], "]"}], "/", "1000"}], "]"}]}]], "Input",\

 CellChangeTimes->{{3.94775177967113*^9, 3.9477517976298647`*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"f9129b9f-2c88-4bdb-8784-eb8838ad73ae"],

Cell[BoxData["0.156`"], "Output",
 CellChangeTimes->{{3.947751792234989*^9, 3.947751798148327*^9}, 
   3.9804534359610004`*^9},
 CellLabel->"Out[70]=",ExpressionUUID->"055c0cd0-25ec-b249-b934-f178754cd795"]
}, Open  ]],

