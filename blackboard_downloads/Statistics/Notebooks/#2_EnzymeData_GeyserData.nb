Cell[TextData[{
 "The following function creates bins of width 10, starting at ",
 StyleBox["Ceiling[Min[data]-dx,dx]",
  FontWeight->"Bold"],
 ", and the last bin ending at ",
 StyleBox["Floor[Max[data]+dx,dx]",
  FontWeight->"Bold"],
 ", and it counts how many samples fall within each bin:"
}], "Text",
