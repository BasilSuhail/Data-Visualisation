Cell["\<\
We now take 10,000 samples of size n and calculate the mean for each of them. \
We want to explore how the distribution of the sample mean is distributed as \
we change the sample size n:\
\>", "Text",
 CellChangeTimes->{{3.7816855582275963`*^9, 3.781685617551652*^9}, {
  3.9480873292603283`*^9, 
  3.9480873978750353`*^9}},ExpressionUUID->"7b1377e4-d74a-43e9-9fc0-\
20cc23c9e903"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"meansample", "[", "n_", "]"}], ":=", 
  RowBox[{"Mean", "[", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{"tridis", ",", "n"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
