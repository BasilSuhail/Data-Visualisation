Cell["\<\
We now generate 200 samples, each having 4 samples of random numbers drawn \
from a Bernoulli distribution with parameter p, and we calculate the \
arithmetic mean for each of the samples:\
\>", "Text",
 CellChangeTimes->{{3.94808363736614*^9, 3.948083646180298*^9}, {
  3.948083698926136*^9, 3.948083700024947*^9}, {3.948083741078452*^9, 
  3.948083793923922*^9}},ExpressionUUID->"cc483047-1788-4a63-aa09-\
a01067639dfc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"p", "=", "0.3"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"probability", " ", "of", " ", "success"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nsample1", "=", "4"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"size", " ", "of", " ", "the", " ", "sample"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nrepeat", "=", "1000"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "we", " ", "repeat", " ", "the", " ", "experiment", " ", "1000", " ", 
    "times"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"meansamp", "[", 
   RowBox[{"p_", ",", "nsample_"}], "]"}], ":=", 
  RowBox[{"N", "[", 
   RowBox[{"Mean", "[", 
    RowBox[{"RandomVariate", "[", 
     RowBox[{
      RowBox[{"BernoulliDistribution", "[", "p", "]"}], ",", "nsample"}], 
     "]"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"reslist", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"meansamp", "[", 
      RowBox[{"p", ",", "nsample1"}], "]"}], ",", "  ", "nrepeat"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.781623401635301*^9, 3.781623607794853*^9}, {
   3.7816236381892023`*^9, 3.781623720479298*^9}, {3.781624379769775*^9, 
   3.781624394892589*^9}, {3.7816244251548967`*^9, 3.7816244776663847`*^9}, {
   3.781625849821699*^9, 3.7816258638018427`*^9}, {3.781882142323164*^9, 
   3.781882142904833*^9}, {3.781882211485797*^9, 3.781882219457032*^9}, {
   3.781882256831954*^9, 3.781882257843946*^9}, {3.781882299126842*^9, 
   3.7818823552366333`*^9}, {3.781882431429037*^9, 3.7818824338256207`*^9}, {
   3.781882526559084*^9, 3.7818825297669067`*^9}, {3.781883236586357*^9, 
   3.781883255421198*^9}, 3.7818833074320498`*^9, {3.948083532257648*^9, 
   3.94808353620721*^9}, {3.948083577112499*^9, 3.9480836273681917`*^9}, {
   3.948083702986438*^9, 3.948083730668923*^9}, {3.94808391473324*^9, 
   3.948083923077827*^9}, {3.948084290951428*^9, 3.948084378188892*^9}, {
   3.948084813969715*^9, 3.948084842580861*^9}, {3.948084977938501*^9, 
   3.948084982280622*^9}, {3.9480856239355507`*^9, 3.948085629856689*^9}},
 CellLabel->"In[82]:=",ExpressionUUID->"d0b1a9d7-50ec-4b12-88dd-e781dbe884f3"],

Cell["\<\
The result is a list of 200 elements, each containing the mean of each of the \
1000 samples. We can inspect e.g. the 10 first elements:\
\>", "Text",
