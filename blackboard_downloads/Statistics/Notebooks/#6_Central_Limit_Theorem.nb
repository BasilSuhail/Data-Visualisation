Cell[TextData[StyleBox["Continuous Distribution", "Chapter"]], "Text",
 CellChangeTimes->{{3.781626301793517*^9, 3.781626331581114*^9}, {
   3.781684513163484*^9, 3.7816845946817703`*^9}, 3.948086917531464*^9, {
