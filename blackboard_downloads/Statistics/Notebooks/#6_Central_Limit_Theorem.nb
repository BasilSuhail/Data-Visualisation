Cell["\<\
Now we plot the two obtained histograms using the same scale for comparison:\
\>", "Text",
 CellChangeTimes->{{3.94808641934667*^9, 
  3.948086439650448*^9}},ExpressionUUID->"26546f87-d901-4d30-92a9-\
55646c841635"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"plot1b", "=", 
  RowBox[{"plot1", "=", 
   RowBox[{"Show", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Histogram", "[", 
       RowBox[{"reslist", ",", "Automatic", ",", "\"\<PDF\>\"", ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "0.5"}], ",", "1.2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "6.5"}], "}"}]}], "}"}]}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"PDF", "[", 
         RowBox[{
          RowBox[{"NormalDistribution", "[", 
           RowBox[{"mu", ",", 
            RowBox[{"std", "/", 
             RowBox[{"Sqrt", "[", "nsample1", "]"}]}]}], "]"}], ",", "x"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "0.5"}], ",", "1.2"}], "}"}]}], "]"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.948086444004072*^9, 3.9480864673919487`*^9}, {
  3.948086627709572*^9, 3.948086631875266*^9}},
