Cell[BoxData[
 RowBox[{"RandomVariate", "[", 
  RowBox[{
   RowBox[{"BernoulliDistribution", "[", "0.3", "]"}], ",", "1"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.781622280053419*^9, 3.7816222909435472`*^9}, {
   3.78162236838828*^9, 3.781622411883646*^9}, 3.781622500617353*^9},
 CellLabel->
  "In[661]:=",ExpressionUUID->"897ef656-0864-45d2-994a-082d284bd120"],

