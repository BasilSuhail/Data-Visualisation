Cell["\<\
We now compare the empirically obtained distribution with the normal \
distribution with expect from the CLT. Notice that because we have increase \
the sample size of each of the samples, we expect the standard deviation to \
decrease and the distribution of the sample mean to be better approximated by \
the  normal distribution:\
\>", "Text",
 CellChangeTimes->{{3.9480846910622597`*^9, 3.948084725498949*^9}, {
  3.948085218897448*^9, 3.9480852468287477`*^9}, {3.948087021959529*^9, 
  3.9480870375283613`*^9}},ExpressionUUID->"2289dd27-46e6-4dbd-8ea3-\
befae180f043"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"plot2", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Histogram", "[", 
      RowBox[{"reslist50", ",", "Automatic", ",", "\"\<PDF\>\""}], "]"}], ",", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"PDF", "[", 
        RowBox[{
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"mu", ",", 
           RowBox[{"std", "/", 
            RowBox[{"Sqrt", "[", "nsample2", "]"}]}]}], "]"}], ",", "x"}], 
        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "0.1"}], ",", "1."}], "}"}]}], "]"}]}], 
    "\[IndentingNewLine]", "}"}], "]"}]}]], "Input",
