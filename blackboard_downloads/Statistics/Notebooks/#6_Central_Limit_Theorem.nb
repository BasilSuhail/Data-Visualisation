 CellLabel->
  "Out[661]=",ExpressionUUID->"dded4f4a-7e0b-4042-9ad1-05335cce5391"]
}, Open  ]],

Cell["\<\
Now we sample 4 numbers according to the Bernoulli distribution:\
\>", "Text",
 CellChangeTimes->{{3.9480834170058193`*^9, 
  3.9480834348233833`*^9}},ExpressionUUID->"fcb400fa-b8c3-4968-95e9-\
80e5dd4ac49d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rndseq", "=", 
  RowBox[{"RandomVariate", "[", 
   RowBox[{
    RowBox[{"BernoulliDistribution", "[", "0.3", "]"}], ",", "4"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.7816225521833267`*^9, 3.7816225547572412`*^9}, {
   3.781622739979062*^9, 3.78162274477451*^9}, {3.781623166410698*^9, 
