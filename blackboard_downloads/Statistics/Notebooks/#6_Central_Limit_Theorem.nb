   3.980457968985771*^9}},ExpressionUUID->"afe81c64-6bb9-48eb-9950-\
1ff0ec6e6adc"],

Cell["\<\
We now assume that we draw numbers from a triangular distribution. How does \
the distribution of the sample mean look like when we increase the sample \
size?\
\>", "Text",
 CellChangeTimes->{{3.948087079782609*^9, 
  3.948087128159223*^9}},ExpressionUUID->"016004a4-48f2-437b-bb9f-\
6ec036784aaa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"PDF", "[", 
    RowBox[{
     RowBox[{"TriangularDistribution", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "7"}], "}"}], ",", "0.2"}], "]"}], ",", "x"}], 
    "]"}], " ", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "7"}], "}"}], ",", 
   RowBox[{"Filling", "\[Rule]", "Axis"}], ",", 
   RowBox[{"Exclusions", "\[Rule]", "None"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.78168462622425*^9, 3.7816847208539886`*^9}},
 CellLabel->
  "In[984]:=",ExpressionUUID->"37c27729-96ea-4d52-a089-1e175156a31f"],

