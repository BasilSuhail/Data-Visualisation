Cell["\<\
We now compare the empirically obtained distribution with the normal \
distribution we expect from the CLT:\
\>", "Text",
 CellChangeTimes->{{3.9480846910622597`*^9, 3.948084725498949*^9}, {
  3.951104480427746*^9, 
  3.951104482193722*^9}},ExpressionUUID->"e79d1041-932f-409e-b03e-\
ecd28f96cdc2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"plot1", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Histogram", "[", 
      RowBox[{"reslist", ",", "Automatic", ",", "\"\<PDF\>\"", ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
