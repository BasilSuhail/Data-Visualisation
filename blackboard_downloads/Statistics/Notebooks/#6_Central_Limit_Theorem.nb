Cell["\<\
The Bernoulli distribution with p=0.3 has the following expected value, \
variance and standard deviation:\
\>", "Text",
 CellChangeTimes->{{3.9480845551625643`*^9, 3.948084583743433*^9}, {
  3.948084946067623*^9, 
  3.948084951557982*^9}},ExpressionUUID->"28ccf44c-5951-4a58-97fd-\
b3d34700b125"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"mu", "=", 
  RowBox[{"Expectation", "[", 
   RowBox[{"x", ",", 
    RowBox[{"x", "\[Distributed]", 
     RowBox[{"BernoulliDistribution", "[", "p", "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.948084586241035*^9, 3.948084645179914*^9}, {
  3.948084736064827*^9, 3.948084736788333*^9}},
