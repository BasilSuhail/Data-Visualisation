Cell["Now we increase the size of each of the samples to 50:", "Text",
 CellChangeTimes->{{3.948085042926013*^9, 3.9480850707429943`*^9}, {
  3.9480854236876*^9, 
  3.948085435034376*^9}},ExpressionUUID->"9952a54c-9e59-4aae-ab69-\
c4ff14fcbf08"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"p", "=", "0.3"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"probability", " ", "of", " ", "success"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nsample2", "=", "50"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"size", " ", "of", " ", "the", " ", "sample"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nrepeat", "=", "1000"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "we", " ", "repeat", " ", "the", " ", "experiment", " ", "1000", " ", 
    "times"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"meansamp", "[", 
   RowBox[{"p_", ",", "nsample_"}], "]"}], ":=", 
  RowBox[{"N", "[", 
   RowBox[{"Mean", "[", 
    RowBox[{"RandomVariate", "[", 
     RowBox[{
      RowBox[{"BernoulliDistribution", "[", "p", "]"}], ",", "nsample"}], 
     "]"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"reslist50", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"meansamp", "[", 
      RowBox[{"p", ",", "nsample2"}], "]"}], ",", "  ", "nrepeat"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.781623401635301*^9, 3.781623607794853*^9}, {
   3.7816236381892023`*^9, 3.781623720479298*^9}, {3.781624379769775*^9, 
