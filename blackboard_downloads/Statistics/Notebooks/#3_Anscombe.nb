Cell[CellGroupData[{
Cell[TextData[StyleBox["The Anscombe\[CloseCurlyQuote]s quartet   ", \
"Chapter"]], "Section",
 CellChangeTimes->{{3.7814203532964983`*^9, 3.781420376239333*^9}, {
  3.946815010437323*^9, 
  3.9468150254030857`*^9}},ExpressionUUID->"f07d19c0-482b-4939-b940-\
3142a38657dd"],

Cell["\<\
The Anscombe\[CloseCurlyQuote]s quartet comprises four datasets, each \
containing eleven (x, y) points, that share nearly identical simple \
descriptive statistics\[LongDash]such as means and variances\[LongDash]yet \
exhibit markedly different distributions when graphed. \
\>", "Text",
 CellChangeTimes->{{3.946815134344058*^9, 
  3.94681519082953*^9}},ExpressionUUID->"b1bf49ad-2488-4ca9-a474-\
4e6f11317bbc"],

