Cell["\<\

Let\[CloseCurlyQuote]s add some noise.
\
\>", "Text",
 CellChangeTimes->{{3.781526464300892*^9, 3.7815264719912043`*^9}, {
  3.94709248676798*^9, 
  3.9470924891099663`*^9}},ExpressionUUID->"6f0b19a1-b4df-457c-a7fa-\
d93bb1ba7e4f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sigma", " ", "=", " ", "0.3"}], ";"}], "   ", 
  RowBox[{"(*", "  ", 
   RowBox[{
    RowBox[{
    "standard", " ", "deviation", " ", "of", " ", "the", " ", "Normal", " ", 
     "Distribution"}], "  ", "-", " ", 
    RowBox[{"noise", " ", "strength"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"set4", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"#", ",", 
        RowBox[{"#", "+", 
         RowBox[{"RandomVariate", "[", 
          RowBox[{"NormalDistribution", "[", 
           RowBox[{"0", ",", "sigma"}], "]"}], "]"}]}]}], "}"}], "&"}], "/@", 
     " ", 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", "1", ",", "0.0001"}], "]"}]}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"test", " ", "different", " ", "noise", " ", "strength"}], "  ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Correlation", "[", 
  RowBox[{
   RowBox[{"set4", "[", 
    RowBox[{"[", 
     RowBox[{";;", ",", "1"}], "]"}], "]"}], ",", 
   RowBox[{"set4", "[", 
    RowBox[{"[", 
     RowBox[{";;", ",", "2"}], "]"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", "set4", "]"}]}], "Input",
