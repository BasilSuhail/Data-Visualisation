Cell["\<\

alternative approach for the first purely random paired data sample, now with \
normal distribution instead of uniform in set 1\
\>", "Text",
 CellChangeTimes->{{3.781527499019629*^9, 3.781527559003751*^9}, 
   3.9804530652495193`*^9},ExpressionUUID->"6b245374-af2a-42e1-a8aa-\
fec8f75760f1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p1", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"NormalDistribution", "[", 
      RowBox[{"0", ",", "0.3"}], "]"}], ",", "100"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p2", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"NormalDistribution", "[", 
      RowBox[{"0", ",", "0.3"}], "]"}], ",", "100"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Correlation", "[", 
  RowBox[{"p1", ",", "p2"}], "]"}]}], "Input",
 CellChangeTimes->{{3.781527005502469*^9, 3.781527071020699*^9}, {
  3.781527132481997*^9, 3.781527157449916*^9}, {3.812898417812654*^9, 
  3.812898426500586*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"79d83911-0791-4dfe-b720-1172283d526d"],

Cell[BoxData[
 RowBox[{"-", "0.01727483251232044`"}]], "Output",
 CellChangeTimes->{{3.947092595272395*^9, 3.9470925987319593`*^9}, 
   3.980453069562359*^9},
 CellLabel->"Out[62]=",ExpressionUUID->"dd6bd19e-6305-7840-9797-02c160c2f623"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Length", "[", "p1", "]"}], "\[IndentingNewLine]", 
