Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Liters of alcohol",
  FontVariations->{"Underline"->True}],
 " consumed, per capita. Notice that numbers are similar to the ones for the \
other table for ",
 StyleBox["liters of wine",
  FontVariations->{"Underline"->True}],
 ". "
}], "Item",
 CellChangeTimes->{{3.808566859193138*^9, 3.808566888203602*^9}, {
  3.808567182247361*^9, 3.80856719813487*^9}, {3.8085675216206*^9, 
