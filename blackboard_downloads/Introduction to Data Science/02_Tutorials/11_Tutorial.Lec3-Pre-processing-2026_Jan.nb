Cell[TextData[{
 "See good explanation for Normal in [",
 StyleBox[ButtonBox["quora",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.quora.com/What-exactly-is-a-normal-expression-in-\
mathematica"], None},
  ButtonNote->
   "https://www.quora.com/What-exactly-is-a-normal-expression-in-mathematica"],
  FontColor->RGBColor[1, 0, 0]],
 "]. Bellow the ",
 StyleBox["Normal",
  FontWeight->"Bold"],
 " shows the \[OpenCurlyDoubleQuote]raw\[CloseCurlyDoubleQuote] true form of \
what is inside the dat variable which is a Dataset object. The opposite \
function  ",
 StyleBox["FullForm",
  FontWeight->"Bold"],
 ", which shows \[OpenCurlyDoubleQuote]everything\[CloseCurlyDoubleQuote]."
}], "Text",
