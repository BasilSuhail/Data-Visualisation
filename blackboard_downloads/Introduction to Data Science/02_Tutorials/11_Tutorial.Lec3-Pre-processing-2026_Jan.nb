  3.812295375376896*^9}},ExpressionUUID->"bc94cd99-b0d1-43a2-a2b4-\
20e08060aed1"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Number of ",
 StyleBox["heart disease deaths",
  FontVariations->{"Underline"->True}],
 ", per 1,000,000 people, according to TB Shah."
}], "Item",
 CellChangeTimes->{{3.808566859193138*^9, 3.808566937313667*^9}, {
   3.808567214960813*^9, 3.808567215170108*^9}, 3.808568273231579*^9, 
