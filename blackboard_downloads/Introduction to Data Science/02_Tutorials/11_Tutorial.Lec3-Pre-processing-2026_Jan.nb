    RowBox[{"Which", "[", 
     RowBox[{
      RowBox[{"0", "<", 
       RowBox[{"red2", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "3"}], "]"}], "]"}], "<", "1"}], ",", "0", ",", 
      RowBox[{"1", "\[LessEqual]", 
       RowBox[{"red2", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "3"}], "]"}], "]"}], "<", "2"}], ",", "1", ",", 
      RowBox[{"2", "\[LessEqual]", 
       RowBox[{"red2", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "3"}], "]"}], "]"}], "<", "5"}], ",", "2", ",", 
      RowBox[{
