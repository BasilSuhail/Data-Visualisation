Cell["Data Transformation ", "Title",
 CellChangeTimes->{{3.808636285855413*^9, 
  3.808636290186832*^9}},ExpressionUUID->"c0ef2618-84da-4b09-bb7e-\
51b94e19f173"],

Cell["\<\
Aimed at smoothing, removing noise data, aggregation, normalization.\
\>", "Text",
 CellChangeTimes->{{3.808638059840274*^9, 3.808638088206927*^9}, {
  3.8086382021637383`*^9, 3.808638223753216*^9}},
 FontWeight->"Bold",ExpressionUUID->"d3af76d9-cce4-4a7b-b01a-9e33cd1b3ef3"],

Cell["Let us look at the alcohol consumption per capita attribute", "Text",
 CellChangeTimes->{{3.8086363767222013`*^9, 
  3.808636411568693*^9}},ExpressionUUID->"fa5c1110-504a-4434-9fee-\
bd49f2301add"],

Cell[TextData[{
 StyleBox["Without context, and without knowing the period the data was taken",
  FontWeight->"Bold"],
 ": Data value for Italy (27.9) seems to be too large, and for Norway (0.08) \
too little. So, as done in TB one could consider these to be outliers, and \
replaced them by 7.9 (for Italy) and 0.8 (for Norway)."
}], "Item",
 CellChangeTimes->{{3.808636334085157*^9, 3.808636368598447*^9}, {
   3.808636419886998*^9, 3.808636426538508*^9}, {3.8086364753430367`*^9, 
   3.808636579990167*^9}, 3.808636637135178*^9, {3.808636948657055*^9, 
   3.808636953967708*^9}, {3.808637033250999*^9, 
   3.808637038660838*^9}},ExpressionUUID->"c9366fb9-dc34-4f35-9605-\
98ab71e4567e"],

Cell[TextData[{
 StyleBox["With context",
  FontWeight->"Bold"],
 ":  The data for Italy is close to the real value (50 bottles per capita ",
 StyleBox["per year ",
  FontVariations->{"Underline"->True}],
 "), and I would leave this data as it is. Norway is in fact too low, looks \
like it can be corrected by multiplying by 10. In fact, all  the other data \
for wine consumption could be multiplied by 10. "
}], "Item",
 CellChangeTimes->{{3.808636334085157*^9, 3.808636368598447*^9}, {
  3.808636419886998*^9, 3.808636426538508*^9}, {3.8086364753430367`*^9, 
  3.808636630879711*^9}, {3.808636751757246*^9, 3.808636763080204*^9}, {
  3.80863705978045*^9, 3.808637109587721*^9}, {3.812298797644639*^9, 
  3.81229886404828*^9}},ExpressionUUID->"ddf84332-1e30-42ef-b076-\
6e33c6d7f3c6"],

