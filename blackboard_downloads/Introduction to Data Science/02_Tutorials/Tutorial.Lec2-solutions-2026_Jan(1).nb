Cell[TextData[{
 StyleBox["For the fourth and final option, you can bake loaves of bread, \
where you will need only flour and butter for the ingredients, which will \
cost you ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["$3 per lb",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[". The initial setup cost is marginal between ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["$270 and $350",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox["; however, the labour charge is high, ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["$40 per hour",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[". However, you can bake as many as ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["1000 loaves in 2 hours",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox["; each can be priced at ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["$3",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[". Each 1000 loaves require ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["30lb of ingredients.",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[" So, ",
  FontSize->24,
  FontWeight->"Regular"]
}], "Item",
 CellChangeTimes->{{3.811598090828949*^9, 3.81159812479241*^9}, {
