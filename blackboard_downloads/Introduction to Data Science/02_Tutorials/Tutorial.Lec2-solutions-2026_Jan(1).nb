Cell[TextData[{
 StyleBox["In the third option, you can make bagels in your shop, which will \
require flour, butter and other ingredients, which will cost you ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["$2.50 per lb",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[". The initial setup cost is low, at ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["$680",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[", as is the labor cost at ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["$25 per hour",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[". In one batch, using ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["20 lb of ingredients",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[", you can make ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["300 bagels in 45 minutes",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[" (300*60/45 bagels per hour). Each bagel can be sold at ",
  FontSize->24,
  FontWeight->"Regular"],
 StyleBox["$1.75",
  FontSize->24,
  FontWeight->"Regular",
  FontVariations->{"Underline"->True}],
 StyleBox[".",
  FontSize->24,
  FontWeight->"Regular"]
}], "Item",
