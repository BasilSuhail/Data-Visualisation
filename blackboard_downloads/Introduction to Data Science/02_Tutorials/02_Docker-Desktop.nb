Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"a39afeaa-85a8-426d-b1f1-033279d4a352"],

Cell[CellGroupData[{

Cell["Connect to your MySQL Server", "Section",
 CellChangeTimes->{{3.981730885624647*^9, 
  3.981730892380926*^9}},ExpressionUUID->"26ca83c4-b7eb-4f8f-a437-\
0d95f9a5dd53"],

Cell[TextData[{
 "You can use command line tools like the mysql client in the ",
 StyleBox["Exec",
  FontWeight->"Plain",
  FontSlant->"Italic"],
 " tab of the container in the application or the ",
 ButtonBox["MySQL Shell",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/downloads/shell/"], None},
  ButtonNote->"https://dev.mysql.com/downloads/shell/"],
 " on the host system"
}], "Item",
 CellChangeTimes->{{3.981731661580049*^9, 3.981731742343162*^9}, {
  3.981733439615644*^9, 
  3.981733471082016*^9}},ExpressionUUID->"b449d903-2d33-48a9-88fb-\
68a6ddf50dd6"],

Cell[TextData[{
 "You can also use graphical tools like ",
 ButtonBox["HeidiSQL",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.heidisql.com"], None},
  ButtonNote->"https://www.heidisql.com"],
 ", ",
 ButtonBox["MySQL Workbench",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/downloads/workbench/"], None},
  ButtonNote->"https://dev.mysql.com/downloads/workbench/"],
 ", or ",
 ButtonBox["phpMyAdmin",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.phpmyadmin.net"], None},
  ButtonNote->"https://www.phpmyadmin.net"],
 " (also available as a Docker image)"
}], "Item",
 CellChangeTimes->{{3.981731661580049*^9, 3.9817318004749317`*^9}, {
  3.9817323316269197`*^9, 3.981732331627658*^9}, {3.981733193691249*^9, 
  3.9817332153837*^9}},ExpressionUUID->"8180970b-09e8-4f6f-af0b-f36540bcccc6"],

