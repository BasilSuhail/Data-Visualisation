 CellChangeTimes->{{3.981701255616741*^9, 3.981701256600363*^9}, {
  3.981701298319601*^9, 3.981701298319626*^9}},
 TextAlignment->Right,ExpressionUUID->"0d29302b-b3b0-4f33-9e9b-019d071cac08"],

Cell[TextData[{
 "Docker is piece of software that allows running \"",
 ButtonBox["containers",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Containerization_(computing)"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Containerization_(computing)"],
 "\" which share some system resources but otherwise act as completely \
separate computers within the host computer"
}], "Item",
 CellChangeTimes->{{3.981696918264783*^9, 3.981696945804961*^9}, {
  3.981696999163136*^9, 3.9816969991636133`*^9}, {3.981697058684968*^9, 
  3.981697058806991*^9}, {3.981697417717299*^9, 
  3.98169745986697*^9}},ExpressionUUID->"26c2f4c3-9262-44df-a8ed-\
8782aaa73cf6"],

Cell[TextData[{
 "There are many prebuilt \"",
 ButtonBox["images",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://docs.docker.com/get-started/docker-concepts/the-basics/what-\
is-an-image/"], None},
  ButtonNote->
   "https://docs.docker.com/get-started/docker-concepts/the-basics/what-is-an-\
image/"],
 "\" or templates for running software packages on a wide variety of systems \
with minimal setup"
}], "Item",
 CellChangeTimes->{{3.981696918264783*^9, 3.981696945804961*^9}, {
  3.981696999163136*^9, 3.9816969991636133`*^9}, {3.981697058684968*^9, 
  3.981697058806991*^9}, {3.981697417717299*^9, 3.981697457154985*^9}, {
  3.981697549311905*^9, 3.98169755661757*^9}, {3.981697681006583*^9, 
  3.9816976878861732`*^9}, {3.9816977946073914`*^9, 3.981697820007575*^9}, {
  3.981697860232067*^9, 
  3.9816978730294228`*^9}},ExpressionUUID->"e97bb5ae-9d1c-43d3-ac00-\
ac5d27685c8d"],

Cell[TextData[{
 "The containers can then be assigned \"",
 ButtonBox["ports",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Port_(computer_networking)"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Port_(computer_networking)"],
 "\" and \"",
 ButtonBox["volumes",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://docs.docker.com/engine/storage/volumes/"], None},
  ButtonNote->"https://docs.docker.com/engine/storage/volumes/"],
 "\" to allow you to connect to it as well as save the state of the \
container"
}], "Item",
 CellChangeTimes->{{3.981696918264783*^9, 3.981696945804961*^9}, {
  3.981696999163136*^9, 3.9816969991636133`*^9}, {3.981697058684968*^9, 
  3.981697058806991*^9}, {3.981697417717299*^9, 3.981697457154985*^9}, {
  3.981697549311905*^9, 3.98169755661757*^9}, {3.981697681006583*^9, 
  3.9816976878861732`*^9}, {3.9816977946073914`*^9, 3.981697820007575*^9}, {
  3.981697860232067*^9, 3.981697892037385*^9}, {3.981697968169952*^9, 
  3.9816979681705847`*^9}, {3.981698021108062*^9, 
  3.98169805519772*^9}},ExpressionUUID->"2104d9c4-afda-4db9-8042-\
bfc5f863fb8e"]
}, Open  ]]
}, Open  ]],

