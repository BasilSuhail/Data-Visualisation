   {Cell[TextData[{
     "\[LineSeparator]\[LineSeparator]3. Start the container with ",
     StyleBox["Optional Settings",
      FontSlant->"Italic"],
     ":\[LineSeparator]",
     StyleBox["Port:",
      FontWeight->"Bold"],
     " ",
     StyleBox["3306",
      FontWeight->"Bold"],
     "       ",
     StyleBox["(default MySQL port)",
      FontSize->14],
     "\n",
     StyleBox["Volume:",
      FontWeight->"Bold"],
     " ",
     StyleBox["/var/lib/mysql",
      FontWeight->"Bold"],
     "\[LineSeparator]",
     StyleBox["(pick a folder on your computer in Host Path)\n",
      FontSize->14],
     StyleBox["Variable: MYSQL_ROOT_PASSWORD\[LineSeparator]",
      FontWeight->"Bold"],
     StyleBox["(whatever you would like)",
      FontSize->14,
      FontWeight->"Plain"]
    }], "Item",
     LineSpacing->{1, 3},ExpressionUUID->
