Cell["Are these lengths correlated or anti - correlated?", "Text",
 CellChangeTimes->{{3.842968433969178*^9, 
  3.842968464419351*^9}},ExpressionUUID->"8dffe06b-99c8-44a7-b086-\
72463ccab036"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Correlation", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"assocDS", "[", 
      RowBox[{"All", ",", "\"\<Time\>\""}], "]"}], "//", "Normal"}], ",", 
    RowBox[{
     RowBox[{"assocDS", "[", 
      RowBox[{"All", ",", "\"\<AcuteT\>\""}], "]"}], "//", "Normal"}]}], 
   "]"}], "//", "N"}]], "Input",
