Cell["Depression : Medicine for treatment", "Title",
 CellChangeTimes->{{3.812755275622931*^9, 
  3.812755283002355*^9}},ExpressionUUID->"397da39a-d71d-4ccf-8b2e-\
4a613c935eb0"],

Cell[CellGroupData[{

Cell["depression", "Section",ExpressionUUID->"127843cf-6d3f-4ccc-963e-0e3c2c398756"],

Cell["\<\
Depression affects 6% of adults each year and is the leading cause of \
suicide. The exact cause of depression is unknown.\
\>", "Text",ExpressionUUID->"f9389277-5807-478c-a2dc-4b665bf1815e"],

Cell["Symptoms can be disabling and its effects pervasive", "Item",ExpressionUUID->"99c09647-6db8-4188-9382-79b6e8580982"],

Cell["\<\
People with depression have a consistently low mood and other symptoms severe \
enough to interfere with normal day-to-day activities. \
\>", "SideNote",ExpressionUUID->"d3a7c8ef-94de-44a5-a2de-f212609f7592"],

Cell["It can become chronic if treated inadequately ", "Item",ExpressionUUID->"4432158b-5eb9-4cd4-9487-e1b1d446253e"],

Cell["Current medications: Lithium and Imipramine", "Item",ExpressionUUID->"9488019a-047e-4bbf-b73c-eaccbf1dd333"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"8784b9f2-c8c1-4500-862e-94b7a568250d"],

