Cell[TextData[{
 "SHAP (SHapley Additive exPlanations): ",
 ButtonBox["LInk",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://christophm.github.io/interpretable-ml-book/shap.html"], None},
  ButtonNote->"https://christophm.github.io/interpretable-ml-book/shap.html"]
}], "Section",
