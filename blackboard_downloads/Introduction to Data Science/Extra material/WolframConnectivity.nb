Cell["In SPARQLExecute[url, query] : ", "Text",
 CellChangeTimes->{{3.7752125150193872`*^9, 
  3.7752125345777617`*^9}},ExpressionUUID->"13b25e3a-5276-444b-b3e3-\
9cbf849d998f"],

Cell[CellGroupData[{

Cell["\<\
query can be a symbolic SPARQL query, or update request, or a string.\
\>", "Item",
 CellChangeTimes->{{3.7752125150193872`*^9, 
  3.775212554685183*^9}},ExpressionUUID->"5516266c-e323-499a-ab0d-\
7bda3ac354e3"],

Cell["\<\
Possible symbolic query forms include SPARQLSelect, SPARQLAsk and \
SPARQLConstruct.\
\>", "Item",
 CellChangeTimes->{{3.7752125150193872`*^9, 
  3.775212540805601*^9}},ExpressionUUID->"b2e86d93-b7f2-406d-b914-\
7709ed4b5b90"]
}, Open  ]],

Cell["A basic SPARQL query ", "Text",
 CellChangeTimes->{
  3.775212772272078*^9, {3.775212962886774*^9, 
   3.7752129904544153`*^9}},ExpressionUUID->"a19fc9bb-c0a7-4935-9842-\
b43235936cd1"],

Cell[CellGroupData[{

Cell["starts with a query form: SELECT in this case.", "Item",
 CellChangeTimes->{
  3.775212772272078*^9, {3.775212962886774*^9, 
   3.775213008962882*^9}},ExpressionUUID->"dd898a18-a31d-4aca-9da0-\
92aef2ac3024"],

Cell["\<\
then lists the variables that you are interested in: *stands for all variables\
\>", "Item",
 CellChangeTimes->{
  3.775212772272078*^9, {3.775212962886774*^9, 
   3.775213017531777*^9}},ExpressionUUID->"48b81966-92c0-409b-9ea6-\
dbbfb2a40f63"],

Cell["\<\
followed by a graph pattern: the WHERE clause.
 \
\>", "Item",
 CellChangeTimes->{
  3.775212772272078*^9, {3.775212962886774*^9, 
   3.775213043468514*^9}},ExpressionUUID->"363acdd5-f1d8-4892-9ce2-\
3206f28ed613"]
}, Open  ]],

Cell[TextData[{
 "The ",
 StyleBox["graph pattern",
  FontWeight->"Bold"],
 " is a triple pattern in the form of : subject predicate object"
}], "Text",
 CellChangeTimes->{{3.775213058036031*^9, 
  3.77521310544044*^9}},ExpressionUUID->"592663ba-eddc-446b-8198-\
9ca936581810"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["subject",
  FontWeight->"Bold"],
 " in above example is IRI (wd:Q765883) that identifies the song \
\[OpenCurlyDoubleQuote]La cumparsita\[CloseCurlyDoubleQuote]."
}], "Item",
 CellChangeTimes->{{3.775213107951172*^9, 3.7752131397301397`*^9}, {
  3.775213170484508*^9, 3.775213246153336*^9}, {3.775213291714732*^9, 
  3.7752133048617897`*^9}},ExpressionUUID->"2a0bf2b1-566e-427b-abc1-\
67cded0d554b"],

Cell[TextData[{
 StyleBox["predicate,",
  FontWeight->"Bold"],
 " the IRI for the property \[OpenCurlyDoubleQuote]composer\
\[CloseCurlyDoubleQuote] (wdt:P86)."
}], "Item",
 CellChangeTimes->{{3.775213107951172*^9, 3.7752131397301397`*^9}, {
  3.775213170484508*^9, 3.775213258700202*^9}, {3.775213293377882*^9, 
  3.7752133073108892`*^9}},ExpressionUUID->"6ac9660d-3c1e-45a7-8435-\
00edce688dcf"],

Cell[TextData[{
 StyleBox["object",
  FontWeight->"Bold"],
 ", is a variable that starts with ?\n"
}], "Item",
 CellChangeTimes->{{3.775213107951172*^9, 3.7752131397301397`*^9}, {
  3.775213170484508*^9, 3.775213258700202*^9}, {3.775213293377882*^9, 
  3.77521332744697*^9}},ExpressionUUID->"c5a37f5e-f03f-41d0-99d4-\
8ebb50a665e7"]
}, Open  ]],

Cell["Wikipedia vocabulary: ", "Text",
 CellChangeTimes->{{3.775213486791428*^9, 3.7752134950501957`*^9}, {
  3.7752136347307158`*^9, 3.77521364542667*^9}, {3.775213938622622*^9, 
  3.7752139445774717`*^9}},ExpressionUUID->"d73b39c5-0dc0-4ae9-8ee5-\
1fa8f59d2d1f"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"wd", "[", "s_", "]"}], ":=", 
     RowBox[{"IRI", "[", 
      RowBox[{
      "\"\<http://www.wikidata.org/entity/\>\"", " ", "<>", " ", "s"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"wdt", "[", "s_", "]"}], ":=", 
     RowBox[{"IRI", "[", 
      RowBox[{"\"\<http://www.wikidata.org/prop/direct/\>\"", "<>", "s"}], 
      "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.77521365044377*^9, 3.775213650779148*^9}, {
  3.775213682877317*^9, 3.775213738053301*^9}},
 CellLabel->
  "In[687]:=",ExpressionUUID->"e687fcb3-3ad2-44cc-8f4a-8c62b32bca7d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"query2", "=", 
  RowBox[{"SPARQLSelect", "[", 
   RowBox[{"RDFTriple", "[", 
    RowBox[{
     RowBox[{"wd", "[", "\"\<Q765883\>\"", "]"}], ",", 
     RowBox[{"wdt", "[", "\"\<P86\>\"", "]"}], ",", 
     RowBox[{"SPARQLVariable", "[", "\"\<composer\>\"", "]"}]}], "]"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.7752122785032167`*^9, 3.775212281350878*^9}, {
   3.775213344625065*^9, 3.775213346569713*^9}, {3.775213407415907*^9, 
   3.775213419246168*^9}, 3.775213781165764*^9, {3.7752138113877563`*^9, 
   3.775213866162458*^9}, 3.775213913125341*^9},
 CellLabel->
  "In[689]:=",ExpressionUUID->"ced6ce29-4596-4f67-8874-090870026a88"],

Cell[BoxData[
 RowBox[{"SPARQLSelect", "[", 
  RowBox[{"RDFTriple", "[", 
   RowBox[{
    RowBox[{"IRI", "[", 
     TemplateBox[{"\"http://www.wikidata.org/entity/Q765883\""},
      "URLArgument"], "]"}], ",", 
    RowBox[{"IRI", "[", 
     TemplateBox[{"\"http://www.wikidata.org/prop/direct/P86\""},
      "URLArgument"], "]"}], ",", 
    RowBox[{"SPARQLVariable", "[", "\<\"composer\"\>", "]"}]}], "]"}], 
  "]"}]], "Output",
 CellChangeTimes->{{3.775213913774912*^9, 3.775213928530697*^9}, 
   3.780115333160454*^9},
 CellLabel->
  "Out[689]=",ExpressionUUID->"87260745-b6d5-44ec-aa89-4599fe158750"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SPARQLExecute", "[", 
  RowBox[{"endpoint", ",", "query2"}], "]"}]], "Input",
 CellChangeTimes->{{3.7752133952067833`*^9, 3.7752133952160807`*^9}, {
  3.775213875937788*^9, 3.7752138955397863`*^9}},
 CellLabel->
  "In[690]:=",ExpressionUUID->"2a2c1689-03b1-4576-a012-a350d0f6c17c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[LeftAssociation]", 
   RowBox[{"\<\"composer\"\>", "\[Rule]", 
    RowBox[{"IRI", "[", 
     TemplateBox[{"\"http://www.wikidata.org/entity/Q937502\""},
      "URLArgument"], "]"}]}], "\[RightAssociation]"}], "}"}]], "Output",
 CellChangeTimes->{{3.7752138964669724`*^9, 3.775213931888176*^9}, 
   3.780115343243465*^9},
 CellLabel->
  "Out[690]=",ExpressionUUID->"9d7b227d-0c22-42cd-982c-9b612368f808"]
}, Open  ]],

Cell[BoxData[
 RowBox[{"You", " ", "can", " ", "now", " ", "understand", " ", "more", " ", 
  "complicated", " ", "queries", " ", "as", " ", "shown", " ", 
  SubscriptBox["in", 
   SubscriptBox["\[Placeholder]", "\[Placeholder]"]], 
  "\"\<\!\(\*ButtonBox[RowBox[{RowBox[{RowBox[{\"Let\", \"'\"}], \" \", \
\"s\", \" \", RowBox[{\"Tango\", \" \", \":\", \" \", RowBox[{\"Computational\
\", \" \", \"Musicology\", \" \", \"Using\", \" \", \"Wikidata\"}]}]}], \
\",\", \" \", RowBox[{\"MusicBrainz\", \" \", \"and\", \" \", \"the\", \" \", \
\"Wolfram\", \" \", \"Language\"}]}],BaseStyle->\"Hyperlink\",ButtonData->{
URL[\"https://blog.wolfram.com/2019/02/14/lets-tango-computational-musicology-\
using-wikidata-musicbrainz-and-the-wolfram-language/\"], \
None},ButtonNote->\"https://blog.wolfram.com/2019/02/14/lets-tango-\
computational-musicology-using-wikidata-musicbrainz-and-the-wolfram-language/\
\"]\)\>\""}]], "Text",
 CellChangeTimes->{{3.77521410433104*^9, 3.775214120646556*^9}, {
  3.775214155782187*^9, 3.775214169454873*^9}},
 FontSize->24,ExpressionUUID->"bcec1f26-0f64-41c6-8844-840d41c67b18"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  StyleBox[
   RowBox[{"Also", ",", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"consider", " ", "watching", " ", "the", " ", 
       ButtonBox["video",
        BaseStyle->"Hyperlink",
