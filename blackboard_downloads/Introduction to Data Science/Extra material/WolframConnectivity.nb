 CellChangeTimes->{{3.780141439455368*^9, 
  3.780141516492758*^9}},ExpressionUUID->"87977881-08a4-43ea-beea-\
06600778762d"],

Cell[CellGroupData[{

Cell["\<\
API : [Wikipedia] : In computer programming, an application programming \
interface (API) is a set of subroutine definitions, protocols, and tools for \
building software and applications.\
\>", "Item",
 CellChangeTimes->{{3.780141687086029*^9, 
  3.7801417118412237`*^9}},ExpressionUUID->"4706f420-ba36-4362-ac48-\
504f5391eae1"],

Cell["\<\
API is some kind of interface which has a set of functions that allow \
programmers to access specific features or data of an application, operating \
system or other services.\
\>", "Item",
 CellChangeTimes->{{3.780141687086029*^9, 
  3.780141753713458*^9}},ExpressionUUID->"eb649ed6-5b43-46a0-bf3d-\
dafee7755c41"],

Cell["\<\
Web API as the name suggests, is an API over the web which can be accessed \
using HTTP protocol.\
\>", "Item",
 CellChangeTimes->{{3.780141687086029*^9, 
  3.780141754029735*^9}},ExpressionUUID->"4eaf3f5b-1b86-4588-a5f1-\
e059bab3d82f"]
}, Open  ]],

