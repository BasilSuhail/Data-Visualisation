 CellTags->
  "SlideShowHeader",ExpressionUUID->"6343979b-da8a-4864-aa24-9b67d484ebd3"],

Cell["Query the Wikidata SPARQL endpoint (a web API)", "Title",
 CellChangeTimes->{{3.775211621798544*^9, 3.775211628926865*^9}, {
  3.775211664340407*^9, 3.775211666201823*^9}, {3.775211748186763*^9, 
  3.775211756922282*^9}, {3.7800774637050867`*^9, 
  3.780077467101104*^9}},ExpressionUUID->"03b76aec-65d3-46ec-ab40-\
4d3185536294"],

Cell["\<\
Load GraphStore : The GraphStore package provides capabilities for \
representing, querying and updating RDF graphs and datasets.\
\>", "Text",
 CellChangeTimes->{{3.775211794097663*^9, 
  3.775211804551661*^9}},ExpressionUUID->"87460fa5-9d48-4721-8e97-\
47b6f56534dd"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<GraphStore`\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.77521166822362*^9, 3.7752116682273684`*^9}},
 CellLabel->"In[87]:=",ExpressionUUID->"b6b9b2ab-9383-4c57-b0e1-7663ed148489"],

Cell[TextData[{
 "\n",
 StyleBox["Endpoints",
  FontWeight->"Bold"],
 " [wikipedia]:\n\n",
 StyleBox["Endpoints",
  FontWeight->"Bold"],
 " are important aspects of interacting with server - side web APIs, as they \
specify where resources lie that can be accessed by third party software. \
Usually the access is via a URI to which HTTP requests are posted, and from \
which the response is thus expected.\n"
}], "Text",
 CellChangeTimes->{{3.780076977208864*^9, 3.780077004312069*^9}, 
   3.780077475370472*^9, 
   3.780078134273942*^9},ExpressionUUID->"15704d2e-cd5b-4634-95a7-\
4254c2f6b27c"],

Cell["Specify the endpoint", "Text",
 CellChangeTimes->{{3.775211824009301*^9, 
  3.77521185398702*^9}},ExpressionUUID->"4f364677-afaa-4b7c-9352-\
1e72e265b958"],

Cell[BoxData[
 RowBox[{
  RowBox[{"endpoint", "=", "\"\<https://query.wikidata.org/sparql\>\""}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.775211846378111*^9, 3.775211846382647*^9}},
 CellLabel->
  "In[681]:=",ExpressionUUID->"a680a9b7-aaee-478c-919b-d9aad5e176b3"],

