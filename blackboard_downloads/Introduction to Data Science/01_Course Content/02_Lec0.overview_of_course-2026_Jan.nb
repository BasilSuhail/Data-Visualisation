Cell[TextData[{
 StyleBox["Chapter 3",
  FontWeight->"Bold"],
 " is a complementary reference for our ",
 StyleBox["Lecture 8",
  FontWeight->"Bold"],
 ", on techniques for data science."
}], "Subitem",
 CellChangeTimes->{{3.811578994949765*^9, 
  3.8115790219195547`*^9}},ExpressionUUID->"5008f80a-ccd9-446a-96aa-\
6e2dd649bc4f"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Section 5.6",
  FontWeight->"Bold"],
 " of Chapter 5 and ",
 StyleBox["Sec. 9.2",
  FontWeight->"Bold"],
 " are a reference for our ",
 StyleBox["Lecture 9",
  FontWeight->"Bold"],
 " about machine learning. "
}], "Subitem",
 CellChangeTimes->{{3.811576065424609*^9, 3.811576087676814*^9}, {
   3.811576270387297*^9, 3.811576451214027*^9}, {3.811576517145719*^9, 
   3.811576517147863*^9}, {3.811576608189933*^9, 3.8115766520861893`*^9}, {
   3.811576726322089*^9, 3.8115767491535378`*^9}, 3.811577011445827*^9, {
   3.811577383885388*^9, 3.811577424626296*^9}, {3.8115775425846047`*^9, 
   3.8115775425849133`*^9}, {3.8115783849227123`*^9, 3.811578387682561*^9}, {
   3.811578419609338*^9, 3.811578494119031*^9}, {3.81157868726619*^9, 
   3.81157869698929*^9}},ExpressionUUID->"608ce5e1-8349-48c6-bad8-\
af562334ffbb"],

Cell["\<\
Chapters 4, 5, 6 introduce UNIX, Python and R.  These topics are not part of \
this course. However, it introduces how UNIX can be used to do simple data \
science projects, and also introduces these languages and how they can be \
used to data science. \
\>", "Subsubitem",
 CellChangeTimes->{{3.811576065424609*^9, 3.811576087676814*^9}, {
   3.811576270387297*^9, 3.811576451214027*^9}, {3.811576517145719*^9, 
   3.811576517147863*^9}, {3.811576608189933*^9, 3.8115766520861893`*^9}, {
   3.811576726322089*^9, 3.8115767491535378`*^9}, 3.811577011445827*^9, {
   3.811577383885388*^9, 3.811577424626296*^9}, {3.8115775425846047`*^9, 
   3.8115775425849133`*^9}, {3.8115783849227123`*^9, 3.811578387682561*^9}, {
   3.811578419609338*^9, 3.811578474922984*^9}, {3.811578539828569*^9, 
   3.81157863374218*^9}, {3.811924202893714*^9, 3.811924205444262*^9}, {
   3.822282224317423*^9, 
   3.82228222543829*^9}},ExpressionUUID->"f34d4031-1a7a-4c7f-98f9-\
4d358a6fec65"]
}, Open  ]],

Cell[TextData[{
 StyleBox["Chapter 7",
  FontWeight->"Bold"],
 " provides a complementary reference for our ",
 StyleBox["Lecture 10",
  FontWeight->"Bold"],
 ", on MySQL."
}], "Subitem",
 CellChangeTimes->{{3.811576065424609*^9, 3.811576087676814*^9}, {
   3.811576270387297*^9, 3.811576451214027*^9}, {3.811576517145719*^9, 
   3.811576517147863*^9}, {3.811576608189933*^9, 3.8115766520861893`*^9}, {
   3.811576726322089*^9, 3.8115767491535378`*^9}, 3.811577011445827*^9, {
   3.811577383885388*^9, 3.811577424626296*^9}, {3.81157754353373*^9, 
   3.811577558391028*^9}, {3.811578648342595*^9, 
   3.811578652254382*^9}},ExpressionUUID->"8ae42fbd-94a6-4b92-a505-\
2ede5c3f83ba"],

Cell["\<\
It provides plenty of material (e.g. datasets) and ideas (about hands on \
exercises and problems) for us to develop relevant hands-on activities. The \
hands on approach provides me and you with a better idea of how to use tools \
for which problem.  We will incorporate these proposed hands on activity \
through out our course. \
\>", "Subitem",
 CellChangeTimes->{{3.811576065424609*^9, 3.811576087676814*^9}, {
  3.811576270387297*^9, 3.811576451214027*^9}, {3.811576518021286*^9, 
  3.811576551175238*^9}, {3.811576669929658*^9, 3.811576683687489*^9}, {
  3.8115767661291313`*^9, 3.811576770690754*^9}, {3.8115768779532*^9, 
  3.811576924559794*^9}, {3.811577134904152*^9, 3.811577157885543*^9}, {
  3.811577204605967*^9, 3.811577258362121*^9}, {3.811577468880563*^9, 
  3.811577471441435*^9}, {3.811578775743145*^9, 3.811578781810053*^9}, {
  3.811578834330714*^9, 
  3.811578846321116*^9}},ExpressionUUID->"30b14b42-5e59-44b9-9f15-\
b6f0afa86222"],

Cell[TextData[{
 "The ",
 StyleBox["final chapters",
  FontWeight->"Bold"],
 " provide examples using social media data, introducing the use of \
Application Programming Interface (API) and a chapter on data collection and \
experimentation. There are several appendices, including one on ethics, \
useful for a data scientist.  We will mention the use of API in this course. \
"
}], "Subitem",
 CellChangeTimes->{{3.811576065424609*^9, 3.811576087676814*^9}, {
   3.811576270387297*^9, 3.811576451214027*^9}, {3.811576518021286*^9, 
   3.811576551175238*^9}, {3.811576669929658*^9, 3.811576683687489*^9}, {
   3.8115767661291313`*^9, 3.811576770690754*^9}, {3.8115768779532*^9, 
   3.811576924559794*^9}, {3.811577134904152*^9, 3.811577158489747*^9}, {
   3.811577265329757*^9, 3.8115773399369307`*^9}, {3.811578791560749*^9, 
   3.8115788167445107`*^9}, {3.822282260286355*^9, 3.822282288233675*^9}, {
   3.883136169173958*^9, 3.883136169757923*^9}, 
   3.977221666494129*^9},ExpressionUUID->"c1fa2db6-49e5-41cf-b3e6-\
f5cbe4a9eeeb"]
}, Open  ]]
}, Open  ]],

