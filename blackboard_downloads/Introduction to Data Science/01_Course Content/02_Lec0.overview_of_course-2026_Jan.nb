Cell[TextData[{
 StyleBox["Lecture 9",
  FontWeight->"Bold"],
 ": A brief introduction to machine learning, supervised (e.g. clustering) \
and unsupervised (e.g. classification, regression) learning approaches. "
}], "Subitem",
