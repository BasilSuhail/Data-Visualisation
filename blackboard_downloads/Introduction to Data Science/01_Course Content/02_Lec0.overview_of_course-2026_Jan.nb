 FontFamily->"Source Sans Pro",
 FontSize->12,
 FontWeight->"Regular",ExpressionUUID->"d3f029ed-1d9e-4b8a-b659-15fab3ae7e39"],

Cell["Lecture 4: The Wolfram data structure", "Item",
 CellChangeTimes->{{3.90540880817388*^9, 3.905408810998073*^9}, {
  3.9054088899378777`*^9, 3.9054089080420637`*^9}, {3.9054089521207027`*^9, 
  3.9054089533589363`*^9}},
 FontFamily->"Source Sans Pro",
 FontSize->12,
 FontWeight->"Regular",ExpressionUUID->"4ba1306e-57fa-41c5-9344-522cf62313fa"],

Cell["Lecture 5 : time-series, image, audio, and video", "Item",
 CellChangeTimes->{{3.90540880817388*^9, 3.905408810998073*^9}, {
   3.9054088899378777`*^9, 3.9054089080420637`*^9}, 3.9054089521207027`*^9, {
   3.9054089856627603`*^9, 3.905408986882066*^9}},
 FontFamily->"Source Sans Pro",
 FontSize->12,
 FontWeight->"Regular",ExpressionUUID->"41455b28-5aec-466d-92ae-3622459320a6"],

Cell["\<\
Lecture 6: Data Collection,  some basic preprocessing (querying and \
cleaning), storage (exporting).\
\>", "Item",
 CellChangeTimes->{{3.90540880817388*^9, 3.905408810998073*^9}, {
   3.9054088899378777`*^9, 3.9054089080420637`*^9}, 3.9054089521207027`*^9, {
