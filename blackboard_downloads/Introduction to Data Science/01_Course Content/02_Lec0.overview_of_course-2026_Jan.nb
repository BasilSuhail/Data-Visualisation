Cell[TextData[{
 StyleBox["Extra comment on hands-on tutorials", "Section"],
 ": Lectures 5 and 8 have no tutorials, since these topics will be dealt with \
great details in further courses of this degree. Lecture 7 brings tools from \
the Wolfram language to pre-process data, but complementary hands-on material \
for pre-processing is also presented during the lectures 3, 5, and 6. "
}], "Text",
 CellChangeTimes->{{3.811604881109562*^9, 3.811605086825642*^9}, {
