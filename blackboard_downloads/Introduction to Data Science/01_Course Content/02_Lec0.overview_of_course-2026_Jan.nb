Cell[CellGroupData[{

Cell["The course is organized in 11 lecturers :", "Subsubsection",
 CellChangeTimes->{{3.905408830018973*^9, 3.90540883632644*^9}},
 FontFamily->"Source Sans Pro",
 FontSize->12,
 FontWeight->"Regular",ExpressionUUID->"69b7a701-cb55-4ca3-ad1d-610ae83096fc"],

Cell[TextData[StyleBox["Lecture 1 Introduction to data science",
 FontSize->14]], "Item",
 CellChangeTimes->{{3.90540880817388*^9, 3.905408810998073*^9}, {
  3.9054088899378777`*^9, 3.905408935147004*^9}},
 FontFamily->"Source Sans Pro",
 FontSize->12,
 FontWeight->"Regular",ExpressionUUID->"f3b71b98-cd4c-48c9-964c-c8958dfcd922"],

Cell["\<\
Lecture 2: Conceptual introduction to data types (structured or unstructured) \
and  databases (relational, non-relational, time-series)\
\>", "Item",
 CellChangeTimes->{{3.90540880817388*^9, 3.905408810998073*^9}, {
  3.9054088899378777`*^9, 3.905408933966432*^9}},
