 FontSize->12,
 FontWeight->"Regular",ExpressionUUID->"f32c37a0-9af6-4c06-b579-2622e1a0b777"],

Cell["\<\
Lecture 3 : A conceptual introduction to data pre - processing.\
\>", "Item",
 CellChangeTimes->{{3.90540880817388*^9, 3.905408810998073*^9}, {
  3.9054088899378777`*^9, 3.9054089080420637`*^9}, {3.905408941107636*^9, 
