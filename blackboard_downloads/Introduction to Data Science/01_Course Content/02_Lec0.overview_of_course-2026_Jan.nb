Cell[TextData[{
 StyleBox["Lecture 8",
  FontWeight->"Bold"],
 ": Techniques for data science. Data analysis, data analytics, descriptive \
analysis (descriptive and dispersion statistics), diagnostic analysis \
(correlation, network inference), evaluating your model (the ROC curve)."
}], "Subitem",
