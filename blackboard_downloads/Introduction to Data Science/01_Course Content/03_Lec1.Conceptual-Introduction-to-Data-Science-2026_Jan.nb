Cell[TextData[{
 StyleBox["Science [Oxford dictionary] ",
  FontWeight->"Bold"],
 ": systematic study of the structure and behaviour of the physical and \
natural world through observation and experiment.   "
}], "Text",
 CellChangeTimes->{{3.8066597252963653`*^9, 
  3.806659792593112*^9}},ExpressionUUID->"9952cef1-79e6-4a51-bd5e-\
3ad5ba89e9be"],

Cell[TextData[{
 StyleBox["Thinking as a scientist",
  FontWeight->"Bold"],
 " : understanding the scientific method can help you much to design your \
data science project.  "
}], "Text",
 CellChangeTimes->{{3.806655693252913*^9, 
  3.8066557423380337`*^9}},ExpressionUUID->"54b5e663-8bab-479f-953d-\
0279bec3e255"],

Cell[TextData[{
 StyleBox["Recognize a problem, by doing observations: ",
  FontWeight->"Bold"],
 " Where is the Earth in the Universe (in the centre or revolving around the \
Sun)?"
}], "Item",
 CellChangeTimes->{
  3.774331498150041*^9, {3.7743316675015507`*^9, 3.774331686574356*^9}, {
   3.774331958452651*^9, 3.7743319624163227`*^9}, {3.7743320141598063`*^9, 
   3.774332089160074*^9}},ExpressionUUID->"3fc7c1b4-23f3-4c9f-a103-\
0fe1dc9d5ac4"],

Cell[CellGroupData[{

Cell[TextData[{
