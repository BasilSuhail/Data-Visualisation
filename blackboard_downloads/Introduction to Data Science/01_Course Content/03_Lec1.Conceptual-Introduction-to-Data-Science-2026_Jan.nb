Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Willing to experiment",
  FontWeight->"Bold"],
 ": Data scientist needs to have the drive, intuition, and curiosity not only \
to solve problems as they are presented, but also to identify and articulate \
problems of their own. "
}], "Item",
 CellChangeTimes->{{3.806652332942682*^9, 3.80665234202794*^9}, {
  3.806738944735862*^9, 
  3.8067390039770813`*^9}},ExpressionUUID->"971ccd8e-5df7-4b7c-b115-\
656dad1f51df"],

Cell[CellGroupData[{

Cell["\<\
employers are seeking applicants who can answer questions to define \
intelligent hypothesis and to explore the data utilizing basic statistical \
methods and models: \[OpenCurlyDoubleQuote]How many golf balls would fit in a \
school bus?\[CloseCurlyDoubleQuote], \[OpenCurlyDoubleQuote]How many candies \
fit in a jar glass\[CloseCurlyDoubleQuote]? To solve this you need to : \
\>", "Subitem",
 CellChangeTimes->{{3.806652332942682*^9, 3.80665234202794*^9}, {
   3.806738944735862*^9, 3.806739008357172*^9}, {3.806739056625032*^9, 
   3.8067391221756067`*^9}, 3.811920765681147*^9, {3.812104740229266*^9, 
   3.812104754278935*^9}, {3.916740598551515*^9, 3.9167406096432037`*^9}, {
   3.9167443256971617`*^9, 3.916744361151976*^9}, {3.946120283923628*^9, 
   3.946120285377915*^9}},ExpressionUUID->"b0849695-1107-4a30-b4e8-\
f172314d4781"],

Cell["\<\
do an experiment: estimate the volume of candies you can see, and the volume \
of the glass\
\>", "Subsubitem",
 CellChangeTimes->{{3.806652332942682*^9, 3.80665234202794*^9}, {
   3.806738944735862*^9, 3.806739008357172*^9}, {3.806739056625032*^9, 
