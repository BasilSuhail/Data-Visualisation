Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"5c86cff3-b030-4205-88db-f20c9286147c"],

Cell["\<\
To reduce an array or aggregate it to calculate Mean, Total, \
StandardDeviation along specific dimensions of an array:\
\>", "Text",
 CellChangeTimes->{{3.822286226960987*^9, 3.822286237792192*^9}, {
  3.822286290000383*^9, 3.822286374028479*^9}, {3.843025118247654*^9, 
  3.8430251307511597`*^9}, {3.843025180703489*^9, 
  3.843025231761778*^9}},ExpressionUUID->"5d40cbaf-079a-440b-b4c7-\
9da3c5277f73"],

Cell["\<\
1 indicates reduction is done on the rows - each column produces an average.\
\>", "Item",
 CellChangeTimes->{{3.822286226960987*^9, 3.822286237792192*^9}, {
  3.822286290000383*^9, 3.822286374028479*^9}, {3.843025118247654*^9, 
  3.8430251307511597`*^9}, {3.843025180703489*^9, 
  3.84302525291537*^9}},ExpressionUUID->"ae5e7c7b-9b26-40af-a63d-\
000e09b62812"],

Cell["\<\
2 reduction is done on the columns - each row produces an average, for \
example when each column has information about a variable in different \
dates/times and one wants a year average.\
\>", "Item",
 CellChangeTimes->{{3.822286226960987*^9, 3.822286237792192*^9}, {
  3.822286290000383*^9, 3.822286374028479*^9}, {3.843025118247654*^9, 
  3.8430251307511597`*^9}, {3.843025180703489*^9, 
  3.843025333627964*^9}},ExpressionUUID->"a531fb72-5dde-4a17-b004-\
9b56628b497e"],

Cell["\<\
So, let us \"reduce\" the rows, calculating the mean values for height and \
weight\
\>", "Text",
 CellChangeTimes->{{3.8430252886632833`*^9, 3.843025290169949*^9}, 
   3.9162436575395737`*^9},ExpressionUUID->"8fa003ff-f637-4fce-9ed0-\
da27175ea47d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ArrayReduce", "[", 
  RowBox[{"Mean", ",", "points", ",", "1"}], "]"}]], "Input",
 CellChangeTimes->{{3.822286147902703*^9, 3.822286207500985*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"5a5ec44f-25b9-4999-be3c-fcdf9e63a7cf"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"65", ",", 
   FractionBox["2051", "15"]}], "}"}]], "Output",
 CellChangeTimes->{3.822286209148888*^9, 3.946121654644558*^9, 
  3.977293393422229*^9},
 CellLabel->"Out[24]=",ExpressionUUID->"c8109db4-e451-4fd2-91c6-31b01cd191a8"]
}, Open  ]],

