Cell[CellGroupData[{

Cell["Data Science", "Section",
 CellChangeTimes->{{3.806392043367118*^9, 3.806392049554367*^9}, {
  3.8063920878748503`*^9, 3.806392087875222*^9}, {3.811917854932248*^9, 
  3.811917857322485*^9}},ExpressionUUID->"3dcf7450-4f62-4f3c-a156-\
0480d27807fb"],

Cell["\<\
It is a multidisciplinary evolving and dynamic field, with several incipient \
definitions.\
\>", "Item",
 CellChangeTimes->{{3.806651758611839*^9, 3.806651763580714*^9}, 
   3.811916794517877*^9, {3.811916891745208*^9, 3.811916902395753*^9}, {
   3.811916932511936*^9, 3.811916974929475*^9}, {3.905238026529829*^9, 
   3.905238042255374*^9}},ExpressionUUID->"91d19c78-3764-4ad0-984a-\
0cb401e3eb4e"],

Cell[TextData[{
 "[",
 ButtonBox["Wikipedia",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Data_science"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Data_science"],
 "] Interdisciplinary field about processes and systems to extract knowledge \
or insights from data in various forms, either structured or unstructured."
}], "Item",
 CellChangeTimes->{{3.806651758611839*^9, 3.806651763580714*^9}, 
   3.811916794517877*^9, {3.811916891745208*^9, 3.811916902395753*^9}, {
   3.811916932511936*^9, 3.811916985378187*^9}, {3.8119170322357388`*^9, 
   3.8119170322358923`*^9}, {3.811917084050971*^9, 
   3.811917084057398*^9}},ExpressionUUID->"cab417a9-5893-445a-9647-\
363ab42ed649"],

Cell[TextData[{
 "[",
 ButtonBox["Hayashi, Chikio, 1998",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.springer.com/book/9784431702085"], None},
  ButtonNote->"https://www.springer.com/book/9784431702085"],
 "]  Data science is a \[OpenCurlyDoubleQuote]concept to unify statistics, \
data analysis and their related methods\[CloseCurlyDoubleQuote] in order to \
\[OpenCurlyDoubleQuote]understand and analyze actual phenomena\
\[CloseCurlyDoubleQuote] with data."
}], "Item",
 CellChangeTimes->{{3.806651758611839*^9, 3.806651763580714*^9}, 
   3.811916794517877*^9, {3.811916891745208*^9, 3.811916902395753*^9}, {
   3.811916932511936*^9, 3.811916985378187*^9}, {3.811917033027508*^9, 
   3.811917070214089*^9}, {3.811917116907036*^9, 3.811917116907348*^9}, {
   3.8119174023709*^9, 
   3.811917404346491*^9}},ExpressionUUID->"f279c488-30ac-4ba2-9935-\
a4220b280d5e"],

Cell["\<\
[Chirag Shah] A field of study and practice that involves the collection, \
storage, and processing of data in order to derive important insights into a \
problem or a phenomenon.\
\>", "Item",
 CellChangeTimes->{{3.806651758611839*^9, 3.806651763580714*^9}, 
   3.811916794517877*^9, {3.811916891745208*^9, 3.811916902395753*^9}, {
   3.811916932511936*^9, 3.811916985378187*^9}, {3.811917033027508*^9, 
   3.811917070214089*^9}, {3.811917116907036*^9, 3.811917116907348*^9}, {
   3.81191747772217*^9, 
   3.811917478982973*^9}},ExpressionUUID->"bac431a4-2dab-45ee-91bb-\
0582f662bac2"],

Cell["\<\
Turing award winner Jim Gray imagined data science as a \
\[OpenCurlyDoubleQuote]fourth paradigm\[CloseCurlyDoubleQuote] of science \
(empirical, theoretical, computational and now data-driven) and asserted that \
\[OpenCurlyDoubleQuote]everything about science is changing because of the \
impact of information technology\[CloseCurlyDoubleQuote] and the data deluge.\
\
\>", "Item",
 CellChangeTimes->{{3.806651758611839*^9, 3.806651763580714*^9}, 
   3.811916794517877*^9, {3.811916891745208*^9, 3.811916902395753*^9}, {
   3.811916932511936*^9, 3.811916985378187*^9}, {3.811917033027508*^9, 
   3.811917070214089*^9}, {3.811917116907036*^9, 3.811917116907348*^9}, {
   3.811917624395584*^9, 
   3.811917632970049*^9}},ExpressionUUID->"043e5654-4da0-484b-9d86-\
63ba7291c780"],

Cell["\<\
[M. S. Baptista] It is the scientific method applied to data (any type of \
data), and supported by approaches and tools from different disciplines.\
\>", "Item",
 CellChangeTimes->{{3.806651758611839*^9, 3.806651763580714*^9}, 
   3.811916794517877*^9, {3.811916891745208*^9, 3.811916902395753*^9}, {
   3.811916932511936*^9, 3.811916985378187*^9}, {3.811917033027508*^9, 
   3.811917070214089*^9}, {3.811917117717176*^9, 3.811917165663063*^9}, {
   3.8119172083203588`*^9, 3.811917250080627*^9}, {3.811917315460726*^9, 
   3.811917382301523*^9}, {3.905238122887158*^9, 
   3.905238163325562*^9}},ExpressionUUID->"3f7454bb-b688-421c-877e-\
dc5df71258e5"],

Cell["\[OpenCurlyDoubleQuote]The sexist job of the 21st century\
\[CloseCurlyDoubleQuote]", "Item",
 CellChangeTimes->{{3.806651758611839*^9, 3.8066517708112783`*^9}, {
  3.806651816237298*^9, 
  3.806651816582912*^9}},ExpressionUUID->"3158a513-4bca-472b-9b60-\
5cd854957615"]
}, Open  ]]
}, Open  ]],

