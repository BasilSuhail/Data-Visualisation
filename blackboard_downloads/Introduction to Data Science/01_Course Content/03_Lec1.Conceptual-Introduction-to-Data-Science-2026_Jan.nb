Cell[CellGroupData[{

Cell["Reproducible Research Checklist", "Section",ExpressionUUID->"de2f28a8-effa-4dfc-9a6e-371d6de81a45"],

Cell["\<\
Plan out a modular pipeline for the analysis: Data wrangling, Data cleaning, \
Exploratory analysis, Data preprocessing, ..., as previously described. But \
further: \
\>", "ItemNumbered",
 CellChangeTimes->{{3.9052500353223*^9, 
  3.905250090461104*^9}},ExpressionUUID->"b41061e0-71c4-4525-bd45-\
a923d747ceb0"],

Cell["\<\
Automate wherever possible (e.g. scripts instead of point-and-click)\
\>", "ItemNumbered",ExpressionUUID->"8a9c8785-8c23-4f43-8bbc-d5e755c4b633"],

Cell["Document your code", "ItemNumbered",ExpressionUUID->"6ad75fcb-a233-412e-b0b9-f0167138d3ae"],

Cell["Use version control", "ItemNumbered",ExpressionUUID->"84a99ae1-f3a2-4cda-b573-c041876569ec"],

Cell[CellGroupData[{

Cell["Record and preserve:", "ItemNumbered",ExpressionUUID->"d56f2a12-9673-4b39-bf30-a56958babe6b"],

Cell["Sources: raw data, goals, references", "Subitem",ExpressionUUID->"4e989483-d376-4325-b68b-47023fbc522f"],

Cell["\<\
Process: explorations, final code, observations and comments (selections and \
rejections)\
\>", "Subitem",ExpressionUUID->"6270cd53-4d6b-47a5-a8b6-a6a00cf0d663"],

Cell["Output: clean data, graphics, reports", "Subitem",ExpressionUUID->"476c3104-6702-42ac-814c-69fbc1998f2b"]
}, Open  ]],

Cell["\<\
Prepare for obsolescence (things will change; data sources will get removed)\
\>", "ItemNumbered",
 CellChangeTimes->{{3.946120455121573*^9, 
  3.946120455491137*^9}},ExpressionUUID->"cc2a3278-443b-44e6-8842-\
e9708a54f874"],

Cell["Prepare for portability", "ItemNumbered",ExpressionUUID->"51397075-a809-4287-82c4-00ec99f3ee20"],

