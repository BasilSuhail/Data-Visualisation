Cell[TextData[{
 StyleBox["Oxford dictionary",
  FontWeight->"Bold"],
 ": Systematic study of the structure and behaviour of the physical and \
natural world through observation and experiment "
}], "Text",
 CellChangeTimes->{{3.811917744894074*^9, 3.811917794426991*^9}, {
   3.811917830199657*^9, 3.811917847252129*^9}, 
   3.8121027792323847`*^9},ExpressionUUID->"af23ed2e-fb28-4c12-9246-\
