Cell[TextData[{
 StyleBox["\"How Professor Neil Ferguson helped save tens of thousands of \
lives worldwide \[LongDash] and carried COVID-19 into Downing Street\" [",
  FontSize->16],
 StyleBox[ButtonBox["Business Insider",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.businessinsider.com/neil-ferguson-transformed-uk-covid-\
response-oxford-challenge-imperial-model-2020-4?r=US&IR=T"], None},
  ButtonNote->
   "https://www.businessinsider.com/neil-ferguson-transformed-uk-covid-\
response-oxford-challenge-imperial-model-2020-4?r=US&IR=T"],
  FontSize->16],
 StyleBox["]. Ferguson\[CloseCurlyQuote]s team warned Boris Johnson that the \
quest for \[OpenCurlyDoubleQuote]herd immunity\[CloseCurlyDoubleQuote] could \
cost 510,000 lives, prompting an abrupt U-turn. His simulations have been \
influential in other countries as well, cited by authorities in the US, \
Germany, and France.",
  FontSize->16]
}], "Subsubitem",
 CellChangeTimes->{{3.812176561061619*^9, 3.81217675688402*^9}, {
  3.812176792575093*^9, 3.812176847624695*^9}, {3.812176947860715*^9, 
