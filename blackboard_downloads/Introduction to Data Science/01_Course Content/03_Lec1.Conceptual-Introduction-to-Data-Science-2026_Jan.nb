Cell[CellGroupData[{

Cell["Why a pipeline?", "Section",
 CellChangeTimes->{{3.709921345540263*^9, 
  3.709921354019617*^9}},ExpressionUUID->"23699ae5-51fb-4ec8-85c1-\
07c10b721e3d"],

Cell[CellGroupData[{

Cell["\<\
For reproducibility. By publishing your work, others can run similar analyses \
to:\
\>", "Item",
 CellChangeTimes->{{3.709896062992856*^9, 3.709896076184438*^9}, {
  3.709897387063979*^9, 3.709897392294224*^9}, {3.709897462602385*^9, 
  3.709897462605427*^9}, {3.774328456688703*^9, 3.774328468216222*^9}, {
  3.774328507955491*^9, 3.774328528241736*^9}, {3.9052486549476433`*^9, 
  3.905248660979916*^9}},ExpressionUUID->"893e5822-b8c2-49e1-8021-\
dc19dd649982"],

Cell["verify results (replication == stronger evidence)", "Subitem",ExpressionUUID->"98555369-669f-4154-a8be-72f99a917e5e"],

Cell["build on existing results", "Subitem",ExpressionUUID->"8a218d05-6498-41fd-8b6b-ab62a43bea97"],

Cell["combine results for better insight", "Subitem",ExpressionUUID->"9f502310-ee48-4961-b8d6-cb7a0dbaa066"],

Cell["\<\
but also to adapt/redo any substeps of the pipeline whenever necessary  \
\>", "Subitem",
 CellChangeTimes->{{3.709896062992856*^9, 3.709896076184438*^9}, {
   3.709897387063979*^9, 3.709897392294224*^9}, {3.709897462602385*^9, 
   3.709897462605427*^9}, {3.774328456688703*^9, 3.774328468216222*^9}, {
   3.774328507955491*^9, 3.774328600962972*^9}, {3.8066538998343573`*^9, 
   3.806653901535569*^9}, 
   3.977293981764826*^9},ExpressionUUID->"02604bc2-848b-4092-a9c0-\
54b29a3117f2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["For agile data science", "Item",
 CellChangeTimes->{{3.709896062992856*^9, 3.709896076184438*^9}, {
   3.709897387063979*^9, 3.709897392294224*^9}, 3.709897464514539*^9, {
   3.774328629977792*^9, 3.7743286711766453`*^9}, {3.774328712206842*^9, 
   3.774328714796332*^9}, {3.774328826399028*^9, 
   3.7743289258316936`*^9}},ExpressionUUID->"42b5a293-478d-40d3-8fbf-\
e2bc38d4116f"],

Cell["Iterative process of tweaking and improving", "Subitem",ExpressionUUID->"0a225497-39b1-4057-81bd-a1827609e12f"],

Cell["Rapid prototyping", "Subitem",ExpressionUUID->"b603b26e-4f15-4444-afeb-d575e2c753c8"]
}, Open  ]],

Cell[TextData[{
 "The pictured pipeline is the sketch of a project (watch YouTube ",
 ButtonBox["video",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.youtube.com/watch?v=cugl5t-W1sE"], None},
  ButtonNote->"https://www.youtube.com/watch?v=cugl5t-W1sE"],
 ").  The picture is oversimplified, giving an almost direct path connecting \
data to reporting. Order of different tasks may need to be different. The \
order with which tasks are done is also not necessarily the one that is ideal \
for your problem. "
}], "Item",
 CellChangeTimes->{{3.709896062992856*^9, 3.709896076184438*^9}, {
   3.709897387063979*^9, 3.709897392294224*^9}, 3.709897464514539*^9, {
   3.774328629977792*^9, 3.7743286711766453`*^9}, {3.774328712206842*^9, 
   3.774328714796332*^9}, {3.774328826399028*^9, 3.774328925018199*^9}, {
   3.774329007826099*^9, 3.774329064177807*^9}, {3.7786502423123426`*^9, 
   3.778650242313401*^9}, {3.778666750394481*^9, 3.778666750916437*^9}, {
   3.806653987188091*^9, 3.806654095424305*^9}, {3.81157025214954*^9, 
   3.81157028013396*^9}},ExpressionUUID->"abaf3a5d-681e-46ae-ac17-\
3ec2ff4c9d95"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

