Cell[TextData[StyleBox["[WikiMedia: A. Repening, A. Basawapatna, and N. \
Scherle, \[OpenCurlyDoubleQuote]Computational Thinking Tools\
\[CloseCurlyDoubleQuote]]",
 FontSize->14]], "Text",
 CellChangeTimes->{{3.874406203145359*^9, 
  3.874406241017579*^9}},ExpressionUUID->"e34fa46d-c8b7-4a85-8884-\
1e9d0feb9dff"],

Cell["\<\
The solution expression can be done by decomposition, were a complex problem \
is broken down into a set of smaller problems, easier to be solved. \
\[OpenCurlyDoubleQuote]If volume in front of a small piece of mud is empty, \
move. A physicist would include some more information. Move it if the gravity \
force is stronger than the friction along the sliding direction.\
\[CloseCurlyDoubleQuote]\
\>", "Text",
 CellChangeTimes->{
  3.806739539672654*^9, {3.806739727966395*^9, 3.806739743918311*^9}, {
   3.806739786409292*^9, 3.806739871236001*^9}, {3.806740118326096*^9, 
   3.8067401199979563`*^9}, {3.806747956879725*^9, 3.806747988615294*^9}, {
   3.806748021595955*^9, 3.8067480596559763`*^9}, {3.81211058903041*^9, 
   3.81211064433132*^9}, {3.82228439011982*^9, 3.822284390460882*^9}, {
   3.885289368775453*^9, 
   3.8852893704094954`*^9}},ExpressionUUID->"0267ed1f-ac97-4377-8053-\
e8a48cdb75ca"],

Cell[TextData[{
 "\n ",
 StyleBox["Hands-on problem 1.1 [textbook]",
  FontSlant->"Italic",
  FontVariations->{"Underline"->True}],
 StyleBox[" ",
  FontSlant->"Italic"],
 "\"what is the largest number of the set: 7, 4, 62, 11, 4, 39, 42, 5, 97, \
54?\"\n "
}], "Text",
 CellChangeTimes->{
  3.806739539672654*^9, {3.806739727966395*^9, 3.806739743918311*^9}, {
   3.806739786409292*^9, 3.806739871236001*^9}, {3.806740118326096*^9, 
   3.8067401199979563`*^9}, {3.806747956879725*^9, 3.806747988615294*^9}, {
   3.806748021595955*^9, 3.806748062646187*^9}, 
   3.811920957772275*^9},ExpressionUUID->"cdeb2718-2117-4c46-bc5e-\
5b30a9a766e0"],

Cell["Take the largest between 7 and 4", "Item",
 CellChangeTimes->{
  3.806739539672654*^9, {3.806739727966395*^9, 3.806739743918311*^9}, {
   3.806739786409292*^9, 3.806739871236001*^9}, {3.806740118326096*^9, 
   3.8067401199979563`*^9}, {3.806747956879725*^9, 3.806747988615294*^9}, {
   3.806748021595955*^9, 3.806748065200763*^9}, {3.80674809727419*^9, 
   3.806748097277762*^9}},ExpressionUUID->"497f8adf-00e0-4928-bc3c-\
7038833a25ee"],

Cell["Compare with the next number, keep the largest", "Item",
 CellChangeTimes->{
  3.806739539672654*^9, {3.806739727966395*^9, 3.806739743918311*^9}, {
   3.806739786409292*^9, 3.806739871236001*^9}, {3.806740118326096*^9, 
   3.8067401199979563`*^9}, {3.806747956879725*^9, 3.806747988615294*^9}, {
   3.806748021595955*^9, 3.806748065200763*^9}, {3.806748098055207*^9, 
   3.8067481089048634`*^9}},ExpressionUUID->"6d46cbbd-0b23-4e76-a9bf-\
73ba6e4a9682"],

Cell["\<\
Repeat until the end \t
\t\
\>", "Item",
 CellChangeTimes->{
  3.806739539672654*^9, {3.806739727966395*^9, 3.806739743918311*^9}, {
   3.806739786409292*^9, 3.806739871236001*^9}, {3.806740118326096*^9, 
   3.8067401199979563`*^9}, {3.806747956879725*^9, 3.806747988615294*^9}, {
