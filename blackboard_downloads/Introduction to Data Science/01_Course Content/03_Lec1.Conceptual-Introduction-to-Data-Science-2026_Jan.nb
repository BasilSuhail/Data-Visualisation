Cell[TextData[{
 "On average, how much increase can we expect in weight (list ",
 StyleBox["weight", "Input"],
 ") with an increase of one inch in height (list ",
 StyleBox["height", "Input"],
 ")? "
}], "Text",
 CellChangeTimes->{{3.806753122821114*^9, 3.806753151643456*^9}, {
  3.822286471348722*^9, 3.822286480529637*^9}, {3.8222865123760643`*^9, 
  3.822286514864846*^9}, {3.843025351224786*^9, 3.843025353169044*^9}, {
  3.8430264229630833`*^9, 3.843026428528679*^9}},
 FontWeight->"Bold",
 FontVariations->{
 "Underline"->True},ExpressionUUID->"390490e2-5f68-419c-a788-452dd4de593c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Max", "[", "weight", "]"}], "-", 
     RowBox[{"Min", "[", "weight", "]"}]}], ")"}], "/", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Max", "[", "height", "]"}], "-", 
     RowBox[{"Min", "[", "height", "]"}]}], ")"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.80675322877637*^9, 3.806753264098701*^9}, {
  3.843026228809969*^9, 3.843026239185555*^9}},
 CellLabel->
  "In[144]:=",ExpressionUUID->"7aaad619-504e-48ae-8600-e4bec9d12d61"],

Cell[BoxData["3.5`"], "Output",
 CellChangeTimes->{{3.806753253898965*^9, 3.806753264324486*^9}, 
   3.806754357896387*^9, 3.8430262397061443`*^9},
 CellLabel->
  "Out[144]=",ExpressionUUID->"0b2bc43f-5b59-444e-9149-4ac82524e98a"]
}, Open  ]],

Cell["\<\
But this analysis will change depending on the range of values for height we \
are considering, since the higher the height the higher the weight\
\>", "Text",
 CellChangeTimes->{{3.806753326751423*^9, 3.806753354783867*^9}, {
  3.843025996942441*^9, 
  3.843025999476129*^9}},ExpressionUUID->"936e8e1a-f840-453d-87be-\
a65b7305d96c"],

Cell["For higher height (use 2 last points of data):", "Text",
 CellChangeTimes->{{3.806754205578248*^9, 3.806754225854579*^9}, {
  3.806754622387293*^9, 3.806754632369457*^9}, {3.811923905736741*^9, 
  3.811923923849907*^9}},ExpressionUUID->"4150a255-bde1-49ce-957e-\
08049382bf0d"],

