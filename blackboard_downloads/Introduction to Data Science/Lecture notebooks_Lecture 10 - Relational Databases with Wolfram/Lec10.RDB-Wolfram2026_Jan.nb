Cell["\<\
As follows from this diagram, the following relationships exist for the \
tables :\
\>", "Text",
 CellChangeTimes->{{3.774864857278006*^9, 3.774864869188083*^9}, 
   3.779636748458696*^9},ExpressionUUID->"5d9312ac-5657-45e6-9f1c-\
539d4d50229f"],

Cell[TextData[{
 StyleBox["offices table ",
  FontWeight->"Bold"],
 "has a 1 to N relationship with ",
 StyleBox["employees table",
  FontWeight->"Bold"],
 " : there are generally many employees working for the same office.The \
relationship is realized via the ",
 StyleBox["foreign key officeCode",
  FontWeight->"Bold",
  FontVariations->{"Underline"->True}],
 " of the employees table corresponding to the ",
 StyleBox["primary key officeCode",
  FontWeight->"Bold",
  FontVariations->{"Underline"->True}],
 " of the offices table."
}], "Item",
 CellChangeTimes->{{3.774864857278006*^9, 3.7748648808072844`*^9}},
 FontSize->18,
 Background->RGBColor[
  0.18588540474555582`, 0.5628595407034409, 
   0.9985656519417105],ExpressionUUID->"07d174f3-b797-4452-9bab-64c983a04446"],

Cell[TextData[{
 StyleBox["employees table",
  FontWeight->"Bold"],
 " has a 1 to N relationship with itself : in general, each employee may have \
0, 1 or more other employees reporting to them.The relationship is realized \
via the foreign key reportsTo, linked to the primary key employeeNumber of \
the same employees table."
}], "Item",
 CellChangeTimes->{{3.774864857278006*^9, 3.774864885613143*^9}},
 FontSize->18,
 Background->RGBColor[
  0.2294346532387274, 0.5307545586327916, 
   0.9985503929198138],ExpressionUUID->"16a3765a-ebf0-4d8d-ad4a-dfd72c325541"],

Cell[TextData[{
 StyleBox["employees table ",
  FontWeight->"Bold"],
 "has 1 to N relationship with customers table : each employee may deal with \
0, 1 or more customers, while each customer is always dealt with by at most \
one employee.The relationship is realized via the foreign key \
salesRepEmployeeNumber of the customers table, which corresponds to the \
primary key employeeNumber of the employees table."
}], "Item",
 CellChangeTimes->{{3.774864857278006*^9, 3.774864894851377*^9}},
 FontSize->18,
 Background->RGBColor[
  0.4, 0.6, 1.],ExpressionUUID->"316f169a-f8f2-404a-a69a-16c53bf3f369"],

Cell["\<\
Primary keys are represented by the key yellow symbols, and there will be a \
number of entities related to them.\
\>", "Item",
 CellChangeTimes->{{3.8133429523503647`*^9, 3.813343002624892*^9}, {
  3.813343171366399*^9, 3.813343187806015*^9}, {3.844783230540894*^9, 
  3.844783230697214*^9}},ExpressionUUID->"61a07646-49a0-48a9-a975-\
1cb2026af89b"],

Cell[TextData[{
 StyleBox["\[EmptyDiamond]",
  FontColor->RGBColor[0, 1, 1]],
 " The \[OpenCurlyDoubleQuote]attribute names\[CloseCurlyDoubleQuote] or in \
Wolfram language the \
\[OpenCurlyDoubleQuote]Properties\[CloseCurlyDoubleQuote] of the entities. "
}], "Item",
 CellChangeTimes->{{3.8133429523503647`*^9, 3.813343002624892*^9}, {
   3.813343171366399*^9, 3.813343206142208*^9}, 3.813343315688109*^9, {
   3.813343574615982*^9, 3.813343599056384*^9}, {3.813351254904777*^9, 
   3.813351254910922*^9}},ExpressionUUID->"9254545f-592c-441d-a81a-\
2d5ba3d4cce1"],

Cell[TextData[{
 StyleBox["\[EmptyDiamond]",
  FontColor->RGBColor[1, 0, 0]],
 " Foreign key"
}], "Item",
 CellChangeTimes->{{3.8133429523503647`*^9, 3.813343002624892*^9}, {
   3.813343171366399*^9, 3.813343206142208*^9}, 3.813343315688109*^9, {
   3.813343574615982*^9, 3.813343599056384*^9}, {3.8133512588153973`*^9, 
   3.813351284661536*^9}, {3.813400446735538*^9, 
   3.813400446737731*^9}},ExpressionUUID->"33009c05-8297-4846-9c43-\
db7e75efc832"],

Cell["The Entities are not being shown in these tables", "Item",
 CellChangeTimes->{{3.8133429523503647`*^9, 3.813343002624892*^9}, {
   3.813343171366399*^9, 3.813343206142208*^9}, 3.813343315688109*^9, {
   3.813343574615982*^9, 3.813343599056384*^9}, {3.8133512588153973`*^9, 
   3.813351284661536*^9}, {3.813400447556333*^9, 3.813400455657239*^9}},
 FontVariations->{
 "Underline"->True},ExpressionUUID->"09f46cb9-f218-4f99-b950-24b33fae8eeb"]
}, Open  ]]
}, Open  ]],

