Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"6eeee972-cd93-44cd-a31a-bd15128c2520"],

Cell["Relational Databases ", "Title",
 CellChangeTimes->{{3.774771312251474*^9, 3.774771318786723*^9}, {
   3.774784700121418*^9, 3.774784700352561*^9}, 
   3.774784830046201*^9},ExpressionUUID->"14c3d9db-1c79-495f-92fa-\
51da0a08a6b3"],

Cell["\<\
For certain large data databases, it is not a good scalable solution to bring \
the data to the computer memory.\
\>", "Item",
 CellChangeTimes->{{3.774784837506921*^9, 
  3.77478491096749*^9}},ExpressionUUID->"0b32c022-b8af-4ae0-b1c0-\
56e924a0aade"],

Cell["\<\
A typical source of large data is usually a relational one that can be \
accessed using SQL. Relational databases and SQL have become the de facto \
standard for interacting with large, structured datasets.\
\>", "Item",
 CellChangeTimes->{{3.774784837506921*^9, 3.774784988170285*^9}, {
  3.774785046037258*^9, 3.774785046506834*^9}, {3.774785747308303*^9, 
  3.774785747308617*^9}, {3.774785833787613*^9, 
  3.774785834460247*^9}},ExpressionUUID->"2a38bf95-8be6-453c-b51e-\
8681c79156e7"],

Cell["\<\
 Version 12 introduces a completely symbolic way of interacting with \
relational databases using entities, which eliminate the need of knowing the \
details of the SQL dialect you are using. \
\>", "Item",
 CellChangeTimes->{{3.774784837506921*^9, 3.774784988170285*^9}, {
   3.774785046037258*^9, 3.774785046506834*^9}, {3.774785748176512*^9, 
   3.774785773461691*^9}, 3.774785805853401*^9, 
   3.8757087227815537`*^9},ExpressionUUID->"7cea3366-81b9-4f1a-99fb-\
402a9334b8ee"],

Cell["\<\
For the first time in the Wolfram Language, tools are provided for \
interacting with terabyte-scale data integrating out-of-core and in-memory \
techniques.\
\>", "Item",
 CellChangeTimes->{{3.774784837506921*^9, 3.774784988170285*^9}, {
   3.774785046037258*^9, 3.774785046506834*^9}, 3.774785748176512*^9, {
   3.774868469568922*^9, 
   3.774868469569848*^9}},ExpressionUUID->"be0a81aa-f06c-41e2-9975-\
e2d11a24090c"],

Cell[TextData[{
 "A \[OpenCurlyDoubleQuote]Quick Start\[CloseCurlyDoubleQuote] (actually \
quite long and detailed...) Tutorial on relational Databases can be accessed \
in ",
 ButtonBox["Tutorial",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/tutorial/\
RelationalDatabasesQuickStart.html"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/tutorial/\
RelationalDatabasesQuickStart.html"],
 "."
}], "Item",
 CellChangeTimes->{{3.774784837506921*^9, 3.774784988170285*^9}, {
   3.774785046037258*^9, 3.774785046506834*^9}, 3.774785748176512*^9, {
   3.774868470155254*^9, 3.774868490343132*^9}, {3.7748685212508283`*^9, 
   3.774868537826847*^9}, 
   3.775400330449272*^9},ExpressionUUID->"0da01029-99ba-4477-99fc-\
83a49401807d"]
}, Open  ]],

