Cell[TextData[{
 "This example looks at airport locations, their altitude and where they are \
most dense on Earth. \n  \nA commonly used database for worldwide airport \
locations (a SQLite DB) is available from this ",
 ButtonBox["website",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://www.partow.net/miscellaneous/airportdatabase/index.html#\
DatabaseStructure"], None},
  ButtonNote->
   "http://www.partow.net/miscellaneous/airportdatabase/index.html#\
DatabaseStructure"],
 "."
}], "Text",
