Cell[TextData[{
 "The ",
 StyleBox["port number ",
  FontWeight->"Bold"],
 "identifies a specific process or a type of network service, for example 20 \
for FTP data transfer, 22 for SSH secure login, 80 for HTTP, etc. See Extra \
Material notebook \"Connectivity models.nb\" in Myaberdeen. "
}], "Item",
