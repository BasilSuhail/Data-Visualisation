Cell[CellGroupData[{

Cell["\<\
Plot a graph representing the correlation of time series with a threshold of \
0.92, and then finding communities in this graph \
\>", "Item",
 CellChangeTimes->{{3.9797957850681334`*^9, 3.979795829493807*^9}, {
  3.979795940305079*^9, 
  3.9797959403598633`*^9}},ExpressionUUID->"5f91bbc1-26dd-487b-ad06-\
70dc0d1a2c10"],

Cell[BoxData[
 RowBox[{"returnsGraph", "=", 
  RowBox[{"WeightedAdjacencyGraph", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Round", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"correlationmatrix", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"2", ";;"}], ",", 
           RowBox[{"2", ";;"}]}], "]"}], "]"}], " ", 
        RowBox[{"UnitStep", "[", 
         RowBox[{
          RowBox[{"correlationmatrix", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"2", ";;"}], ",", 
             RowBox[{"2", ";;"}]}], "]"}], "]"}], "-", "0.92"}], "]"}]}], ",",
        ".01"}], "]"}], "/.", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"1.", "->", "Infinity"}], ",", 
       RowBox[{"0.", "->", "Infinity"}]}], "}"}]}], ",", 
    RowBox[{"VertexLabels", "\[Rule]", "labels"}], ",", 
    RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}]}]], "Input",ExpressionU\
UID->"eb2e6459-b58e-4849-9e95-1292d1cc3e94"],

Cell[BoxData[
 RowBox[{"c", "=", 
  RowBox[{"FindGraphCommunities", "[", "returnsGraph", "]"}]}]], "Input",Expre\
ssionUUID->"8f46f11f-7956-4def-a97e-4d89951419ed"]
}, Open  ]],

