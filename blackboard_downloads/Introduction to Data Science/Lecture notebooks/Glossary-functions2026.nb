 FontWeight->"Regular",
 CellLabel->
  "In[203]:=",ExpressionUUID->"51cadf3b-235d-4988-afbd-8bb082433300"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"DefaultImportElement\"\>", "\[Rule]", "\<\"RawData\"\>"}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{{3.947761746917177*^9, 3.947761767785596*^9}, 
   3.94776199017813*^9, 3.947762233751721*^9, 3.947763062033132*^9, 
