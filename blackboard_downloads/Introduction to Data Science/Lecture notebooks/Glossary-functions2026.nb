Cell[CellGroupData[{

Cell["\<\
a code to transform a string number with comma into a real number and define \
a DateObject from a string date.\
\>", "Item",
 CellChangeTimes->{{3.978430490301217*^9, 
  3.978430540241714*^9}},ExpressionUUID->"85ea43bd-220f-4bea-a49e-\
352a89713747"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"StringQ", "[", "x", "]"}], ",", 
     RowBox[{"ToExpression", "[", 
      RowBox[{"StringReplace", "[", 
       RowBox[{"x", ",", 
        RowBox[{"\"\<,\>\"", "\[Rule]", "\"\<\>\""}]}], "]"}], "]"}], ",", 
     "x"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.844512633449129*^9, 3.84451263892846*^9}, {
  3.948803638739934*^9, 3.948803644376129*^9}},
 CellLabel->"In[94]:=",ExpressionUUID->"c4c66f04-d14f-449c-9f09-4b81a2ce9a10"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tmp2", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"tmp1", ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a_", ",", "b_", ",", "c_", ",", "d_"}], "}"}], "\[RuleDelayed]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"DateObject", "[", "a", "]"}], ",", 
        RowBox[{"f", "[", "b", "]"}], ",", 
        RowBox[{"f", "[", "c", "]"}], ",", 
        RowBox[{"f", "[", "d", "]"}]}], "}"}]}], ",", "\[Infinity]"}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.84451285960679*^9, 3.844512900270143*^9}, 
   3.844512932615242*^9, 3.855047614302835*^9, {3.917761292149458*^9, 
   3.917761296878166*^9}, {3.948805219686964*^9, 3.948805220247045*^9}},
 CellLabel->"In[95]:=",ExpressionUUID->"1f48ae70-e751-4f27-8398-3a7818db8d81"]
}, Open  ]],

