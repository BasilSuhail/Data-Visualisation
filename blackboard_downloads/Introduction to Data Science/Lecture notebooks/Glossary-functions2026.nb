Cell["A code for discretizing a list of real numbers to integers :", "Text",
 CellChangeTimes->{{3.9774684386185713`*^9, 
  3.977468453330771*^9}},ExpressionUUID->"41ef5db9-cefd-44e2-ac27-\
7d6a6d7da260"],

Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "2"}], ",", 
   RowBox[{"i", "\[LessEqual]", 
    RowBox[{"Length", "[", "red2", "]"}]}], ",", 
   RowBox[{"i", "++"}], ",", 
   RowBox[{
    RowBox[{"red2", "[", 
     RowBox[{"[", 
      RowBox[{"i", ",", "3"}], "]"}], "]"}], "=", 
    RowBox[{"Which", "[", 
     RowBox[{
      RowBox[{"0", "<", 
       RowBox[{"red2", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "3"}], "]"}], "]"}], "<", "1"}], ",", "0", ",", 
      RowBox[{"1", "\[LessEqual]", 
       RowBox[{"red2", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "3"}], "]"}], "]"}], "<", "2"}], ",", "1", ",", 
      RowBox[{"2", "\[LessEqual]", 
       RowBox[{"red2", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "3"}], "]"}], "]"}], "<", "5"}], ",", "2", ",", 
      RowBox[{
       RowBox[{"red2", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "3"}], "]"}], "]"}], "\[GreaterEqual]", "5"}], ",",
       "3"}], " ", "]"}]}]}], "]"}]], "Input",ExpressionUUID->"df24a816-48e3-\
45aa-bee0-57a39f1ffffd"]
}, Open  ]],

