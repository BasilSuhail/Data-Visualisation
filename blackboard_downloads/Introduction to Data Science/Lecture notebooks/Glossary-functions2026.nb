Cell[CellGroupData[{

Cell["\<\
Extracting from a 5 columns dataset (vixData) and creating a list of 2 \
columns by  taking the data in the first column and transforming it to a \
DateObject, then transforming the data at the 5th column to an integer, using \
RuleDelayed.  \
\>", "Item",
 CellChangeTimes->{{3.977828682539456*^9, 3.977828802274272*^9}, {
  3.9778289191395903`*^9, 
  3.9778289215174923`*^9}},ExpressionUUID->"e4b26fba-276c-4989-b948-\
44ee7652c8a0"],

Cell[BoxData[
 RowBox[{"vixData", "/.", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d_", ",", "e_", ",", "f_", ",", "g_", ",", "h_"}], "}"}], " ", "\[RuleDelayed]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"DateObject", "[", 
      RowBox[{"ToExpression", "@", 
       RowBox[{"StringSplit", "[", 
        RowBox[{"d", ",", "\"\<-\>\""}], "]"}]}], "]"}], ",", 
     RowBox[{"ToExpression", "[", "h", "]"}]}], "}"}]}]}]], "Input",Expression\
UUID->"d4702fbb-6c56-4776-9a2b-e842036b8399"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Converting a date string to a DateObject", "Item",
 CellChangeTimes->{{3.9778288412168503`*^9, 
  3.977828861192905*^9}},ExpressionUUID->"949318f1-86b2-497f-82e4-\
53523f4da9bf"],

Cell[BoxData[
 RowBox[{"FromDateString", "[", 
  RowBox[{"\"\<2021-03-09\>\"", ",", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<Elements\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<Year\>\"", ",", "\"\<Month\>\"", ",", "\"\<Day\>\""}], 
       "}"}]}], ",", 
     RowBox[{"\"\<Delimiters\>\"", "\[Rule]", "\"\<-\>\""}]}], "|>"}]}], 
  "]"}]], "Input",ExpressionUUID->"2e2ccade-fb8b-4f7b-92b7-404da03ee0a2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Same as before, but now using FromDateString", "Item",
 CellChangeTimes->{{3.977828952415765*^9, 
  3.9778289728590403`*^9}},ExpressionUUID->"85e159de-3a31-4e06-bb5b-\
409c58dccd0e"],

Cell[BoxData[
 RowBox[{"vixData", "/.", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"d_", ",", "e_", ",", "f_", ",", "g_", ",", "h_"}], "}"}], "\[RuleDelayed]",
    " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FromDateString", "[", 
      RowBox[{"d", ",", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Elements\>\"", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"\"\<Year\>\"", ",", "\"\<Month\>\"", ",", "\"\<Day\>\""}],
            "}"}]}], ",", 
         RowBox[{"\"\<Delimiters\>\"", "\[Rule]", "\"\<-\>\""}]}], "|>"}]}], 
      "]"}], ",", 
     RowBox[{"ToExpression", "[", "h", "]"}]}], "}"}]}]}]], "Input",Expression\
UUID->"a11c8ce7-a916-45a7-a3eb-a0349475f56c"]
}, Open  ]],

