Cell[BoxData[
 RowBox[{"data", "=", 
  RowBox[{
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"RowKeys", "->", "#"}], "&"}], "[", 
     RowBox[{
      RowBox[{
       RowBox[{"AssociationThread", "[", 
        RowBox[{
         RowBox[{"ToString", "/@", "ColumnKeys"}], "->", "#"}], "]"}], "&"}], 
      "/@", "myvalues"}], "]"}], "]"}], " ", "//", "Dataset"}]}]], "Input",Exp\
