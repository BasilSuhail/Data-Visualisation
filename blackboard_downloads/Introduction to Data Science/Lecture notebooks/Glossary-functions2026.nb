Cell[CellGroupData[{

Cell[TextData[{
 "Selecting from a list using Cases and 1 pattern. ",
 StyleBox["Notice, Level 0 \[RightArrow] the entire expression.  \
Cases[event[[5]], KeyValuePattern[...] -> d, {0}] : Return {d} if and only if \
event[[5]] itself matches that KeyValuePattern:",
  FontWeight->"Plain",
  FontColor->GrayLevel[0.5]]
}], "Item",
 CellChangeTimes->{{3.977379698158063*^9, 3.977379748061035*^9}, {
  3.977379838668482*^9, 
  3.9773798612438393`*^9}},ExpressionUUID->"0c459c3f-c794-4ffa-a228-\
f8278cdc3432"],

Cell[BoxData[
 RowBox[{"Cases", "[", 
  RowBox[{
   RowBox[{"event", "[", 
    RowBox[{"[", "5", "]"}], "]"}], ",", 
   RowBox[{
    RowBox[{"KeyValuePattern", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<id\>\"", "\[Rule]", " ", "a_"}], ",", 
       RowBox[{"\"\<index\>\"", "\[Rule]", " ", "b_"}], ",", 
       RowBox[{"\"\<period\>\"", "\[Rule]", " ", "c_"}], ",", 
       RowBox[{"\"\<timestamp\>\"", "\[Rule]", " ", "d_"}], ",", 
       RowBox[{"\"\<minute\>\"", "\[Rule]", " ", "e_"}], " ", ",", 
       RowBox[{"\"\<second\>\"", " ", "\[Rule]", " ", "f_"}], ",", 
       RowBox[{"\"\<type\>\"", "\[Rule]", " ", "g_"}], " ", ",", 
       RowBox[{"\"\<possession\>\"", "\[Rule]", " ", "h_"}], ",", 
       RowBox[{"\"\<possession_team\>\"", "\[Rule]", " ", "i_"}], " ", ",", 
       RowBox[{"\"\<play_pattern\>\"", "\[Rule]", " ", "j_"}], ",", 
       RowBox[{"\"\<team\>\"", " ", "\[Rule]", " ", "k_"}], ",", 
       RowBox[{"\"\<player\>\"", " ", "\[Rule]", " ", "l_"}], ",", 
       RowBox[{"\"\<position\>\"", "\[Rule]", " ", "m_"}], ",", 
       RowBox[{"\"\<location\>\"", "\[Rule]", " ", "n_"}], ",", 
       RowBox[{"\"\<duration\>\"", "\[Rule]", " ", "o_"}], ",", 
       RowBox[{"\"\<related_events\>\"", "\[Rule]", " ", "p_"}], ",", 
       RowBox[{"\"\<pass\>\"", "\[Rule]", " ", "q_"}]}], "}"}], "]"}], " ", "->",
     " ", "d"}], ",", 
   RowBox[{"{", "0", "}"}]}], "]"}]], "Input",ExpressionUUID->"96adc23f-1bb2-\
495d-bd16-d3260e24cf97"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Selecting from a list using Cases and 2 patterns. Notice that {0, Infinity} \
\[RightArrow] the whole expression and everything inside it:\
\>", "Item",
 CellChangeTimes->{{3.977379698158063*^9, 3.977379768650441*^9}, {
  3.977379901940435*^9, 
  3.977379905177663*^9}},ExpressionUUID->"a3f4b23a-7b5a-40d1-bc4a-\
c2b7ca8b6aad"],

Cell[BoxData[
 RowBox[{"Cases", "[", 
  RowBox[{
   RowBox[{"event", "[", 
    RowBox[{"[", "5", "]"}], "]"}], ",", " ", 
   RowBox[{
    RowBox[{"KeyValuePattern", "[", 
     RowBox[{"\"\<player\>\"", " ", "->", " ", 
      RowBox[{"KeyValuePattern", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<id\>\"", " ", "->", " ", "a_"}], ",", " ", 
         RowBox[{"\"\<name\>\"", " ", "->", " ", "b_"}]}], "}"}], "]"}]}], 
     "]"}], " ", ":>", " ", "b"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"0", ",", " ", "\[Infinity]"}], "}"}]}], "]"}]], "Input",Expressio\
nUUID->"a2684b33-1378-4019-ae98-3c068ab970d3"]
}, Open  ]]
}, Open  ]],

