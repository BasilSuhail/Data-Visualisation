Cell[CellGroupData[{

Cell["\<\
Notice that the syntax #age is equivalent to #[\"age\"] . If you do not \
define keys as strings, then you need to use #[a] or #[[Key[a]]] . So, \
basically, always use strings as keys !\
\>", "Subsubsection",
 CellChangeTimes->{{3.977403279555834*^9, 
  3.977403284537176*^9}},ExpressionUUID->"b900d822-33a6-4a13-9fcf-\
