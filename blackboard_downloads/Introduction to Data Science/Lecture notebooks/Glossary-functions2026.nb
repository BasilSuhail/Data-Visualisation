Cell[CellGroupData[{

Cell["\<\
A named database connection save your connection properties and parameters so \
that you don' t have to re-enter them every time you use them\
\>", "Item",
 CellChangeTimes->{{3.775560881312046*^9, 3.775560906342975*^9}, {
  3.7792825500935907`*^9, 
  3.7792825576942453`*^9}},ExpressionUUID->"ba919fba-4556-40d4-b2d9-\
406b150cd0d5"],

Cell[BoxData[
 RowBox[{"conn", "=", 
  RowBox[{"OpenSQLConnection", "[", "\"\<demo\>\"", "]"}]}]], "Input",
 CellChangeTimes->{{3.775476217760023*^9, 3.775476217764233*^9}},
 CellLabel->
  "In[109]:=",ExpressionUUID->"5da541a9-40fd-4e32-842f-a01ef4e6e7ac"]
}, Open  ]],

Cell["\<\
There is also a GUI method to connect to the database that is invoked by \
executing OpenSQLConnection with no arguments :\
\>", "Text",
 CellChangeTimes->{{3.775476418667139*^9, 
  3.775476424212328*^9}},ExpressionUUID->"7cce0700-5f1f-4e81-ae49-\
a9f6f378eef7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"conn", "=", 
   RowBox[{"OpenSQLConnection", "[", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.78031718394911*^9, 3.780317186390744*^9}, 
   3.855310309918363*^9},
 CellLabel->
  "In[183]:=",ExpressionUUID->"fb7ca48c-1c7b-4104-a6e7-644407eb4512"],

Cell["Looking inside the table", "Text",
 CellChangeTimes->{{3.980401341430633*^9, 
  3.980401350760171*^9}},ExpressionUUID->"0b4ac225-ff10-4f41-b158-\
5f54d7da5d43"],

Cell[BoxData[
 RowBox[{"data", "=", 
  RowBox[{"SQLSelect", "[", 
   RowBox[{"conn", ",", "\"\<SAMPLETABLE1\>\""}], "]"}]}]], "Input",
 CellChangeTimes->{{3.775477816211413*^9, 3.775477816214336*^9}, {
  3.775478109719584*^9, 3.775478125014042*^9}},
 CellLabel->
  "In[115]:=",ExpressionUUID->"7360bf4d-d328-4df3-acad-02560cd98f96"],

Cell["and using SQL raw command to look inside ", "Text",
 CellChangeTimes->{{3.980401361616194*^9, 
  3.980401371252925*^9}},ExpressionUUID->"0b1fc71d-d07f-4fe2-bc94-\
62b69b46f8ba"],

Cell[BoxData[
 RowBox[{"SQLExecute", "[", 
  RowBox[{"conn", ",", "\"\<SELECT * FROM SAMPLETABLE1\>\""}], "]"}]], "Input",\

 CellChangeTimes->{{3.775545708398683*^9, 3.775545708401608*^9}},
 CellLabel->
  "In[189]:=",ExpressionUUID->"5f069bc5-38e6-42a7-a72a-79c6c8c6b851"]
}, Open  ]]
}, Open  ]]
