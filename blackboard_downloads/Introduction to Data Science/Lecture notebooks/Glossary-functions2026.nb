Cell["Replace a Row 3 of a data by a list (dd1) :", "Text",
 CellChangeTimes->{{3.97746814436378*^9, 
  3.977468171899357*^9}},ExpressionUUID->"5c66accd-70d3-4661-bf75-\
9410afbe22bf"],

Cell[BoxData[
 RowBox[{"ReplacePart", "[", 
