Cell[CellGroupData[{

Cell["\<\
Adding keys to a data set/array, transforming it to an Association and then \
to a Dataset object:\
\>", "Item",
 CellChangeTimes->{{3.977374833361826*^9, 
  3.977374858474024*^9}},ExpressionUUID->"5fa2728b-576a-4784-ab54-\
544702eca7d9"],

Cell[BoxData[
 RowBox[{"myDataset", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"AssociationThread", "[", 
      RowBox[{"mykeys", "\[Rule]", "#"}], "]"}], "&"}], "/@", 
    RowBox[{"myvalues", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "All"}], "]"}], "]"}]}], "//", 
   "Dataset"}]}]], "Input",ExpressionUUID->"1b6d6b4d-46b8-432e-b7e4-\
eb05ac63ddef"]
}, Open  ]],

