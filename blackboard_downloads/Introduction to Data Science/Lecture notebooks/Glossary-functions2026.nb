Cell[CellGroupData[{

Cell["Updating a dataset selectively :", "Item",
 CellChangeTimes->{{3.977465977835381*^9, 
  3.977465984021429*^9}},ExpressionUUID->"9399d4f8-409b-4f39-9a82-\
92ea15ff5644"],

Cell[BoxData[
 RowBox[{"titanic1", "=", 
  RowBox[{
   RowBox[{"Query", "[", 
    RowBox[{"All", ",", 
     RowBox[{
      RowBox[{"Association", "[", 
       RowBox[{"#", ",", 
        RowBox[{"\"\<age\>\"", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"#sex", "===", "\"\<male\>\""}], ",", 
           RowBox[{"#age", "+", "1"}], ",", "#age"}], "]"}]}]}], "]"}], 
      "&"}]}], "]"}], "[", "titanic", "]"}]}]], "Input",ExpressionUUID->\
"f54a8f0c-c4b2-4f14-91a9-914ec791664e"]
}, Open  ]],

