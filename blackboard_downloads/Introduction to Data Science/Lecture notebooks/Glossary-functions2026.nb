Cell[CellGroupData[{

Cell["Updating a Dataset to impute \"\" with a global average :", "Item",
 CellChangeTimes->{{3.977380022272241*^9, 
  3.9773800602358627`*^9}},ExpressionUUID->"786fca5f-de20-4155-9dfb-\
9555cb7fb9f3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"AverageX", "=", 
   RowBox[{"Mean", "@", 
    RowBox[{
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"Normal", "@", "dataset"}], ",", 
       RowBox[{
        RowBox[{"#VariableX", "=!=", 
         RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], "&"}]}], 
      "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "\"\<VariableX\>\""}], "]"}], "]"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.97737456810682*^9, 
  3.977374569195826*^9}},ExpressionUUID->"b0367b94-f6c3-4ba3-9a3d-\
f8531c35f670"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cleanedDataset", "=", 
   RowBox[{"dataset", "[", 
    RowBox[{"All", ",", 
     RowBox[{
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<PrimaryKey\>\"", "->", "#PrimaryKey"}], ",", 
        RowBox[{"\"\<VariableX\>\"", "->", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"#VariableX", "===", 
            RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], ",", 
           "averageX", ",", "#VariableX"}], "]"}]}], ",", 
        RowBox[{"\"\<VariableY\>\"", "->", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"#VariableY", "===", 
            RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], ",", 
           "averageY", ",", "#VariableY"}], "]"}]}]}], "|>"}], "&"}]}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9773746111948223`*^9, 3.97737461366774*^9}, {
  3.977374708879682*^9, 
  3.97737472846692*^9}},ExpressionUUID->"dd9e5e2a-a010-4dff-a5b9-\
4a8b0c6fbf6a"]
}, Open  ]],

Cell["Discretizing a list by using Replace:", "Text",
 CellChangeTimes->{{3.9773746111948223`*^9, 3.97737461366774*^9}, {
  3.977374708879682*^9, 3.977374735766304*^9}, {3.97738006773909*^9, 
  3.977380080039139*^9}},ExpressionUUID->"235fad97-6d8f-4a9c-a318-\
edf182d05b67"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"databridge", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "11"}], "]"}], "]"}], "=", 
   RowBox[{"Replace", "[", 
    RowBox[{
     RowBox[{"databridge", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "11"}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<SHORT\>\"", "\[Rule]", " ", "1"}], ",", 
       RowBox[{"\"\<MEDIUM\>\"", "\[Rule]", " ", "2"}], ",", 
       RowBox[{"\"\<LONG\>\"", "\[Rule]", " ", "3"}]}], "}"}], ",", 
     RowBox[{"{", "1", "}"}]}], " ", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9773746111948223`*^9, 3.97737461366774*^9}, {
  3.977374708879682*^9, 
  3.977374731115803*^9}},ExpressionUUID->"027b8acc-e1ad-467e-872e-\
62b93ac2dec1"],

