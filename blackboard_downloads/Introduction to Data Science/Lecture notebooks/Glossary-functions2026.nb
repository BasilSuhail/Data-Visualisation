Cell[CellGroupData[{

Cell["\<\
Selecting from a list using Cases with a pattern. \
{\[OpenCurlyDoubleQuote]Brazil\[CloseCurlyDoubleQuote] | \
\[OpenCurlyDoubleQuote]Germany\[CloseCurlyDoubleQuote], _?(1990 <= # <= 2021 \
&), ___} Matches a list whose : First element = \[OpenCurlyDoubleQuote]Brazil\
\[CloseCurlyDoubleQuote] or \[OpenCurlyDoubleQuote]Germany\
\[CloseCurlyDoubleQuote] Second element = a year between 1990 and 2021
Remaining elements = anything (or nothing)\
\>", "Item",
 CellChangeTimes->{{3.977380250121387*^9, 3.9773802602955303`*^9}, {
  3.977380675641056*^9, 
  3.977380727034195*^9}},ExpressionUUID->"026338b9-f8ad-4d68-8193-\
a9736628340c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"emissionReducedCountries", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"emissionReduced1", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<Brazil\>\"", "|", " ", "\"\<Germany\>\""}], ",", 
       RowBox[{"_", "?", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"1990", "<=", "#", "<=", "2021"}], "&"}], ")"}]}], ",", 
       "___"}], "}"}]}], "]"}]}], ";"}]], "Input",ExpressionUUID->"659be4c0-\
a1da-489f-935d-e07f0895b43c"]
}, Open  ]],

