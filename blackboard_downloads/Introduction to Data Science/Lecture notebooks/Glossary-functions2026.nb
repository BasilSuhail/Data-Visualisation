 FontSize->13,
 FontWeight->"Regular",ExpressionUUID->"ef6a856b-d701-4cd5-82bd-9ca91d3b654b"],

Cell[TextData[StyleBox["To disable this do :",
 FontSize->24,
 FontWeight->"Regular"]], "Text",
 CellChangeTimes->{{3.947761948210477*^9, 3.9477619733544893`*^9}},
 FontFamily->"Source Sans Pro",
 FontSize->13,
 FontWeight->"Regular",ExpressionUUID->"336dcb1c-b324-41eb-bab8-d3ce1f9730cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SetFileFormatProperties", "[", 
  RowBox[{"\"\<CSV\>\"", ",", 
   RowBox[{"\"\<DefaultImportElement\>\"", "->", "\"\<RawData\>\""}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.9477616405388412`*^9, 3.947761640542611*^9}, {
  3.947761741315177*^9, 3.947761777809483*^9}},
