Cell[CellGroupData[{

Cell["Revoking Account Privileges", "Section",
 CellChangeTimes->{{3.779344517170478*^9, 
  3.779344519660268*^9}},ExpressionUUID->"70e1f604-bc17-4eca-be2a-\
fec7efa0ecfb"],

Cell["\<\
To revoke account privileges, use the REVOKE statement.Privileges can be \
revoked at different levels, just as they can be granted at different levels.\
\
\>", "Text",
 CellChangeTimes->{{3.813435349422339*^9, 
  3.813435351223092*^9}},ExpressionUUID->"93935b21-c4bb-45f5-9fda-\
89b4d14aacb7"],

Cell["Revoke global privileges :", "Text",
 CellChangeTimes->{{3.813435357358057*^9, 
  3.813435358844583*^9}},ExpressionUUID->"939e6c91-14bf-47ff-8052-\
846de89b8ea4"],

Cell["\<\
REVOKE ALL
ON *.*
FROM 'finley'@'localhost';

REVOKE RELOAD
ON *.*
FROM 'admin'@'localhost';\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.813435365290722*^9, 3.813435384895337*^9}, {
  3.875712262568816*^9, 3.875712267240731*^9}, {3.9500217976950417`*^9, 
  3.9500217996402884`*^9}},ExpressionUUID->"67d6b123-8d97-4ea1-bb5b-\
5390e7b49573"],

Cell["Revoke database - level privileges :", "Text",
 CellChangeTimes->{{3.8134354119760027`*^9, 3.813435436111991*^9}, 
   3.813435540572061*^9},ExpressionUUID->"d4e8fe1f-e95f-4fcd-84f2-\
109000af9ae5"],

Cell["\<\
REVOKE CREATE, DROP
ON expenses.*
FROM 'custom'@'host47.example.com';\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.8134354119760027`*^9, 3.8134354518781*^9}, {
  3.813435538969399*^9, 
  3.813435566660334*^9}},ExpressionUUID->"516263a1-1135-4759-a491-\
110874db5df5"],

Cell["Revoke table - level privileges : ", "Text",
 CellChangeTimes->{{3.8134354119760027`*^9, 3.813435454000935*^9}, 
   3.813435530542691*^9, {3.813435574863629*^9, 3.81343557989491*^9}, {
   3.813435618840773*^9, 
   3.813435622057047*^9}},ExpressionUUID->"0cee0474-b1c9-4e9c-a8d5-\
70b6101f897e"],

Cell["\<\
REVOKE INSERT, UPDATE, DELETE
ON customer.addresses
FROM 'custom'@'%.example.com';\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.8134354119760027`*^9, 3.813435454000935*^9}, {
  3.813435532416399*^9, 3.81343553429354*^9}, {3.8134355819839077`*^9, 
  3.813435614643878*^9}},ExpressionUUID->"82f18b22-1475-427b-80b5-\
926382a93779"],

Cell["\<\
To check the effect of privilege revocation, use SHOW GRANTS :\
\>", "Text",
 CellChangeTimes->{{3.8134354119760027`*^9, 3.8134354726732483`*^9}, 
   3.813435522549649*^9},ExpressionUUID->"62ca0a17-5b55-40f5-8b85-\
6f67edd30247"],

Cell["\<\
mysql > SHOW GRANTS FOR 'admin'@'localhost';

+---------------------------------------------+
 | Grants for admin@localhost | +---------------------------------------------+
 | GRANT PROCESS ON*.*TO' admin'@' localhost' | \
+---------------------------------------------+\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.8134354119760027`*^9, 3.8134354937426567`*^9}, 
   3.813435525969427*^9, {3.813435631032168*^9, 
   3.813435641777355*^9}},ExpressionUUID->"56a9df6f-bb10-414a-9202-\
66922b772ba2"],

Cell[TextData[{
 StyleBox["\n",
  FontColor->RGBColor[1, 0, 0]],
 StyleBox["Once you create a new user, open a new window and try to connect \
to the DB using this new account",
  FontColor->GrayLevel[0]]
}], "Text",
 CellChangeTimes->{{3.779345405168417*^9, 3.779345434394653*^9}, {
  3.813435899973909*^9, 
  3.813435904201439*^9}},ExpressionUUID->"b746a3c2-dc05-40c2-a695-\
dcc3a2fdc085"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Querying info about users:", "Section",
 CellChangeTimes->{{3.8134394106563053`*^9, 
  3.8134394179466257`*^9}},ExpressionUUID->"ab5b0c16-1a7d-440d-b09f-\
0e72fe286cab"],

Cell[TextData[StyleBox["To show users of the database use, query for the user \
table named mysql.user. All the information can be viewed using ",
 FontColor->GrayLevel[0]]], "Text",
 CellChangeTimes->{{3.779345405168417*^9, 3.779345434394653*^9}, {
   3.813435899973909*^9, 3.813435939786135*^9}, {3.813438089384105*^9, 
