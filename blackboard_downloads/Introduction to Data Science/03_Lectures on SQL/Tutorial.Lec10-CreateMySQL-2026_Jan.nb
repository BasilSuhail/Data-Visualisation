  "/"}]], "Input",
 CellChangeTimes->{{3.980528927533618*^9, 
  3.980528938008699*^9}},ExpressionUUID->"201bbd5a-6640-4f1f-8b04-\
75c495a27719"],

Cell["\<\
It is a protected folder, in Mac, open Finder, then go to Go, and click the \
option key . \
\>", "Text",
 CellChangeTimes->{{3.9805289499868193`*^9, 
  3.980528991418046*^9}},ExpressionUUID->"6a84eadd-f445-44ba-b614-\
8844f0d05ae6"],

Cell["\<\
From here you can simply go below and define a named connection, or connect \
directly.  But if you want to use the connection tool, so:\
\>", "Text",
 CellChangeTimes->{{3.980527895794375*^9, 
  3.980527932855454*^9}},ExpressionUUID->"fbb35ea0-e546-489d-8881-\
590be03dcd65"],

Cell["Open the tool and type the MariaDB URL explicitly :", "Text",
 CellChangeTimes->{{3.98052781645185*^9, 
  3.980527818279045*^9}},ExpressionUUID->"91490c1a-c215-4ce0-87aa-\
7f687058d5a9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OpenSQLConnection", "[", "]"}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"opens", " ", "the", " ", "tool"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.980527829710886*^9, 3.980527829713606*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"dce9c938-3190-4ac4-a619-c5e905ba0e43"],

Cell["\<\
When the Connection Tool window opens, fill in : 

Driver : MySQL (Connector/J)
Server : 127.0 .0 .1 (Use this instead of localhost to avoid DNS or IPv6 \
issues .)
Port : 3306
Database : test
Username : root
Password : 12345678\
\>", "Text",
 CellChangeTimes->{{3.980527855487282*^9, 
  3.980527866332931*^9}},ExpressionUUID->"e519108a-a5c6-431c-98ac-\
58d02ccde905"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Or do a save connection directly without the use of conneciton tool: \
\>", "Section",
 CellChangeTimes->{{3.9805258824498463`*^9, 3.9805259204044447`*^9}, 
   3.980529530485013*^9, {3.980529643899027*^9, 
   3.980529675056985*^9}},ExpressionUUID->"34f7f872-98c6-4446-a4bb-\
c9930093e46d"],

Cell["clear any stuck Java/JDBC state", "Text",
 CellChangeTimes->{{3.9805259313409853`*^9, 
  3.980525932300599*^9}},ExpressionUUID->"3de02f61-d00f-4d92-ae30-\
e40879e6e272"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Needs", "[", "\"\<JLink`\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ReinstallJava", "[", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Needs", "[", "\"\<DatabaseLink`\>\"", "]"}], ";"}], "\n"}], "Input",\

 CellChangeTimes->{{3.980525940398115*^9, 3.980525940401272*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"edffbfa9-9a7c-4669-bcbb-16a7f9158db7"],

Cell["\<\
Try the safe MariaDB\:2011driver connection (the default in WL 14.3). Uses \
127.0.0.1 (no DNS), short timeouts, no pooling, no SSL while testing.\
\>", "Text",
 CellChangeTimes->{{3.980525970375597*^9, 
  3.980525983322678*^9}},ExpressionUUID->"ad2ab9b4-f38a-46b0-b573-\
bca3ec5bca3d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"conn", "=", 
    RowBox[{"Check", "[", 
     RowBox[{
      RowBox[{"OpenSQLConnection", "[", 
       RowBox[{
        RowBox[{"JDBC", "[", 
         RowBox[{"\"\<MySQL(Connector/J)\>\"", 
          ",", "\"\<127.0.0.1:3306/test\>\""}], "]"}], ",", 
        RowBox[{"\"\<Username\>\"", "->", "\"\<root\>\""}], ",", 
        RowBox[{"\"\<Password\>\"", "->", "\"\<12345678\>\""}], ",", 
        RowBox[{"\"\<UseConnectionPool\>\"", "->", "False"}], ",", 
        RowBox[{"\"\<LoginTimeout\>\"", "->", "5"}], ",", 
        RowBox[{"\"\<Properties\>\"", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\"\<connectTimeout\>\"", "->", "\"\<5000\>\""}], ",", 
           RowBox[{"(*", "ms", "*)"}], 
           RowBox[{"\"\<socketTimeout\>\"", "->", "\"\<5000\>\""}], ",", 
           RowBox[{"(*", "ms", "*)"}], 
           RowBox[{"\"\<useSSL\>\"", "->", "\"\<false\>\""}], ",", 
           RowBox[{"\"\<serverTimezone\>\"", "->", "\"\<UTC\>\""}], ",", 
           
           RowBox[{"\"\<allowPublicKeyRetrieval\>\"", 
            "->", "\"\<true\>\""}]}], "  ", 
          RowBox[{"(*", 
           RowBox[{"helps", " ", "when", " ", "SSL", " ", "is", " ", "off"}], 
           "*)"}], "}"}]}]}], "]"}], ",", "$Failed"}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"{", 
  RowBox[{"conn", ",", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"conn", "=!=", "$Failed"}], ",", 
     RowBox[{
      RowBox[{"SQLConnectionInformation", "[", "conn", "]"}], 
      "[", "\"\<Driver\>\"", "]"}], ",", "$Failed"}], "]"}]}], 
  "}"}], "\n"}], "Input",
 CellChangeTimes->{{3.980526004058545*^9, 3.9805260040597687`*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"07db2acd-b1f6-448f-a1a6-0dfda1cba745"],

Cell["\<\
If this succeeds : the stall was a blocking negotiation; keep the timeouts \
and then re\:2011enable pooling/SSL later if you need them.\
\>", "Text",
 CellChangeTimes->{{3.980526045787856*^9, 3.980526047654647*^9}, 
   3.9805264362958193`*^9},ExpressionUUID->"293dfd4e-ef4f-47f7-a513-\
f1063331af7c"],

Cell["Safe test :", "Text",
 CellChangeTimes->{{3.9805264307304153`*^9, 
  3.9805264332333107`*^9}},ExpressionUUID->"14cbe1a0-1b2f-4236-bcbd-\
1dafd8a96fc4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SQLExecute", "[", 
  RowBox[{"conn", ",", "\"\<SELECT 1+1 AS two\>\""}], "]"}]], "Input",
 CellChangeTimes->{{3.9805263992690697`*^9, 3.980526399271894*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"0e878811-7225-4357-a022-0e141974203e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", "2", "}"}], "}"}]], "Output",
 CellChangeTimes->{3.9805264065485992`*^9},
 CellLabel->"Out[13]=",ExpressionUUID->"5d077dcf-bc9f-4902-aaea-7730d17c8350"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"CloseSQLConnection", "[", "conn", "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.980526451744897*^9, 3.980526451747628*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"080fd896-9d39-4a69-a071-76a67002d710"],

Cell["Another safe test to connect", "Text",
 CellChangeTimes->{{3.980526734816966*^9, 
  3.980526744964321*^9}},ExpressionUUID->"96a251ab-c017-47af-9bda-\
6c67e6c99ca0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Needs", "[", "\"\<DatabaseLink`\>\"", "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"conn", "=", 
    RowBox[{"OpenSQLConnection", "[", 
     RowBox[{
      RowBox[{"JDBC", "[", 
       RowBox[{"\"\<MySQL(Connector/J)\>\"", 
        ",", "\"\<127.0.0.1:3306/test\>\""}], "]"}], ",", 
      RowBox[{"\"\<Username\>\"", "->", "\"\<root\>\""}], ",", 
      RowBox[{"\"\<Password\>\"", "->", "\"\<12345678\>\""}], ",", 
      RowBox[{"\"\<UseConnectionPool\>\"", "->", "False"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "avoids", " ", "any", " ", "pool", " ", "lock", " ", "while", " ", 
        "testing"}], "*)"}], 
      RowBox[{"\"\<LoginTimeout\>\"", "->", "5"}], ",", 
      RowBox[{"(*", "seconds", "*)"}], 
      RowBox[{"\"\<Properties\>\"", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<connectTimeout\>\"", "->", "\"\<5000\>\""}], ",", 
         RowBox[{"(*", "ms", "*)"}], 
         RowBox[{"\"\<socketTimeout\>\"", "->", "\"\<5000\>\""}], ",", 
         RowBox[{"(*", "ms", "*)"}], 
         RowBox[{"\"\<useSSL\>\"", "->", "\"\<false\>\""}], ",", 
         RowBox[{"(*", 
          RowBox[{"local", " ", "dev"}], "*)"}], 
         RowBox[{"\"\<serverTimezone\>\"", "->", "\"\<UTC\>\""}], ",", 
         RowBox[{"\"\<allowPublicKeyRetrieval\>\"", "->", "\"\<true\>\""}]}], 
        "}"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SQLConnectionInformation", "[", "conn", "]"}], 
  "[", "\"\<Driver\>\"", "]"}], "\n"}], "Input",
 CellChangeTimes->{{3.980526746539912*^9, 3.980526746542701*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"ea4d48f7-5425-4a91-abfb-b8fd70e378ce"]
}, Open  ]]
}, Open  ]]
},
