Cell["\<\
where your_mysql _name is the MySQL user name assigned to you (root) and \
your_client _host (localhost) is the host from which you connect to the \
server.\
\>", "Text",
 CellChangeTimes->{{3.7793431941156*^9, 3.779343195952381*^9}, {
  3.779614495592114*^9, 
  3.77961450541641*^9}},ExpressionUUID->"535d71c2-c095-49ad-a00d-\
2306376a36cb"],

Cell["\<\
mysql> grant all on test.* TO 'root'@'localhost';
\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.779614537932914*^9, 3.779614559434233*^9}, 
   3.779614706938154*^9, {3.7796292140155077`*^9, 3.779629219123097*^9}, {
   3.780038648445605*^9, 3.78003865204111*^9}, {3.813433664716189*^9, 
   3.813433669626089*^9}, {3.813440974391638*^9, 
   3.813440975979884*^9}},ExpressionUUID->"01734d6b-6ea3-4668-b900-\
fe27024582d7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"f84faab4-f82b-4f66-aea1-a0c39e16a957"],

Cell[CellGroupData[{

Cell[TextData[{
 "Adding Accounts, Assigning Privileges, and Dropping Accounts [",
 ButtonBox["Documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.0/en/creating-accounts.html"], 
    None},
  ButtonNote->
   "https://dev.mysql.com/doc/refman/8.0/en/creating-accounts.html"],
 "]"
}], "Section",
 CellChangeTimes->{{3.7793439971880207`*^9, 
  3.779344024022216*^9}},ExpressionUUID->"f808f3a6-e1a1-45b6-9c37-\
34e8aa641cb1"],

Cell["\<\

To manage MySQL accounts, use the SQL statements intended for that purpose :\
\>", "Text",
 CellChangeTimes->{{3.779344026103633*^9, 3.779344048916814*^9}, {
  3.813434283769669*^9, 3.813434284585944*^9}, {3.813435836168065*^9, 
  3.8134358368657837`*^9}},ExpressionUUID->"a77efd9f-6a46-4dbf-83be-\
0d358dfecfec"],

Cell["CREATE USER and DROP USER create and remove accounts.", "Item",
 CellChangeTimes->{{3.779344026103633*^9, 
  3.779344057571423*^9}},ExpressionUUID->"297de3d1-7dfa-4bba-bac0-\
501f3cc8482c"],

Cell["\<\
GRANT and REVOKE assign privileges to and revoke privileges from accounts.\
\>", "Item",
 CellChangeTimes->{{3.779344026103633*^9, 
  3.7793440611709557`*^9}},ExpressionUUID->"02083c20-23b8-44de-a56d-\
534796f8b800"],

Cell["SHOW GRANTS displays account privilege assignments.", "Item",
 CellChangeTimes->{{3.779344026103633*^9, 
  3.779344053634291*^9}},ExpressionUUID->"02e54dc4-081a-4bb5-abf4-\
98640debc34b"],

Cell["\<\
The following example uses CREATE USER and GRANT statements to set up four \
accounts (where you see' password', substitute an appropriate password) :\
\>", "Text",
 CellChangeTimes->{{3.779344335624364*^9, 
  3.779344336743034*^9}},ExpressionUUID->"4af4f38c-974a-4d74-ac51-\
ee53dff80dc1"],

Cell["\<\
CREATE USER 'finley'@'localhost'
IDENTIFIED BY 'password';
GRANT ALL
ON *.*
TO 'finley'@'localhost'
WITH GRANT OPTION;

CREATE USER 'finley'@'%.example.com'
IDENTIFIED BY 'password';
GRANT ALL
ON *.*
TO 'finley'@'%.example.com'
WITH GRANT OPTION;

CREATE USER 'admin'@'localhost'
IDENTIFIED BY 'password';
GRANT RELOAD, PROCESS
ON *.*
TO 'admin'@'localhost';

CREATE USER' dummy'@'localhost';\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.813434367012516*^9, 3.813434399042108*^9}, {
  3.813434433893623*^9, 
  3.813434497631335*^9}},ExpressionUUID->"b890170e-fa81-4317-86e7-\
69b208b15291"],

Cell[BoxData[""], "Input",
 CellChangeTimes->{
  3.813434543101355*^9},ExpressionUUID->"5aa738be-f371-42e0-955b-\
c365dbc841a2"],

Cell["\<\
The previous example grants privileges at the global level. The next example \
creates three accounts and grants them access at lower levels to specific \
databases or objects within the databases. Each account has a user name of \
custom, but the host name parts differ:\
\>", "Text",
 CellChangeTimes->{{3.779344361168583*^9, 3.779344385399414*^9}, {
  3.813396303870495*^9, 3.8133963101257267`*^9}, {3.813433266606758*^9, 
  3.8134332776931543`*^9}, {3.813434613947349*^9, 
  3.813434650933352*^9}},ExpressionUUID->"225ada73-47ef-4089-a59b-\
0a916608624f"],

Cell["\<\
CREATE USER 'custom'@'localhost'
IDENTIFIED BY 'password';
GRANT ALL
ON bankaccount.*
TO 'custom'@'localhost';

CREATE USER 'custom'@'host47.example.com'
IDENTIFIED BY 'password';
GRANT SELECT, INSERT, UPDATE, DELETE, CREATE, DROP
ON expenses.*
TO 'custom'@'host47.example.com';

CREATE USER 'custom'@'%.example.com'
IDENTIFIED BY 'password';
GRANT SELECT, INSERT, UPDATE, DELETE, CREATE, DROP
ON customer.addresses
TO 'custom'@'%.example.com';\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.813434656845725*^9, 
  3.813434747644059*^9}},ExpressionUUID->"026f7f27-3235-42e1-be76-\
343052afb89a"],

Cell["Let us create a user : ", "Text",
 CellChangeTimes->{{3.780039141355118*^9, 3.78003917255161*^9}, {
   3.780039344219328*^9, 3.78003934497265*^9}, {3.813396576826517*^9, 
   3.8133965898406353`*^9}, {3.813396620409995*^9, 3.813396621674067*^9}, {
   3.813396667488699*^9, 3.813396675992682*^9}, {3.813434792325358*^9, 
   3.813434802268429*^9}, 
   3.813440996213994*^9},ExpressionUUID->"095cd56a-94d3-4bca-b142-\
33f7788dcf8e"],

Cell["\<\
CREATE USER 'finley'@'localhost'
IDENTIFIED BY 'password';
GRANT ALL
ON *.*
TO 'finley'@'localhost'
WITH GRANT OPTION;\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.813434804350101*^9, 
  3.8134348173797197`*^9}},ExpressionUUID->"82220cdc-f52c-4411-952d-\
f5d6e016f327"]
}, Open  ]],

