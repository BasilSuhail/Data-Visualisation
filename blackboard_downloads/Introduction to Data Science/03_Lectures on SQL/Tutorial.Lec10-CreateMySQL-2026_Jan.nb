Cell[CellGroupData[{

Cell["Appendix D: Updating the Connector/J driver", "Section",
 CellChangeTimes->{{3.855303944604998*^9, 3.855303963238689*^9}, {
  3.950027839507206*^9, 
  3.950027842137587*^9}},ExpressionUUID->"10c224d0-dde1-4501-b475-\
ab406a1500c0"],

Cell[TextData[{
 "If you would like to update the driver, download the MySQL Connector/J \
driver at ",
 ButtonBox["Link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/downloads/connector/j/"], None},
  ButtonNote->"https://dev.mysql.com/downloads/connector/j/"],
 ". ",
 StyleBox["Choose Platform Independent for Mac and also for windows",
  FontWeight->"Bold"],
 ", other systems can be chosen as well. "
}], "Text",
