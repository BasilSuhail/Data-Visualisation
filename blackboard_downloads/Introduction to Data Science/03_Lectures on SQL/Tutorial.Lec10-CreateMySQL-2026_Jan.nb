Cell["\<\
CREATE TABLE pet (name VARCHAR(20), owner VARCHAR(20), species VARCHAR(20), \
sex CHAR(1), birth DATE, death DATE);\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.779298146762533*^9, 3.779298146764605*^9}, 
