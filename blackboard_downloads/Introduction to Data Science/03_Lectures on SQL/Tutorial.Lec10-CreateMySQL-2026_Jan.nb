Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"d133c74f-af11-463d-a08e-70051639f97d"],

Cell[TextData[{
 "Creating and Using a Database [",
 ButtonBox["Documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.0/en/database-use.html"], None},
  ButtonNote->"https://dev.mysql.com/doc/refman/8.0/en/database-use.html"],
 "]"
}], "Title",
 CellChangeTimes->{{3.779295181401441*^9, 
  3.779295200711438*^9}},ExpressionUUID->"32f04a34-3711-4a05-aa55-\
668d234e69c6"],

Cell[CellGroupData[{

Cell["Create a Database test :", "Item",
 CellChangeTimes->{{3.77929699863628*^9, 3.779297015668775*^9}, {
  3.779297062627225*^9, 
  3.779297063223937*^9}},ExpressionUUID->"fea6ef91-4550-43af-bc63-\
107f35c90711"],

Cell["mysql > CREATE DATABASE test;", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.77929699863628*^9, 3.779297022869869*^9}, {
  3.813440599890622*^9, 
  3.813440610404749*^9}},ExpressionUUID->"72dcb68f-9190-4cb6-974c-\
540d8decf353"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Notice that in the command line you type only ", "Item",
 CellChangeTimes->{{3.780037053887162*^9, 
  3.780037062490877*^9}},ExpressionUUID->"c4769be4-1b72-493c-bb37-\
2766a122e653"],

Cell["CREATE DATABASE test;", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.780037053887162*^9, 3.780037067622038*^9}, {
  3.813440620086594*^9, 3.813440631684821*^9}, {3.8866872094332533`*^9, 
  3.886687210267415*^9}},ExpressionUUID->"21731428-f55c-485f-86fb-\
13cd8baeb9a9"],

Cell["\<\
Notice that under UNIX/MacOS/Linux, names are  case sensitive!\
\>", "Subitem",
 CellChangeTimes->{{3.779297027829167*^9, 
  3.779297071593848*^9}},ExpressionUUID->"1eecf7b5-6b3a-4b56-b72f-\
3c5405d0662d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Creating a database does not select it for use; you must do that explicitly. \
To make test the current database, use this statement:\
\>", "Item",
 CellChangeTimes->{{3.779297027829167*^9, 3.779297089955332*^9}, {
  3.7792973471482577`*^9, 
  3.7792973471484632`*^9}},ExpressionUUID->"235298ea-16b9-435f-aa59-\
8b9b4f36f03c"],

Cell["mysql > USE test", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.779297027829167*^9, 3.779297089955332*^9}, {
  3.779297348369026*^9, 3.779297352137776*^9}, {3.779297496720213*^9, 
  3.779297496720459*^9}, {3.780037114034736*^9, 3.780037123318343*^9}, {
  3.813440642940365*^9, 
  3.813440645246458*^9}},ExpressionUUID->"eacff67e-202e-490c-93ee-\
d892db90e4fa"]
}, Open  ]],

Cell[CellGroupData[{

Cell["To connect directly to  Database from command line, use:", "Item",
 CellChangeTimes->{{3.779297027829167*^9, 3.779297089955332*^9}, {
  3.779297348369026*^9, 3.779297352137776*^9}, {3.779297498248916*^9, 
  3.7792975121206098`*^9}},ExpressionUUID->"8f5eb068-8f69-4168-a7bd-\
f4eddec4830c"],

Cell["shell > ./mysql -u root -p test", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.779297027829167*^9, 3.779297089955332*^9}, {
  3.779297348369026*^9, 3.779297352137776*^9}, {3.779297498248916*^9, 
  3.77929752641881*^9}, {3.779297567299017*^9, 3.77929758755399*^9}, {
  3.780037254823227*^9, 3.780037263865361*^9}, {3.813440656618561*^9, 
  3.813440661228101*^9}, {3.813574492219296*^9, 
  3.813574494166019*^9}},ExpressionUUID->"bb813f00-1596-4799-8233-\
329cee44f32c"],

Cell["test is not a password, but the Database", "Subitem",
 CellChangeTimes->{{3.779297027829167*^9, 3.779297089955332*^9}, {
   3.779297348369026*^9, 3.779297352137776*^9}, {3.779297498248916*^9, 
   3.77929752641881*^9}, {3.779297567299017*^9, 3.77929759611452*^9}, 
   3.779297639838669*^9, {3.779343633797666*^9, 3.779343633798144*^9}, {
   3.813395974235863*^9, 
   3.813395978680536*^9}},ExpressionUUID->"4dbfc08d-c16a-44e7-a07d-\
9feb5b9240af"]
}, Open  ]],

Cell[CellGroupData[{

Cell["You can also use :", "Item",
 CellChangeTimes->{{3.77934363720584*^9, 
  3.779343639943129*^9}},ExpressionUUID->"14b80456-9700-4e7a-b4ed-\
3b981f004232"],

Cell["shell > mysql -- user = user -- password test", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.779297027829167*^9, 3.779297089955332*^9}, {
   3.779297348369026*^9, 3.779297352137776*^9}, {3.779297498248916*^9, 
   3.77929752641881*^9}, {3.779297567299017*^9, 3.77929759611452*^9}, 
   3.779297639838669*^9, {3.779343641847115*^9, 3.779343654809708*^9}, {
   3.779343845832815*^9, 3.779343845834701*^9}, {3.813440671963149*^9, 
   3.813440674153558*^9}},ExpressionUUID->"45ece40f-290f-4b38-bc2a-\
5f00f5015b03"]
}, Open  ]],

Cell["\<\
Notice shell > only means the shell command line in terminal, do not type \
shell >\
\>", "Item",
 CellChangeTimes->{{3.780037356208896*^9, 3.780037376498424*^9}, 
   3.813395959138811*^9, {3.8134409563377247`*^9, 
   3.813440957805057*^9}},ExpressionUUID->"ffcd9389-7467-4c38-83ad-\
7c2bd0258ccd"],

Cell["\<\
In my MacOS installation (and also as in the Windows), the username was given \
to me as root. Notice that I am using a root account\
\>", "Item",
 CellChangeTimes->{{3.779345317671084*^9, 3.779345382808017*^9}, {
  3.779629180714644*^9, 3.779629188356845*^9}},
 FontWeight->"Bold",ExpressionUUID->"18a01e15-3620-42ce-8017-5c8b9c963448"],

Cell["My password was the one set during installation", "Item",
 CellChangeTimes->{{3.779345317671084*^9, 3.7793453925968447`*^9}},
 FontWeight->"Bold",ExpressionUUID->"807b2c39-aee8-4a76-b871-7752a8e98000"],

Cell[CellGroupData[{

Cell[TextData[{
 "A ",
 StyleBox["host ",
  FontWeight->"Bold"],
 "value can be a host name or an IP address (IPv4 or IPv6). The name \
\[OpenCurlyQuote]localhost\[CloseCurlyQuote] indicates the local host. "
}], "Item",
 CellChangeTimes->{{3.779297027829167*^9, 3.779297089955332*^9}, {
   3.779297348369026*^9, 3.779297352137776*^9}, {3.779297498248916*^9, 
   3.77929752641881*^9}, {3.779297567299017*^9, 3.77929759611452*^9}, 
   3.779297639838669*^9, {3.779343641847115*^9, 3.779343654809708*^9}, {
   3.779343847203697*^9, 
   3.7793438599047623`*^9}},ExpressionUUID->"9562fa8b-9de2-4e29-9b7c-\
c619c2011b5e"],

Cell["\<\
The IP address '127.0.0.1' indicates the IPv4 loopback interface.\
\>", "Subitem",
 CellChangeTimes->{{3.779297027829167*^9, 3.779297089955332*^9}, {
   3.779297348369026*^9, 3.779297352137776*^9}, {3.779297498248916*^9, 
   3.77929752641881*^9}, {3.779297567299017*^9, 3.77929759611452*^9}, 
   3.779297639838669*^9, {3.779343641847115*^9, 3.779343654809708*^9}, {
   3.779343847203697*^9, 
   3.779343865316436*^9}},ExpressionUUID->"fa7b6a00-01b7-4900-be54-\
f1dd1aac8e55"],

Cell["The IP address '::1' indicates the IPv6 loopback interface.", "Subitem",
 CellChangeTimes->{{3.779297027829167*^9, 3.779297089955332*^9}, {
   3.779297348369026*^9, 3.779297352137776*^9}, {3.779297498248916*^9, 
   3.77929752641881*^9}, {3.779297567299017*^9, 3.77929759611452*^9}, 
   3.779297639838669*^9, {3.779343641847115*^9, 3.779343654809708*^9}, {
   3.779343847203697*^9, 
   3.7793438647313647`*^9}},ExpressionUUID->"67dd0d68-5824-4a48-8c45-\
a3f2200bb8bb"]
}, Open  ]]
}, Open  ]],

