Cell["Look at the driver :", "Text",
 CellChangeTimes->{{3.980505247148155*^9, 
  3.980505250813982*^9}},ExpressionUUID->"d819c818-d50d-4adb-a15d-\
75e09200ffda"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"JDBCDrivers", "[", "\"\<MySQL(Connector/J)\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.98050524157557*^9, 3.980505241578586*^9}},
 CellLabel->"In[23]:=",ExpressionUUID->"bdcc23ba-b13c-4bb4-adaa-fc05b46fc89f"],

Cell[BoxData[
 RowBox[{"JDBCDriver", "[", 
  RowBox[{
   RowBox[{"\<\"Name\"\>", "\[Rule]", "\<\"MySQL(Connector/J)\"\>"}], ",", 
   RowBox[{"\<\"Driver\"\>", "\[Rule]", "\<\"org.mariadb.jdbc.Driver\"\>"}], ",", 
   RowBox[{"\<\"Protocol\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\<\"jdbc:mariadb://\"\>", 
      ",", "\<\"jdbc:mariadb:loadbalance://\"\>"}], "}"}]}], ",", 
   RowBox[{"\<\"Version\"\>", "\[Rule]", "4.1`"}], ",", 
   RowBox[{"\<\"Description\"\>", 
    "\[Rule]", "\<\"MySQL using Connector/J - Version 3.2.1\"\>"}], ",", 
   RowBox[{"\<\"Location\"\>", 
    "\[Rule]", "\<\"/Applications/Wolfram \
14.3.app/Contents/SystemFiles/Links/DatabaseLink/DatabaseResources/mysql.m\"\>\
"}]}], "]"}]], "Output",
 CellChangeTimes->{3.980505242378148*^9},
 CellLabel->"Out[23]=",ExpressionUUID->"24afc8cc-feaf-41c9-adc7-a32b4d656139"]
}, Open  ]],

Cell[CellGroupData[{

Cell["To open the connection in a safe mode, use :", "Subsubsection",
 CellChangeTimes->{{3.980527458907669*^9, 
  3.980527468080833*^9}},ExpressionUUID->"41d04748-31f8-4aed-86ba-\
a354827ad682"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"conn", "=", 
    RowBox[{"OpenSQLConnection", "[", 
     RowBox[{"\"\<testWL\>\"", ",", 
      RowBox[{"\"\<UseConnectionPool\>\"", "->", "False"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "turn", " ", "back", " ", "on", " ", "later", " ", "if", " ", "you", " ",
         "want"}], "*)"}], 
      RowBox[{"\"\<LoginTimeout\>\"", "->", "5"}], ",", 
      RowBox[{"\"\<Properties\>\"", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<connectTimeout\>\"", "->", "\"\<5000\>\""}], ",", 
         RowBox[{"\"\<socketTimeout\>\"", "->", "\"\<5000\>\""}], ",", 
         RowBox[{"\"\<useSSL\>\"", "->", "\"\<false\>\""}], ",", 
         RowBox[{"\"\<serverTimezone\>\"", "->", "\"\<UTC\>\""}], ",", 
         RowBox[{"\"\<allowPublicKeyRetrieval\>\"", "->", "\"\<true\>\""}]}], 
        "}"}]}]}], "]"}]}], ";"}], "\n"}]], "Input",
 CellChangeTimes->{{3.9805274703405857`*^9, 
  3.980527470343783*^9}},ExpressionUUID->"6dafa3e1-7554-4e84-a733-\
65cb6e4f3f2b"]
}, Open  ]],

