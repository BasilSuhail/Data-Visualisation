  3.779297549982921*^9}},ExpressionUUID->"ae17e160-b9c0-4e98-8531-\
9ed2cc7e9863"],

Cell["cd /usr/local/mysql/bin", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.779293631319693*^9, 3.779293758594677*^9}, {
  3.779293866498165*^9, 3.7792938932901087`*^9}, {3.7792940141496897`*^9, 
