Cell["\<\
There is a GUI method to connect to NAMED database (connection tool) that is \
invoked by executing OpenSQLConnection with no arguments :\
\>", "Text",
 CellChangeTimes->{{3.775476418667139*^9, 3.775476424212328*^9}, {
  3.779365063037519*^9, 3.7793650667587347`*^9}, {3.823712794894006*^9, 
  3.823712799593976*^9}, {3.844866045976614*^9, 
  3.8448660465727243`*^9}},ExpressionUUID->"ccfd047a-b264-411b-b69f-\
bd81a7f6bd6a"],

Cell[TextData[{
 StyleBox["Let us create a name, ", "Section"],
 StyleBox["testWL", "Section",
  FontVariations->{"Underline"->True}],
 StyleBox[",  (which contains the parameters) for the connection with \
database called ", "Section"],
 StyleBox["test", "Section",
  FontVariations->{"Underline"->True}]
}], "Text",
 CellChangeTimes->{{3.950022379632484*^9, 
  3.950022428725957*^9}},ExpressionUUID->"de456543-2baa-4eeb-8f15-\
ef8026b4a3bd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"conn", "=", 
   RowBox[{"OpenSQLConnection", "[", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.77936255072281*^9, 3.779362553659217*^9}, 
   3.813442001909423*^9, 3.81344811195083*^9, {3.813448651854508*^9, 
