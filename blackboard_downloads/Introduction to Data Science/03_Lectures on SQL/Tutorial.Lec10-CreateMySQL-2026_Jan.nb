Cell[CellGroupData[{

Cell["\<\
Creating your own MySQL database, and integrating it with Wolfram\
\>", "Section",
 CellChangeTimes->{{3.779285668280012*^9, 3.779285685923873*^9}, {
  3.813449653541481*^9, 
  3.8134496583412323`*^9}},ExpressionUUID->"c5942ded-ff15-45b5-a3b0-\
531cf6ba22b2"],

Cell["MySQL is the world' s most popular open - source database.", "Item",
 CellChangeTimes->{{3.779285768380467*^9, 
  3.779285775499918*^9}},ExpressionUUID->"c1ec95df-cfbe-4ede-be5a-\
d958151edc8e"],

Cell[TextData[{
 "This Tutorial follows the documentation at the ",
 ButtonBox["Reference Manual ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.0/en/"], None},
  ButtonNote->"https://dev.mysql.com/doc/refman/8.0/en/"],
 "and  ",
 ButtonBox["MySQL",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/mysql-getting-started/en/"], None},
  ButtonNote->"https://dev.mysql.com/doc/mysql-getting-started/en/"]
}], "Item",
 CellChangeTimes->{{3.779285768380467*^9, 3.779285811794083*^9}, {
  3.813434140308701*^9, 
  3.813434160755751*^9}},ExpressionUUID->"32a587b8-80dd-4d12-ab95-\
4bcf8cc76db3"],

Cell["\<\
We also explain how to perform some basic operations with MySQL using the \
MySQL client.\
\>", "Item",
 CellChangeTimes->{{3.77928587619228*^9, 3.779285884282368*^9}, {
  3.779285919538692*^9, 
  3.779285922370333*^9}},ExpressionUUID->"8b80d8ae-b9ed-4655-99ae-\
410b93edcc11"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"0d1a3d8f-668f-4c4e-b477-329cb4506636"],

Cell["Installing and Starting MySQL", "Title",
 CellChangeTimes->{{3.779285952199128*^9, 
  3.779285953740604*^9}},ExpressionUUID->"de063264-d2e2-4345-ac9c-\
2f65a26ce386"],

Cell[TextData[{
 ButtonBox["First, decide whether to install from a bugfix series like MySQL \
8.4, or use an innovation release like MySQL 9.6. ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/downloads/"], None},
  ButtonNote->"https://dev.mysql.com/downloads/"],
 StyleBox[ButtonBox["For January 2026 class, I will go with the 8.4! ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/downloads/"], None},
  ButtonNote->"https://dev.mysql.com/downloads/"],
  FontWeight->"Bold"]
}], "Item",
 CellChangeTimes->{{3.779285986575218*^9, 3.779286014190412*^9}, {
  3.7792865500602818`*^9, 3.779286550064233*^9}, {3.980495178976211*^9, 
  3.980495181669138*^9}},ExpressionUUID->"0f95962d-e6e2-4627-b92b-\
3bebab1f0b38"],

Cell[TextData[{
 StyleBox["Linux",
  FontWeight->"Bold"],
 " : The easiest way to install MySQL is to use the ",
 ButtonBox["MySQL repositories ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/downloads/"], None},
  ButtonNote->"https://dev.mysql.com/downloads/"],
 "or use ",
 ButtonBox["Link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.4/en/linux-installation.html"], 
    None},
  ButtonNote->
   "https://dev.mysql.com/doc/refman/8.4/en/linux-installation.html"]
}], "Item",
 CellChangeTimes->{{3.779285986575218*^9, 3.779286014190412*^9}, {
  3.7792865500602818`*^9, 3.779286550064233*^9}, {3.980495269406858*^9, 
  3.9804952828008842`*^9}},ExpressionUUID->"11f0bb46-8655-4c9d-b575-\
4aaad56e124e"],

Cell[TextData[{
 StyleBox["Microsoft Windows",
  FontWeight->"Bold"],
 ".  The recommended way to install MySQL on Microsoft Windows is to use the \
MySQL Installer. See ",
 ButtonBox["MySQL Installer Method",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/5.7/en/windows-installation.html#\
windows-installation-simple"], None},
  ButtonNote->
   "https://dev.mysql.com/doc/refman/5.7/en/windows-installation.html#windows-\
installation-simple"],
 " on how to download and run the MySQL Installer. For a detailed explanation \
for each step of the installation wizard, see ",
 ButtonBox["MySQL Installer for Windows",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.0/en/mysql-installer.html"], None},
  ButtonNote->
   "https://dev.mysql.com/doc/refman/8.0/en/mysql-installer.html"],
 ".",
 StyleBox[" Choose the community version. Use",
  FontVariations->{"Underline"->True}],
 StyleBox[ButtonBox[" Link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.4/en/windows-installation.html"], 
    None},
  ButtonNote->
   "https://dev.mysql.com/doc/refman/8.4/en/windows-installation.html"],
  FontVariations->{"Underline"->False}]
}], "Item",
 CellChangeTimes->{{3.779285986575218*^9, 3.779286056005524*^9}, {
  3.779286094457813*^9, 3.779286094458086*^9}, {3.7792864760736847`*^9, 
  3.779286522935721*^9}, {3.8134134498609877`*^9, 3.813413454944178*^9}, {
  3.9804952105736933`*^9, 
  3.9804952395175743`*^9}},ExpressionUUID->"7dbfd4ec-8e5b-42be-9aff-\
253c282646b4"],

Cell[TextData[{
 StyleBox["OS X.  The recommended way for installing MySQL on OS X is to use \
the ",
  FontWeight->"Bold"],
 StyleBox[ButtonBox["Link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.4/en/macos-installation.html"], 
    None},
  ButtonNote->
   "https://dev.mysql.com/doc/refman/8.4/en/macos-installation.html"],
  FontWeight->"Bold"],
 StyleBox[". Direct access to downloads is at ",
  FontWeight->"Bold"],
 StyleBox[ButtonBox["Link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/downloads/mysql/"], None},
  ButtonNote->"https://dev.mysql.com/downloads/mysql/"],
  FontWeight->"Bold"],
 StyleBox[". Download the \[OpenCurlyDoubleQuote]DMG Archive\
\[CloseCurlyDoubleQuote].",
  FontWeight->"Bold"]
}], "Item",
 CellChangeTimes->{{3.779285986575218*^9, 3.779286056005524*^9}, 
   3.779286095222168*^9, {3.779286443726788*^9, 3.779286443734419*^9}, {
   3.7792871234010267`*^9, 3.779287136552086*^9}, {3.779287610680174*^9, 
   3.779287618057008*^9}, 3.779289064749336*^9, 3.779289130425725*^9, 
   3.779293623338418*^9, {3.812994459106623*^9, 3.81299447238151*^9}, {
   3.8553112173496647`*^9, 3.855311220797657*^9}, {3.855311278999824*^9, 
   3.855311295200266*^9}, {3.8756132174596577`*^9, 3.875613231576046*^9}, {
   3.8756132664202547`*^9, 3.875613291351903*^9}, {3.917967491144858*^9, 
   3.9179674949346457`*^9}, {3.950019682259425*^9, 3.950019684314066*^9}, 
   3.950019758530136*^9, {3.980495019133511*^9, 3.980495047016*^9}, {
   3.980495108829886*^9, 3.9804951257945557`*^9}, 3.9804951771183577`*^9, 
   3.9804968377874947`*^9},ExpressionUUID->"5afae50f-ef97-4bf3-b289-\
4b671281c2f6"],

Cell[TextData[StyleBox["YOU  DO  NOT  NEED  TO  SIGN  UP  TO  ORACLE! Just \
click the link \[OpenCurlyDoubleQuote] No thanks, just start my download.\
\[CloseCurlyDoubleQuote]\n\nYou will be asked to enter a root password. DO \
NOT FORGET IT!",
 FontSize->24,
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.91796760645599*^9, 3.9179676260305223`*^9}, {
  3.9179676848403053`*^9, 3.917967697240925*^9}, {3.980496856137185*^9, 
  3.980496870274466*^9}},
 Background->None,ExpressionUUID->"047b2706-9fb1-40b2-a5fb-33e3e51c4b12"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"af5e942d-faac-450f-b7e0-3ec5774ddf2a"],

Cell["For Windows 10 (by Serena Lo Xu Ning) ", "Title",
 CellChangeTimes->{{3.813392150547113*^9, 
  3.813392197312967*^9}},ExpressionUUID->"7be71b66-da57-4ee5-82b8-\
b02565ea0bc2"],

Cell[TextData[{
 "How I installed mySQL on Win 10 : Follow this ",
 ButtonBox["link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.0/en/mysql-installer.html"], None},
  ButtonNote->
   "https://dev.mysql.com/doc/refman/8.0/en/mysql-installer.html"],
 ", download and install the application to get a \"MySQL Installer\". I \
chose \"Full\" setup type and just clicked through and installed everything."
}], "Item",
 CellChangeTimes->{{3.813392150547113*^9, 3.81339217114236*^9}, 
   3.813392203515588*^9, {3.813392273996496*^9, 
   3.813392316799039*^9}},ExpressionUUID->"ec832435-dc24-4290-a31f-\
556ce9f7dcdc"],

Cell["\<\
 Once that was done, I launched the \"MySQL Installer\" again and clicked on \
the \"add\[Ellipsis]\" button on the right menu to manually install the MySQL \
Workbench and also a MySQL Server when you will be given the option to create \
a username and pw to access your own MySQL.\
\>", "Item",
 CellChangeTimes->{{3.813392150547113*^9, 3.81339217114236*^9}, 
   3.813392203515588*^9, {3.813392273996496*^9, 3.813392331488222*^9}, {
   3.813488644656039*^9, 
   3.813488644658925*^9}},ExpressionUUID->"c4f460df-3bd2-4327-9a54-\
9dff968a2691"],

Cell["\<\
Then, go to apps, and execute \[OpenCurlyDoubleQuote]Command Line Client\
\[CloseCurlyDoubleQuote]. You will be asked for your root password. Once you \
entered, you have accessed the MySQL server.  \
\>", "Item",
 CellChangeTimes->{{3.813392150547113*^9, 3.81339217114236*^9}, 
   3.813392203515588*^9, {3.813392273996496*^9, 3.813392331488222*^9}, {
   3.813488645370166*^9, 3.813488672938041*^9}, {3.813491833074953*^9, 
   3.813491834513284*^9}, {3.813511115944197*^9, 3.8135111181261883`*^9}, {
   3.855313686652832*^9, 
   3.855313737090885*^9}},ExpressionUUID->"a7a84fba-2204-41f1-b7c8-\
e289760a82d1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"62169059-3e17-4109-9e56-7fd57750dd62"],

Cell["Activation of MySQL for Windows", "Title",
 CellChangeTimes->{{3.813511144460395*^9, 
  3.813511203321632*^9}},ExpressionUUID->"c704567f-aa72-4647-92ef-\
eadbb22042a3"],

Cell[TextData[{
 "To activate MySQL go to Start Menu, and choose ",
 StyleBox["MySQL command line",
  FontVariations->{"Underline"->True}],
 ". You will see a command line screen, this is the ",
 StyleBox["SQL server",
  FontVariations->{"Underline"->True}],
 ". "
}], "Item",
 CellChangeTimes->{{3.813511148702122*^9, 
  3.813511157995919*^9}},ExpressionUUID->"d94048d8-bf9a-4037-b0f4-\
0d864366eabb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"7a539929-31e3-461a-8173-4c43f1d922c6"],

Cell["Installation and activation of MySQL for MacOS", "Title",
 CellChangeTimes->{{3.7792881199078193`*^9, 3.7792881208034*^9}, {
   3.77928815371731*^9, 3.779288174288684*^9}, {3.779289188499608*^9, 
   3.7792891886274977`*^9}, {3.81351119083329*^9, 3.813511220015213*^9}, 
   3.980495783122136*^9},ExpressionUUID->"78862a65-a031-4e9e-af16-\
79a0de424902"],

Cell["mysql - 8.4 .8 - macos15 - arm64 . pkg", "Text",
 CellChangeTimes->{{3.980495780285448*^9, 
  3.9804957852956047`*^9}},ExpressionUUID->"642f1c6c-537f-4ae4-b4f8-\
d0c7e4644856"],

Cell["\<\
When installing using the package installer, the files are installed into a \
directory within /usr/local matching the name of the installation version and \
platform. For example, the installer file mysql - 8.4 .8 - macos15 - arm64 . \
pkg installs MySQL into /usr/local/ with a symlink to /usr/local/mysql. \
\>", "Item",
 CellChangeTimes->{{3.779289135919039*^9, 3.779289141648053*^9}, {
  3.813392532181985*^9, 3.813392532182301*^9}, {3.980495774120262*^9, 
  3.980495793332924*^9}, {3.980497004396373*^9, 
  3.9804970089849243`*^9}},ExpressionUUID->"c288fe5e-676e-4045-b774-\
1e7b8ed0cbaa"],

Cell["\<\
The version I downloaded and installed February 2025 is: \
mysql-9.2.0-macos15-arm64.pkg\
\>", "Item",
 CellChangeTimes->{{3.779289135919039*^9, 3.779289141648053*^9}, {
   3.813392533161942*^9, 3.813392544348578*^9}, {3.813392660746129*^9, 
   3.813392660746708*^9}, {3.875613554149417*^9, 3.875613587320176*^9}, {
   3.875613744403507*^9, 3.875613744405918*^9}, {3.875614581753495*^9, 
   3.875614581755991*^9}, {3.917967518310625*^9, 3.917967535204611*^9}, 
   3.9179675710406237`*^9, {3.950019805215266*^9, 
   3.950019823868947*^9}},ExpressionUUID->"a1e24bef-8a54-4530-b3b4-\
223a95bac59c"],

Cell[TextData[{
 "You will download the ",
 StyleBox[".dmg Archive",
  FontWeight->"Bold"],
 " which will create the installer .pkg file. "
}], "Item",
 CellChangeTimes->{{3.779289135919039*^9, 3.779289141648053*^9}, {
   3.813392533161942*^9, 3.813392544348578*^9}, {3.813392660746129*^9, 
   3.813392660746708*^9}, {3.875613554149417*^9, 3.875613587320176*^9}, {
   3.875613744403507*^9, 3.875613744405918*^9}, {3.875614582688272*^9, 
   3.875614685454855*^9}, {3.875614799757531*^9, 3.875614799760008*^9}, 
   3.9500199909542103`*^9, {3.980495526312315*^9, 
   3.980495528710144*^9}},ExpressionUUID->"34d5e1d3-7961-4555-9448-\
58d32ed7d31c"],

Cell["\<\
Finally, choose a password, and DO NOT FORGET. I chose my password 12345678\
\>", "Item",
 CellChangeTimes->{{3.779289135919039*^9, 3.779289141648053*^9}, {
  3.813392533161942*^9, 3.813392544348578*^9}, {3.813392660746129*^9, 
  3.813392660746708*^9}, {3.875613554149417*^9, 3.875613587320176*^9}, {
  3.875613744403507*^9, 3.875613744405918*^9}, {3.875614582688272*^9, 
  3.875614685454855*^9}, {3.87561480058027*^9, 3.875614806803801*^9}, {
  3.9179678972143393`*^9, 3.91796790197219*^9}, {3.917968007728037*^9, 
  3.917968018491716*^9}},
 Background->RGBColor[
  0.87, 0.94, 1],ExpressionUUID->"b5d89cc8-618f-4d2d-a550-19e5d0c4a1e9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"1913d0b9-9e58-43fa-a74e-7b85ec22d279"],

Cell[CellGroupData[{

Cell[TextData[{
 "Installing and Using the MySQL Launch Daemon (MacOS) [",
 ButtonBox["Documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.0/en/osx-installation-launchd.\
html"], None},
  ButtonNote->
   "https://dev.mysql.com/doc/refman/8.0/en/osx-installation-launchd.html"],
 "]"
}], "Section",
 CellChangeTimes->{{3.779289195296874*^9, 
  3.779289230750197*^9}},ExpressionUUID->"257a39f8-a1cb-44fe-9469-\
19732bb024cc"],

Cell["\<\
macOS uses launch-daemons to automatically start, stop, and manage processes \
and applications such as MySQL.\
\>", "Item",
 CellChangeTimes->{{3.779289310037559*^9, 3.779289336656642*^9}, {
  3.813393093639206*^9, 
  3.813393100728775*^9}},ExpressionUUID->"fc37377d-f5f1-4f25-9944-\
fbdeef4d34e8"],

Cell[CellGroupData[{

Cell["To enable the launch-d service do:", "Item",
 CellChangeTimes->{{3.779289310037559*^9, 3.779289359549062*^9}, {
   3.7792895257258387`*^9, 3.779289529070574*^9}, {3.812993019304801*^9, 
   3.8129930193561707`*^9}, 3.81339306687012*^9, {3.813393107050997*^9, 
   3.813393107109996*^9}, {3.813393140439262*^9, 
   3.813393142454293*^9}},ExpressionUUID->"19386ecf-1415-49f7-9564-\
0ad1337934cf"],

Cell["\<\
Open macOS system preferences and select the MySQL preference panel, and then \
execute Start MySQL Server. \
\>", "Subitem",
 CellChangeTimes->{{3.779289310037559*^9, 3.7792893620645742`*^9}, {
  3.875613949704813*^9, 
  3.875613967793925*^9}},ExpressionUUID->"543beb30-c7f4-4226-8ab8-\
52cdd3e2bd23"],

Cell["\<\
The Instances page includes an option to start or stop MySQL, and Initialize \
Database recreates the data/ directory. Uninstall uninstalls MySQL Server and \
optionally the MySQL preference panel and launch-d information.\
\>", "Subitem",
 CellChangeTimes->{{3.779289310037559*^9, 3.779289360528009*^9}, 
   3.779289398793918*^9, 
   3.81339311518182*^9},ExpressionUUID->"a79f25da-c187-4931-8322-\
f5356bb4a4c1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
The Instances page includes an option to activate or stop MySQL, and \
Initialize Database recreates the data/directory. Uninstall uninstalls MySQL \
Server and optionally the MySQL preference panel and launch-d information.\
\>", "Item",
 CellChangeTimes->{{3.779289472397986*^9, 3.77928947916672*^9}, 
   3.81339311919459*^9, {3.9179685480087757`*^9, 
   3.917968550287401*^9}},ExpressionUUID->"a1b20e39-d2d3-4f53-b80e-\
