  3.9072234504394712`*^9}},ExpressionUUID->"ccc55cd4-6305-417a-b77d-\
e71cd6315859"],

Cell[CellGroupData[{

Cell["For Mac type in the command line: ", "Subitem",
 CellChangeTimes->{{3.779293631319693*^9, 3.779293758594677*^9}, {
  3.779293866498165*^9, 3.7792938932901087`*^9}, {3.7792940141496897`*^9, 
  3.779294040560016*^9}, {3.77929409553838*^9, 3.779294112152286*^9}, {
