c9a1750cd17d"],

Cell["mysql> SELECT * from mysql.user;", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.813435943143765*^9, 3.813435946175777*^9}, {
  3.8134381376819897`*^9, 3.813438142157443*^9}, {3.813441010333506*^9, 
  3.813441011634416*^9}},ExpressionUUID->"0a0c8d9f-f899-42ed-b6d3-\
c4c77c1536ee"],

Cell["\<\
You can see only information about the values appearing in columns (e.g., \
host, user) of the table mysql.user related to info about the accounts, using \
: \
\>", "Text",
 CellChangeTimes->{{3.813439099187275*^9, 3.813439117342677*^9}, {
  3.813439231482304*^9, 3.813439238215501*^9}, {3.81343933980722*^9, 
  3.813439341093135*^9}, {3.813490862715771*^9, 
  3.8134909103942537`*^9}},ExpressionUUID->"492f2efb-1461-4870-8219-\
3069636570c1"],

Cell["musql> select host, user, grant_priv from mysql.user;", \
"ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.813439120079455*^9, 3.813439131556201*^9}, {
  3.813439224144998*^9, 3.813439225769208*^9}, {3.813439317670599*^9, 
