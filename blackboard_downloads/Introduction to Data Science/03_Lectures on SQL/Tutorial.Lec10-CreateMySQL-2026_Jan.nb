Cell[CellGroupData[{

Cell["Installing Mathematica", "Section",
 CellChangeTimes->{{3.907299715004019*^9, 
  3.907299718845487*^9}},ExpressionUUID->"85e3dd9a-a51f-4f56-802b-\
b2662c89bda2"],

Cell[TextData[{
 "Download the Mathematica installer ",
 Cell[BoxData[
  RowBox[{"Mathematica_", "13.2", ".1", "_BNDL", 
   RowBox[{"_LINUX", ".", "sh"}]}]], "InlineCode",ExpressionUUID->
  "535eb779-9adf-45e0-b30a-099885fb55a5"],
 " from the ",
 ButtonBox["Wolfram User Portal",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://user.wolfram.com/portal/myProducts.html"], None},
  ButtonNote->"https://user.wolfram.com/portal/myProducts.html"],
 ".\nAdd the file to your Nix store with the following commands:\n",
 StyleBox["$ chmod +x Mathematica_13.2.1_BNDL_LINUX.sh", "ExternalLanguage"],
 "\n",
 StyleBox["$ nix-store --add-fixed sha256 Mathematica_13.2.1_BNDL_LINUX.sh", 
  "ExternalLanguage"]
}], "Text",
 CellChangeTimes->{{3.907299849177942*^9, 3.907299869948931*^9}, {
   3.907299930400601*^9, 3.907299957742496*^9}, {3.907300024338335*^9, 
   3.907300051138633*^9}, {3.907300221877513*^9, 3.907300300655264*^9}, 
   3.907300660232538*^9},ExpressionUUID->"3d9c38ff-1d94-48a5-922d-\
0aa453a1e1ca"],

Cell[TextData[{
 "Add the following to your ",
 Cell[BoxData[
  RowBox[{"configuration", ".", "nix"}]], "InlineCode",ExpressionUUID->
  "f84c7406-bf66-4f2c-a0b2-2de99f79f55b"],
 " file:"
}], "Text",
 CellChangeTimes->{{3.907300066862874*^9, 3.907300071380168*^9}, {
  3.907300211910789*^9, 3.907300218212023*^9}, {3.907300326619232*^9, 
  3.90730034857167*^9}, {3.907300424701803*^9, 
  3.907300491538052*^9}},ExpressionUUID->"356035e3-baa0-4053-90ed-\
3ce2428b533f"],

Cell["\<\
{
  ...
    environment.systemPackages = [
      ...
      pkgs.mathematica
      ...
    ];
  ...
}\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Shell",
 CellChangeTimes->{{3.907300066862874*^9, 3.907300071380168*^9}, {
   3.907300211910789*^9, 3.907300218212023*^9}, {3.907300326619232*^9, 
   3.90730034857167*^9}, {3.907300424701803*^9, 3.907300468615233*^9}, {
   3.907300510574814*^9, 3.907300531269929*^9}, 3.907300567614599*^9, {
   3.907300793033328*^9, 
   3.907300832926882*^9}},ExpressionUUID->"a23612b6-6cba-45d8-8ce1-\
41e79a28dcc6"],

Cell[TextData[{
 "Finally, rebuild your configuration with:\n",
 StyleBox["# nixos-rebuild switch", "ExternalLanguage"]
}], "Text",
 CellChangeTimes->{{3.907300066862874*^9, 3.907300071380168*^9}, {
  3.907300211910789*^9, 3.907300218212023*^9}, {3.907300326619232*^9, 
  3.90730034857167*^9}, {3.907300424701803*^9, 3.907300468615233*^9}, {
  3.907300617298026*^9, 
  3.90730067274504*^9}},ExpressionUUID->"30c36ad2-6274-49ae-93ac-\
0b9e81f38b61"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Installing MySQL", "Section",
 CellChangeTimes->{{3.907300846083501*^9, 
  3.907300850157765*^9}},ExpressionUUID->"ee1ed168-83b0-47ab-b6db-\
0fe56aca8714"],

Cell[TextData[{
 "Add the following to your ",
 Cell[BoxData[
  RowBox[{"configuration", ".", "nix"}]], "InlineCode",ExpressionUUID->
  "d55551c4-633d-45ad-9fdc-fe849ee370db"],
 " file, replacing ",
 Cell[BoxData[
  RowBox[{"<", "user", ">"}]], "InlineCode",ExpressionUUID->
  "bc9d801e-141e-4557-83e1-25fe09f1f515"],
 " with your username:"
}], "Text",
 CellChangeTimes->{{3.90730097868982*^9, 3.907300996236207*^9}, {
  3.907301144587892*^9, 
  3.9073011663668537`*^9}},ExpressionUUID->"8091c6b1-d5d3-4ca0-b963-\
b3a9a17a4f2b"],

Cell["\<\
{
  ...
  services.mysql = {
    enable = true;
    package = pkgs.mysql80;
    ensureUsers = [
      {
        name = \"<user>\";
        ensurePermisions = {
          \"*.*\" = \"ALL PRIVILEGES\";
        };
      }
    ];
  };
  ...
}\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Shell",
 CellChangeTimes->{{3.907301043906139*^9, 3.907301139560918*^9}, {
  3.907301171257265*^9, 3.907301187048455*^9}, {3.907301456370444*^9, 
  3.907301479872007*^9}},ExpressionUUID->"79273d06-9cf2-4f48-92cf-\
5209ef1cb3d5"],

Cell[TextData[{
 "Rebuild your configuration and reboot with:\n",
 StyleBox["# nixos-rebuild boot\n# shutdown -r now", "ExternalLanguage"]
}], "Text",
 CellChangeTimes->{{3.9073014957741213`*^9, 
  3.90730152964282*^9}},ExpressionUUID->"fc773e85-a015-49cf-906d-\
1694f9737a91"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Linking in Mathematica", "Section",
 CellChangeTimes->{{3.907300859137663*^9, 
  3.9073008642418413`*^9}},ExpressionUUID->"a9d11c5c-054c-43ed-a73b-\
17e2c5e6dfd2"],

Cell[TextData[{
 "First we need to create a database in MySQL:\n",
 StyleBox["$ mysql\nmysql> CREATE DATABASE test;", "ExternalLanguage"]
}], "Text",
 CellChangeTimes->{{3.907301648460105*^9, 
  3.907301680580855*^9}},ExpressionUUID->"ee36b136-6f1a-4991-941a-\
1225490307c1"],

Cell["Load the needed Mathematica package:", "Text",
 CellChangeTimes->{{3.9073018666280546`*^9, 3.90730188433799*^9}, {
  3.9073019305174313`*^9, 
  3.907301932295982*^9}},ExpressionUUID->"03dac1b7-1bb6-4dc9-970a-\
e8327b666c7a"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<DatabaseLink`\>\"", "]"}]], "Code",
 CellChangeTimes->{{3.90730188810252*^9, 3.907301892126341*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"47a031ea-cc4f-4948-b054-1f347cd96f9c"],

Cell["\<\
Connect to a database with the built-in GUI, giving the connection a name, \
using the MySQL(Connector/J) driver, and setting:
\tHostname: localhost
\tPort: 3306
\tUsername: root\
\>", "Text",
 CellChangeTimes->{{3.907301911136082*^9, 3.907302050844009*^9}, {
  3.9073024419441633`*^9, 
  3.907302444901824*^9}},ExpressionUUID->"410a308a-b850-48fd-a156-\
272813c13db0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"conn", " ", "=", " ", 
   RowBox[{"OpenSQLConnection", "[", "]"}]}], ";"}]], "Code",
 CellChangeTimes->{{3.907301935414096*^9, 3.907301942118123*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"2822f5d0-f805-4357-85ba-034531592fa0"],

Cell["We can check the status of the connection with:", "Text",
 CellChangeTimes->{{3.907302457142288*^9, 
  3.907302468528769*^9}},ExpressionUUID->"0795638c-0100-46a6-90d1-\
58c3087809e5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SQLSelect", "[", "conn", "]"}]], "Code",
 CellChangeTimes->{{3.90730247199887*^9, 3.9073024760440693`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"308a489a-1c37-4f9f-a8ff-cb72c9ffc09e"],

Cell[BoxData[
 RowBox[{"SQLSelect", "[", "$Canceled", "]"}]], "Output",
 CellChangeTimes->{3.907302512539205*^9, 3.9073886213150997`*^9, 
  3.917968752724048*^9, 3.917972550015231*^9, 3.918126786401104*^9, 
  3.9182802130295963`*^9, 3.950021886077734*^9, 3.95002591105687*^9, 
  3.950265221623623*^9, 3.9503454129889812`*^9, 3.980497503413615*^9, 
  3.980504534145376*^9, 3.980525951184313*^9, 3.980529369073867*^9, 
  3.9805299297425947`*^9, 3.980530116417863*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"d5c52ef7-efbd-4907-824b-79333f473cc4"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Troubleshooting", "Section",
 CellChangeTimes->{{3.907302656229237*^9, 
  3.907302659434525*^9}},ExpressionUUID->"443dc4a1-2a5d-4b35-8a49-\
659a3e1fd049"],

Cell[CellGroupData[{

Cell["\<\
Mathematica fails to open (serious startup error) from second time onwards, \
with malformed error code.\
\>", "Subsection",
 CellChangeTimes->{{3.907302673062971*^9, 
  3.907302725764416*^9}},ExpressionUUID->"2db8e3f1-9e78-4840-b588-\
2f6ab2d7421a"],

Cell["\<\
This is due to a bug in Mathematica. A quick patch can be applied by deleting \
the offending file before startup. This solution is not desirable, but will \
suffice until the bug is fixed upstream.\
\>", "Text",
 CellChangeTimes->{{3.90730270318258*^9, 
  3.907302788269284*^9}},ExpressionUUID->"482cefa4-1363-4d0f-9068-\
c2f0fe5e18f5"],

Cell[TextData[{
 "Add the following to your ",
 StyleBox["configuration.nix", "ExternalLanguage"],
 " file:"
}], "Text",
 CellChangeTimes->{{3.907302793202419*^9, 
  3.9073028035599546`*^9}},ExpressionUUID->"cce18c31-4d52-415a-b9f8-\
0fbae0d41064"],

Cell["\<\
{ config, pkgs, lib, ... }:

{
  ...
  environment.systemPackages = with pkgs; let
    m = writeScriptBin \"mathematica\" ''
      rm ~/.Mathematica/Autoload/PacletManager/Configuration/FrontEnd/init_${\
mathematica.version}.0.m
      exec ${lib.getBin mathematica}/bin/mathematica \"$@\"
    '';
    in
  [
    ...
    mathematica
    m
  ];
}\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Shell",
 CellChangeTimes->{{3.907302841928185*^9, 
  3.907303025066393*^9}},ExpressionUUID->"9119ba72-1e24-44e9-878f-\
e56e422e36e6"],

Cell[TextData[{
 "Rebuild your configuration with:\n",
 StyleBox["# nixos-rebuild switch", "ExternalLanguage"]
}], "Text",
 CellChangeTimes->{{3.907300066862874*^9, 3.907300071380168*^9}, {
   3.907300211910789*^9, 3.907300218212023*^9}, {3.907300326619232*^9, 
   3.90730034857167*^9}, {3.907300424701803*^9, 3.907300468615233*^9}, {
   3.907300617298026*^9, 3.90730067274504*^9}, 
   3.907303050597618*^9},ExpressionUUID->"e3d8d2a9-17d0-41c8-a2bd-\
e0f8351c7f14"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

