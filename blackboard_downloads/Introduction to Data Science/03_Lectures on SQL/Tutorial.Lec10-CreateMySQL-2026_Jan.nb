Cell[TextData[{
 StyleBox["Mac user",
  FontVariations->{"Underline"->True}],
 ": Connecting to and Disconnecting from the Server [",
 ButtonBox["documentation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dev.mysql.com/doc/refman/8.0/en/connecting-disconnecting.\
html"], None},
  ButtonNote->
   "https://dev.mysql.com/doc/refman/8.0/en/connecting-disconnecting.html"],
 "]"
}], "Title",
 CellChangeTimes->{{3.779290315290942*^9, 3.779290345186265*^9}, {
  3.907223439080049*^9, 3.907223442278216*^9}},
 FontSize->36,ExpressionUUID->"e8fcf35e-3540-41ef-b0ae-69eedc508756"],

Cell["\<\
0) Open a terminal. You can find it in Applications -> Utilities. Or type \
terminal in Spotlight search (cmd + space bar)\
\>", "Item",
 CellChangeTimes->{{3.779293631319693*^9, 3.779293758594677*^9}, {
  3.779293866498165*^9, 3.7792938932901087`*^9}, {3.7792940141496897`*^9, 
  3.779294040560016*^9}, {3.77929409553838*^9, 3.779294096134075*^9}, {
  3.7792942893741713`*^9, 3.779294297712867*^9}, {3.907223449216082*^9, 
  3.907223497549476*^9}},ExpressionUUID->"a1dd2701-1b31-437b-aca9-\
83f6d8098714"],

Cell[CellGroupData[{

Cell["\<\
1) Go to the directory where the binary files for MySQL are installed, or \
create an alias...\t\
\>", "Item",
 CellChangeTimes->{{3.779293631319693*^9, 3.779293758594677*^9}, {
  3.779293866498165*^9, 3.7792938932901087`*^9}, {3.7792940141496897`*^9, 
  3.779294040560016*^9}, {3.77929409553838*^9, 3.779294096134075*^9}, {
