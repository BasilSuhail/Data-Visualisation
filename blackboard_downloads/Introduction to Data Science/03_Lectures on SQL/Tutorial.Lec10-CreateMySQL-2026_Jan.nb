Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"conn", "=", 
    RowBox[{"OpenSQLConnection", "[", 
     RowBox[{
      RowBox[{"JDBC", "[", 
       RowBox[{"\"\<MySQL(Connector/J)\>\"", 
        ",", "\"\<localhost:3306/test\>\""}], "]"}], ",", 
      RowBox[{"\"\<Username\>\"", "->", "\"\<root\>\""}], ",", 
      RowBox[{"\"\<Password\>\"", "->", "\"\<12345678\>\""}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"SQLConnectionInformation", "[", "conn", "]"}], 
  "[", "\"\<Driver\>\"", "]"}]}], "Input",
 CellChangeTimes->{{3.980503601077259*^9, 3.980503639927227*^9}, {
