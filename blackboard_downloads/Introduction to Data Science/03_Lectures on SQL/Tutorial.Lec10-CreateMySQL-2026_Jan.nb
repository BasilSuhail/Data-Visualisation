Cell["\<\
(the command above means : show ALL from the my_table things that whose key \
name are ' Smith and key age are larger than 30. However the string Smith \
needs to come inside single quote in both sides : ' Smith' or \"Smith\")\
\>", "Text",
 CellChangeTimes->{
  3.813440919074854*^9, {3.813489678240917*^9, 3.813489680665226*^9}, {
   3.950021151247941*^9, 
   3.950021152976603*^9}},ExpressionUUID->"9853f1d0-bdc6-4168-9635-\
794594f38112"],

