d01dc01e9b3b"]
}, Open  ]]
}, Open  ]],

Cell["Use > for the command line!", "Text",
 CellChangeTimes->{{3.844864173081602*^9, 3.8448641801609993`*^9}},
 FontWeight->"Bold",ExpressionUUID->"423bdac0-1b86-4a1d-82c5-d5a2dfdc091b"],

Cell[CellGroupData[{

Cell["\<\
2) If you are using your own computer as a host (host address), then type :\
\>", "Item",
 CellChangeTimes->{{3.779293631319693*^9, 3.779293758594677*^9}, {
   3.779293866498165*^9, 3.7792938932901087`*^9}, {3.7792940141496897`*^9, 
