   StripOnInput->False],
  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "WriteDataSource[name, opts] stores on the file system an SQLConnection \
configuration.", "Documentation" -> None, "OwnValues" -> None, "UpValues" -> 
    None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, DatabaseLink`WriteDataSource, {DatabaseLink`WriteDataSource[
         Pattern[DatabaseLink`DataSources`Private`name, 
          Blank[String]], 
         Pattern[DatabaseLink`DataSources`Private`opts, 
          OptionsPattern[]]] :> 
       DatabaseLink`WriteDataSource[
        DatabaseLink`DataSources`Private`name, "HSQL(Standalone)", 
         DatabaseLink`DataSources`Private`opts], 
       DatabaseLink`WriteDataSource[
         Pattern[DatabaseLink`DataSources`Private`name, 
          Blank[String]], 
         Pattern[DatabaseLink`DataSources`Private`driver, 
          Blank[String]], 
         Pattern[DatabaseLink`DataSources`Private`opts, 
          OptionsPattern[]]] :> 
       Module[{DatabaseLink`DataSources`Private`desc, 
          DatabaseLink`DataSources`Private`url, 
          DatabaseLink`DataSources`Private`user, 
          DatabaseLink`DataSources`Private`passwd, 
          DatabaseLink`DataSources`Private`ucp, 
          DatabaseLink`DataSources`Private`ro, 
          DatabaseLink`DataSources`Private`til, 
          DatabaseLink`DataSources`Private`cat, 
          DatabaseLink`DataSources`Private`props, 
          DatabaseLink`DataSources`Private`loc, 
          DatabaseLink`DataSources`Private`i, 
          DatabaseLink`DataSources`Private`rel, 
          DatabaseLink`DataSources`Private`conn, 
          DatabaseLink`DataSources`Private`dbrdir, 
          DatabaseLink`DataSources`Private`dir, 
          DatabaseLink`DataSources`Private`useOpts}, 
         DatabaseLink`DataSources`Private`useOpts = Join[
            DatabaseLink`Package`canonicalOptions[
             Flatten[{DatabaseLink`DataSources`Private`opts}]], 
            Options[DatabaseLink`WriteDataSource]]; 
         DatabaseLink`DataSources`Private`desc = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, "Description"]; 
         DatabaseLink`DataSources`Private`url = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, "URL"]; 
         DatabaseLink`DataSources`Private`user = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, "Username"]; 
         DatabaseLink`DataSources`Private`passwd = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, "Password"]; 
         DatabaseLink`DataSources`Private`props = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, "Properties"]; 
         DatabaseLink`DataSources`Private`loc = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, "Location"]; 
         DatabaseLink`DataSources`Private`rel = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, "RelativePath"]; 
         DatabaseLink`DataSources`Private`ucp = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, 
            "UseConnectionPool"]; 
         DatabaseLink`DataSources`Private`cat = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, "Catalog"]; 
         DatabaseLink`DataSources`Private`ro = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, "ReadOnly"]; 
         DatabaseLink`DataSources`Private`til = 
          Lookup[DatabaseLink`DataSources`Private`useOpts, 
            "TransactionIsolationLevel"]; 
         Switch[DatabaseLink`DataSources`Private`loc, "User", 
           DatabaseLink`DataSources`Private`dbrdir = $UserBaseDirectory; 
           DatabaseLink`DataSources`Private`dir = 
            ToFileName[{$UserBaseDirectory, "DatabaseResources"}], "System", 
           DatabaseLink`DataSources`Private`dbrdir = $BaseDirectory; 
           DatabaseLink`DataSources`Private`dir = 
            ToFileName[{$BaseDirectory, "DatabaseResources"}], 
           Blank[], Message[
             MessageName[DatabaseLink`WriteDataSource, "location"], 
             DatabaseLink`DataSources`Private`loc]; Return[$Failed]]; 
         If[DatabaseLink`DataSources`Private`url === Automatic, 
           Switch[DatabaseLink`DataSources`Private`driver, 
             Alternatives["HSQL(Standalone)", "H2(Embedded)"], 
             DatabaseLink`DataSources`Private`url = 
              DatabaseLink`DataSources`Private`name; 
             If[DatabaseLink`DataSources`Private`user === Automatic, 
               DatabaseLink`DataSources`Private`user = None]; 
             If[DatabaseLink`DataSources`Private`rel === Automatic, 
               DatabaseLink`DataSources`Private`rel = True], 
             "Derby(Embedded)", DatabaseLink`DataSources`Private`url = 
             DatabaseLink`DataSources`Private`name <> ";create=true", 
             "HSQL(Memory)", 
             DatabaseLink`DataSources`Private`url = 
              DatabaseLink`DataSources`Private`name; 
             If[DatabaseLink`DataSources`Private`user === Automatic, 
               DatabaseLink`DataSources`Private`user = None], 
             Alternatives["SQLite(Memory)", "H2(Memory)"], 
             DatabaseLink`DataSources`Private`url = ""; 
             If[DatabaseLink`DataSources`Private`user === Automatic, 
               DatabaseLink`DataSources`Private`user = None], 
             Blank[], Message[
               MessageName[DatabaseLink`WriteDataSource, "url"], 
               DatabaseLink`DataSources`Private`driver]; Return[$Failed]]; 
           Null]; If[
          DatabaseLink`DataSources`Private`user === Automatic, 
           DatabaseLink`DataSources`Private`user = None]; 
         If[DatabaseLink`DataSources`Private`passwd === Automatic, 
           DatabaseLink`DataSources`Private`passwd = None]; 
         If[DatabaseLink`DataSources`Private`props === Automatic, 
           DatabaseLink`DataSources`Private`props = {}]; 
         DatabaseLink`DataSources`Private`loc = 
          DatabaseLink`DataSources`Private`name <> ".m"; 
         DatabaseLink`DataSources`Private`i = 0; 
         While[FileNames[
            DatabaseLink`DataSources`Private`loc, 
             DatabaseLink`DataSources`Private`dir] =!= {}, 
           DatabaseLink`DataSources`Private`loc = ((
              DatabaseLink`DataSources`Private`name <> "(") <> ToString[
               PreIncrement[DatabaseLink`DataSources`Private`i]]) <> ").m"]; 
         DatabaseLink`DataSources`Private`loc = 
          ToFileName[
           DatabaseLink`DataSources`Private`dir, 
            DatabaseLink`DataSources`Private`loc]; 
         DatabaseLink`DataSources`Private`conn = DatabaseLink`SQLConnection[
            DatabaseLink`JDBC[
            DatabaseLink`DataSources`Private`driver, 
             DatabaseLink`DataSources`Private`url], "Name" -> 
            DatabaseLink`DataSources`Private`name, "Description" -> 
            DatabaseLink`DataSources`Private`desc, "Username" -> 
            DatabaseLink`DataSources`Private`user, "Password" -> 
            DatabaseLink`DataSources`Private`passwd, "Properties" -> 
            DatabaseLink`DataSources`Private`props, "RelativePath" -> 
            TrueQ[DatabaseLink`DataSources`Private`rel], "UseConnectionPool" -> 
            DatabaseLink`DataSources`Private`ucp, "Catalog" -> 
            DatabaseLink`DataSources`Private`cat, "ReadOnly" -> 
            DatabaseLink`DataSources`Private`ro, "TransactionIsolationLevel" -> 
            DatabaseLink`DataSources`Private`til, "Version" -> 
            DatabaseLink`Information`$VersionNumber]; 
         If[FileNames[
            "DatabaseResources", {
             DatabaseLink`DataSources`Private`dbrdir}] === {}, 
           CreateDirectory[DatabaseLink`DataSources`Private`dir]; Null]; If[
           MemberQ[
            DatabaseLink`DataSourceNames[], 
            DatabaseLink`DataSources`Private`name], Message[
             MessageName[DatabaseLink`WriteDataSource, "exists"], 
             DatabaseLink`DataSources`Private`name]; $Failed, 
           Put[DatabaseLink`DataSources`Private`conn, 
             DatabaseLink`DataSources`Private`loc]; 
           DatabaseLink`DataSources`Private`conn]]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {
     "Description" -> "", "URL" -> Automatic, "Username" -> Automatic, 
      "Password" -> Automatic, "Properties" -> Automatic, "Location" -> 
      "User", "RelativePath" -> Automatic, "UseConnectionPool" -> Automatic, 
      "Catalog" -> Automatic, "ReadOnly" -> Automatic, 
      "TransactionIsolationLevel" -> Automatic}, "Attributes" -> {}, 
    "FullName" -> "DatabaseLink`WriteDataSource"|>, False]]], "Output",
 CellChangeTimes->{3.813482499525838*^9},
 CellLabel->
  "Out[216]=",ExpressionUUID->"04ac2b3a-e5d6-45bb-b4cf-933fc7bfdba9"]
}, Open  ]],

Cell["With the following format:", "Text",
 CellChangeTimes->{{3.8134825045381727`*^9, 
  3.8134825129497538`*^9}},ExpressionUUID->"98c299f0-6d8f-4b67-bc04-\
25b3e7294495"],

Cell[BoxData[
 RowBox[{"WriteDataSource", "[", 
  RowBox[{"\"\<testWL\>\"", ",", "\"\<MySQL(Connector/J)\>\"", ",", 
   RowBox[{"\"\<URL\>\"", "\[Rule]", "\"\<main/test\>\""}], ",", 
   RowBox[{"\"\<Username\>\"", "\[Rule]", "\"\<user\>\""}], ",", 
   RowBox[{"\"\<Password\>\"", "\[Rule]", "\"\<password\>\""}], ",", 
   RowBox[{"\"\<Location\>\"", "\[Rule]", "\"\<User\>\""}]}], "]"}]], "Input",\

 CellChangeTimes->{{3.813482668765917*^9, 3.813482668767915*^9}, {
  3.813483125666842*^9, 3.813483132315442*^9}, {3.855247757587462*^9, 
  3.8552477578651857`*^9}},
 CellLabel->
  "In[190]:=",ExpressionUUID->"aa22a0f5-72ba-4298-811c-8f756a2fa2f1"],

Cell["\<\
Note that this does not communicate with the MySQL server to create the \
database, main/test. It is assumed that the database already exists. However, \
this is still a convenient way to create a named connection that we place in \
the first \[OpenCurlyDoubleQuote]testWL\[CloseCurlyDoubleQuote]. Note how the \
parameters such as Username, Password, and Location are set. The choices for \
Location are \"User\" and \"System\" (visibility, or who can use).\
\>", "Text",
 CellChangeTimes->{{3.813482682520541*^9, 3.8134826837564173`*^9}, {
  3.813482773674205*^9, 3.813482804619994*^9}, {3.813482898923641*^9, 
  3.813482964271393*^9}, {3.813484020184993*^9, 3.8134840242004213`*^9}, {
  3.855247766884448*^9, 
  3.855247773483419*^9}},ExpressionUUID->"1aca3fbe-f593-4dad-9f93-\
26e830f48c20"],

Cell[TextData[StyleBox["Then, we are ready to create, assuming testWL does \
not exist :", "Section"]], "Text",
 CellChangeTimes->{{3.813483002372921*^9, 3.8134830082287397`*^9}, {
  3.9805032491927853`*^9, 
  3.980503254247048*^9}},ExpressionUUID->"58ad06f0-0a26-4c94-aa06-\
fbc04616ecde"],

Cell["\<\
The named database is the first string appearing inside the argument\
\>", "Text",
 CellChangeTimes->{{3.8134852085732193`*^9, 
  3.8134852238815947`*^9}},ExpressionUUID->"acbccb00-a396-4626-bf13-\
56741480072f"],

