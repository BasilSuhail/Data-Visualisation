Cell[CellGroupData[{

Cell["Dropping Accounts", "Section",
 CellChangeTimes->{{3.8134354119760027`*^9, 3.813435512868697*^9}, {
  3.813435765175715*^9, 
  3.813435766530133*^9}},ExpressionUUID->"632cf6dd-96f3-4bd2-8b73-\
faedb813df1b"],

Cell["\<\
To remove an account, use the DROP USER statement.For example, to drop some \
of the accounts created previously :\
\>", "CodeText",
 CellChangeTimes->{{3.8134354119760027`*^9, 
  3.813435518886476*^9}},ExpressionUUID->"9f2c3ecd-752a-4367-bedc-\
1692f89c0ecf"],

Cell["\<\
DROP USER 'finley'@'localhost';
DROP USER 'finley'@'%.example.com';
DROP USER 'admin'@'localhost';
DROP USER 'dummy'@'localhost';
\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.8134354119760027`*^9, 3.813435502535415*^9}, {
  3.813435770267013*^9, 
  3.813435780091614*^9}},ExpressionUUID->"0c9101ba-3612-446c-9e3d-\
4cdea67cb60a"]
}, Open  ]],

