Cell["\<\
MongoCollectionFind has the same syntax as MongoCollectionFindOne, but \
instead of returning a document, it returns a MongoCursor, appropriate for \
handling large datasets.\
\>", "Text",
 CellChangeTimes->{{3.776444501060408*^9, 3.776444516054182*^9}, {
  3.776494024996232*^9, 
  3.776494026032714*^9}},ExpressionUUID->"980d2720-bf25-4f1f-89ac-\
176f413dd613"],

