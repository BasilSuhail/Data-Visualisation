   3.813513475961205*^9}},ExpressionUUID->"3f45821e-17ea-4302-ba75-\
02cecd4cfa1d"],

Cell["\<\
Documents (i.e. objects) correspond to native data types in many programming \
languages.\
\>", "Subitem",
