Cell[CellGroupData[{

Cell["Appendix A: Analyze open data from the UK Land Registry", "Section",
 CellChangeTimes->{{3.823875440878964*^9, 3.823875457979402*^9}, {
  3.875794523736072*^9, 3.875794526058126*^9}, {3.8834733080598*^9, 
  3.883473308274911*^9}},ExpressionUUID->"103766a9-9818-4d5d-bb0a-\
dd54fc264504"],

Cell[TextData[{
 "You can analyse it accessing its freely available online relational \
PostgreSQL server, and treating it as a EntityStore : ",
 ButtonBox["Link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.wolfram.com/language/12/relational-database-connectivity/\
analyze-open-data-from-the-uk-land-registry.html"], None},
  ButtonNote->
   "https://www.wolfram.com/language/12/relational-database-connectivity/\
analyze-open-data-from-the-uk-land-registry.html"]
}], "Item",
 CellChangeTimes->{{3.823875460283389*^9, 3.8238755556016483`*^9}, {
  3.8238756049038463`*^9, 
  3.823875604917342*^9}},ExpressionUUID->"b7bbecb8-f2fe-49f6-b8de-\
0057bd70bf9c"],

Cell[TextData[{
 "Or, you can query its API, and query it using SPARQL language : ",
 ButtonBox["Link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://landregistry.data.gov.uk/app/qonsole"], None},
  ButtonNote->"https://landregistry.data.gov.uk/app/qonsole"],
 "    "
}], "Item",
 CellChangeTimes->{{3.823875460283389*^9, 3.823875588913238*^9}, {
  3.82387618345255*^9, 
  3.823876205610942*^9}},ExpressionUUID->"9e517716-74a2-47ac-ae31-\
55843154e962"]
}, Open  ]]
}, Open  ]],

