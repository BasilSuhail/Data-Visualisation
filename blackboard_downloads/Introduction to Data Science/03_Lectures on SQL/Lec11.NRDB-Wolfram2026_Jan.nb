74cfe0b94b9a"],

Cell["\<\
To verify that MongoDB is running, search for mongod in your running \
processes :\
\>", "Text",
 CellChangeTimes->{{3.813514631441931*^9, 
  3.813514633196539*^9}},ExpressionUUID->"66cc061f-bfb8-4aa5-bb6d-\
8c52de353ccb"],

Cell["ps aux | grep -v grep | grep mongod", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.813514498479635*^9, 3.813514501131295*^9}, {
  3.875791040740018*^9, 
  3.875791052820475*^9}},ExpressionUUID->"cfe52aed-7ac9-4e6e-b7ea-\
