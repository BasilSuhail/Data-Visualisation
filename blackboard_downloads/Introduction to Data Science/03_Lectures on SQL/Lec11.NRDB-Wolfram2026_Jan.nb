Cell["Without the Print, nothing is output. ", "Text",
 CellChangeTimes->{{3.813520572448449*^9, 3.8135205739142637`*^9}, {
  3.813521384737237*^9, 
  3.8135214111055603`*^9}},ExpressionUUID->"f394d5fc-ded5-4bef-9481-\
03a4b6fb550c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"curs", "=", 
   RowBox[{"MongoCollectionFind", "[", "colllocal", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"While", "[", 
   RowBox[{
    RowBox[{"AssociationQ", "[", 
     RowBox[{"data", "=", 
      RowBox[{"Read", "[", "curs", "]"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"data", "[", "\"\<sex\>\"", "]"}], ",", 
      RowBox[{"data", "[", "\"\<_id\>\"", "]"}]}], "}"}]}], "]"}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.776445030410206*^9, 3.776445030418169*^9}, {
  3.7764451695508733`*^9, 3.776445243607904*^9}, {3.779965364675055*^9, 
