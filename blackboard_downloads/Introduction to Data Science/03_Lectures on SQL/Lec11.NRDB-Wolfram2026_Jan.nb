Cell[CellGroupData[{

Cell["\<\
By default, a collection does not require its documents to have the same \
schema;\
\>", "Item",
 CellChangeTimes->{{3.8135163276522837`*^9, 
  3.813516341030281*^9}},ExpressionUUID->"a7deb32d-7f0b-486b-a9a7-\
30e96b9301f6"],

Cell["\<\
i.e.the documents in a single collection do not need to have the same set of \
fields and the data type for a field can differ across documents within a \
collection.\
\>", "Subitem",
 CellChangeTimes->{{3.8135163276522837`*^9, 
  3.813516340391019*^9}},ExpressionUUID->"bb9efae1-5a40-40f3-8772-\
b37b2f8e52f3"]
}, Open  ]],

Cell["\<\
Typically, all documents in a collection have a similar or related purpose.\
\>", "Item",ExpressionUUID->"54cf2a7a-0dea-40df-9937-22d886270239"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"350cf8f9-250b-4e4c-9bea-9d0d4f70bc82"],

Cell[CellGroupData[{

Cell["Documents and collection in the eyes of Wolfram", "Section",
 CellChangeTimes->{{3.813516910873007*^9, 
  3.813516929184952*^9}},ExpressionUUID->"7dd929d1-7d95-427b-a07c-\
f3d497034ba1"],

Cell[CellGroupData[{

Cell["\<\
A Document in MongoDB can be viewed as a (possibly) nested Association whose \
keys must be strings and whose values are limited to a set of types (for \
example, strings, lists, integers, dates, etc). One simple example of a \
document that we will input in our MongoDB is:\
\>", "Item",
 CellChangeTimes->{{3.776438704664444*^9, 3.776438708477042*^9}, 
   3.779962152540306*^9, {3.813515257813036*^9, 3.813515271168095*^9}, {
   3.813515973200644*^9, 3.81351598097751*^9}, {3.823795565656751*^9, 
   3.8237955677797613`*^9}},ExpressionUUID->"8ac5cbd9-5492-4b2a-a6d1-\
91f0ec8899a7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cat1", "=", 
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"\"\<age\>\"", "\[Rule]", "3"}], ",", 
    RowBox[{"\"\<sex\>\"", "\[Rule]", "\"\<female\>\""}], ",", 
    RowBox[{"\"\<date\>\"", "\[Rule]", 
     RowBox[{"DateObject", "[", "]"}]}]}], "|>"}]}]], "Input",
 CellChangeTimes->{{3.776438720236068*^9, 3.776438720243348*^9}},
 CellLabel->
  "In[428]:=",ExpressionUUID->"6f5b9bc2-2862-4260-81aa-41e1db477834"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"age\"\>", "\[Rule]", "3"}], ",", 
   RowBox[{"\<\"sex\"\>", "\[Rule]", "\<\"female\"\>"}], ",", 
   RowBox[{"\<\"date\"\>", "\[Rule]", 
    TemplateBox[{
      RowBox[{"\"Fri 7 Mar 2025 14:21:56\"", 
        StyleBox["\"GMT\"", "TimeZoneLabel"]}], 
      RowBox[{"DateObject", "[", 
        RowBox[{
          RowBox[{"{", 
            
            RowBox[{"2025", ",", "3", ",", "7", ",", "14", ",", "21", ",", 
              "56.696299`8.50612968398967"}], "}"}], ",", "\"Instant\"", ",", 
          "\"Gregorian\"", ",", "0.`"}], "]"}]},
     "DateObject",
     Editable->False]}]}], "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{
  3.776438722120839*^9, 3.780121359123354*^9, 3.81351532902185*^9, 
   3.813575077401129*^9, {3.823797875801993*^9, 3.823797884471642*^9}, {
   3.823942927810993*^9, 3.82394293942844*^9}, 3.823943254185824*^9, 
   3.845096118916417*^9, 3.8757913935766153`*^9, 3.875943316929447*^9, 
   3.886758588661046*^9, 3.907224841742894*^9, 3.907391208357951*^9, 
   3.9182818223677177`*^9, 3.950290637440802*^9, 3.9503461167188807`*^9},
 CellLabel->
  "Out[428]=",ExpressionUUID->"7b726302-edcc-4309-93a0-5a57b531a8ab"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cat1", "//", "Normal"}]], "Input",
 CellChangeTimes->{{3.845096178430924*^9, 3.845096180732188*^9}},
 CellLabel->
  "In[360]:=",ExpressionUUID->"ed6b438a-53d2-4634-a14d-0894d77e087b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\<\"age\"\>", "\[Rule]", "3"}], ",", 
   RowBox[{"\<\"sex\"\>", "\[Rule]", "\<\"female\"\>"}], ",", 
   RowBox[{"\<\"date\"\>", "\[Rule]", 
    TemplateBox[{
      RowBox[{"\"Thu 2 Mar 2023 15:09:48\"", 
        StyleBox["\"GMT\"", FontColor -> GrayLevel[0.5]]}], 
      RowBox[{"DateObject", "[", 
        RowBox[{
          RowBox[{"{", 
            
            RowBox[{"2023", ",", "3", ",", "2", ",", "15", ",", "9", ",", 
              "48.648964`8.439648572288338"}], "}"}], ",", "\"Instant\"", ",",
           "\"Gregorian\"", ",", "0.`"}], "]"}]},
     "DateObject",
     Editable->False]}]}], "}"}]], "Output",
 CellChangeTimes->{3.845096181063829*^9, 3.875791396666595*^9, 
  3.886758592711341*^9},
 CellLabel->
  "Out[360]=",ExpressionUUID->"384f85d6-7388-4547-85c7-be8aa41e8dd5"]
}, Open  ]]
}, Open  ]],

Cell["\<\
So, to the eyes of Wolfram, a Mongo Document is a WL Association or a \
\[OpenCurlyDoubleQuote]SQL row\[CloseCurlyDoubleQuote]. \
\>", "Subsubsection",
 CellChangeTimes->{{3.776439702257405*^9, 3.7764397215257*^9}, {
  3.813515293469735*^9, 3.813515322307815*^9}},
 FontWeight->"Bold",ExpressionUUID->"dcb2256c-2e4f-43ea-8eed-06641a056bd0"]
}, Open  ]]
}, Open  ]],

