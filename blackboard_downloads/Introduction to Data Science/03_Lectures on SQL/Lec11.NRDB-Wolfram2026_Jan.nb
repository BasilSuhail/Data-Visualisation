Cell["To run MongoDB as a macOS service, issue the following :", "Text",
 CellChangeTimes->{{3.775564567522856*^9, 3.7755646501979523`*^9}, {
   3.7764270311554*^9, 3.776427046015328*^9}, {3.776428115858118*^9, 
   3.776428148330027*^9}, {3.776442116729788*^9, 3.7764421350739393`*^9}, 
   3.779961548810875*^9, {3.779961756327382*^9, 3.779961768777615*^9}, {
