Cell[BoxData[
 RowBox[{"Each", " ", "document", " ", 
  SubscriptBox[
   StyleBox["doc", "TI"], 
   StyleBox["n", "TI"]], " ", "is", " ", "an", " ", 
  TemplateBox[{
    Cell[
     TextData["Association"]], "paclet:ref/Association"},
   "RefLink",
   BaseStyle->{"InlineFormula"}], " ", "that", " ", "must", " ", "be", " ", 
  "convertible", " ", "to", " ", "the", " ", "BSON", " ", 
  RowBox[{"format", ".", " ", "Documents"}], " ", "that", " ", "cannot", " ", 
  "be", " ", "converted", " ", "to", " ", "the", " ", "BSON", " ", "format", 
  " ", "will", " ", "cause", " ", "an", " ", "insertion", " ", 
  RowBox[{"failure", ".", " ", "But"}], " ", "notice", " ", "that", " ", 
  "Mathematica", " ", "does", " ", "the", " ", "job", " ", "for", " ", "you", 
  " ", "of", " ", "converting", " ", "to", " ", "BSON", " ", 
