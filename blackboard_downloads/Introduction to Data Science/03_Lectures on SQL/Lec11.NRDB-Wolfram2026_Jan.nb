Cell[CellGroupData[{

Cell["The advantages of using documents are:", "Item",
 CellChangeTimes->{{3.7755642845369887`*^9, 3.775564288226244*^9}, {
   3.775564520610824*^9, 3.775564552757938*^9}, {3.813513338071739*^9, 
