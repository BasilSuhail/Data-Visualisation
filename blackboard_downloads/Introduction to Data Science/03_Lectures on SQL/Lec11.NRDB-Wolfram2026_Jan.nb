   3.875790763781786*^9}},ExpressionUUID->"4ea12029-a921-48ac-947c-\
6097e7b6957d"],

Cell["brew services start mongodb-community@6.0", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.813514234682132*^9, 3.813514236982593*^9}, {
