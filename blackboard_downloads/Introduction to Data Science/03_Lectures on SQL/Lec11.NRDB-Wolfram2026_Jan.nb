Cell["Non - Relational databases: MongoDB", "Title",
 CellChangeTimes->{{3.774941488024667*^9, 3.77494149217568*^9}, {
  3.775563410860828*^9, 3.775563413973953*^9}, {3.775564177376485*^9, 
  3.775564177596261*^9}},ExpressionUUID->"1adbc98c-c2cc-40b7-a81a-\
c5d532a5bb71"],

Cell[TextData[{
 ButtonBox["MongoDB",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://docs.mongodb.com/manual/introduction/"], None},
  ButtonNote->"https://docs.mongodb.com/manual/introduction/"],
 " : is an open source database management system (DBMS) that uses a \
document-oriented database model which supports various forms of data."
}], "Item",
 CellChangeTimes->{{3.7755642845369887`*^9, 3.775564288226244*^9}, {
  3.775564520610824*^9, 3.775564552757938*^9}, {3.813513338071739*^9, 
  3.813513342229255*^9}},ExpressionUUID->"3893124e-b03c-460d-a8e3-\
7c0eb2b823d0"],

Cell[CellGroupData[{

Cell[TextData[{
 "A ",
 StyleBox["record in MongoDB is a document",
  FontWeight->"Bold"],
 ", which is a data structure ",
 StyleBox["composed of field and value pairs",
  FontWeight->"Bold"],
 ". MongoDB documents are similar to JSON objects. In fact, they are a binary \
representation to store data in JSON format (BSON), optimized for speed, \
space, and flexibility. "
}], "Item",
 CellChangeTimes->{{3.7755642845369887`*^9, 3.775564288226244*^9}, {
   3.775564520610824*^9, 3.775564552757938*^9}, {3.813513338071739*^9, 
   3.813513338095549*^9}, 3.813513375720455*^9, {3.813513454354923*^9, 
   3.813513454355832*^9}, {3.813515087328082*^9, 3.813515128605221*^9}, {
   3.8135180643601723`*^9, 
   3.813518065822209*^9}},ExpressionUUID->"f24bdc3f-a905-4d05-9bca-\
a8a392e8099e"],

