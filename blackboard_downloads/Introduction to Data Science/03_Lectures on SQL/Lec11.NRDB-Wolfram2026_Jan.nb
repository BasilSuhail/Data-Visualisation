 CellChangeTimes->{{3.813525881657702*^9, 3.813525914834238*^9}},
 CellLabel->
  "In[682]:=",ExpressionUUID->"3bb6060b-cf2e-484b-8f78-b2b6380ea6dc"],

Cell[TextData[StyleBox["Load MongoLink :", "Section"]], "Text",
 CellChangeTimes->{{3.776428328911068*^9, 
  3.77642833112463*^9}},ExpressionUUID->"3618707a-78ee-4617-bc48-\
f87ec4e031c4"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<MongoLink`\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.776428336663052*^9, 3.77642833666549*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"735de190-9a98-4f29-b630-0c055f6c5adf"],

Cell["MongoLink is a set of tools for working with MongoDB.", "Item",
 CellChangeTimes->{{3.775564182466774*^9, 
  3.775564187618123*^9}},ExpressionUUID->"8a2e402e-7df7-45dd-9182-\
19109f941683"],

Cell["Create a client connection using the default :", "Text",
 CellChangeTimes->{{3.776428453247402*^9, 3.776428478742835*^9}, {
  3.8135153562265267`*^9, 
  3.81351536205161*^9}},ExpressionUUID->"29032b6f-911a-44c8-94be-\
5b7d4b9e893d"],

Cell[TextData[{
 StyleBox["host",
  FontWeight->"Bold"],
 ": \"localhost\""
}], "Item",
 CellChangeTimes->{{3.776428453247402*^9, 3.776428478742835*^9}, {
  3.8135153562265267`*^9, 
  3.813515390307021*^9}},ExpressionUUID->"12fcf654-aab0-4509-8052-\
cabae9b79133"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["port",
  FontWeight->"Bold"],
 ": 27017 (this is the default hostname and port when running the MongoDB \
server on your local machine) "
}], "Item",
 CellChangeTimes->{{3.776428453247402*^9, 3.776428478742835*^9}, {
  3.813515356226527*^9, 
