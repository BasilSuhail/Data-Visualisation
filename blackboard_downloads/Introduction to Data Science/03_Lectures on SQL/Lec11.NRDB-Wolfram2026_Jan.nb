Cell[TextData[{
 StyleBox["Databases or collections",
  FontWeight->"Bold"],
 " are created lazily, so getting a collection or database does not perform \
any operations on the MongoDB server. They are only created once the first \
document is inserted into them."
}], "Text",
 CellChangeTimes->{{3.776438621564683*^9, 3.7764386449165587`*^9}, {
  3.776441037600252*^9, 3.776441068271378*^9}, {3.779962349631798*^9, 
  3.779962351073441*^9}},ExpressionUUID->"af357e06-462d-4850-b6f0-\
3cc4c6ce2ee1"],

Cell[TextData[{
 " The bellow connect to the ",
 StyleBox["collection",
  FontWeight->"Bold"],
 " \[OpenCurlyDoubleQuote]local\[CloseCurlyDoubleQuote] of the \
\[OpenCurlyDoubleQuote]local\[CloseCurlyDoubleQuote] ",
 StyleBox["database",
  FontWeight->"Bold"],
 " in the MongoDB server (db represents the connection to the \
\[OpenCurlyDoubleQuote]local\[CloseCurlyDoubleQuote] database):"
}], "Text",
 CellChangeTimes->{{3.776441269810273*^9, 3.776441280151422*^9}, {
  3.7764417536796417`*^9, 3.776441771660749*^9}, {3.776441843408428*^9, 
  3.776441858698619*^9}, {3.776442372916538*^9, 3.776442374710435*^9}, {
  3.776492519799059*^9, 3.776492539249913*^9}, {3.779962408108709*^9, 
  3.77996241318752*^9}, {3.7799627836877613`*^9, 3.779962791939559*^9}, {
  3.875791622769549*^9, 
  3.875791675425516*^9}},ExpressionUUID->"d5f2eaf6-66d3-407c-bf22-\
5821d5af4a4c"],

