Cell["\<\
As a check - each column and row should add up to zero separately.
Display the table of normalised differences.\
\>", "Text",
 CellChangeTimes->{{3.954264566301152*^9, 
  3.9542645769972754`*^9}},ExpressionUUID->"84cd39c8-eb39-4d9a-ae23-\
8a5c3e218c77"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"expminusobsnorm", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<\>\"", ",", "\"\<A\>\"", ",", "\"\<B\>\"", 
      ",", "\"\<C\>\""}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"eA1", "-", "oA1"}], ")"}], "^", "2"}], "/", "eA1"}], "]"}],
       ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"eB1", "-", "oB1"}], ")"}], "^", "2"}], "/", "eB1"}], "]"}],
       ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"eC1", "-", "oC1"}], ")"}], "^", "2"}], "/", "eC1"}], 
       "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"2", ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"eA2", "-", "oA2"}], ")"}], "^", "2"}], "/", "eA2"}], "]"}],
       ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"eB2", "-", "oB2"}], ")"}], "^", "2"}], "/", "eB2"}], "]"}],
       ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"eC2", "-", "oC2"}], ")"}], "^", "2"}], "/", "eC2"}], 
       "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"3", ",", 
