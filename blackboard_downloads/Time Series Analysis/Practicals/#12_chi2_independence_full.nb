Cell["\<\
Now we can compute the chi-squared statistic for this contingency table.\
\>", "Text",
 CellChangeTimes->{{3.9542611294126377`*^9, 3.9542611641504583`*^9}, 
   3.954264563227396*^9, {3.954264746396495*^9, 
   3.954264747700371*^9}},ExpressionUUID->"3a20de19-17a0-4498-889f-\
51312169410b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"chi2", "=", 
  RowBox[{"N", "[", 
   RowBox[{"Total", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"expminusobs", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"2", ";;", "4"}], ",", 
          RowBox[{"2", ";;", "4"}]}], "]"}], "]"}], "^", "2"}], "/", 
      RowBox[{"expected", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"2", ";;", "4"}], ",", 
         RowBox[{"2", ";;", "4"}]}], "]"}], "]"}]}], ",", "2"}], "]"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9542611450389433`*^9, 3.954261268159292*^9}, {
  3.9542613054981117`*^9, 3.954261320505136*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"32fb6e37-5810-4cd5-8c59-afb4fd4aa45e"],

Cell[BoxData["182.54280469071972`"], "Output",
 CellChangeTimes->{3.9812004839440117`*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"34457a64-9b5f-d349-b102-d250744590cd"]
}, Open  ]],

Cell["\<\
There are three parties and three educational levels so the number of degrees \
of freedom is\
\>", "Text",
 CellChangeTimes->{{3.954261165837267*^9, 3.954261166449177*^9}, {
  3.954261336161427*^9, 
  3.9542613602384443`*^9}},ExpressionUUID->"ba46c526-2ed9-480a-a590-\
fc6b120a535f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"df", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"3", "-", "1"}], ")"}], "*", 
   RowBox[{"(", 
    RowBox[{"3", "-", "1"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9542613616131363`*^9, 3.9542613650264177`*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"c52f6fee-149e-441e-a10e-970fc5ea31d4"],

Cell[BoxData["4"], "Output",
 CellChangeTimes->{3.9812004888471603`*^9},
 CellLabel->"Out[27]=",ExpressionUUID->"df53c88f-c0b8-bc41-804b-d3854909c78d"]
}, Open  ]],

Cell["\<\
Look up the critical value of the chi-squared distribution for 4 degrees of \
freedom at 5% significance.\
\>", "Text",
 CellChangeTimes->{{3.9542613734357567`*^9, 
  3.9542614055537786`*^9}},ExpressionUUID->"f24b377a-b330-4455-8e60-\
116fd7d866f8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Quantile", "[", 
  RowBox[{
   RowBox[{"ChiSquareDistribution", "[", "df", "]"}], ",", "0.95"}], 
  "]"}]], "Input",
 CellLabel->"In[28]:=",ExpressionUUID->"98ef5d13-7d69-4a20-b8f9-0dbd1be13446"],

Cell[BoxData["9.487729036781156`"], "Output",
 CellChangeTimes->{3.98120049219166*^9},
 CellLabel->"Out[28]=",ExpressionUUID->"47b67198-a935-8547-a37a-235c0cc071f1"]
}, Open  ]],

Cell["\<\
Equivalently, calculate the p-value for the measured chi-squared value.\
\>", "Text",
 CellChangeTimes->{{3.9542615586942863`*^9, 
  3.954261571731187*^9}},ExpressionUUID->"54e96801-59de-42a6-bf63-\
e8805d28734b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"1", "-", 
   RowBox[{"CDF", "[", 
    RowBox[{
     RowBox[{"ChiSquareDistribution", "[", "df", "]"}], ",", "chi2"}], 
    "]"}]}], "//", "N"}]], "Input",
 CellChangeTimes->{{3.95426157351785*^9, 3.954261589524559*^9}, {
  3.95426173656153*^9, 3.954261737031847*^9}},
 CellLabel->"In[29]:=",ExpressionUUID->"110b2518-1d2b-4d69-ae1e-b8bac013efa0"],

Cell[BoxData["0.`"], "Output",
 CellChangeTimes->{3.981200495186302*^9},
 CellLabel->"Out[29]=",ExpressionUUID->"ee08f663-4e4c-6440-a643-cf6ff1a95c5c"]
}, Open  ]],

Cell["\<\
The measured chi - squared value is (much) more than the critical value at \
the 5% significance level (equivalently, the p-value is much less than 0.05).
So the null hypothesis is rejected - there is evidence that party choice is \
not independent of educational level.\
\>", "Text",
 CellChangeTimes->{{3.9542614269136257`*^9, 3.954261458893505*^9}, {
  3.954261748122507*^9, 3.95426174916968*^9}, {3.954261927478835*^9, 
  3.954261937083253*^9}, {3.954264512225918*^9, 
  3.954264521322007*^9}},ExpressionUUID->"9fee4b31-b30c-4b5c-a50f-\
e841ec9cc70f"]
}, Open  ]]
},
