Cell[BoxData["1000"], "Output",
 CellChangeTimes->{3.9811966527416706`*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"9fb2ed94-c23a-9f4b-b313-0bbbc65b23b2"]
}, Open  ]],

Cell["\<\
If party and educational level are independent, then the frequency of party \
choice should be the same for each education level.
This means the expected number for party Y for education level X is given by \
the total number of people with education level X multiplied by the fraction \
of the total who support party Y.
From this we can compute all the expected numbers.\
\>", "Text",
 CellChangeTimes->{{3.954260586405344*^9, 
  3.954260694377028*^9}},ExpressionUUID->"9efca6c4-691a-40cf-af18-\
1085beae58d8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"eA1", "=", 
  RowBox[{"o1total", "*", 
   RowBox[{"oAtotal", "/", "ototal"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"eB1", "=", 
  RowBox[{"o1total", "*", 
   RowBox[{"oBtotal", "/", "ototal"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"eC1", "=", 
  RowBox[{"o1total", "*", 
   RowBox[{"oCtotal", "/", "ototal"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"eA2", "=", 
  RowBox[{"o2total", "*", 
   RowBox[{"oAtotal", "/", "ototal"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"eB2", "=", 
  RowBox[{"o2total", "*", 
   RowBox[{"oBtotal", "/", "ototal"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"eC2", "=", 
  RowBox[{"o2total", "*", 
   RowBox[{"oCtotal", "/", "ototal"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"eA3", "=", 
  RowBox[{"o3total", "*", 
   RowBox[{"oAtotal", "/", "ototal"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"eB3", "=", 
  RowBox[{"o3total", "*", 
   RowBox[{"oBtotal", "/", "ototal"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"eC3", "=", 
  RowBox[{"o3total", "*", 
   RowBox[{"oCtotal", "/", "ototal"}]}]}]}], "Input",
 CellChangeTimes->{{3.954260699218547*^9, 3.954260771287271*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"6ad43902-0e1a-4c2f-82fc-de5ee89b5455"],

