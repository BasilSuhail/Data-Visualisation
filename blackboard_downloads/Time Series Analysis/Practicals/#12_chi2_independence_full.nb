Cell[BoxData["310"], "Output",
 CellChangeTimes->{3.9811966527403736`*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"935e7e76-1f9d-964d-87d7-29bb8a70146c"],

Cell[BoxData["410"], "Output",
 CellChangeTimes->{3.9811966527416706`*^9},
 CellLabel->"Out[4]=",ExpressionUUID->"cfb23a29-e19b-fa4e-a32b-1ecb3739c217"],

Cell[BoxData["600"], "Output",
 CellChangeTimes->{3.9811966527416706`*^9},
 CellLabel->"Out[5]=",ExpressionUUID->"5503d8e4-9aeb-a342-bfd0-702559c831b8"],

Cell[BoxData["300"], "Output",
