Notebook[{

Cell[CellGroupData[{
Cell["Example: chi-squared independence test", "Section",
 CellChangeTimes->{{3.95425976496506*^9, 
  3.954259781419063*^9}},ExpressionUUID->"81090f06-17a5-4c6e-b064-\
65694e8b4c23"],

Cell[TextData[{
 "Heumann et al. (2023) Example 10.8.1.\n\nThe following contingency table \
summarises the observed number of people who have a preference for a \
particular political party Y (part A, B, or C), depending on their \
educational level X (Level 1, 2, or 3).\n\n",
 Cell[BoxData[
  FormBox[GridBox[{
     {" ", " ", " ", 
      RowBox[{"Party", " ", "Y"}], " ", " "},
     {" ", " ", "A", "B", "C", "Total"},
     {"Education", "1", "100", "200", "300", "600"},
     {"level", "2", "100", "100", "100", "300"},
     {"X", "3", "80", "10", "10", "100"},
     {" ", "Total", "280", "310", "410", "1000"}
    }], TraditionalForm]],ExpressionUUID->
  "8b74a618-ef1c-47d6-abdb-1d011e497a72"]
}], "Text",
 CellChangeTimes->{{3.954259846923009*^9, 3.954260136209429*^9}, {
  3.954260188953989*^9, 3.954260191934926*^9}, {3.954260551750045*^9, 
  3.9542605519191093`*^9}},ExpressionUUID->"88417ff0-8b79-4209-ba10-\
d18bcef9ca62"],

Cell["\<\
The null hypothesis H0: Party choice and  level of education are independent \
of each other.
The alternative hypothesis H1: Party choice and level of education are not \
independent of each other.

- Create an equivalent table containing the expected number of people in each \
of the nine categories, assuming the party and education level are independent.
- Compute the chi-squared statistic.
- Perform a chi-squared test at the 5% significance level to test whether to \
reject H0.\
\>", "Text",
 CellChangeTimes->{{3.954260146174921*^9, 3.954260294620659*^9}, 
   3.9542620004216413`*^9},ExpressionUUID->"71c4a425-6967-4ec5-8902-\
cff9f2c537e1"],

Cell["\<\
The contingency table is small so we just specify each of the boxes manually:\
\
\>", "Text",
 CellChangeTimes->{{3.9542603238044157`*^9, 3.954260360158537*^9}, {
  3.954261843065696*^9, 
  3.954261844397334*^9}},ExpressionUUID->"2136f1bd-73f5-4955-8f9a-\
347a162d3a19"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{
   "oA1", ",", "oA2", ",", "oA3", ",", "oB1", ",", "oB2", ",", "oB3", ",", 
    "oC1", ",", "oC2", ",", "oC3"}], "}"}], "=", 
  RowBox[{"{", 
   RowBox[{
   "100", ",", "100", ",", "80", ",", "200", ",", "100", ",", "10", ",", 
    "300", ",", "100", ",", "10"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.954260363313621*^9, 3.9542604002047157`*^9}, {
  3.954260536707295*^9, 3.954260539222484*^9}, {3.9542617858591146`*^9, 
  3.954261815023592*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"dd5c5905-041a-4c11-a4d3-4e4a8558dd34"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "100", ",", "100", ",", "80", ",", "200", ",", "100", ",", "10", ",", "300",
    ",", "100", ",", "10"}], "}"}]], "Output",
 CellChangeTimes->{3.981196648581827*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"0376d392-13ff-cc4e-a3af-eb55e50abeb6"]
}, Open  ]],

Cell["Calculate the various totals.", "Text",
 CellChangeTimes->{{3.954260408051598*^9, 3.954260417815175*^9}, {
  3.954262019475801*^9, 
  3.9542620241729927`*^9}},ExpressionUUID->"55a2b707-b68d-43b1-bb2c-\
98a0b0f96685"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"oAtotal", "=", 
  RowBox[{"oA1", "+", "oA2", "+", "oA3"}]}], "\[IndentingNewLine]", 
 RowBox[{"oBtotal", "=", 
  RowBox[{"oB1", "+", "oB2", "+", "oB3"}]}], "\[IndentingNewLine]", 
 RowBox[{"oCtotal", "=", 
  RowBox[{"oC1", "+", "oC2", "+", "oC3"}]}], "\[IndentingNewLine]", 
 RowBox[{"o1total", "=", 
  RowBox[{"oA1", "+", "oB1", "+", "oC1"}]}], "\[IndentingNewLine]", 
 RowBox[{"o2total", "=", 
  RowBox[{"oA2", "+", "oB2", "+", "oC2"}]}], "\[IndentingNewLine]", 
 RowBox[{"o3total", "=", 
  RowBox[{"oA3", "+", "oB3", "+", "oC3"}]}], "\[IndentingNewLine]", 
 RowBox[{"ototal", "=", 
  RowBox[{"oAtotal", "+", "oBtotal", "+", "oCtotal"}]}]}], "Input",
 CellChangeTimes->{{3.954260419878319*^9, 3.954260484284607*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"b00b60b6-da99-4659-9372-410f61303407"],

