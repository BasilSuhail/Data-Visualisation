Cell["\<\
Split the heart rate data into the five categories for a one way ANOVA :
- All participants with no disease (NORM)
- All participants with CD
- All participants with STTC
- All participants with HYP
- All participants with MI\
\>", "Text",
 CellChangeTimes->{
  3.9801883424481897`*^9, {3.980188710086509*^9, 3.980188736573039*^9}, {
   3.980189116073264*^9, 
   3.980189129283532*^9}},ExpressionUUID->"eeec5f2d-9fad-4b7f-88fb-\
e0ab63c0570d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"anorm", "=", 
   RowBox[{
    RowBox[{"Select", "[", 
     RowBox[{"data", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "\[Equal]", "\"\<NORM\>\""}], 
       "&"}]}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"acd", "=", 
   RowBox[{
    RowBox[{"Select", "[", 
     RowBox[{"data", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "\[Equal]", "\"\<CD\>\""}], "&"}]}], 
     "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"asttc", "=", 
   RowBox[{
    RowBox[{"Select", "[", 
     RowBox[{"data", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "\[Equal]", "\"\<STTC\>\""}], 
       "&"}]}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "3"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ahyp", "=", 
   RowBox[{
    RowBox[{"Select", "[", 
     RowBox[{"data", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "\[Equal]", "\"\<HYP\>\""}], "&"}]}],
      "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "3"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ami", "=", 
   RowBox[{
    RowBox[{"Select", "[", 
     RowBox[{"data", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "\[Equal]", "\"\<MI\>\""}], "&"}]}], 
     "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.980188183672071*^9, 3.980188185616922*^9}, 
   3.980189105989607*^9, {3.9809479078380184`*^9, 3.9809479183953705`*^9}},
 CellLabel->"In[44]:=",ExpressionUUID->"958dfdb6-9ddb-4ec7-9a52-5dfe87828f98"],

