Cell[TextData[{
 StyleBox["CellMeans",
  FontWeight->"Bold"],
 " lists the means of each group, each combination of groups, and the overall \
mean.\nThere are 2-1=1 degrees of freedom for sex,  5-1=4 for diseases, and \
(2-1)*(5-1)=4 for the interaction.\nWithin individual groups there are  996 \
degrees of freedom.\nThe first three columns of the rows labelled ",
 StyleBox["sex",
  FontWeight->"Bold"],
 " and ",
 StyleBox["disease",
  FontWeight->"Bold"],
 " display the between-group statistics for those groups (same as for the \
one-way ANOVA).\nThe first three columns of the row labelled ",
 StyleBox["disease sex",
  FontWeight->"Bold"],
 " displays the between-group statistics for groups where sex and disease are \
separated\nThe row labelled ",
 StyleBox["Error",
  FontWeight->"Bold"],
 " displays the within-group statistics for all groups combined.\nThe fourth \
column ",
 StyleBox["FRatio",
  FontWeight->"Bold"],
 " displays the ratio of variances Model:Error for the three cases\nThe fifth \
column ",
 StyleBox["PValue",
  FontWeight->"Bold"],
 " displays the ",
 StyleBox["p",
  FontSlant->"Italic"],
 "-value associated with these FRatio values, assuming FRatio is distributed \
according to an ",
 StyleBox["F",
  FontSlant->"Italic"],
 "-distribution.\n"
}], "Text",
 CellChangeTimes->{{3.9801921548306828`*^9, 3.9801922158479548`*^9}, {
  3.980192525130022*^9, 3.980192531667272*^9}, {3.980192583204966*^9, 
  3.980192583410397*^9}, {3.980193354656026*^9, 
  3.9801934936809397`*^9}},ExpressionUUID->"b025d5ae-5c85-42c3-9a7b-\
bc1a9fd23536"],

Cell[TextData[StyleBox["Conclusions", "Subsubsection"]], "Text",
 CellChangeTimes->{{3.921742629303694*^9, 3.921742710867457*^9}, 
   3.92174282665441*^9, {3.921743063595952*^9, 3.921743195702332*^9}, {
   3.921743381601109*^9, 3.921743384568164*^9}, {3.921751005033297*^9, 
   3.921751020695103*^9}, {3.922869470087961*^9, 3.9228694737384157`*^9}, {
   3.948192263110865*^9, 
   3.948192264786037*^9}},ExpressionUUID->"90e20c79-7385-41d2-a10a-\
4485692b6b64"],

Cell[TextData[{
 "There was a significant effect of gender (",
 StyleBox["p",
  FontSlant->"Italic"],
 " = 0.0055 < 0.05) on heart rate.\nThere was a significant effect of disease \
(",
 StyleBox["p ",
  FontSlant->"Italic"],
 "= 0.0076 < 0.05) on heart rate. \nThere was no significant effect for \
disease and gender (",
 StyleBox["p",
  FontSlant->"Italic"],
 " = 0.298 > 0.05) on heart rate.\nThe data suggests that women have higher \
heart rate on an average than men, and that certain diseases show \
significantly different heart rate from the average."
}], "Text",
 CellChangeTimes->{
  3.94819226687798*^9, {3.980193516006179*^9, 3.980193526618043*^9}, {
   3.98019355898127*^9, 
   3.980193688166671*^9}},ExpressionUUID->"0e33cbaf-51b2-41d4-962e-\
ded0e4ac0df7"]
}, Open  ]]
}, Open  ]]
