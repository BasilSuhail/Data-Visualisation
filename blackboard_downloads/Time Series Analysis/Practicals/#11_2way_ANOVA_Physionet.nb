(* Beginning of Notebook Content *)
Notebook[{
Cell[TextData[{
 "\n",
 StyleBox["The effect of disease types and gender on heart rate", "Section"],
 "\n\nThe datafile contains heart rate data for various disease classes for a \
little less than 1000 patients. 5 disease superclasses (NORM, HYP, STTC, MI \
and CD) and sex (m,F)  are provided.\n\nFactors to be analysed:\nIn a one way \
ANOVA: Factor A (Disease)\nIn a two way ANOVA:  Factor A( Disease) and\t\
Factor B (Sex)\nOutcome variable was the heart rate of the individuals.\n\n",
 StyleBox["Load the data, split it into groups, and display descriptive \
statistics", "Subsection"]
}], "Text",
 CellChangeTimes->{{3.7810745789295816`*^9, 3.781074636968286*^9}, {
   3.782128737938488*^9, 3.78212876685076*^9}, {3.782391739684818*^9, 
   3.782392215163604*^9}, {3.9217396906463346`*^9, 3.921739694604685*^9}, {
   3.921739735448274*^9, 3.921739907223635*^9}, {3.921739969891453*^9, 
   3.921739989112232*^9}, 3.921740941761549*^9, {3.921741286497757*^9, 
   3.921741323851842*^9}, {3.921751126629789*^9, 3.921751131736023*^9}, {
   3.947142090987739*^9, 3.947142097048972*^9}, {3.9481921567682867`*^9, 
   3.948192157533565*^9}, {3.980193728433613*^9, 
   3.980193919883444*^9}},ExpressionUUID->"db273ec0-9dd7-4c4b-9ad8-\
990d5d407b34"],

Cell[TextData[{
 "Read the data file  beer_goggles_effect.xls, ",
 StyleBox["modifying the path below as necessary.", "Text",
  FontColor->GrayLevel[0]],
 "\nThis contains columns containing the gender of the participant, amount of \
alcohol they drunk, and the (independently-rated) attractiveness of the \
person they selected.\n",
 StyleBox["Flatten",
  FontWeight->"Bold"],
 " is used to remove any unnecessary levels of nested lists."
}], "Text",
 CellChangeTimes->{
  3.9481921600502243`*^9},ExpressionUUID->"470f085e-8e31-414a-9438-\
29609c574845"],

