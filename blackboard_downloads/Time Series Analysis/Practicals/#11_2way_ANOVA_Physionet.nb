Cell["Lets check if the standard deviation assumption holds", "Text",
 CellChangeTimes->{{3.980191788359168*^9, 
  3.9801918033784246`*^9}},ExpressionUUID->"da9d025a-0b4e-4c9b-a9ee-\
6b6739309b4e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"stdgrouplist", "=", 
   RowBox[{"Sort", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"StandardDeviation", "[", "#", "]"}], "&"}], "/@", 
     RowBox[{"{", 
      RowBox[{
      "fnorm", ",", "fcd", ",", "fsttc", ",", " ", "fhyp", ",", " ", "fmi", ",",
        "mnorm", ",", "mcd", ",", "msttc", ",", " ", "mhyp", ",", " ", 
       "mmi"}], " ", "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9801916691954308`*^9, 3.9801917019124727`*^9}, 
   3.980949109423645*^9},
 CellLabel->"In[93]:=",ExpressionUUID->"ce959a91-2e64-48c6-83b8-b974086bb573"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Max", "[", "stdgrouplist", "]"}], "/", 
