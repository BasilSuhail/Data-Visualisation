  "fcc0a96e-b5ab-4935-8dc9-8ef7f625d836"],
 ")]/(",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Sigma]", 
        StyleBox["X", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\sigma_X", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c93c7c25-51f3-48ac-a6a6-ef3d2fd1cae5"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Sigma]", 
        StyleBox["Y", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\sigma_Y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "93388006-87bb-4dd1-bdf6-c1e8b7628e70"],
 ") "
}], "Text",
 CellChangeTimes->{{3.777096109896418*^9, 3.777096135506915*^9}, {
  3.777096205845714*^9, 3.777096230587037*^9}, {3.7770962700622387`*^9, 
  3.777096344789701*^9}, {3.777096388127881*^9, 3.777096412125512*^9}, {
