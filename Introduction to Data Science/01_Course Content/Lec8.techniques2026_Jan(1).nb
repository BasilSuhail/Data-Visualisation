Cell[TextData[{
 "you can set the palette of colours inside the MatrixPlot using the option \
ColorFunction[]. To show a bar indicating how the colours relate to the \
values of the correlation, you should use the function BarLegend.Take a look \
at the forum ",
 ButtonBox["Link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://mathematica.stackexchange.com/questions/222654/how-to-make-\
barlegend-colors-conform-with-matrixplot-ones"], None},
  ButtonNote->
   "https://mathematica.stackexchange.com/questions/222654/how-to-make-\
barlegend-colors-conform-with-matrixplot-ones"],
 ". Or refer back to your ",
 StyleBox["Lecture 5,",
  FontVariations->{"Underline"->True}],
 StyleBox[" slide \[OpenCurlyDoubleQuote]Examples of the use of MatrixPlot\
\[CloseCurlyDoubleQuote]",
  FontVariations->{"Underline"->False}]
}], "Item",
