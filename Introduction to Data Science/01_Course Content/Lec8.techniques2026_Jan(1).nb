Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"i", ",", 
      RowBox[{"i", "[", "pp", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", 
      RowBox[{"{", 
       RowBox[{
       "Mean", ",", "Median", ",", "Variance", ",", "StandardDeviation", ",", 
        " ", "Quartiles"}], "}"}]}], "}"}]}], "]"}], "//", "Grid"}]], "Input",\

