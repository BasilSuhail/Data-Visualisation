e40de0a414d6"],

Cell[CellGroupData[{

Cell[TextData[{
 "So :\n\n  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Rho]", 
        RowBox[{
          StyleBox["X", "TI"], ",", 
          StyleBox["Y", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\rho_{X,Y}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "96f71b0b-959e-4845-af72-c2f00e7cd50e"],
 " = ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       FractionBox[
        SubscriptBox["\[Sigma]", 
         RowBox[{
           StyleBox["X", "TI"], ",", 
           StyleBox["Y", "TI"]}]], 
        RowBox[{
          SubscriptBox["\[Sigma]", 
           StyleBox["X", "TI"]], 
          SubscriptBox["\[Sigma]", 
           StyleBox["Y", "TI"]]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{\\sigma_{X,Y}}{\\sigma_X \\sigma_Y}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "86ac737e-072f-4401-96fa-fcd72bcb9071"],
 "  \n\nwhere E is the expected value operator. Notably, ",
 StyleBox["correlation",
  FontWeight->"Bold"],
 " is dimensionless while ",
 StyleBox["covariance",
  FontWeight->"Bold"],
 " is in units obtained by multiplying the units of the two variables."
}], "Item",
 CellChangeTimes->{{3.777096109896418*^9, 3.777096135506915*^9}, {
   3.777096205845714*^9, 3.777096230587037*^9}, {3.7770962700622396`*^9, 
