Cell[TextData[{
 "Attitude or the variable ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5868c90d-ece3-429c-97bd-f2ca02c10b12"],
 " is the \"predictor variable\". Score, represented by  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["y", "TI"], TraditionalForm], "errors" -> {}, "input" -> "y", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4d77749f-8067-46bd-b748-bf6a2d2c9b96"],
 " is called \[OpenCurlyDoubleQuote]outcome variable\[CloseCurlyDoubleQuote]. "
}], "Text",
