Cell[TextData[{
 "Prescriptive ",
 StyleBox["analytics",
  FontVariations->{"Underline"->True}]
}], "Title",
 CellChangeTimes->{{3.811249341058408*^9, 
  3.811249343725793*^9}},ExpressionUUID->"2afcb65d-2af8-4180-aa8c-\
c3cb4dc1ada1"],

Cell["\<\
An area of business analytics dedicated to finding the best course of action \
for a given situation that involves decisions. For example, analysing the \
potential decisions (let us trust this particular set of suppliers, or not \
and what are the risks involved and the costs associated?), the way different \
decisions interrelates and are influence by external agents, and how this can \
lead to an optimal course of action. \
\>", "Item",
 CellChangeTimes->{{3.811249358098999*^9, 3.811249363208282*^9}, {
  3.813310098529231*^9, 3.813310190945194*^9}, {3.81331022503878*^9, 
  3.813310274475029*^9}, {3.813310312511621*^9, 3.813310334413901*^9}, {
  3.813387618545023*^9, 3.813387654370551*^9}, {3.813387698247645*^9, 
  3.81338770440397*^9}, {3.813388213151261*^9, 3.813388250730729*^9}, {
  3.813401658762285*^9, 3.813401658976003*^9}, {3.97912430218181*^9, 
  3.979124302233643*^9}},ExpressionUUID->"fcb1326d-9506-4506-81aa-\
f01665e32bd9"],

Cell["\<\
This analytics can involve statistical tools, computing science algorithms, \
game-theoretical approaches, and it can also rely on results from AI and \
machine learning algorithms.  \
\>", "Item",
 CellChangeTimes->{{3.811249358098999*^9, 3.811249363208282*^9}, {
  3.813310098529231*^9, 3.813310190945194*^9}, {3.81331022503878*^9, 
  3.813310274475029*^9}, {3.813310312511621*^9, 3.813310334413901*^9}, {
  3.813387618545023*^9, 3.813387654370551*^9}, {3.813387698247645*^9, 
  3.81338770440397*^9}, {3.813388213151261*^9, 
  3.813388246351137*^9}},ExpressionUUID->"b34ea929-7b67-4d51-ad88-\
f84d6feae739"]
}, Open  ]],

