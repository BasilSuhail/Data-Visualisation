Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       OverscriptBox[
        StyleBox["x", "TI"], "_"], "\[LongEqual]", 
       FractionBox["1", 
        StyleBox["M", "TI"]], 
       UnderscriptBox["\[Sum]", 
        StyleBox["i", "TI"], LimitsPositioning -> True], 
       StyleBox["N", "TI"], 
       RowBox[{"(", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["i", "TI"]], ")"}], 
       SubscriptBox[
        StyleBox["x", "TI"], 
        StyleBox["i", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
   "$\\bar{x}=\\frac{1}{M}\\sum_i N({x_i}) x_i$", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellChangeTimes->{3.886684530899406*^9},
 CellLabel->
  "In[324]:=",ExpressionUUID->"340cf063-f23c-4e5e-9bbc-a3b40b544c67"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["N", "TI"], "(", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["i", "TI"]], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$N(x_i)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f27eee06-00eb-4159-b799-c562162f4313"],
 " represents the number of observations for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["x", "TI"], 
        StyleBox["i", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "x_i", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f4afa5bb-f74b-4f70-b534-848962960a21"],
 " and M is the total number of observations (e.g. population)"
}], "Text",
 CellChangeTimes->{{3.886684608610053*^9, 3.886684641400711*^9}, {
   3.8866853300509567`*^9, 3.886685424520269*^9}, {3.949403396399641*^9, 
   3.949403396802279*^9}, 
   3.949403440867831*^9},ExpressionUUID->"578e1ca2-1319-476a-8a87-\
153f207867ea"],

Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       StyleBox["M", "TI"], "\[LongEqual]", 
       UnderscriptBox["\[Sum]", 
        StyleBox["i", "TI"], LimitsPositioning -> True], 
       StyleBox["N", "TI"], 
       RowBox[{"(", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["i", "TI"]], ")"}]}], TraditionalForm], "errors" -> {}, 
   "input" -> "$M=\\sum_i N(x_i) $", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellChangeTimes->{{3.886684666875704*^9, 3.886684684803981*^9}, {
