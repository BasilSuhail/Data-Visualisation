Cell[TextData[{
 "Nice form of using Table to obtain other statistical quantities. Notice \
that ",
 StyleBox["i", "Input"],
 " does not vary for numerical values, but according to the function inside \
the list:"
}], "Text",
 CellChangeTimes->{{3.8132406793419037`*^9, 3.813240687131472*^9}, {
