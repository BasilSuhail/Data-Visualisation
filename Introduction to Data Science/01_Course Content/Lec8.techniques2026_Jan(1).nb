Cell[TextData[{
 StyleBox["True positive rate (TPR), or sensitivity",
  FontWeight->"Bold"],
 ": proportion of actual positives that are correctly identified : "
}], "Item",
 CellChangeTimes->{{3.7771958078321953`*^9, 3.7771958590331798`*^9}, {
   3.7801583346915493`*^9, 3.780158351472115*^9}, {3.78015869134179*^9, 
