Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"returnsGraph2", "=", 
  RowBox[{"WeightedAdjacencyGraph", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Round", "[", 
      RowBox[{
       RowBox[{"matrixCorr", " ", 
        RowBox[{"UnitStep", "[", 
         RowBox[{
          RowBox[{"Abs", "[", "matrixCorr", "]"}], "-", "0.6"}], "]"}]}], ",",
        ".01"}], "]"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"1.", "->", "Infinity"}], ",", 
       RowBox[{"0.", "->", "Infinity"}]}], "}"}]}], ",", 
    RowBox[{"VertexLabels", "\[Rule]", "labels"}], ",", 
    RowBox[{"VertexLabelStyle", "->", "18"}], ",", 
    RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.877701493637873*^9, 3.877701497390128*^9}, {
   3.884955134705858*^9, 3.884955135840149*^9}, 3.88495560633145*^9, {
