Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       OverscriptBox[
        StyleBox["x", "TI"], "_"], "\[LongEqual]", 
       UnderscriptBox["\[Sum]", 
        RowBox[{
          StyleBox["i", "TI"], "\[LongEqual]", "1"}], LimitsPositioning -> 
        True], 
       SubscriptBox[
        StyleBox["w", "TI"], 
        StyleBox["i", "TI"]], 
       SubscriptBox[
        StyleBox["x", "TI"], 
        StyleBox["i", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
   "$\\bar{x} = \\sum_{i=1}w_i x_i$", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellChangeTimes->{3.8848589021294117`*^9, 3.886684515282719*^9},
 CellLabel->
  "In[235]:=",ExpressionUUID->"bec4b3ac-bdc4-475d-a65e-efc81bbdc9d3"],

