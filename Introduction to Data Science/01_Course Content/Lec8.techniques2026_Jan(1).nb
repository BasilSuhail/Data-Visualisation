Cell["Descriptive Statistics", "Title",
 CellChangeTimes->{{3.7770315006644583`*^9, 3.7770315006665497`*^9}, 
   3.777031537053903*^9, {3.823508831996409*^9, 
   3.823508834245329*^9}},ExpressionUUID->"3df17cc3-f25c-4436-8ea1-\
9fac66dafb02"],

Cell["\<\
Descriptive statistics provide simple summaries about the sample and about \
the observations that have been made, for example after the survey is \
conducted. \
\>", "Item",
 CellChangeTimes->{{3.77703153330277*^9, 3.777031542119915*^9}, {
  3.777031747709334*^9, 3.777031747709567*^9}, {3.811247718476576*^9, 
  3.81124772217097*^9}, {3.85486934136341*^9, 
  3.854869347813169*^9}},ExpressionUUID->"64d42c55-4fbb-417f-acf2-\
2ba75a3ecdef"],

Cell[CellGroupData[{

Cell["\<\
It aims at understanding the properties of probability distributions (i.e., \
frequency distributions):\
\>", "Item",
 CellChangeTimes->{{3.77703153330277*^9, 3.777031542119915*^9}, {
   3.777031747709334*^9, 3.777031747709567*^9}, {3.811247718476576*^9, 
   3.811247763712429*^9}, 
   3.811247809259563*^9},ExpressionUUID->"12cd80e0-7146-4cfc-a40d-\
e47f5dfd87a5"],

Cell["measures of locality and centrality (mean)  ", "Subitem",
 CellChangeTimes->{{3.77703153330277*^9, 3.777031542119915*^9}, {
  3.777031747709334*^9, 3.777031747709567*^9}, {3.811247718476576*^9, 
