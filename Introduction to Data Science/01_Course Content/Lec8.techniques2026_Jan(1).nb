   3.7801591292262583`*^9}, 3.780160486788042*^9, {3.9494092970740557`*^9, 
   3.9494092989625063`*^9}},
 FontFamily->"Arial",ExpressionUUID->"5800f2e6-b1cc-4181-bf44-f10a99ec30be"],

Cell["\<\
In the \"real-world\" : tested people that were correctly identified as \
covid19 positive\
\>", "Text",
 CellChangeTimes->{{3.780160489926101*^9, 3.780160510420978*^9}, {
