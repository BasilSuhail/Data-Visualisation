   3.7801439087014856`*^9, 3.7801439218769636`*^9}, {3.780143952378806*^9, 
   3.780143965066226*^9}},ExpressionUUID->"a6e1ab6e-b25a-4949-b26b-\
0bef9c5ff194"],

