Cell[TextData[{
 StyleBox["Mean[data]",
  FontWeight->"Bold"],
 " : The most basic estimate of location is the mean, or\naverage, or \
expected value."
}], "Text",
 CellChangeTimes->{{3.7770321189325943`*^9, 3.7770321307979536`*^9}, {
  3.777032388137974*^9, 
  3.777032389369575*^9}},ExpressionUUID->"4c58c724-9b9f-4979-9181-\
59e3beb859c6"],

Cell[TextData[{
 StyleBox["Median",
  FontWeight->"Bold"],
 ": The value such that one - half of the data lies above and below. "
}], "Text",
 CellChangeTimes->{{3.777031861978744*^9, 3.777031865006955*^9}, 
   3.777031899767648*^9, {3.777032393407271*^9, 3.777032420859554*^9}, {
   3.777095572300745*^9, 3.777095658866715*^9}, {3.777095689273977*^9, 
   3.777095722698694*^9}, {3.780143833558118*^9, 
   3.780143844301282*^9}},ExpressionUUID->"871f3ed5-3804-41b6-80a1-\
ec0da637450a"],

Cell["\<\
The median depends only on the values in the center of the sorted data.\
\>", "Item",
 CellChangeTimes->{{3.777031861978744*^9, 3.777031865006955*^9}, 
   3.777031899767648*^9, {3.777032393407271*^9, 3.777032420859554*^9}, {
   3.777095572300745*^9, 3.777095658866715*^9}, {3.777095689273977*^9, 
   3.777095722698694*^9}, {3.780143833558118*^9, 
   3.780143861917012*^9}},ExpressionUUID->"2b58e5ff-2799-4dab-b28b-\
1e160e9136d3"],

Cell[TextData[{
 "Good as a measure of location ",
 StyleBox["when data has an outlier",
  FontVariations->{"Underline"->True}],
 ". For example, to compute the average income in a neighborhood where a \
single household income is much much larger than that of any other household. "
}], "Item",
 CellChangeTimes->{{3.777031861978744*^9, 3.777031865006955*^9}, 
   3.777031899767648*^9, {3.777032393407271*^9, 3.777032420859554*^9}, {
   3.777095572300745*^9, 3.777095658866715*^9}, {3.777095689273977*^9, 
   3.777095722698694*^9}, {3.780143833558118*^9, 
   3.780143865231756*^9}},ExpressionUUID->"9b1bec87-4f53-4464-8484-\
bccd9bcf642d"],

Cell["\<\
The median will not change (\[OpenCurlyDoubleQuote]much\
\[CloseCurlyDoubleQuote]) its value due to this single outlier.\
\>", "Item",
 CellChangeTimes->{{3.777031861978744*^9, 3.777031865006955*^9}, 
   3.777031899767648*^9, {3.777032393407271*^9, 3.777032420859554*^9}, {
   3.777095572300745*^9, 3.777095658866715*^9}, {3.777095689273977*^9, 
   3.777095722698694*^9}, {3.780143833558118*^9, 3.7801438617101393`*^9}, {
   3.87560124515198*^9, 
   3.875601248839163*^9}},ExpressionUUID->"d2332692-61b7-486c-8c9f-\
be5ac6bcda49"],

Cell[TextData[{
 StyleBox["TrimmedMean",
  FontWeight->"Bold"],
 " : The average of all values after dropping a fixed number of extreme \
values. "
}], "Text",
 CellChangeTimes->{{3.777031887323661*^9, 3.777031897465602*^9}, {
   3.777032061638256*^9, 3.777032066546321*^9}, {3.777032142103798*^9, 
   3.777032146345254*^9}, {3.777032366074171*^9, 3.777032381052693*^9}, 
   3.777032433990486*^9, {3.777032596426945*^9, 3.777032692060004*^9}, {
   3.7801439087014856`*^9, 
   3.78014391580794*^9}},ExpressionUUID->"a2098d25-b850-4bcb-8259-\
bd751f04d21d"],

Cell["A trimmed mean eliminates the influence of extreme values. ", "Item",
 CellChangeTimes->{{3.777031887323661*^9, 3.777031897465602*^9}, {
   3.777032061638256*^9, 3.777032066546321*^9}, {3.777032142103798*^9, 
   3.777032146345254*^9}, {3.777032366074171*^9, 3.777032381052693*^9}, 
   3.777032433990486*^9, {3.777032596426945*^9, 3.777032692060004*^9}, {
   3.7801439087014856`*^9, 
   3.780143944866147*^9}},ExpressionUUID->"39dfc861-3a46-44ba-9320-\
b7953aa61555"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["For example, in international diving the top and \
bottom scores from five judges are dropped, and the final score is the \
average of the three remaining judges [Wikipedia-2016].",
 FontWeight->"Bold"]], "Item",
 CellChangeTimes->{{3.777031887323661*^9, 3.777031897465602*^9}, {
   3.777032061638256*^9, 3.777032066546321*^9}, {3.777032142103798*^9, 
