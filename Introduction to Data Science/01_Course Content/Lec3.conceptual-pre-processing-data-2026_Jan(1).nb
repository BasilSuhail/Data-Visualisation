Cell["\<\
Dates are presented in several different styles, and you will need to choose \
one style.\
\>", "Item",
 CellChangeTimes->{{3.843718833811729*^9, 3.843718864899993*^9}, 
   3.84371890362348*^9},ExpressionUUID->"d445e0a5-7755-47e5-afee-\
059fe15db1a2"],

Cell[CellGroupData[{

Cell[TextData[{
 "We will work much to handle dates, but good to know that Mathematica can \
deal with many forms of entries, and can create objects that are identified \
by a calendar date, actually many types of calendars, and time systems (UTI, \
UTC (or GMT), ECT...) (introduced in ",
 StyleBox["Mathematica 13.0",
  FontVariations->{"Underline"->True}],
 ")."
}], "Item",
 CellChangeTimes->{{3.843718833811729*^9, 3.843718898669186*^9}, {
  3.843719065736251*^9, 3.843719082169443*^9}, {3.843719128256629*^9, 
  3.843719130485569*^9}, {3.844146436296605*^9, 3.844146436500081*^9}, {
  3.874052890309058*^9, 3.874052896118413*^9}, {3.874053002103629*^9, 
  3.8740530398274393`*^9}, {3.874053110262258*^9, 3.874053114319841*^9}, {
  3.874053225164134*^9, 3.874053232175669*^9}, {3.874053736585809*^9, 
  3.874053744052924*^9}},ExpressionUUID->"b064047e-4b9f-4389-a835-\
20334a09187a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DateObject", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"2022", ",", "10", ",", "1", ",", "0", ",", "0", ",", "0"}], 
    "}"}], ",", 
   RowBox[{"TimeSystem", "->", "\"\<UTC\>\""}], ",", 
   RowBox[{"TimeZone", "->", "0"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8740531481354713`*^9, 3.874053148150177*^9}, {
  3.87405322133816*^9, 3.874053240772835*^9}},
 CellLabel->
  "In[851]:=",ExpressionUUID->"465a5c4e-985a-4ba4-a2aa-1a6283aa1847"],

