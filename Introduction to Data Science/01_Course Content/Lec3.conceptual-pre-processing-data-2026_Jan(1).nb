Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"nRows", "=", "10"}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"Number", " ", "of", " ", "rows"}], "*)"}], "\[IndentingNewLine]", 
  "\n", 
  RowBox[{"(*", 
   RowBox[{"Generate", " ", "data", " ", "for", " ", "columns"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"xChoice", ",", "yChoice"}], "}"}], ",", 
        RowBox[{
         RowBox[{"xChoice", "=", 
          RowBox[{"RandomChoice", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0.8", ",", "0.2"}], "}"}], "->", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"RandomReal", "[", "10", "]"}], ",", 
              RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], 
             "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"yChoice", "=", 
          RowBox[{"RandomChoice", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0.8", ",", "0.2"}], "}"}], "->", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"RandomReal", "[", "10", "]"}], ",", 
              RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], 
             "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<PrimaryKey\>\"", "->", "i"}], ",", 
           RowBox[{"\"\<VariableX\>\"", "->", "xChoice"}], ",", 
           RowBox[{"\"\<VariableY\>\"", "->", "yChoice"}]}], "|>"}]}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "nRows"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Create", " ", "the", " ", "dataset"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dataset", "=", 
    RowBox[{"Dataset", "[", "data", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\n", 
  RowBox[{"(*", 
   RowBox[{"Display", " ", "the", " ", "dataset"}], 
   "*)"}]}], "\[IndentingNewLine]", "dataset"}], "Input",
