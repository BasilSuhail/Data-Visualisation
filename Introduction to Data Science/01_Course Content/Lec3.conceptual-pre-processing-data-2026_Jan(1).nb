Cell[CellGroupData[{

Cell[TextData[{
 "Encoding: suppose you want to construct a health index, indicating how \
healthy an individual is. Also, suppose the candidate was asked about having \
or not a set of conditions/diseases. For 5 questions, an individual would \
have answers encoded by the sequence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["s", 
       RowBox[{"1", " "}]], " ", "=", " ", "0"}], ",", " ", 
     RowBox[{
      SubscriptBox["s", 
       RowBox[{"2", " "}]], "=", "1"}], ",", 
     SubscriptBox["s", "3"]}]}], TraditionalForm]],ExpressionUUID->
  "f7c86ba5-8148-4b6f-a413-634b4b44974c"],
 " = 0, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", 
    RowBox[{"4", " "}]], TraditionalForm]],ExpressionUUID->
  "2dee400a-7068-47c3-ab83-4056574d2f4a"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"=", "1"}], ",", 
    SubscriptBox["s", 
     RowBox[{"5", " "}]]}], TraditionalForm]],ExpressionUUID->
  "e66c8c25-ff51-45c4-ad24-7bdb4135436f"],
 "= 1}, where \"1\" would signify the individual has a condition and \
\[OpenCurlyDoubleQuote]0\[CloseCurlyDoubleQuote] otherwise. A health index \
can be defined using a binary to real conversion by "
}], "Subitem",
 CellChangeTimes->{{3.905420400295114*^9, 3.905420465848065*^9}, {
   3.905420555406697*^9, 3.905420556580401*^9}, {3.905421794324049*^9, 
   3.905421801259309*^9}, {3.905421858995981*^9, 3.905421863323551*^9}, 
   3.906188757667802*^9, {3.977312301237134*^9, 3.977312310931797*^9}, {
   3.977312350021805*^9, 3.977312352873946*^9}, {3.977312530417502*^9, 
   3.97731254824401*^9}, {3.977312786844042*^9, 3.977312819854762*^9}, {
   3.97731296500567*^9, 
   3.977313056869935*^9}},ExpressionUUID->"4c2cb800-4a1e-4884-ba6c-\
56800073f3d6"],

Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       UnderoverscriptBox["\[Sum]", 
        StyleBox["i", "TI"], 
        StyleBox["L", "TI"], LimitsPositioning -> True], 
       FractionBox[
        RowBox[{
          SubscriptBox[
           StyleBox["s", "TI"], 
           StyleBox["i", "TI"]], 
          SuperscriptBox["2", 
           RowBox[{
             StyleBox["L", "TI"], "-", 
             StyleBox["i", "TI"]}]]}], 
        RowBox[{
          SuperscriptBox["2", 
           StyleBox["L", "TI"]], "-", "1"}]]}], TraditionalForm], 
   "errors" -> {}, "input" -> "\\sum_i^L\\frac{s_i 2^{L-i}}{2^L-1}", "state" -> 
   "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellChangeTimes->{
  3.9796357500608892`*^9},ExpressionUUID->"961ae505-89da-41d1-88ca-\
633bf3194246"],

Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{"\[LongEqual]", 
       SubscriptBox[
        StyleBox["s", "TI"], "1"], 
       SuperscriptBox["2", "4"], "+", 
       SubscriptBox[
        StyleBox["s", "TI"], "2"], 
       SuperscriptBox["2", "3"], "+", 
       SubscriptBox[
        StyleBox["s", "TI"], "3"], 
       SuperscriptBox["2", "2"], "+", 
       SubscriptBox[
        StyleBox["s", "TI"], "4"], 
       SuperscriptBox["2", "1"], 
       SubscriptBox[
        StyleBox["s", "TI"], "5"], 
       SuperscriptBox["2", "0"], "/", 
       RowBox[{"(", 
         RowBox[{
           SuperscriptBox["2", "5"], "-", "1"}], ")"}]}], TraditionalForm], 
   "errors" -> {}, "input" -> 
   "=s_1 2^{4}+s_2 2^{3} + s_3 2^{2} + s_4 2^{1} s_5 2^{0}/(2^5-1)", "state" -> 
   "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellChangeTimes->{
  3.9796352796303797`*^9},ExpressionUUID->"2878718a-ed44-4f82-9dcf-\
5596a3c4e0f0"],

