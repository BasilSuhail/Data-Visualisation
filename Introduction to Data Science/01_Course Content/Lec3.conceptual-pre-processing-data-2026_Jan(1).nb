Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"9a1e27ec-a622-49e4-89ff-e7386be48c6b"],

Cell[TextData[{
 "Manipulate the data (wrangling or munging) to turn into something more \
convenient, useful\n\nconsider the following BBC pizza dough recipe ",
 ButtonBox["Link",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.bbcgoodfood.com/recipes/pizza-margherita-4-easy-steps"], 
    None},
  ButtonNote->
   "https://www.bbcgoodfood.com/recipes/pizza-margherita-4-easy-steps"],
 ":\n\n\[OpenCurlyDoubleQuote]Put 300g strong bread flour, 1 tsp instant \
yeast, 1 tsp of salt, 1 tbsp of olive oil into a large bowl, with 200ml warm \
water and knead for 5 mins until smooth.\[CloseCurlyDoubleQuote] "
}], "Text",
 CellChangeTimes->{{3.8085540005564613`*^9, 3.808554064891885*^9}, {
   3.808554235239497*^9, 3.8085542753088017`*^9}, {3.8085545731474857`*^9, 
   3.808554720662761*^9}, 
   3.808554754276835*^9},ExpressionUUID->"f88a977c-2ce9-4619-9ec7-\
7e93cbe7864d"],

Cell["Manually or automatically one needs to identify items", "Item",
 CellChangeTimes->{{3.8085562268280168`*^9, 
  3.808556247159873*^9}},ExpressionUUID->"419ec9a9-5ff3-448f-a4ab-\
ecc0a1216811"],

Cell[TextData[{
 "\"Put ",
 StyleBox["300",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["g",
  FontColor->RGBColor[0.6, 0.4, 0.2]],
 " ",
 StyleBox["strong bread flour",
  FontVariations->{"Underline"->True}],
 ", ",
 StyleBox["1",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["tsp",
  FontColor->RGBColor[0.6, 0.4, 0.2]],
 " ",
 StyleBox["instant yeast",
  FontVariations->{"Underline"->True}],
 ", ",
 StyleBox["1",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["tsp",
  FontColor->RGBColor[0.6, 0.4, 0.2]],
 " of ",
 StyleBox["salt",
  FontVariations->{"Underline"->True}],
 ", ",
 StyleBox["1",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["tbsp",
  FontColor->RGBColor[0.6, 0.4, 0.2]],
 " of ",
 StyleBox["olive oil",
  FontVariations->{"Underline"->True}],
 " into a large bowl, with ",
 StyleBox["200",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["ml",
  FontColor->RGBColor[0.6, 0.4, 0.2]],
 " ",
 StyleBox["warm water",
  FontVariations->{"Underline"->True}],
 " and knead for ",
 StyleBox["5",
  FontColor->RGBColor[0, 0, 1]],
 "mins until smooth.\" "
}], "Text",
 CellMargins:>
