     RowBox[{
       RowBox[{"{", 
         RowBox[{"2022", ",", "10", ",", "1", ",", "0", ",", "0", ",", "0"}], 
         "}"}], ",", "\"Instant\"", ",", "\"Gregorian\"", ",", "0.`", ",", 
       "\"UTC\""}], "]"}]},
