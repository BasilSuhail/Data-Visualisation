Cell["\<\
Knowing that numbers had a uniform random distribution, it makes sense to \
replace missing (either \"\" or Missing[\"NotAvailable\"]) by the average in \
the column \
\>", "Text",
 CellChangeTimes->{{3.905410331443383*^9, 
  3.905410387046493*^9}},ExpressionUUID->"c48c72e8-0cf8-4147-893b-\
6e4a2aab8773"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Calculate", " ", "the", " ", "average", " ", "values", " ", "of", " ", 
    "each", " ", "column"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"averageX", "=", 
     RowBox[{"Mean", "@", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"Normal", "@", "dataset"}], ",", 
         RowBox[{
          RowBox[{"#VariableX", "=!=", 
           RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], "&"}]}], 
        "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "\"\<VariableX\>\""}], "]"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"averageY", "=", 
     RowBox[{"Mean", "@", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"Normal", "@", "dataset"}], ",", 
         RowBox[{
          RowBox[{"#VariableY", "=!=", 
           RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], "&"}]}], 
        "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "\"\<VariableY\>\""}], "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Replace", " ", "NA", " ", "and", " ", "zero", " ", "values", " ", "with",
      " ", "the", " ", "calculated", " ", "averages"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cleanedDataset", "=", 
     RowBox[{"dataset", "[", 
      RowBox[{"All", ",", 
       RowBox[{
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<PrimaryKey\>\"", "->", "#PrimaryKey"}], ",", 
          RowBox[{"\"\<VariableX\>\"", "->", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"#VariableX", "===", 
              RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], ",", 
             "averageX", ",", "#VariableX"}], "]"}]}], ",", 
          RowBox[{"\"\<VariableY\>\"", "->", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"#VariableY", "===", 
              RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}]}], ",", 
             "averageY", ",", "#VariableY"}], "]"}]}]}], "|>"}], "&"}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"cleaned", " ", "dataset"}], "*)"}], "\[IndentingNewLine]", 
   "cleanedDataset"}]}]], "Input",
