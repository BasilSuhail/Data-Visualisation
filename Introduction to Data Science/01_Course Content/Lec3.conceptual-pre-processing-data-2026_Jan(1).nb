Cell["\<\
Now, let us only get data from Brazil and Germany for the period 1990, 2021. \
Use Cases[expr, pattern]\
\>", "Text",
 CellChangeTimes->{{3.874073609589741*^9, 3.874073627480597*^9}, {
  3.977313632937263*^9, 
  3.977313634176215*^9}},ExpressionUUID->"73f7e4fa-6d19-4a48-b66c-\
3f664cf65800"],

Cell[BoxData[
 RowBox[{
  RowBox[{"emissionReducedCountries", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"emissionReduced1", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<Brazil\>\"", "|", " ", "\"\<Germany\>\""}], ",", 
       RowBox[{"_", "?", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"1990", "<=", "#", "<=", "2021"}], "&"}], ")"}]}], ",", 
       "___"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.874073659855529*^9, 3.874073704976734*^9}, {
