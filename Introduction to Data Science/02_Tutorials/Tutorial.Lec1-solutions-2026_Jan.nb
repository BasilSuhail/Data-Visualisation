Cell["\<\
The first \"x\" denotes the terms of a polynomial . For multilinear \
regression one could do {sin[x], cos[y]} . The second \"x\"  represents the \
argument of the function, which could be {x, y} for a multilinear regression \
. \
\>", "Text",
 CellChangeTimes->{{3.873950323649753*^9, 3.873950403045575*^9}, {
  3.874486494131609*^9, 
  3.874486498600175*^9}},ExpressionUUID->"15dac3de-9bfc-48ac-8151-\
3b43caa780e2"],

