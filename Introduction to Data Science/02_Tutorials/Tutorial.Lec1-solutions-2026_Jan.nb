Cell["\<\
The Plot shows a linear relationship, thus a linear regression will express \
well the relationship between the 2 datasets\
\>", "Text",
 CellChangeTimes->{{3.811587302657085*^9, 
  3.811587350284589*^9}},ExpressionUUID->"f18ca1fb-fe74-4d4e-9f5d-\
a7d21bf8867b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Let us model the data and estimate the linear relationship :", "Section",
 CellChangeTimes->{{3.811587372814065*^9, 3.811587382265138*^9}, {
  3.811590263217259*^9, 
  3.811590266210855*^9}},ExpressionUUID->"55718ede-99ab-40bf-94cd-\
a59f6abb64ac"],

Cell["It should be of the form : ", "Text",
 CellChangeTimes->{{3.811587390552291*^9, 
  3.811587395390828*^9}},ExpressionUUID->"ce0a1691-60df-4588-a9ff-\
51dae2091cbd"],

Cell[BoxData[
 RowBox[{"Y", "=", 
  RowBox[{"aX", "+", "b"}]}]], "DisplayFormula",
 CellChangeTimes->{{3.8115874204493723`*^9, 3.811587463226177*^9}},
 FontSlant->"Italic",ExpressionUUID->"6645d1fe-f685-442b-b196-f2652c1b7e3e"],

Cell[TextData[{
 "where ",
 StyleBox["a",
  FontSlant->"Italic"],
 " is the linear coefficient (the slope of the line) and ",
 StyleBox["b",
  FontSlant->"Italic"],
 " the constant term (intercept)"
}], "Text",
 CellChangeTimes->{{3.811587466926454*^9, 3.811587512980855*^9}, {
  3.885387958821255*^9, 
  3.885387965328362*^9}},ExpressionUUID->"1de83756-59cb-42dc-a9c7-\
179956fc7526"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"a", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"Max", "[", 
     RowBox[{
      RowBox[{"dataset1", "[", 
       RowBox[{"[", 
        RowBox[{";;", ",", "2"}], "]"}], "]"}], "-", 
      RowBox[{"Min", "[", 
       RowBox[{"dataset1", "[", 
        RowBox[{"[", 
         RowBox[{";;", ",", "2"}], "]"}], "]"}], "]"}]}], "]"}], ")"}], "/", 
   RowBox[{"(", 
    RowBox[{"Max", "[", 
     RowBox[{
      RowBox[{"dataset1", "[", 
       RowBox[{"[", 
        RowBox[{";;", ",", "1"}], "]"}], "]"}], "-", 
      RowBox[{"Min", "[", 
       RowBox[{"dataset1", "[", 
        RowBox[{"[", 
         RowBox[{";;", ",", "1"}], "]"}], "]"}], "]"}]}], "]"}], 
    ")"}]}]}]], "Input",
 CellChangeTimes->{{3.8115876155563097`*^9, 3.811587615618158*^9}, {
  3.81158764664294*^9, 3.811587704896145*^9}, {3.811587744303965*^9, 
  3.811587751677953*^9}, {3.811588330292323*^9, 3.811588349226594*^9}},
