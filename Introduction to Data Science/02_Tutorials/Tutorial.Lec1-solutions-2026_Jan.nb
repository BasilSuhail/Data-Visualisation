Cell[CellGroupData[{

Cell["Hands-on Problem 1.1 [TB, by Shah Chapter 1]", "Section",
 CellChangeTimes->{{3.811585410001328*^9, 
  3.811585524481511*^9}},ExpressionUUID->"a914e5c9-d15f-4f7e-8f8b-\
b3b763e1d4e9"],

Cell[TextData[{
 "Imagine you see yourself as the next Harland Sanders (founder of KFC) and \
want to learn about the poultry business at a much earlier age than Mr. \
Sanders did. You want to figure out what kind of feed can help grow healthier \
chickens. Use the dataset from ",
 ButtonBox["OA 1.3",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://raw.githubusercontent.com/vincentarelbundock/Rdatasets/\
master/csv/datasets/chickwts.csv"], None},
  ButtonNote->
   "https://raw.githubusercontent.com/vincentarelbundock/Rdatasets/master/csv/\
datasets/chickwts.csv"],
 ". \n"
}], "Text",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, 
   3.811588813050367*^9},ExpressionUUID->"368403b7-9ca2-4693-ad56-\
bcbbdd085a21"]
}, Open  ]],

