 CellTags->
  "SlideShowHeader",ExpressionUUID->"edbce187-caa0-4ec4-b949-9cc947185611"],

Cell["Depression : Medicine for treatment", "Title",
 CellChangeTimes->{{3.812755275622931*^9, 
  3.812755283002355*^9}},ExpressionUUID->"cd208037-3bce-400e-8785-\
20da1c7c68d8"],

Cell[CellGroupData[{

Cell["depression", "Section",ExpressionUUID->"5f45c6f2-3630-433f-ada7-b7c8ca9987a9"],

Cell[TextData[{
 "Depression affects ",
 StyleBox["6% ",
  FontWeight->"Bold"],
 "of adults each year and is the",
 StyleBox[" leading cause of suicide",
  FontWeight->"Bold"],
 ". The ",
 StyleBox["exact cause",
  FontWeight->"Bold"],
 " of depression is ",
 StyleBox["unknown",
  FontWeight->"Bold"],
 "."
}], "Text",ExpressionUUID->"12f61f5d-acb9-4217-afe7-7564e9957335"],

Cell["Symptoms can be disabling and its effects pervasive", "Item",ExpressionUUID->"50b17547-4f4c-477f-837a-8168fa86ab93"],

Cell["\<\
People with depression have a consistently low mood and other symptoms severe \
enough to interfere with normal day-to-day activities. \
\>", "SideNote",ExpressionUUID->"fd2fce19-6bfd-416f-a352-93110e12323d"],

Cell["It can become chronic if treated inadequately ", "Item",ExpressionUUID->"12e21767-8753-4008-a60d-3c4b92ce8649"],

Cell["Current medications: Lithium and Imipramine", "Item",ExpressionUUID->"8fd78a7e-1ba3-4d2f-aeae-3fd05736f4ae"]
}, Open  ]]
}, Open  ]]
