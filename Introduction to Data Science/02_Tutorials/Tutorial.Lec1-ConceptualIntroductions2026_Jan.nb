Cell[CellGroupData[{

Cell["\<\
Exercise 1

Try it Yourself  1.2 [TB, by Shah Chapter 1] \
\>", "Section",
 CellChangeTimes->{{3.806659848885989*^9, 3.80665986381691*^9}, {
  3.806749068928473*^9, 3.806749070423398*^9}, {3.81157295437516*^9, 
  3.8115729721326437`*^9}, {3.811573069777534*^9, 3.8115730903142014`*^9}, {
  3.8115851644980297`*^9, 3.811585171497061*^9}, {3.811585251919408*^9, 
  3.811585270699855*^9}, {3.811585392565782*^9, 3.811585397252912*^9}, {
  3.8115854939897013`*^9, 
  3.8115855110293713`*^9}},ExpressionUUID->"e3f021e5-1608-47cd-8d56-\
59a312a5620a"],

Cell[TextData[{
 "Use a dataset that describes ",
 StyleBox["list price (X)",
  FontVariations->{"Underline"->True}],
 " and ",
 StyleBox["best price (Y)",
  FontVariations->{"Underline"->True}],
 " in $1000 for a new pick up truck. The dataset is available from OA1.2. You \
can find this data in Myaberdeen, or simply use the link ",
 ButtonBox["OA1 .2",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://college.cengage.com/mathematics/brase/understandable_\
statistics/7e/students/datasets/slr/excel/slr01.xls"], None},
  ButtonNote->
   "https://college.cengage.com/mathematics/brase/understandable_statistics/\
7e/students/datasets/slr/excel/slr01.xls"],
 ". Use this dataset to predict the best price of a pickup truck that has \
been listed at $24, 000 by a dealer. "
}], "Text",
 CellChangeTimes->{{3.8115852920949383`*^9, 3.811585386182104*^9}, 
   3.811585645259735*^9, {3.811585750378262*^9, 3.811585750383038*^9}, {
   3.81200691154091*^9, 3.812006974176231*^9}, 
   3.812190654598713*^9},ExpressionUUID->"cbd6a2dd-fef7-4664-80b3-\
6ba59c3b65bd"],

Cell["collect the data", "Item",
 CellChangeTimes->{{3.811590385382522*^9, 
  3.811590449348687*^9}},ExpressionUUID->"7c42e52f-7f9f-4f6b-a307-\
42ae0ac0112e"],

Cell["clean the data to extract numerical values", "Item",
 CellChangeTimes->{{3.811590385382522*^9, 
  3.811590462282969*^9}},ExpressionUUID->"2893887a-3a90-4578-b836-\
9214a549d9aa"],

Cell["explore the data", "Item",
 CellChangeTimes->{{3.811590385382522*^9, 
  3.81159046930723*^9}},ExpressionUUID->"395db73b-5a23-4b01-b71f-\
fbaee8185e1f"],

Cell["Do you see a linear relationship between X and Y?", "Item",
 CellChangeTimes->{{3.811590385382522*^9, 
  3.811590486163719*^9}},ExpressionUUID->"4568151d-a109-43f5-8592-\
fe298a93bb16"],

Cell["\<\
Firstly, estimate the linear relationship by estimating linear coefficient \
(slope of line) and the constant coefficient by guessing where Y would be for \
X=0\
\>", "Item",
 CellChangeTimes->{{3.811590385382522*^9, 
  3.8115905424916353`*^9}},ExpressionUUID->"ca3e49fc-8f34-4217-a074-\
27c90e201290"],

Cell["\<\
Do a linear regression  : (Y = s.X + I), X and Y are variables, s is the \
slope and I the intercept, or constant coefficient of the linear regression. \
The intercept can be calculated by setting X=0 and guessing where Y is. \
\>", "Item",
 CellChangeTimes->{{3.811590385382522*^9, 3.811590570176103*^9}, {
  3.812191143566744*^9, 3.812191193318469*^9}, {3.812191250216137*^9, 
  3.812191254117845*^9}, {3.812191285081029*^9, 
  3.812191294886012*^9}},ExpressionUUID->"58b1f5e8-386f-4389-85aa-\
9183a32f9369"],

Cell["\<\
Suggestion: do this tutorial using Excel, or similar, initially if you want.\
\>", "Text",
 CellChangeTimes->{{3.8121960609852324`*^9, 
  3.812196160238173*^9}},ExpressionUUID->"95833d13-73eb-4f01-9f88-\
fd8ea16dfc3f"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

