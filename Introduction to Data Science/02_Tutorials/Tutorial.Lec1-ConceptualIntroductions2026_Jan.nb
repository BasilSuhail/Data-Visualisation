Cell["Exercise 2", "Section",
 CellChangeTimes->{{3.811585410001328*^9, 
  3.811585442038231*^9}},ExpressionUUID->"7d63c194-1bc6-48ae-8969-\
89a6dea44bbe"],

Cell[CellGroupData[{

Cell["Hands-on Problem 1.1 [TB, by Shah Chapter 1]", "Section",
 CellChangeTimes->{{3.811585410001328*^9, 
  3.811585524481511*^9}},ExpressionUUID->"a914e5c9-d15f-4f7e-8f8b-\
b3b763e1d4e9"],

Cell[TextData[{
 "Imagine you see yourself as the next Harland Sanders (founder of KFC) and \
want to learn about the poultry business at a much earlier age than Mr. \
Sanders did. You want to figure out what kind of feed can help grow healthier \
chickens. Use the dataset from ",
 ButtonBox["OA 1.3",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://raw.githubusercontent.com/vincentarelbundock/Rdatasets/\
master/csv/datasets/chickwts.csv"], None},
  ButtonNote->
   "https://raw.githubusercontent.com/vincentarelbundock/Rdatasets/master/csv/\
datasets/chickwts.csv"],
 ". "
}], "Text",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, {
   3.811590629057156*^9, 
   3.811590638823051*^9}},ExpressionUUID->"368403b7-9ca2-4693-ad56-\
bcbbdd085a21"],

Cell["collect the data", "Item",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, {
   3.811590629057156*^9, 
   3.811590648308691*^9}},ExpressionUUID->"b423989e-8f7b-48f0-a6ae-\
d4b9ea977c5a"],

Cell["clean the data to extract numerical values", "Item",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, {
   3.811590629057156*^9, 
   3.8115906529471903`*^9}},ExpressionUUID->"fb089f88-2f99-466b-831b-\
b8af13f79878"],

Cell["Group data by type of feed", "Item",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, {
   3.811590629057156*^9, 
   3.8115906604980583`*^9}},ExpressionUUID->"b751b753-7b68-479e-8b1d-\
959d77062b64"],

Cell["explore the data", "Item",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, {
   3.811590629057156*^9, 
   3.811590671069479*^9}},ExpressionUUID->"2637c958-544a-4d60-b125-\
92b404fba2ce"],

Cell["\<\
What averages of weight can tell about the feed? What can you conclude?\
\>", "Item",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, {
   3.811590629057156*^9, 3.8115906857668447`*^9}, {3.811593895921893*^9, 
   3.8115939019676533`*^9}},ExpressionUUID->"4e1dff60-2789-4cc2-bf19-\
e1ee526f2ff5"],

Cell["Calculate minimal, maximal values for the chicken weights. ", "Item",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, {
   3.811590629057156*^9, 3.8115906857668447`*^9}, {3.811593895921893*^9, 
   3.811593918727871*^9}},ExpressionUUID->"941e2c84-ae94-4101-bf2c-\
18693fce57b0"],

Cell["\<\
Put all this data into a table (TableView in Mathematica) and visualize this \
data\
\>", "Item",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, {
   3.811590629057156*^9, 3.8115906857668447`*^9}, {3.811593895921893*^9, 
   3.81159394460282*^9}},ExpressionUUID->"4ca9a008-94c2-4d4d-b563-\
d2cbabf4e447"],

Cell["\<\
Assuming average weight a measure of Healthy in the chicken population, and \
volatility of weight (difference between maximal and minimal values) as a \
market constraint, what conclusions do you get in terms of the best feed?\
\>", "Item",
 CellChangeTimes->{{3.811585410001328*^9, 3.8115856363835*^9}, {
   3.81158579007806*^9, 3.81158579008603*^9}, 3.811585829251256*^9, {
   3.811590629057156*^9, 3.8115906857668447`*^9}, {3.811593895921893*^9, 
   3.8115940156851053`*^9}, {3.812178559107874*^9, 
   3.812178573761085*^9}},ExpressionUUID->"07aad635-fb09-46e0-b4c2-\
9aab7dac4420"]
}, Open  ]]
}, Open  ]]
