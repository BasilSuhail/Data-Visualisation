   3.813926361116995*^9, 3.8139264342917747`*^9, {3.8139272418461246`*^9, 
   3.813927241929469*^9}, {3.813927691301581*^9, 3.8139277025799913`*^9}, {
   3.813933127015397*^9, 3.813933141939146*^9}, {3.813933187293353*^9, 
   3.8139332054212303`*^9}, {3.813933290104446*^9, 3.813933297372861*^9}, 
   3.813933507109918*^9, 3.813933553745697*^9, {3.813933690761402*^9, 
   3.813933700920405*^9}, {3.813933753961591*^9, 3.813933757648974*^9}, 
   3.813933832399737*^9, 3.81393389710325*^9, 3.813934062648817*^9, 
   3.813934188748057*^9, 3.813934446269651*^9, 3.813934539050815*^9, {
   3.8139346155696497`*^9, 3.813934622212075*^9}, {3.8139347313051243`*^9, 
   3.813934744658079*^9}, 3.8139347806115294`*^9, {3.813934841951078*^9, 
   3.813934890483181*^9}, 3.8139349966406307`*^9, {3.8139350888481293`*^9, 
   3.813935089543149*^9}, {3.81393514382773*^9, 3.813935144051133*^9}, {
   3.8139351973676567`*^9, 3.813935225569582*^9}, {3.8139358776876802`*^9, 
   3.813935878532941*^9}, {3.813936110422744*^9, 3.813936121234445*^9}, {
   3.8139361764610233`*^9, 3.813936176555542*^9}, {3.81393633815588*^9, 
   3.813936346103133*^9}, {3.813938686534552*^9, 3.813938687383873*^9}, {
   3.813942255756804*^9, 3.813942255883144*^9}, {3.8139432600070353`*^9, 
   3.813943275193191*^9}, {3.813943452961727*^9, 3.813943453612451*^9}, {
   3.813949444007559*^9, 3.813949444555304*^9}},
