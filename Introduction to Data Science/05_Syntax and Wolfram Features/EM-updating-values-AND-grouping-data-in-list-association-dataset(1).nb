  "Out[339]=",ExpressionUUID->"054ffe85-ab8c-4111-8cd5-262974f5e860"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Transforming Lists to Associations", "Subchapter",
 CellChangeTimes->{{3.813935326512431*^9, 3.8139353309755096`*^9}, {
  3.813943575261039*^9, 
  3.813943583208746*^9}},ExpressionUUID->"55388d8b-355f-466a-911a-\
f42bb6f6bdfc"],

Cell["We first transform the dataset to an association ", "Text",
 CellChangeTimes->{{3.81393611327986*^9, 3.8139361526448603`*^9}, 
   3.813936745750595*^9},ExpressionUUID->"6e6fd09e-7fbf-4c25-84af-\
085b6b99e8cc"],

Cell["\<\
Create a list for Keys (column names/attribute names, etc...) :\
\>", "Text",
 CellChangeTimes->{{3.8139361648883877`*^9, 
  3.8139361934906*^9}},ExpressionUUID->"b6fc64d2-f3f8-4ebe-9232-cf2019bc5939"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"mykeys", "=", 
  RowBox[{"dataset", "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", "All"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.813936173878448*^9, 3.813936206560725*^9}, {
  3.8139363046412163`*^9, 3.813936304839116*^9}},
 CellLabel->
  "In[504]:=",ExpressionUUID->"571dbceb-50b4-4860-b7c0-71de96cd2a3b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"id\"\>", ",", "\<\"Column2\"\>", ",", "\<\"Column3\"\>"}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.8139362014724827`*^9, 3.8139362271125526`*^9}, 
   3.8139363109061747`*^9, 3.8139363508903112`*^9, 3.813942258903867*^9, 
   3.813943028312694*^9, 3.813943104030902*^9},
 CellLabel->
  "Out[504]=",ExpressionUUID->"1c956bc1-e60a-4199-852c-53826f3dccf5"]
}, Open  ]],

Cell["Separate the data :", "Text",
 CellChangeTimes->{{3.8139362546556883`*^9, 
  3.813936264346138*^9}},ExpressionUUID->"7013f616-8c74-4800-8ba7-\
c34ced4cfa97"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"data", "=", 
  RowBox[{"dataset", "[", 
   RowBox[{"[", 
    RowBox[{
     RowBox[{"2", ";;"}], ",", "All"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8139362657994757`*^9, 3.813936275458609*^9}},
 CellLabel->
  "In[505]:=",ExpressionUUID->"e2850457-6d15-43d2-b88f-4b30ecb1164f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\<\"1\"\>", ",", "2.1`", ",", "2.3`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"2\"\>", ",", "2.9`", ",", "3"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"3\"\>", ",", "0.2`", ",", "4"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"4\"\>", ",", "0.5`", ",", "6"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"5\"\>", ",", "0.1`", ",", "5"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\<\"6\"\>", ",", "2.5`", ",", "0.2`"}], "}"}]}], "}"}]], "Output",\

 CellChangeTimes->{3.813936277731065*^9, 3.813936352171823*^9, 
  3.8139422603086243`*^9, 3.813943029630434*^9, 3.8139431054020567`*^9},
 CellLabel->
  "Out[505]=",ExpressionUUID->"91837772-dd41-486d-91c9-829584489d20"]
}, Open  ]],

Cell["Then, use AssociationThread", "Text",
 CellChangeTimes->{{3.813936238160679*^9, 
  3.813936243887136*^9}},ExpressionUUID->"5f4a0d54-2a13-46bd-8fc3-\
91be30586d79"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"datasetAssoc", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"AssociationThread", "[", 
     RowBox[{"mykeys", "\[Rule]", "#"}], "]"}], "&"}], "/@", 
   "data"}]}]], "Input",
 CellChangeTimes->{{3.813936249715478*^9, 3.813936249999764*^9}, {
  3.81393628829622*^9, 3.813936328697459*^9}, {3.813937205215559*^9, 
  3.813937218590047*^9}},
 CellLabel->
  "In[506]:=",ExpressionUUID->"6d8a478b-9cb0-49e7-af02-cc60cb09cbb1"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"id\"\>", "\[Rule]", "\<\"1\"\>"}], ",", 
     RowBox[{"\<\"Column2\"\>", "\[Rule]", "2.1`"}], ",", 
     RowBox[{"\<\"Column3\"\>", "\[Rule]", "2.3`"}]}], 
    "\[RightAssociation]"}], ",", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"id\"\>", "\[Rule]", "\<\"2\"\>"}], ",", 
     RowBox[{"\<\"Column2\"\>", "\[Rule]", "2.9`"}], ",", 
     RowBox[{"\<\"Column3\"\>", "\[Rule]", "3"}]}], "\[RightAssociation]"}], 
   ",", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"id\"\>", "\[Rule]", "\<\"3\"\>"}], ",", 
     RowBox[{"\<\"Column2\"\>", "\[Rule]", "0.2`"}], ",", 
     RowBox[{"\<\"Column3\"\>", "\[Rule]", "4"}]}], "\[RightAssociation]"}], 
   ",", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"id\"\>", "\[Rule]", "\<\"4\"\>"}], ",", 
     RowBox[{"\<\"Column2\"\>", "\[Rule]", "0.5`"}], ",", 
     RowBox[{"\<\"Column3\"\>", "\[Rule]", "6"}]}], "\[RightAssociation]"}], 
   ",", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"id\"\>", "\[Rule]", "\<\"5\"\>"}], ",", 
     RowBox[{"\<\"Column2\"\>", "\[Rule]", "0.1`"}], ",", 
     RowBox[{"\<\"Column3\"\>", "\[Rule]", "5"}]}], "\[RightAssociation]"}], 
   ",", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"id\"\>", "\[Rule]", "\<\"6\"\>"}], ",", 
     RowBox[{"\<\"Column2\"\>", "\[Rule]", "2.5`"}], ",", 
     RowBox[{"\<\"Column3\"\>", "\[Rule]", "0.2`"}]}], 
    "\[RightAssociation]"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.813936314348815*^9, 3.813936356504242*^9}, {
   3.813937186434987*^9, 3.813937223000436*^9}, {3.813937265898168*^9, 
   3.8139372889710093`*^9}, 3.8139390682335987`*^9, 3.8139422627667313`*^9, 
   3.813943032173685*^9, 3.813943108005319*^9},
 CellLabel->
  "Out[506]=",ExpressionUUID->"887022a8-0948-43e0-8321-5f745b500f53"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Updating/replacing", "Subchapter",
 CellChangeTimes->{{3.813935326512431*^9, 
  3.8139353309755096`*^9}},ExpressionUUID->"ba57e284-bedc-4dd8-a30d-\
deef7f1fa659"],

Cell["\<\
From now on, I would simply transform the association to a dataset and \
query/transform it using the Query formalism. But Associations can be often \
present, for example when importing JSON datasets (e.g. querying Wikipedia). \
\
\>", "Text",
 CellChangeTimes->{{3.8139373770603037`*^9, 3.81393743386066*^9}, {
  3.813938981357078*^9, 
  3.813939050985096*^9}},ExpressionUUID->"efa2265e-e48b-45dc-8584-\
004fe5663f30"],

Cell["\<\
Every value associated to an association can be extract asking for its \
associated key, and then one can update it. For example, to access the values \
of Column2 we can do:\
\>", "Text",
 CellChangeTimes->{{3.813937448031014*^9, 3.813937480093148*^9}, {
  3.813939086301013*^9, 
  3.81393909726785*^9}},ExpressionUUID->"81f2a540-dd3f-47cc-a0c2-\
1688b3efc957"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"datasetAssoc", "[", 
  RowBox[{"[", 
   RowBox[{"All", ",", "2"}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.813937485256522*^9, 3.813937566334381*^9}, {
  3.813939060843424*^9, 3.8139390992186003`*^9}},
 CellLabel->
  "In[507]:=",ExpressionUUID->"2e1bcb81-7ee7-48b2-95d4-c60a4ff9fa09"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "2.1`", ",", "2.9`", ",", "0.2`", ",", "0.5`", ",", "0.1`", ",", "2.5`"}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.813937489510537*^9, 3.81393755944042*^9}, {
   3.8139390651041183`*^9, 3.8139391010215178`*^9}, 3.813942266127143*^9, 
   3.8139430363367453`*^9, 3.8139431120486727`*^9},
 CellLabel->
  "Out[507]=",ExpressionUUID->"15b3b983-d808-4ef9-b4fb-582900cbf06b"]
}, Open  ]],

Cell["\<\
But associations are already \"clever\" then Lists. We can use the keys to \
query it. \
\>", "Text",
 CellChangeTimes->{{3.813939103874905*^9, 
  3.813939122430238*^9}},ExpressionUUID->"cfcf5492-6d1d-4545-ba71-\
6ebd0e387d3e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"datasetAssoc", "[", 
  RowBox[{"[", 
   RowBox[{"All", ",", "\"\<Column2\>\""}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.81393912998577*^9, 3.813939132860178*^9}, {
  3.8139396037037*^9, 3.813939628800972*^9}},
 CellLabel->
  "In[508]:=",ExpressionUUID->"a3220af3-2645-4298-864b-d78e895fa73e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "2.1`", ",", "2.9`", ",", "0.2`", ",", "0.5`", ",", "0.1`", ",", "2.5`"}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.813939133213709*^9, {3.8139396067695847`*^9, 3.8139396293758163`*^9}, 
   3.8139405849981318`*^9, 3.813942267698312*^9, 3.8139430382201*^9, 
   3.813943113485671*^9},
 CellLabel->
  "Out[508]=",ExpressionUUID->"c7e04293-edd5-46cb-96bc-ace42620fa74"]
}, Open  ]],

Cell["Or using the Query[] function", "Text",
 CellChangeTimes->{{3.813941898471002*^9, 
  3.8139419056570807`*^9}},ExpressionUUID->"564e289c-5e9a-49b7-aebb-\
564e6f06f746"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Query", "[", 
   RowBox[{"All", ",", 
    RowBox[{"#Column2", "&"}]}], "]"}], "[", "datasetAssoc", "]"}]], "Input",
 CellChangeTimes->{{3.813941907800902*^9, 3.81394193026436*^9}},
 CellLabel->
  "In[509]:=",ExpressionUUID->"12235812-2d62-4ee5-afdb-8be66eb95033"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "2.1`", ",", "2.9`", ",", "0.2`", ",", "0.5`", ",", "0.1`", ",", "2.5`"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.813942807182991*^9, 3.813943115684381*^9},
 CellLabel->
  "Out[509]=",ExpressionUUID->"4d17b0bb-f29d-4c0d-a6dc-f6ba7389fecd"]
}, Open  ]],

Cell["\<\
You can simply change values as done in Lists using a For loop and then \
update the values of the association one by one, or more automatically using \
a function. Let us define the threshold to discretize data:\
\>", "Text",
 CellChangeTimes->{{3.8139400404326487`*^9, 3.8139400677982283`*^9}, {
  3.813941980892969*^9, 3.813941985237616*^9}, {3.8139429995573587`*^9, 
  3.8139430088425837`*^9}},ExpressionUUID->"afbafb3f-8aad-4ceb-b22b-\
d10bffbbe3c5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"threshold", "=", "2"}], ";"}]], "Input",
 CellChangeTimes->{{3.813943010666687*^9, 3.813943014032888*^9}},
 CellLabel->
  "In[510]:=",ExpressionUUID->"8d911a61-550d-4f99-8c17-04dae7bf1935"],

Cell["Let us define the function to transform the data :", "Text",
 CellChangeTimes->{{3.8139431281202183`*^9, 
  3.813943135206699*^9}},ExpressionUUID->"f2c45f33-1ee4-40c0-be4b-\
23d7bf5d8c06"],

Cell[BoxData[
 RowBox[{
  RowBox[{"function", "[", "x_", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"x", "<", "threshold"}], ",", "0", ",", "1"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.813940340683964*^9, 3.81394039187193*^9}, {
  3.813940469620782*^9, 3.813940482019376*^9}, {3.8139407478731813`*^9, 
  3.813940775943295*^9}, {3.813940809094652*^9, 3.813940822342596*^9}, {
  3.813942444556911*^9, 3.813942448254018*^9}, {3.813942620406736*^9, 
  3.813942726094262*^9}, {3.813942761249113*^9, 3.813942773229671*^9}, {
  3.813942993784523*^9, 3.8139429959469624`*^9}},
 CellLabel->
  "In[512]:=",ExpressionUUID->"0b25e249-1a0c-42ca-b335-0dee3e2bce11"],

Cell["Let see what the Query function does : ", "Text",
 CellChangeTimes->{{3.813943143967156*^9, 
  3.813943154159329*^9}},ExpressionUUID->"2851fe5a-b181-42b9-a1dd-\
76fb41e7a1e1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Query", "[", 
   RowBox[{"All", ",", 
    RowBox[{"#Column2", "&"}], ",", "function"}], "]"}], "[", "datasetAssoc", 
  "]"}]], "Input",
 CellChangeTimes->{{3.81394166294134*^9, 3.813941850061171*^9}, {
  3.813942023610614*^9, 3.813942039500968*^9}, {3.813942134956112*^9, 
  3.813942202613758*^9}, {3.813942289844275*^9, 3.8139423428503733`*^9}, {
  3.813942382998002*^9, 3.813942410070587*^9}, {3.8139428391641283`*^9, 
  3.813942850381476*^9}, {3.813942897058481*^9, 3.813942897604495*^9}},
 CellLabel->
  "In[514]:=",ExpressionUUID->"d9c93020-c8b9-4155-97fa-7197f3c24f79"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "1", ",", "0", ",", "0", ",", "0", ",", "1"}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.8139422477062807`*^9, 3.813942343739745*^9}, {
   3.813942385826065*^9, 3.813942421096759*^9}, {3.813942674827653*^9, 
   3.813942699105215*^9}, {3.813942777852215*^9, 3.813942799927259*^9}, {
   3.813942839818638*^9, 3.813942847866671*^9}, 3.813942898179769*^9, {
   3.81394301884079*^9, 3.81394304636327*^9}, {3.8139431415460367`*^9, 
   3.81394315814049*^9}},
 CellLabel->
  "Out[514]=",ExpressionUUID->"99fb9e33-6444-45e9-b567-d3c8cd47a022"]
}, Open  ]],

Cell["We update Column2 by :", "Text",
 CellChangeTimes->{{3.8139429018678303`*^9, 
  3.813942916689485*^9}},ExpressionUUID->"0719bec3-6e6f-4682-b0fa-\
450641041718"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"datasetAssoc", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "\"\<Column2\>\""}], "]"}], "]"}], "=", 
   RowBox[{
    RowBox[{"Query", "[", 
     RowBox[{"All", ",", 
      RowBox[{"#Column2", "&"}], ",", "function"}], "]"}], "[", 
    "datasetAssoc", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.813942929697178*^9, 3.81394294613523*^9}},
 CellLabel->
  "In[515]:=",ExpressionUUID->"0a4693e6-9186-4246-802d-6a38e14ed648"],

Cell["\<\
We can do the same for \"column3\", using the Column3 threshold of 3:\
\>", "Text",
 CellChangeTimes->{{3.8139429566162157`*^9, 3.8139429734306507`*^9}, {
  3.813943080059793*^9, 
  3.813943081513578*^9}},ExpressionUUID->"38f3693e-7d3f-49ca-ae9f-\
35b7d61fd6a0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"threshold", "=", "3"}], ";"}]], "Input",
 CellChangeTimes->{{3.81394308456629*^9, 3.81394308824188*^9}},
 CellLabel->
  "In[516]:=",ExpressionUUID->"6b7f2319-d9a3-48ee-ada3-b9d57f05dacf"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"datasetAssoc", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "\"\<Column3\>\""}], "]"}], "]"}], "=", 
   RowBox[{
    RowBox[{"Query", "[", 
     RowBox[{"All", ",", 
      RowBox[{"#Column3", "&"}], ",", "function"}], "]"}], "[", 
    "datasetAssoc", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.813943092454282*^9, 3.813943095179722*^9}},
 CellLabel->
  "In[517]:=",ExpressionUUID->"529386e3-58fd-43f3-af36-2c03f60883ea"],

Cell["Let us now check our updated Association", "Text",
 CellChangeTimes->{{3.8139431674039783`*^9, 
  3.813943182322892*^9}},ExpressionUUID->"3b91234f-ec3e-4ced-a845-\
b293d01e22cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"datasetAssoc", "//", "Dataset"}]], "Input",
 CellChangeTimes->{{3.813943192321203*^9, 3.81394319355902*^9}},
 CellLabel->
  "In[519]:=",ExpressionUUID->"947a0027-dc59-468f-9940-99b5e6d12d58"],

