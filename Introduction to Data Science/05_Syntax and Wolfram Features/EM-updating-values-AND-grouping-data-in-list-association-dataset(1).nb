 CellLabel->
  "In[562]:=",ExpressionUUID->"d38290e0-6376-4bba-99af-0fb55f76eb04"],

Cell[BoxData[
 RowBox[{
  RowBox[{"functionWithThreshold", "[", 
   RowBox[{"x_", ",", "threshold_"}], "]"}], ":=", 
