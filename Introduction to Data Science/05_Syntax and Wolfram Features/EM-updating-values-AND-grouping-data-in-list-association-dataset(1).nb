 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "1"}], ",", 
   RowBox[{"i", "<", 
    RowBox[{"Length", "[", "dataset", "]"}]}], ",", 
   RowBox[{
    RowBox[{"i", "++"}], ";", 
    RowBox[{"If", "[", 
     RowBox[{
