       Association["id" -> "3", "Column2" -> 0, "Column3" -> 1], 
       Association["id" -> "4", "Column2" -> 0, "Column3" -> 1], 
       Association["id" -> "5", "Column2" -> 0, "Column3" -> 1], 
       Association["id" -> "6", "Column2" -> 1, "Column3" -> 0]}, 
     "InitialShape" -> TypeSystem`PackageScope`HeaderShape[
