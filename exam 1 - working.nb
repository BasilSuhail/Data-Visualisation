$CellContext`plotData$ = {}; $CellContext`plotColors$ = {}; \
$CellContext`legendLabels$ = {}; 
         If[Length[$CellContext`belowThreshold$] > 0, 
           AppendTo[$CellContext`plotData$, 
             Map[Tooltip[{
                Part[#, 3], Part[#, 2]/$CellContext`scaleFactor}, 
               Part[#, 1]]& , $CellContext`belowThreshold$]]; 
           AppendTo[$CellContext`plotColors$, Blue]; 
           AppendTo[$CellContext`legendLabels$, "GDP pc less than $" <> 
             ToString[
               Round[$CellContext`gdpThreshold$$]]]]; 
         If[Length[$CellContext`aboveThreshold$] > 0, 
           AppendTo[$CellContext`plotData$, 
             Map[Tooltip[{
                Part[#, 3], Part[#, 2]/$CellContext`scaleFactor}, 
               Part[#, 1]]& , $CellContext`aboveThreshold$]]; 
           AppendTo[$CellContext`plotColors$, Orange]; 
           AppendTo[$CellContext`legendLabels$, "GDP pc greater than $" <> 
             ToString[
               Round[$CellContext`gdpThreshold$$]]]]; 
         ListPlot[$CellContext`plotData$, 
           PlotStyle -> $CellContext`plotColors$, 
           PlotLegends -> $CellContext`legendLabels$, 
           AxesLabel -> {"literacy", "wealth"}, 
           Ticks -> {Automatic, {0, 0.02, 0.04, 0.06, 0.08, 0.1}}]], 
        StandardForm],
