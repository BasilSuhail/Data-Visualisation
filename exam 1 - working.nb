              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"xAXISminimum", ",", "averagevalues"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"xAXISmaximum", ",", "averagevalues"}], "}"}]}], 
               "}"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Thin", ",", "Dashed", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"xAXISminimum", ",", "maximumvalues"}], "}"}], ",", 
