                  RowBox[{"#", "[", 
                   RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "&"}], "/@", 
             RowBox[{"Select", "[", 
              RowBox[{"dataQuestion2", ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"#", "[", 
