Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dataQuestion2", "=", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"CountryData", "[", 
           RowBox[{"#", ",", "\"\<Name\>\""}], "]"}], ",", 
          RowBox[{"QuantityMagnitude", "[", 
           RowBox[{"CountryData", "[", 
            RowBox[{"#", ",", "\"\<GDPPerCapita\>\""}], "]"}], "]"}], ",", 
          RowBox[{"QuantityMagnitude", "[", 
           RowBox[{"CountryData", "[", 
            RowBox[{"#", ",", "\"\<LiteracyFraction\>\""}], "]"}], "]"}]}], 
         "}"}], "&"}], "/@", 
       RowBox[{"CountryData", "[", "]"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"NumericQ", "[", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "]"}], "&&", 
        RowBox[{"NumericQ", "[", 
