Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"propPlot", "[", 
    RowBox[{"country_", ",", "property_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Question1", ",", "dataQuestion1", ",", "cleanedDataQ1", ",", 
       "valuesQ1", ",", "averagevalues", ",", "maximumvalues", ",", 
       "minimumvalues", ",", "maximumpoint", ",", "minimumpoint", ",", 
       "xAXISminimum", ",", "xAXISmaximum"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Question1", "=", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", 
         RowBox[{"{", 
          RowBox[{"property", ",", "All"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dataQuestion1", "=", 
       RowBox[{"Normal", "[", 
        RowBox[{"Question1", "[", "\"\<Path\>\"", "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"cleanedDataQ1", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"DateValue", "[", 
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<Year\>\""}], "]"}], ",", 
            RowBox[{"QuantityMagnitude", "[", 
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}], "&"}], ",", 
         "dataQuestion1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"cleanedDataQ1", "=", 
       RowBox[{"Select", "[", 
        RowBox[{"cleanedDataQ1", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"NumberQ", "[", 
            RowBox[{"Last", "[", "#", "]"}], "]"}], "&&", 
           RowBox[{"1960", "<=", 
            RowBox[{"First", "[", "#", "]"}], "<=", "2022"}]}], "&"}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"valuesQ1", "=", 
       RowBox[{"cleanedDataQ1", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"averagevalues", "=", 
       RowBox[{"Mean", "[", "valuesQ1", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"maximumvalues", "=", 
       RowBox[{"Max", "[", "valuesQ1", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"minimumvalues", "=", 
       RowBox[{"Min", "[", "valuesQ1", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"maximumpoint", "=", 
       RowBox[{
        RowBox[{"SortBy", "[", 
         RowBox[{"cleanedDataQ1", ",", "Last"}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"minimumpoint", "=", 
       RowBox[{
        RowBox[{"SortBy", "[", 
         RowBox[{"cleanedDataQ1", ",", "Last"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"xAXISminimum", "=", 
       RowBox[{"Min", "[", 
        RowBox[{"cleanedDataQ1", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"xAXISmaximum", "=", 
       RowBox[{"Max", "[", 
        RowBox[{"cleanedDataQ1", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"plotLines", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Thick", ",", "Dashed", ",", 
           RowBox[{"InfiniteLine", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "averagevalues"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Thin", ",", "Dashed", ",", 
           RowBox[{"InfiniteLine", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "maximumvalues"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Thin", ",", "Dashed", ",", 
           RowBox[{"InfiniteLine", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "minimumvalues"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Black", ",", 
           RowBox[{"PointSize", "[", "Large", "]"}], ",", 
           RowBox[{"Point", "[", 
            RowBox[{"{", 
             RowBox[{"maximumpoint", ",", "minimumpoint"}], "}"}], "]"}]}], 
          "}"}]}], "}"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"ListLinePlot", "[", 
       RowBox[{"cleanedDataQ1", ",", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{
         "property", "<>", "\"\< for \>\"", "<>", "country", 
          "<>", "\"\< over the years\>\""}]}], ",", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<year\>\"", ",", "property"}], "}"}]}], ",", 
        RowBox[{"Epilog", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Thick", ",", "Dashed", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"xAXISminimum", ",", "averagevalues"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"xAXISmaximum", ",", "averagevalues"}], "}"}]}], 
               "}"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Thin", ",", "Dashed", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"xAXISminimum", ",", "maximumvalues"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"xAXISmaximum", ",", "maximumvalues"}], "}"}]}], 
               "}"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Thin", ",", "Dashed", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"xAXISminimum", ",", "minimumvalues"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"xAXISmaximum", ",", "minimumvalues"}], "}"}]}], 
               "}"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Black", ",", 
             RowBox[{"PointSize", "[", "Large", "]"}], ",", 
             RowBox[{"Point", "[", "maximumpoint", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Black", ",", 
             RowBox[{"PointSize", "[", "Large", "]"}], ",", 
             RowBox[{"Point", "[", "minimumpoint", "]"}]}], "}"}]}], 
          "}"}]}]}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Testing", " ", "Functions"}], "*)"}]}], "\n", 
 RowBox[{"propPlot", "[", 
  RowBox[{"\"\<Brazil\>\"", ",", "\"\<GDPPerCapita\>\""}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"propPlot", "[", 
  RowBox[{"\"\<Pakistan\>\"", ",", "\"\<GDPPerCapita\>\""}], "]"}]}], "Input",\

