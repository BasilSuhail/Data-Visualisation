          RowBox[{"Thin", ",", "Dashed", ",", 
           RowBox[{"InfiniteLine", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "minimumvalues"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Black", ",", 
           RowBox[{"PointSize", "[", "Large", "]"}], ",", 
           RowBox[{"Point", "[", 
            RowBox[{"{", 
             RowBox[{"maximumpoint", ",", "minimumpoint"}], "}"}], "]"}]}], 
          "}"}]}], "}"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"ListLinePlot", "[", 
       RowBox[{"cleanedDataQ1", ",", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{
         "property", "<>", "\"\< for \>\"", "<>", "country", 
          "<>", "\"\< over the years\>\""}]}], ",", 
        RowBox[{"AxesLabel", "->", 
