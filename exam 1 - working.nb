          RowBox[{"[", "3", "]"}], "]"}], "]"}]}], "&"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"maximumvalue", "=", "60000"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Question2", "=", 
  RowBox[{"DynamicModule", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"gdpThreshold", "=", "10000"}], "}"}], ",", 
    RowBox[{"Column", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Slider", "[", 
        RowBox[{
         RowBox[{"Dynamic", "[", "gdpThreshold", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "maximumvalue"}], "}"}]}], "]"}], ",", 
       RowBox[{"Dynamic", "[", 
        RowBox[{"ListPlot", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Tooltip", "[", 
